{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "jsxImportSource": "nativewind",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/utils/*": [
        "./utils/*"
      ],
      "@/components/*": [
        "./components/*"
      ],
      "tailwind.config": [
        "./tailwind.config.js"
      ]
    },
    "strictNullChecks": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "vite.config.ts",
    "main.tsx",
    "nativewind-env.d.ts",
    "tailwind-variants.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
