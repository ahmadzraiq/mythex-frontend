{
  "id": "sys-breadcrumbs",
  "name": "Breadcrumbs",
  "description": "Breadcrumb trail. `items` is an array of `{ label, href }`. The component renders a Text + separator Icon per item (separator hidden on the last item). Clicking an item emits `On item click` with `{ label, href, index }` so the parent decides how to navigate.",
  "properties": [
    { "id": "prop-bc-items",     "name": "items",         "type": "list", "defaultValue": [{ "label": "Home", "href": "/" }, { "label": "Category", "href": "/category" }, { "label": "Page", "href": "/category/page" }] },
    { "id": "prop-bc-separator", "name": "separatorIcon", "type": "icon", "defaultValue": "lucide:chevron-right" }
  ],
  "triggers": [
    {
      "id": "bc-t-on-item-click",
      "name": "On item click",
      "payload": { "formula": "{ label: context?.item?.data?.label, href: context?.item?.data?.href, index: context?.item?.data?.index }" }
    }
  ],
  "variables": {},
  "workflows": {
    "bc-wf-item-click": {
      "id": "bc-wf-item-click",
      "name": "Click Item",
      "trigger": "click",
      "description": "Emit On item click with the clicked breadcrumb's label/href/index.",
      "steps": [
        {
          "id": "emit-click",
          "type": "emitComponentTrigger",
          "config": { "triggerId": "bc-t-on-item-click" }
        }
      ]
    }
  },
  "content": {
    "type": "Box",
    "props": { "className": "flex flex-row items-center gap-[4px]" },
    "children": [
      {
        "type": "Box",
        "map": { "formula": "(()=>{const items=Array.isArray(context?.component?.props?.items)?context.component.props.items:[];return items.map((it,i)=>({label:it?.label||'',href:it?.href||'',index:i,isLast:i===items.length-1}))})()" },
        "key": "context.item.data.index",
        "props": { "className": "contents" },
        "children": [
          {
            "type": "Text",
            "props": {
              "className": "text-[14px] font-medium",
              "style": {
                "color": { "formula": "context?.item?.data?.isLast?'var(--theme-foreground)':'var(--theme-primary)'" },
                "cursor": { "formula": "context?.item?.data?.isLast?'default':'pointer'" }
              }
            },
            "actions": [{ "action": "bc-wf-item-click" }],
            "text": "{{context.item.data.label}}"
          },
          {
            "type": "Icon",
            "condition": "!context?.item?.data?.isLast",
            "props": {
              "icon": { "formula": "context?.component?.props?.separatorIcon || 'lucide:chevron-right'" },
              "size": 14,
              "color": "#9ca3af"
            }
          }
        ]
      }
    ]
  },
  "isBuiltIn": true,
  "icon": "›"
}
