{
  "id": "sys-select",
  "name": "Select",
  "description": "Click-to-open dropdown with a popover list. Bind `value` (current selection) and `options` (array of { label, value }) via formulas. The component does not own the selected value; it emits the chosen value through the `On change` trigger so the parent page (or shared component) can update its own variable.",
  "properties": [
    { "id": "prop-sel-options", "name": "options", "type": "list", "defaultValue": [{ "label": "Option 1", "value": "option1" }, { "label": "Option 2", "value": "option2" }, { "label": "Option 3", "value": "option3" }] },
    { "id": "prop-sel-value",   "name": "value",   "type": "text", "defaultValue": "" }
  ],
  "triggers": [
    {
      "id": "sel-t-on-change",
      "name": "On change",
      "payload": { "formula": "{ value: context?.item?.data?.value, label: context?.item?.data?.label }" }
    }
  ],
  "variables": {
    "sel-v-is-open-uuid": {
      "label": "isOpen",
      "type": "boolean",
      "initialValue": false,
      "folder": "Select"
    }
  },
  "workflows": {
    "sel-wf-select-item": {
      "id": "sel-wf-select-item",
      "name": "Select Item",
      "trigger": "click",
      "description": "Close the popover and emit the On change event with the clicked option's value/label.",
      "steps": [
        {
          "id": "close-popover",
          "type": "changeVariableValue",
          "config": { "variableName": "sel-v-is-open-uuid", "value": false }
        },
        {
          "id": "emit-change",
          "type": "emitComponentTrigger",
          "config": { "triggerId": "sel-t-on-change" }
        }
      ]
    }
  },
  "content": {
    "type": "Box",
    "props": {
      "className": "flex flex-row items-center justify-between gap-[8px] px-[12px] py-[8px] rounded-[6px] border border-border bg-background cursor-pointer hover:border-primary w-full"
    },
    "popover": {
      "trigger": "click",
      "placement": "bottom-start",
      "offset": 4,
      "openVariable": "sel-v-is-open-uuid"
    },
    "children": [
      {
        "type": "Text",
        "props": { "className": "flex-1 text-[14px] text-foreground" },
        "text": {
          "formula": "(()=>{const v=context?.component?.props?.value;const opts=Array.isArray(context?.component?.props?.options)?context.component.props.options:[];const m=opts.find(o=>o?.value===v);return m?.label||'Select...'})()"
        }
      },
      {
        "type": "Icon",
        "props": { "icon": "lucide:chevron-down", "size": 16, "color": "#6b7280" }
      },
      {
        "type": "Box",
        "_popoverContent": true,
        "props": {
          "className": "min-w-[200px] max-h-[300px] overflow-auto bg-background border border-border rounded-[6px] shadow-md py-[4px]"
        },
        "children": [
          {
            "type": "Box",
            "map": { "formula": "Array.isArray(context?.component?.props?.options) ? context.component.props.options : []" },
            "key": "context.item.data.value",
            "props": { "className": "contents" },
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "flex flex-row items-center px-[12px] py-[8px] cursor-pointer hover:bg-muted"
                },
                "actions": [{ "action": "sel-wf-select-item" }],
                "children": [
                  {
                    "type": "Text",
                    "props": { "className": "text-[14px] text-foreground" },
                    "text": "{{context.item.data.label}}"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "isBuiltIn": true,
  "icon": "▾"
}
