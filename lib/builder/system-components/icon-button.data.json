{
  "id": "sys-icon-button",
  "name": "Icon Button",
  "description": "Square or round icon-only button. Variant (`ghost|solid|outline`) + size (`sm|md|lg`) + shape (`square|round`) drive individual style properties via formulas. When `disabled` is true the click workflow short-circuits and never emits the public `On click` trigger.",
  "properties": [
    { "id": "prop-ibtn-icon",     "name": "icon",     "type": "icon",    "defaultValue": "lucide:star" },
    { "id": "prop-ibtn-shape",    "name": "shape",    "type": "select",  "defaultValue": "square",  "options": [{ "label": "Square", "value": "square" }, { "label": "Round", "value": "round" }] },
    { "id": "prop-ibtn-size",     "name": "size",     "type": "select",  "defaultValue": "md",      "options": [{ "label": "Small", "value": "sm" }, { "label": "Medium", "value": "md" }, { "label": "Large", "value": "lg" }] },
    { "id": "prop-ibtn-variant",  "name": "variant",  "type": "select",  "defaultValue": "ghost",   "options": [{ "label": "Ghost", "value": "ghost" }, { "label": "Solid", "value": "solid" }, { "label": "Outline", "value": "outline" }] },
    { "id": "prop-ibtn-disabled", "name": "disabled", "type": "boolean", "defaultValue": false }
  ],
  "triggers": [
    {
      "id": "ibtn-t-on-click",
      "name": "On click",
      "payload": { "formula": "{ icon: context?.component?.props?.icon }" }
    }
  ],
  "variables": {},
  "workflows": {
    "ibtn-wf-on-click": {
      "id": "ibtn-wf-on-click",
      "name": "On click",
      "trigger": "click",
      "description": "Short-circuit if `disabled` is true, otherwise emit the public On click trigger.",
      "steps": [
        {
          "id": "guard-disabled",
          "type": "branch",
          "config": { "condition": "!context?.component?.props?.disabled" },
          "trueBranch": [
            {
              "id": "emit-click",
              "type": "emitComponentTrigger",
              "config": { "triggerId": "ibtn-t-on-click" }
            }
          ],
          "falseBranch": []
        }
      ]
    }
  },
  "content": {
    "type": "Box",
    "props": {
      "className": "flex items-center justify-center hover:opacity-90 active:opacity-80 transition-colors",
      "style": {
        "width": { "formula": "context?.component?.props?.size==='sm'?'32px':context?.component?.props?.size==='lg'?'48px':'40px'" },
        "height": { "formula": "context?.component?.props?.size==='sm'?'32px':context?.component?.props?.size==='lg'?'48px':'40px'" },
        "borderRadius": { "formula": "context?.component?.props?.shape==='round'?'9999px':'6px'" },
        "backgroundColor": { "formula": "context?.component?.props?.variant==='solid'?'var(--theme-primary)':'transparent'" },
        "borderWidth": { "formula": "context?.component?.props?.variant==='outline'?'1px':'0'" },
        "borderStyle": { "formula": "context?.component?.props?.variant==='outline'?'solid':'none'" },
        "borderColor": { "formula": "context?.component?.props?.variant==='outline'?'var(--theme-foreground)':'transparent'" },
        "opacity": { "formula": "context?.component?.props?.disabled?'0.5':'1'" },
        "cursor": { "formula": "context?.component?.props?.disabled?'not-allowed':'pointer'" },
        "pointerEvents": { "formula": "context?.component?.props?.disabled?'none':'auto'" }
      }
    },
    "actions": [{ "action": "ibtn-wf-on-click" }],
    "children": [
      {
        "type": "Icon",
        "props": {
          "icon": { "formula": "context?.component?.props?.icon || 'lucide:star'" },
          "size": { "formula": "context?.component?.props?.size==='sm'?14:context?.component?.props?.size==='lg'?22:18" },
          "color": { "formula": "context?.component?.props?.variant==='solid'?'var(--theme-primary-foreground)':'var(--theme-muted-foreground)'" }
        }
      }
    ]
  },
  "isBuiltIn": true,
  "icon": "⬚"
}
