{
  "id": "sys-radio-group",
  "name": "Radio Group",
  "description": "Accessible radio group built on the real RadioGroup/Radio/RadioIndicator/RadioLabel primitives. `options` is an array of `{ value, label }`. The current selection is mirrored on the per-instance `rg-v-value-uuid` variable (initialised from `value` on `created`). When the user picks a new option the variable is updated and `On change` is emitted with `{ value }`.",
  "properties": [
    { "id": "prop-rg-options",     "name": "options",     "type": "list",   "defaultValue": [{ "value": "a", "label": "Option A" }, { "value": "b", "label": "Option B" }, { "value": "c", "label": "Option C" }] },
    { "id": "prop-rg-value",       "name": "value",       "type": "text",   "defaultValue": "" },
    { "id": "prop-rg-orientation", "name": "orientation", "type": "select", "defaultValue": "vertical", "options": [{ "label": "Vertical", "value": "vertical" }, { "label": "Horizontal", "value": "horizontal" }] }
  ],
  "triggers": [
    {
      "id": "rg-t-on-change",
      "name": "On change",
      "payload": { "formula": "{ value: context?.component?.variables?.['rg-v-value-uuid'] }" }
    }
  ],
  "variables": {
    "rg-v-value-uuid": {
      "label": "selectedValue",
      "type": "string",
      "initialValue": "",
      "folder": "RadioGroup"
    }
  },
  "workflows": {
    "rg-wf-init": {
      "id": "rg-wf-init",
      "name": "Init",
      "trigger": "created",
      "steps": [
        {
          "id": "init-value",
          "type": "changeVariableValue",
          "config": {
            "variableName": "rg-v-value-uuid",
            "value": { "formula": "context?.component?.props?.value || ''" }
          }
        }
      ]
    },
    "rg-wf-on-change": {
      "id": "rg-wf-on-change",
      "name": "On change",
      "trigger": "valueChange",
      "description": "RadioGroup onValueChange — store the new value on the instance variable then emit On change.",
      "steps": [
        {
          "id": "store-value",
          "type": "changeVariableValue",
          "config": {
            "variableName": "rg-v-value-uuid",
            "value": { "formula": "context?.event?.value" }
          }
        },
        {
          "id": "emit-change",
          "type": "emitComponentTrigger",
          "config": { "triggerId": "rg-t-on-change" }
        }
      ]
    }
  },
  "content": {
    "type": "RadioGroup",
    "props": {
      "value": { "formula": "context?.component?.variables?.['rg-v-value-uuid'] || ''" },
      "className": "flex",
      "style": {
        "flexDirection": { "formula": "context?.component?.props?.orientation==='horizontal'?'row':'column'" },
        "gap": { "formula": "context?.component?.props?.orientation==='horizontal'?'16px':'12px'" }
      }
    },
    "actions": [{ "action": "rg-wf-on-change" }],
    "children": [
      {
        "type": "Box",
        "map": { "formula": "Array.isArray(context?.component?.props?.options) ? context.component.props.options : []" },
        "key": "context.item.data.value",
        "props": { "className": "contents" },
        "children": [
          {
            "type": "Radio",
            "props": { "value": { "formula": "context?.item?.data?.value" } },
            "children": [
              { "type": "RadioIndicator" },
              {
                "type": "RadioLabel",
                "text": "{{context.item.data.label}}"
              }
            ]
          }
        ]
      }
    ]
  },
  "isBuiltIn": true,
  "icon": "◎"
}
