{
  "id": "sys-chip",
  "name": "Chip",
  "description": "Pill-shaped chip with optional left icon, label, and a remove icon. Variant (`primary|secondary|outline`) drives individual style properties via formulas. Clicking the body emits `On click`. Clicking the remove icon emits `On remove` and stops propagation so the parent click doesn't also fire.",
  "properties": [
    { "id": "prop-chip-label",     "name": "label",     "type": "text",    "defaultValue": "Chip" },
    { "id": "prop-chip-variant",   "name": "variant",   "type": "select",  "defaultValue": "primary", "options": [{ "label": "Primary", "value": "primary" }, { "label": "Secondary", "value": "secondary" }, { "label": "Success", "value": "success" }, { "label": "Warning", "value": "warning" }, { "label": "Error", "value": "error" }, { "label": "Outline", "value": "outline" }] },
    { "id": "prop-chip-removable", "name": "removable", "type": "boolean", "defaultValue": false },
    { "id": "prop-chip-icon-left", "name": "iconLeft",  "type": "icon",    "defaultValue": "" }
  ],
  "triggers": [
    {
      "id": "chip-t-on-click",
      "name": "On click",
      "payload": { "formula": "{ label: context?.component?.props?.label }" }
    },
    {
      "id": "chip-t-on-remove",
      "name": "On remove",
      "payload": { "formula": "{ label: context?.component?.props?.label }" }
    }
  ],
  "variables": {},
  "workflows": {
    "chip-wf-on-click": {
      "id": "chip-wf-on-click",
      "name": "On click",
      "trigger": "click",
      "description": "Emit the public On click trigger.",
      "steps": [
        {
          "id": "emit-click",
          "type": "emitComponentTrigger",
          "config": { "triggerId": "chip-t-on-click" }
        }
      ]
    },
    "chip-wf-remove": {
      "id": "chip-wf-remove",
      "name": "Remove",
      "trigger": "click",
      "stopPropagation": true,
      "description": "Emit On remove. Stops propagation so the parent chip body click doesn't also fire.",
      "steps": [
        {
          "id": "emit-remove",
          "type": "emitComponentTrigger",
          "config": { "triggerId": "chip-t-on-remove" }
        }
      ]
    }
  },
  "content": {
    "type": "Box",
    "props": {
      "className": "inline-flex flex-row items-center gap-[6px] px-[12px] py-[4px] rounded-[9999px] cursor-pointer hover:opacity-90",
      "style": {
        "backgroundColor": { "formula": "context?.component?.props?.variant==='secondary'?'var(--theme-muted)':context?.component?.props?.variant==='outline'?'transparent':'var(--theme-primary)'" },
        "color": { "formula": "context?.component?.props?.variant==='secondary'?'var(--theme-muted-foreground)':context?.component?.props?.variant==='outline'?'var(--theme-foreground)':'var(--theme-primary-foreground)'" },
        "borderWidth": { "formula": "context?.component?.props?.variant==='outline'?'1px':'0'" },
        "borderStyle": { "formula": "context?.component?.props?.variant==='outline'?'solid':'none'" },
        "borderColor": { "formula": "context?.component?.props?.variant==='outline'?'var(--theme-foreground)':'transparent'" }
      }
    },
    "actions": [{ "action": "chip-wf-on-click" }],
    "children": [
      {
        "type": "Icon",
        "condition": "!!context?.component?.props?.iconLeft",
        "props": {
          "icon": { "formula": "context?.component?.props?.iconLeft || 'lucide:tag'" },
          "size": 12,
          "color": "currentColor"
        }
      },
      {
        "type": "Text",
        "props": { "className": "text-[12px] font-medium" },
        "text": { "formula": "context?.component?.props?.label || ''" }
      },
      {
        "type": "Box",
        "condition": "!!context?.component?.props?.removable",
        "props": { "className": "ml-[2px] flex items-center justify-center cursor-pointer hover:opacity-70" },
        "actions": [{ "action": "chip-wf-remove", "stopPropagation": true }],
        "children": [
          { "type": "Icon", "props": { "icon": "lucide:x", "size": 12, "color": "currentColor" } }
        ]
      }
    ]
  },
  "isBuiltIn": true,
  "icon": "◉"
}
