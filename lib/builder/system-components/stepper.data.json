{
  "id": "sys-stepper",
  "name": "Stepper",
  "description": "Step progress indicator. `steps` is an array of `{ label }`, `activeStep` is the 1-indexed current step. Each step renders one of three states (`done | current | upcoming`) via formula-driven style properties. Connector lines between steps use the same comparison. Clicking a step emits `On step click` with `{ index }`.",
  "properties": [
    { "id": "prop-stepper-steps",       "name": "steps",       "type": "list",   "defaultValue": [{ "label": "Step 1" }, { "label": "Step 2" }, { "label": "Step 3" }] },
    { "id": "prop-stepper-active",      "name": "activeStep",  "type": "number", "defaultValue": 1 },
    { "id": "prop-stepper-orientation", "name": "orientation", "type": "select", "defaultValue": "horizontal", "options": [{ "label": "Horizontal", "value": "horizontal" }, { "label": "Vertical", "value": "vertical" }] }
  ],
  "triggers": [
    {
      "id": "stepper-t-on-step-click",
      "name": "On step click",
      "payload": { "formula": "{ index: (Number(context?.item?.data?.index) || 0) + 1, label: context?.item?.data?.label }" }
    }
  ],
  "variables": {},
  "workflows": {
    "stepper-wf-step-click": {
      "id": "stepper-wf-step-click",
      "name": "Click Step",
      "trigger": "click",
      "description": "Emit On step click with the clicked step's 1-indexed position.",
      "steps": [
        {
          "id": "emit-click",
          "type": "emitComponentTrigger",
          "config": { "triggerId": "stepper-t-on-step-click" }
        }
      ]
    }
  },
  "content": {
    "type": "Box",
    "props": {
      "className": "flex w-full",
      "style": {
        "flexDirection": { "formula": "context?.component?.props?.orientation==='vertical'?'column':'row'" },
        "alignItems": { "formula": "context?.component?.props?.orientation==='vertical'?'flex-start':'center'" },
        "gap": { "formula": "context?.component?.props?.orientation==='vertical'?'8px':'0px'" }
      }
    },
    "children": [
      {
        "type": "Box",
        "map": { "formula": "(()=>{const steps=Array.isArray(context?.component?.props?.steps)?context.component.props.steps:[];const active=Number(context?.component?.props?.activeStep)||1;return steps.map((s,i)=>{const idx=i+1;const state=idx<active?'done':idx===active?'current':'upcoming';return{step:idx,label:s?.label||('Step '+idx),state:state,isLast:i===steps.length-1}})})()" },
        "key": "context.item.data.step",
        "props": { "className": "contents" },
        "children": [
          {
            "type": "Box",
            "props": { "className": "flex flex-col items-center gap-[4px] cursor-pointer" },
            "actions": [{ "action": "stepper-wf-step-click" }],
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "w-[32px] h-[32px] rounded-[9999px] flex items-center justify-center",
                  "style": {
                    "backgroundColor": { "formula": "context?.item?.data?.state==='upcoming'?'transparent':'var(--theme-primary)'" },
                    "borderWidth": { "formula": "context?.item?.data?.state==='upcoming'?'2px':'0'" },
                    "borderStyle": { "formula": "context?.item?.data?.state==='upcoming'?'solid':'none'" },
                    "borderColor": { "formula": "context?.item?.data?.state==='upcoming'?'var(--border)':'transparent'" }
                  }
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-[14px] font-bold",
                      "style": {
                        "color": { "formula": "context?.item?.data?.state==='upcoming'?'var(--theme-muted-foreground)':'var(--theme-primary-foreground)'" }
                      }
                    },
                    "text": "{{context.item.data.step}}"
                  }
                ]
              },
              {
                "type": "Text",
                "props": {
                  "className": "text-[12px]",
                  "style": {
                    "color": { "formula": "context?.item?.data?.state==='upcoming'?'var(--theme-muted-foreground)':'var(--theme-primary)'" }
                  }
                },
                "text": "{{context.item.data.label}}"
              }
            ]
          },
          {
            "type": "Box",
            "condition": "!context?.item?.data?.isLast && context?.component?.props?.orientation !== 'vertical'",
            "props": {
              "className": "flex-1 h-px mx-[8px]",
              "style": {
                "backgroundColor": { "formula": "context?.item?.data?.state==='done'?'var(--theme-primary)':'var(--border)'" }
              }
            }
          }
        ]
      }
    ]
  },
  "isBuiltIn": true,
  "icon": "①"
}
