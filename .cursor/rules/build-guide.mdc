## Bootstrap Files (Required When Starting Fresh)

When `config/` is empty, create these 2 wiring files before anything else. Without them layouts and `resolveScreenConfig` all fail.

**Do NOT modify `app/[[...slug]]/page.tsx` or `lib/sdui/`** — they are generic and work as-is for any app.

### `config/layouts/index.ts`
```ts
import store from './store.json';
import account from './account.json';
// import every layout you create

export const layouts = {
  store: store as { structure: object },
  account: account as { structure: object },
} as const;
```

### `config/app.ts`
```ts
import routes from './routes.json';
import { layouts } from './layouts';
import { resolveScreenConfig } from '@/lib/sdui/config-resolver';
// import every screen JSON
import home from './screens/home.json';
import login from './screens/login.json';
// import every action file
import authActions from './actions/auth.json';
import layoutActions from './actions/layout.json';

// Fragments registry is empty — all shared UI is inlined via shared-components.json
const registry = { layouts, fragments: {} };

const rawScreens = { home, login /*, ...*/ };
const screens = Object.fromEntries(
  Object.entries(rawScreens).map(([name, screen]) =>
    [name, resolveScreenConfig(screen as Parameters<typeof resolveScreenConfig>[0], registry)]
  )
) as typeof rawScreens;

const actions = { ...authActions, ...layoutActions /*, ...*/ };

export default { ...routes, screens, actions } as const;
```

