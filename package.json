{
  "name": "starter-kit-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:preview": "next build",
    "start": "next start",
    "lint": "npm run validate:json && next lint",
    "validate:json": "node scripts/validate-json.js",
    "fix:json": "node scripts/fix-json-trailing-commas.js",
    "eval:ai": "npx tsx scripts/eval-ai.ts",
    "eval:page": "npx tsx scripts/eval-ai.ts --generator=page",
    "eval:page:visual": "RUN_VISUAL=1 npx tsx scripts/eval-ai.ts --generator=page",
    "eval:page:visual:retry": "RUN_VISUAL=1 npx tsx scripts/eval-ai.ts --generator=page --only-failures",
    "eval:page:case": "npx tsx scripts/eval-ai.ts --generator=page --case=fashion-homepage-full",
    "add-correction": "npx tsx scripts/add-correction.ts",
    "test:visual-screen": "npx tsx scripts/run-visual-screen-test.ts",
    "check:component-sync": "node scripts/check-component-sync.js",
    "train": "npx tsx scripts/training-loop.ts",
    "train:dry-run": "npx tsx scripts/training-loop.ts --dry-run",
    "eval:page:full": "RUN_VISUAL=1 npx tsx scripts/eval-ai.ts --generator=page && npx tsx scripts/training-loop.ts",
    "capability-scan": "npx tsx scripts/run-capability-scan.ts",
    "capability-scan:dry-run": "npx tsx scripts/run-capability-scan.ts --dry-run",
    "supervisor": "npx tsx scripts/run-supervisor.ts",
    "supervisor:dry-run": "npx tsx scripts/run-supervisor.ts --dry-run",
    "snapshot:sections": "npx tsx scripts/snapshot-sections.ts",
    "snapshot:sections:dark": "npx tsx scripts/snapshot-sections.ts --dark",
    "snapshot:layout-parts": "npx tsx scripts/snapshot-sections.ts --layout-parts",
    "snapshot:all": "npx tsx scripts/snapshot-sections.ts --with-layout-parts",
    "sections:browser": "echo 'Open http://localhost:3000/dev/sections in your browser (requires npm run dev)'"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.30",
    "@expo/html-elements": "^0.12.5",
    "@gluestack-ui/core": "^3.0.12",
    "@gluestack-ui/utils": "^3.0.13",
    "@gluestack/ui-next-adapter": "^3.0.3",
    "@gorhom/bottom-sheet": "^5.0.0-alpha.11",
    "@legendapp/motion": "^2.4.0",
    "ai": "^6.0.97",
    "dom-helpers": "^5.2.1",
    "embla-carousel-react": "^8.6.0",
    "json-logic-js": "^2.0.5",
    "lucide-react-native": "^0.510.0",
    "nativewind": "^4.1.23",
    "next": "15.3.8",
    "react": "^19.2.1",
    "react-aria": "^3.41.1",
    "react-dom": "^19.2.1",
    "react-native-safe-area-context": "^5.6.1",
    "react-native-svg": "^15.12.0",
    "react-native-web": "^0.20.0",
    "react-stately": "^3.39.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^1.14.0",
    "tailwind-variants": "^0.1.20",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@react-native/assets-registry": "^0.79.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-native": "^0.72.8",
    "ajv": "^8.18.0",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-native-web": "^0.20.0",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "15.3.3",
    "json5": "^2.2.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "tsx": "^4.7.0",
    "playwright": "^1.49.0"
  }
}