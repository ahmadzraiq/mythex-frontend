          "validation": {
            "required": true,
            "message": "Please enter your first name"
          }
        },
        {
          "name": "lastName",
          "type": "string",
          "initialValue": "",
          "validation": {
            "required": true,
            "message": "Please enter your last name"
          }
        },
        {
          "name": "password",
          "type": "string",
          "initialValue": "",
          "validation": {
            "required": true,
            "minLength": 8,
            "message": "Password must be at least 8 characters"
          }
        },
        {
          "name": "confirmPassword",
          "type": "string",
          "initialValue": "",
          "validation": {
            "required": true,
            "equalsField": "form.password",
            "message": "Passwords do not match"
          }
        },
        {
          "name": "phoneNumber",
          "type": "string",
          "initialValue": ""
        }
      ]
    },
