      "label": "Sign In Form",
      "type": "form",
      "folder": "Auth",
      "fields": [
        {
          "name": "username",
          "type": "string",
          "initialValue": "",
          "validation": {
            "required": true,
            "pattern": "email",
            "message": "Please enter a valid email address"
          }
        },
        {
          "name": "password",
          "type": "string",
          "initialValue": "",
          "validation": {
            "required": true,
            "message": "Please enter your password"
          }
        }
      ]
    },
    "f7a8b9c0-d1e2-3456-fabc-567890123456": {
      "label": "Register Form",
      "type": "form",
      "folder": "Auth",
      "fields": [
        {
          "name": "emailAddress",
          "type": "string",
          "initialValue": "",
          "validation": {
            "required": true,
            "pattern": "email",
            "message": "Please enter a valid email address"
          }
        },
        {
          "name": "firstName",
          "type": "string",
