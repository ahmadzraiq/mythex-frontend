{
  "initialData": {
    "auth": {
      "user": null,
      "token": null
    },
    "cart": {
      "id": null,
      "code": null,
      "state": null,
      "totalQuantity": 0,
      "subTotalWithTax": 0,
      "shippingWithTax": 0,
      "totalWithTax": 0,
      "currencyCode": "USD",
      "couponCodes": [],
      "discounts": [],
      "lines": []
    },
    "route": {
      "path": "/",
      "slug": "",
      "q": "",
      "sort": "name-asc",
      "facets": []
    },
    "nav": {
      "collections": [],
      "searchQuery": "",
      "themeMenuOpen": false,
      "colorScheme": "system"
    },
    "collectionSkip": 0,
    "collectionPageSize": 12,
    "selectedFacets": [],
    "sortInput": {
      "name": "ASC"
    },
    "sort": "name-asc",
    "sortMenuOpen": false,
    "layout": {
      "drawerOpen": false,
      "cartDrawerOpen": false
    },
    "checkout": {
      "step": 0,
      "shippingMethods": [],
      "paymentMethods": [],
      "countries": [],
      "selectedShippingMethodId": null,
      "selectedPaymentMethodCode": null
    },
    "_workflow": {
      "lastAction": null,
      "lastError": null
    }
  },
  "paths": {
    "authUser": "auth.user",
    "routePath": "route.path",
    "routeSlug": "route.slug",
    "routeQ": "route.q",
    "routeSort": "route.sort",
    "routeFacets": "route.facets"
  },
  "engineConventions": {
    "loadingSuffix": "loading",
    "errorSuffix": "error",
    "defaultStoreIn": "data",
    "defaultStoreErrorsIn": "errors",
    "defaultErrorMessagePath": "message",
    "workflowPath": "_workflow",
    "screenScopedAliases": [
      "form",
      "errors"
    ],
    "defaultFormPath": "form",
    "graphqlEndpoint": "http://localhost:3000/shop-api",
    "graphqlHeaders": {
      "vendure-token": "__default_channel__"
    },
    "graphqlCredentials": "include"
  },
  "computed": [
    {
      "output": "sortInput",
      "expr": {
        "sortInputFromRoute": [
          {
            "var": "route.sort"
          }
        ]
      }
    },
    {
      "output": "collectionPaginationPages",
      "expr": {
        "paginationPages": [
          { "var": ["collection.search.totalItems", 0] },
          { "var": ["collectionSkip", 0] },
          { "var": ["collectionPageSize", 12] }
        ]
      }
    },
    {
      "output": "collectionCurrentPage",
      "expr": {
        "max": [
          1,
          {
            "floor": {
              "+": [
                { "/": [{ "var": ["collectionSkip", 0] }, { "var": ["collectionPageSize", 12] }] },
                1
              ]
            }
          }
        ]
      }
    },
    {
      "output": "collectionTotalPages",
      "expr": {
        "max": [
          1,
          {
            "ceil": {
              "/": [
                { "var": ["collection.search.totalItems", 0] },
                { "var": ["collectionPageSize", 12] }
              ]
            }
          }
        ]
      }
    },
    {
      "output": "collectionPrevPage",
      "expr": { "max": [1, { "-": [{ "var": ["collectionCurrentPage", 1] }, 1] }] }
    },
    {
      "output": "collectionNextPage",
      "expr": { "min": [{ "var": ["collectionTotalPages", 1] }, { "+": [{ "var": ["collectionCurrentPage", 1] }, 1] }] }
    },
    {
      "output": "product.selectedVariantId",
      "expr": { "findMatchingVariantId": [{ "var": "product.variants" }, { "var": "product.optionGroups" }, { "var": "product.selectedOptions" }] }
    },
    {
      "output": "product.primaryCollectionSlug",
      "expr": { "primaryCollectionSlug": [{ "var": "product.collections" }] }
    },
    {
      "output": "product.currentImage",
      "expr": { "at": [{ "var": "product.assets" }, { "var": ["product.imageIndex", 0] }] }
    },
    {
      "output": "product.selectedVariant",
      "expr": { "findVariantById": [{ "var": "product.variants" }, { "var": "product.selectedVariantId" }] }
    },
    {
      "output": "related.products",
      "expr": { "filterRelatedProducts": [{ "var": "related._raw" }, { "var": "product.id" }, 12] }
    }
  ],
  "searchParamSync": [
    { "param": "q", "path": "route.q", "default": "" },
    { "param": "sort", "path": "route.sort", "default": "name-asc" },
    { "param": "facets", "path": "route.facets", "type": "array" },
    { "param": "page", "path": "collectionSkip", "default": "1", "transform": "pageToSkip", "pageSize": 12 }
  ]
}