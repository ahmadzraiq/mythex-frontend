{
  "initialData": {
    "auth": {
      "user": null,
      "token": null
    },
    "cart": {
      "id": null,
      "code": null,
      "state": null,
      "totalQuantity": 0,
      "subTotalWithTax": 0,
      "shippingWithTax": 0,
      "totalWithTax": 0,
      "currencyCode": "USD",
      "couponCodes": [],
      "discounts": [],
      "lines": []
    },
    "route": {
      "path": "/",
      "slug": "",
      "q": "",
      "token": "",
      "sort": "name-asc",
      "facets": []
    },
    "nav": {
      "collections": [],
      "searchQuery": "",
      "themeMenuOpen": false,
      "colorScheme": "system"
    },
    "collectionSkip": 0,
    "searchSkip": 0,
    "collectionPageSize": 12,
    "selectedFacets": [],
    "sortInput": {
      "name": "ASC"
    },
    "sort": "name-asc",
    "sortMenuOpen": false,
    "layout": {
      "drawerOpen": false,
      "cartDrawerOpen": false
    },
    "checkout": {
      "step": "contact",
      "contactCompleted": false,
      "order": null,
      "shippingMethods": [],
      "paymentMethods": [],
      "countries": [],
      "selectedShippingMethodId": null,
      "selectedPaymentMethodCode": null,
      "useSameForBilling": true
    },
    "_workflow": {
      "lastAction": null,
      "lastError": null
    }
  },
  "paths": {
    "authUser": "auth.user",
    "routePath": "route.path",
    "routeSlug": "route.slug",
    "routeQ": "route.q",
    "routeSort": "route.sort",
    "routeFacets": "route.facets"
  },
  "engineConventions": {
    "computedConventionKeys": [
      "sortInputMap",
      "defaultSortInput"
    ],
    "themePath": "nav.colorScheme",
    "defaultPaginationPath": "collectionSkip",
    "defaultPaginationFetchAction": "fetchCollection",
    "shareSlugPrefix": "/product",
    "loadingSuffix": "loading",
    "errorSuffix": "error",
    "defaultStoreIn": "data",
    "defaultStoreErrorsIn": "errors",
    "defaultErrorMessagePath": "message",
    "workflowPath": "_workflow",
    "persistPaths": [
      "checkout.selectedPaymentMethodCode"
    ],
    "sortInputMap": {
      "name-asc": {
        "name": "ASC"
      },
      "name-desc": {
        "name": "DESC"
      },
      "price-asc": {
        "price": "ASC"
      },
      "price-desc": {
        "price": "DESC"
      }
    },
    "defaultSortInput": {
      "name": "ASC"
    },
    "screenScopedAliases": [
      "form",
      "errors"
    ],
    "graphqlEndpoint": "http://localhost:3000/shop-api",
    "graphqlHeaders": {
      "vendure-token": "__default_channel__"
    },
    "graphqlCredentials": "include"
  },
  "globalInitActions": [
    {
      "action": "fetchNavCollections"
    },
    {
      "action": "fetchCart"
    }
  ],
  "computed": [
    {
      "output": "sortInput",
      "expr": {
        "lookupMap": [
          {
            "var": "_conventions.sortInputMap"
          },
          {
            "var": [
              "route.sort",
              "name-asc"
            ]
          },
          {
            "var": "_conventions.defaultSortInput"
          }
        ]
      }
    },
    {
      "output": "collectionPaginationPages",
      "expr": {
        "paginationPages": [
          {
            "var": [
              "collection.search.totalItems",
              0
            ]
          },
          {
            "var": [
              "collectionSkip",
              0
            ]
          },
          {
            "var": [
              "collectionPageSize",
              12
            ]
          }
        ]
      }
    },
    {
      "output": "collectionCurrentPage",
      "expr": {
        "max": [
          1,
          {
            "floor": {
              "+": [
                {
                  "/": [
                    {
                      "var": [
                        "collectionSkip",
                        0
                      ]
                    },
                    {
                      "var": [
                        "collectionPageSize",
                        12
                      ]
                    }
                  ]
                },
                1
              ]
            }
          }
        ]
      }
    },
    {
      "output": "collectionTotalPages",
      "expr": {
        "max": [
          1,
          {
            "ceil": {
              "/": [
                {
                  "var": [
                    "collection.search.totalItems",
                    0
                  ]
                },
                {
                  "var": [
                    "collectionPageSize",
                    12
                  ]
                }
              ]
            }
          }
        ]
      }
    },
    {
      "output": "collectionPrevPage",
      "expr": {
        "max": [
          1,
          {
            "-": [
              {
                "var": [
                  "collectionCurrentPage",
                  1
                ]
              },
              1
            ]
          }
        ]
      }
    },
    {
      "output": "collectionNextPage",
      "expr": {
        "min": [
          {
            "var": [
              "collectionTotalPages",
              1
            ]
          },
          {
            "+": [
              {
                "var": [
                  "collectionCurrentPage",
                  1
                ]
              },
              1
            ]
          }
        ]
      }
    },
    {
      "output": "searchPaginationPages",
      "expr": {
        "paginationPages": [
          {
            "var": [
              "search.totalItems",
              0
            ]
          },
          {
            "var": [
              "collectionSkip",
              0
            ]
          },
          {
            "var": [
              "collectionPageSize",
              12
            ]
          }
        ]
      }
    },
    {
      "output": "searchCurrentPage",
      "expr": {
        "max": [
          1,
          {
            "floor": {
              "+": [
                {
                  "/": [
                    {
                      "var": [
                        "searchSkip",
                        0
                      ]
                    },
                    {
                      "var": [
                        "collectionPageSize",
                        12
                      ]
                    }
                  ]
                },
                1
              ]
            }
          }
        ]
      }
    },
    {
      "output": "searchTotalPages",
      "expr": {
        "max": [
          1,
          {
            "ceil": {
              "/": [
                {
                  "var": [
                    "search.totalItems",
                    0
                  ]
                },
                {
                  "var": [
                    "collectionPageSize",
                    12
                  ]
                }
              ]
            }
          }
        ]
      }
    },
    {
      "output": "searchPrevPage",
      "expr": {
        "max": [
          1,
          {
            "-": [
              {
                "var": [
                  "searchCurrentPage",
                  1
                ]
              },
              1
            ]
          }
        ]
      }
    },
    {
      "output": "searchNextPage",
      "expr": {
        "min": [
          {
            "var": [
              "searchTotalPages",
              1
            ]
          },
          {
            "+": [
              {
                "var": [
                  "searchCurrentPage",
                  1
                ]
              },
              1
            ]
          }
        ]
      }
    },
    {
      "output": "product.selectedVariantId",
      "expr": {
        "findItemByOptionsMatch": [
          {
            "var": "product.variants"
          },
          {
            "var": "product.optionGroups"
          },
          {
            "var": "product.selectedOptions"
          }
        ]
      }
    },
    {
      "output": "product.primaryCollectionSlug",
      "expr": {
        "findFirstByPreference": [
          {
            "var": "product.collections"
          }
        ]
      }
    },
    {
      "output": "product.currentImage",
      "expr": {
        "at": [
          {
            "var": "product.assets"
          },
          {
            "var": [
              "product.imageIndex",
              0
            ]
          }
        ]
      }
    },
    {
      "output": "product.selectedVariant",
      "expr": {
        "findItemById": [
          {
            "var": "product.variants"
          },
          {
            "var": "product.selectedVariantId"
          }
        ]
      }
    },
    {
      "output": "related.products",
      "expr": {
        "filterExcludeByFieldAndSlice": [
          {
            "var": "related._raw"
          },
          "productId",
          {
            "var": "product.id"
          },
          12
        ]
      }
    },
    {
      "output": "checkout.firstIncompleteStep",
      "expr": {
        "if": [
          {
            "!": [
              {
                "or": [
                  {
                    "var": "auth.user"
                  },
                  {
                    "var": [
                      "checkout.order.customer.emailAddress",
                      ""
                    ]
                  }
                ]
              }
            ]
          },
          "contact",
          {
            "if": [
              {
                "!": [
                  {
                    "var": [
                      "checkout.order.shippingAddress.streetLine1",
                      ""
                    ]
                  }
                ]
              },
              "shipping",
              {
                "if": [
                  {
                    "<=": [
                      {
                        "var": [
                          "checkout.order.shippingLines.length",
                          0
                        ]
                      },
                      0
                    ]
                  },
                  "delivery",
                  {
                    "if": [
                      {
                        "!": [
                          {
                            "var": [
                              "checkout.selectedPaymentMethodCode",
                              ""
                            ]
                          }
                        ]
                      },
                      "payment",
                      "review"
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "output": "collection.resultsHeaderText",
      "expr": {
        "if": [
          { "==": [{ "var": ["collection.search.totalItems", 0] }, 1] },
          "1 product",
          { "cat": [{ "var": ["collection.search.totalItems", "0"] }, " products"] }
        ]
      }
    },
    {
      "output": "collection.facetGroups",
      "expr": {
        "groupBy": [
          { "var": ["collection.search.facetValues", []] },
          "facetValue.facet.name",
          "facetValue.facet.id"
        ]
      }
    },
    {
      "output": "search.resultsHeaderText",
      "expr": {
        "if": [
          { "==": [{ "var": ["search.totalItems", 0] }, 1] },
          "1 product",
          { "cat": [{ "var": ["search.totalItems", "0"] }, " products"] }
        ]
      }
    },
    {
      "output": "search.resultsHeadingText",
      "expr": {
        "if": [
          { "!=": [{ "var": ["route.q", ""] }, ""] },
          { "cat": ["Search results for \"", { "var": ["route.q", ""] }, "\""] },
          "Search"
        ]
      }
    },
    {
      "output": "search.facetGroups",
      "expr": {
        "groupBy": [
          { "var": ["search.facetValues", []] },
          "facetValue.facet.name",
          "facetValue.facet.id"
        ]
      }
    },
    {
      "output": "checkout.selectedPaymentMethodDisplay",
      "expr": {
        "lookupInArray": [
          {
            "var": [
              "checkout.paymentMethods",
              []
            ]
          },
          "code",
          {
            "var": [
              "checkout.selectedPaymentMethodCode",
              ""
            ]
          },
          "name"
        ]
      }
    },
    {
      "output": "checkout.contactStepIndicatorClassName",
      "expr": {
        "cat": [
          "flex items-center justify-center w-8 h-8 min-w-8 min-h-8 rounded-full overflow-hidden shrink-0 ",
          {
            "if": [
              {
                "or": [
                  { "var": "auth.user" },
                  { "var": ["checkout.order.customer.emailAddress", false] }
                ]
              },
              "bg-green-500 !text-white",
              {
                "if": [
                  { "==": [{ "var": "checkout.step" }, "contact"] },
                  "bg-[var(--theme-shop-button)] !text-white",
                  "bg-[var(--theme-hero-bg)] !text-[var(--theme-muted-foreground)]"
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "output": "checkout.shippingStepIndicatorClassName",
      "expr": {
        "cat": [
          "flex items-center justify-center w-8 h-8 min-w-8 min-h-8 rounded-full overflow-hidden shrink-0 ",
          {
            "if": [
              { "var": ["checkout.order.shippingAddress.streetLine1"] },
              "bg-green-500 !text-white",
              {
                "if": [
                  { "==": [{ "var": "checkout.step" }, "shipping"] },
                  "bg-[var(--theme-shop-button)] !text-white",
                  "bg-[var(--theme-hero-bg)] !text-[var(--theme-muted-foreground)]"
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "output": "checkout.paymentStepIndicatorClassName",
      "expr": {
        "cat": [
          "flex items-center justify-center w-8 h-8 min-w-8 min-h-8 rounded-full overflow-hidden shrink-0 ",
          {
            "if": [
              { "var": ["checkout.selectedPaymentMethodCode"] },
              "bg-green-500 !text-white",
              {
                "if": [
                  { "==": [{ "var": "checkout.step" }, "payment"] },
                  "bg-[var(--theme-shop-button)] !text-white",
                  "bg-[var(--theme-hero-bg)] !text-[var(--theme-muted-foreground)]"
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "output": "checkout.shippingStepHeaderClassName",
      "expr": {
        "cat": [
          "flex flex-row items-center justify-between w-full py-4 ",
          {
            "if": [
              {
                "or": [
                  { "var": "auth.user" },
                  { "var": ["checkout.order.customer.emailAddress", false] }
                ]
              },
              "",
              "opacity-50 pointer-events-none cursor-not-allowed"
            ]
          }
        ]
      }
    },
    {
      "output": "checkout.paymentStepHeaderClassName",
      "expr": {
        "cat": [
          "flex flex-row items-center justify-between w-full py-4 ",
          {
            "if": [
              {
                "or": [
                  { ">": [{ "var": ["checkout.order.shippingLines.length", 0] }, 0] },
                  { "var": ["checkout.selectedPaymentMethodCode", ""] }
                ]
              },
              "",
              "opacity-50 pointer-events-none cursor-not-allowed"
            ]
          }
        ]
      }
    }
  ],
  "variableStoreInitial": {
    "collectionSkip": 0,
    "searchSkip": 0,
    "sortMenuOpen": false,
    "product": {
      "selectedOptions": {},
      "imageIndex": 0
    }
  },
  "searchParamSync": [
    {
      "param": "q",
      "path": "route.q",
      "default": "",
      "variableStorePath": "nav.searchQuery",
      "triggersParamChange": true
    },
    {
      "param": "token",
      "path": "route.token",
      "default": ""
    },
    {
      "param": "sort",
      "path": "route.sort",
      "default": "name-asc",
      "triggersParamChange": true
    },
    {
      "param": "facets",
      "path": "route.facets",
      "type": "array",
      "triggersParamChange": true
    },
    {
      "param": "page",
      "path": "collectionSkip",
      "default": "1",
      "transform": "pageToSkip",
      "pageSize": 12,
      "variableStorePath": "collectionSkip",
      "routePrefix": "/collection"
    },
    {
      "param": "page",
      "path": "searchSkip",
      "default": "1",
      "transform": "pageToSkip",
      "pageSize": 12,
      "variableStorePath": "searchSkip",
      "routePrefix": "/search"
    }
  ]
}
