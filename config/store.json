{
  "initialData": {
    "auth": {
      "user": null,
      "token": null
    },
    "cart": {
      "id": null,
      "code": null,
      "state": null,
      "totalQuantity": 0,
      "subTotalWithTax": 0,
      "shippingWithTax": 0,
      "totalWithTax": 0,
      "currencyCode": "USD",
      "couponCodes": [],
      "discounts": [],
      "lines": []
    },
    "route": {
      "path": "/",
      "slug": "",
      "q": "",
      "token": "",
      "sort": "name-asc",
      "facets": []
    },
    "nav": {
      "collections": [],
      "searchQuery": "",
      "themeMenuOpen": false,
      "colorScheme": "system"
    },
    "collectionSkip": 0,
    "searchSkip": 0,
    "collectionPageSize": 12,
    "selectedFacets": [],
    "sortInput": {
      "name": "ASC"
    },
    "sort": "name-asc",
    "sortMenuOpen": false,
    "layout": {
      "drawerOpen": false,
      "cartDrawerOpen": false
    },
    "checkout": {
      "step": "contact",
      "contactCompleted": false,
      "order": null,
      "shippingMethods": [],
      "paymentMethods": [],
      "countries": [],
      "selectedShippingMethodId": null,
      "selectedPaymentMethodCode": null,
      "useSameForBilling": true
    },
    "_workflow": {
      "lastAction": null,
      "lastError": null
    }
  },
  "paths": {
    "authUser": "auth.user",
    "routePath": "route.path",
    "routeSlug": "route.slug",
    "routeQ": "route.q",
    "routeSort": "route.sort",
    "routeFacets": "route.facets"
  },
  "engineConventions": {
    "computedConventionKeys": [
      "sortInputMap",
      "defaultSortInput"
    ],
    "themePath": "nav.colorScheme",
    "defaultPaginationPath": "collectionSkip",
    "defaultPaginationFetchAction": "fetchCollection",
    "shareSlugPrefix": "/product",
    "loadingSuffix": "loading",
    "errorSuffix": "error",
    "defaultStoreIn": "data",
    "defaultStoreErrorsIn": "errors",
    "defaultErrorMessagePath": "message",
    "workflowPath": "_workflow",
    "persistPaths": [
      "checkout.selectedPaymentMethodCode"
    ],
    "resetVarsOnNavigate": [
      "nav.themeMenuOpen"
    ],
    "sortInputMap": {
      "name-asc": {
        "name": "ASC"
      },
      "name-desc": {
        "name": "DESC"
      },
      "price-asc": {
        "price": "ASC"
      },
      "price-desc": {
        "price": "DESC"
      }
    },
    "defaultSortInput": {
      "name": "ASC"
    },
    "screenScopedAliases": [
      "form",
      "errors"
    ],
    "graphqlEndpoint": "http://localhost:3000/shop-api",
    "graphqlHeaders": {
      "vendure-token": "__default_channel__"
    },
    "graphqlCredentials": "include"
  },
  "globalInitActions": [
    {
      "action": "fetchNavCollections"
    },
    {
      "action": "fetchCart"
    }
  ],
  "variableStoreInitial": {
    "collectionSkip": 0,
    "searchSkip": 0,
    "sortMenuOpen": false,
    "product": {
      "selectedOptions": {},
      "imageIndex": 0
    }
  },
  "searchParamSync": [
    {
      "param": "q",
      "path": "route.q",
      "default": "",
      "variableStorePath": "nav.searchQuery",
      "triggersParamChange": true
    },
    {
      "param": "token",
      "path": "route.token",
      "default": ""
    },
    {
      "param": "sort",
      "path": "route.sort",
      "default": "name-asc",
      "triggersParamChange": true
    },
    {
      "param": "facets",
      "path": "route.facets",
      "type": "array",
      "triggersParamChange": true
    },
    {
      "param": "page",
      "path": "collectionSkip",
      "default": "1",
      "transform": "pageToSkip",
      "pageSize": 12,
      "variableStorePath": "collectionSkip",
      "triggersParamChange": true,
      "routePrefix": "/collection"
    },
    {
      "param": "page",
      "path": "searchSkip",
      "default": "1",
      "transform": "pageToSkip",
      "pageSize": 12,
      "variableStorePath": "searchSkip",
      "triggersParamChange": true,
      "routePrefix": "/search"
    }
  ]
}
