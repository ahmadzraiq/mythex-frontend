{
  "initialData": {
    "auth": {
      "user": null,
      "token": null
    },
    "cart": {
      "id": null,
      "code": null,
      "state": null,
      "totalQuantity": 0,
      "subTotalWithTax": 0,
      "shippingWithTax": 0,
      "totalWithTax": 0,
      "currencyCode": "USD",
      "couponCodes": [],
      "discounts": [],
      "lines": []
    },
    "route": {
      "path": "/",
      "slug": "",
      "q": "",
      "token": "",
      "sort": "name-asc",
      "facets": []
    },
    "nav": {
      "collections": [],
      "searchQuery": "",
      "themeMenuOpen": false,
      "colorScheme": "system"
    },
    "collectionSkip": 0,
    "searchSkip": 0,
    "collectionPageSize": 12,
    "selectedFacets": [],
    "sortInput": {
      "name": "ASC"
    },
    "sort": "name-asc",
    "sortMenuOpen": false,
    "layout": {
      "drawerOpen": false,
      "cartDrawerOpen": false
    },
    "checkout": {
      "step": "contact",
      "contactCompleted": false,
      "order": null,
      "shippingMethods": [],
      "paymentMethods": [],
      "countries": [],
      "selectedShippingMethodId": null,
      "selectedPaymentMethodCode": null,
      "useSameForBilling": true
    },
    "_workflow": {
      "lastAction": null,
      "lastError": null
    }
  },
  "paths": {
    "authUser": "auth.user",
    "routePath": "route.path",
    "routeSlug": "route.slug",
    "routeQ": "route.q",
    "routeSort": "route.sort",
    "routeFacets": "route.facets"
  },
  "engineConventions": {
    "computedConventionKeys": [
      "sortInputMap",
      "defaultSortInput"
    ],
    "themePath": "nav.colorScheme",
    "defaultPaginationPath": "collectionSkip",
    "defaultPaginationFetchAction": "fetchCollection",
    "shareSlugPrefix": "/product",
    "loadingSuffix": "loading",
    "errorSuffix": "error",
    "defaultStoreIn": "data",
    "defaultStoreErrorsIn": "errors",
    "defaultErrorMessagePath": "message",
    "workflowPath": "_workflow",
    "persistPaths": [
      "checkout.selectedPaymentMethodCode"
    ],
    "resetVarsOnNavigate": [
      "nav.themeMenuOpen"
    ],
    "sortInputMap": {
      "name-asc": {
        "name": "ASC"
      },
      "name-desc": {
        "name": "DESC"
      },
      "price-asc": {
        "price": "ASC"
      },
      "price-desc": {
        "price": "DESC"
      }
    },
    "defaultSortInput": {
      "name": "ASC"
    },
    "screenScopedAliases": [
      "form",
      "errors"
    ],
    "graphqlEndpoint": "http://localhost:3000/shop-api",
    "graphqlHeaders": {
      "vendure-token": "__default_channel__"
    },
    "graphqlCredentials": "include"
  },
  "globalInitActions": [
    {
      "action": "fetchNavCollections"
    },
    {
      "action": "fetchCart"
    }
  ],
  "computed": [
    {
      "output": "sortInput",
      "expr": "lookupMap({{_conventions.sortInputMap}}, {{route.sort}} || 'name-asc', {{_conventions.defaultSortInput}})"
    },
    {
      "output": "collectionPaginationPages",
      "expr": "paginationPages({{collection.search.totalItems}} || 0, {{collectionSkip}} || 0, {{collectionPageSize}} || 12)"
    },
    {
      "output": "collectionCurrentPage",
      "expr": "max(1, floor(({{collectionSkip}} || 0) / ({{collectionPageSize}} || 12) + 1))"
    },
    {
      "output": "collectionTotalPages",
      "expr": "max(1, ceil(({{collection.search.totalItems}} || 0) / ({{collectionPageSize}} || 12)))"
    },
    {
      "output": "collectionPrevPage",
      "expr": "max(1, ({{collectionCurrentPage}} || 1) - 1)"
    },
    {
      "output": "collectionNextPage",
      "expr": "min({{collectionTotalPages}} || 1, ({{collectionCurrentPage}} || 1) + 1)"
    },
    {
      "output": "searchPaginationPages",
      "expr": "paginationPages({{search.totalItems}} || 0, {{searchSkip}} || 0, {{collectionPageSize}} || 12)"
    },
    {
      "output": "searchCurrentPage",
      "expr": "max(1, floor(({{searchSkip}} || 0) / ({{collectionPageSize}} || 12) + 1))"
    },
    {
      "output": "searchTotalPages",
      "expr": "max(1, ceil(({{search.totalItems}} || 0) / ({{collectionPageSize}} || 12)))"
    },
    {
      "output": "searchPrevPage",
      "expr": "max(1, ({{searchCurrentPage}} || 1) - 1)"
    },
    {
      "output": "searchNextPage",
      "expr": "min({{searchTotalPages}} || 1, ({{searchCurrentPage}} || 1) + 1)"
    },
    {
      "output": "product.selectedVariantId",
      "expr": "findItemByOptionsMatch({{product.variants}}, {{product.optionGroups}}, {{product.selectedOptions}})"
    },
    {
      "output": "product.primaryCollectionSlug",
      "expr": "findFirstByPreference({{product.collections}})"
    },
    {
      "output": "product.currentImage",
      "expr": "at({{product.assets}}, {{product.imageIndex}} || 0)"
    },
    {
      "output": "product.selectedVariant",
      "expr": "findItemById({{product.variants}}, {{product.selectedVariantId}})"
    },
    {
      "output": "related.products",
      "expr": "filterExcludeByFieldAndSlice({{related._raw}}, 'productId', {{product.id}}, 12)"
    },
    {
      "output": "checkout.firstIncompleteStep",
      "expr": "!({{auth.user}} || {{checkout.order.customer.emailAddress}} || '') ? 'contact' : !({{checkout.order.shippingAddress.streetLine1}} || '') ? 'shipping' : ({{checkout.order.shippingLines.length}} || 0) <= 0 ? 'delivery' : !({{checkout.selectedPaymentMethodCode}} || '') ? 'payment' : 'review'"
    },
    {
      "output": "collection.resultsHeaderText",
      "expr": "({{collection.search.totalItems}} || 0) === 1 ? '1 product' : ({{collection.search.totalItems}} || 0) + ' products'"
    },
    {
      "output": "collection.facetGroups",
      "expr": "groupBy({{collection.search.facetValues}} || [], 'facetValue.facet.name', 'facetValue.facet.id')"
    },
    {
      "output": "search.resultsHeaderText",
      "expr": "({{search.totalItems}} || 0) === 1 ? '1 product' : ({{search.totalItems}} || 0) + ' products'"
    },
    {
      "output": "search.resultsHeadingText",
      "expr": "({{route.q}} || '') !== '' ? 'Search results for \"' + ({{route.q}} || '') + '\"' : 'Search'"
    },
    {
      "output": "search.facetGroups",
      "expr": "groupBy({{search.facetValues}} || [], 'facetValue.facet.name', 'facetValue.facet.id')"
    },
    {
      "output": "checkout.selectedPaymentMethodDisplay",
      "expr": "lookupInArray({{checkout.paymentMethods}} || [], 'code', {{checkout.selectedPaymentMethodCode}} || '', 'name')"
    },
    {
      "output": "checkout.contactStepIndicatorClassName",
      "expr": "'flex items-center justify-center w-8 h-8 min-w-8 min-h-8 rounded-full overflow-hidden shrink-0 ' + (({{auth.user}} || {{checkout.order.customer.emailAddress}}) ? 'bg-green-500 !text-white' : ({{checkout.step}} === 'contact' ? 'bg-[var(--theme-shop-button)] !text-white' : 'bg-[var(--theme-hero-bg)] !text-[var(--theme-muted-foreground)]'))"
    },
    {
      "output": "checkout.shippingStepIndicatorClassName",
      "expr": "'flex items-center justify-center w-8 h-8 min-w-8 min-h-8 rounded-full overflow-hidden shrink-0 ' + ({{checkout.order.shippingAddress.streetLine1}} ? 'bg-green-500 !text-white' : ({{checkout.step}} === 'shipping' ? 'bg-[var(--theme-shop-button)] !text-white' : 'bg-[var(--theme-hero-bg)] !text-[var(--theme-muted-foreground)]'))"
    },
    {
      "output": "checkout.paymentStepIndicatorClassName",
      "expr": "'flex items-center justify-center w-8 h-8 min-w-8 min-h-8 rounded-full overflow-hidden shrink-0 ' + ({{checkout.selectedPaymentMethodCode}} ? 'bg-green-500 !text-white' : ({{checkout.step}} === 'payment' ? 'bg-[var(--theme-shop-button)] !text-white' : 'bg-[var(--theme-hero-bg)] !text-[var(--theme-muted-foreground)]'))"
    },
    {
      "output": "checkout.shippingStepHeaderClassName",
      "expr": "'flex flex-row items-center justify-between w-full py-4 ' + (({{auth.user}} || {{checkout.order.customer.emailAddress}}) ? '' : 'opacity-50 pointer-events-none cursor-not-allowed')"
    },
    {
      "output": "checkout.paymentStepHeaderClassName",
      "expr": "'flex flex-row items-center justify-between w-full py-4 ' + (({{checkout.order.shippingLines.length}} || 0) > 0 || {{checkout.selectedPaymentMethodCode}} ? '' : 'opacity-50 pointer-events-none cursor-not-allowed')"
    },
    {
      "output": "untitled",
      "expr": {}
    },
    {
      "output": "untitled1",
      "expr": {}
    },
    {
      "output": "untitled2",
      "expr": {}
    },
    {
      "output": "untitled3",
      "expr": {}
    },
    {
      "output": "untitled4",
      "expr": {}
    },
    {
      "output": "untitled5",
      "expr": {}
    },
    {
      "output": "untitled6",
      "expr": {}
    }
  ],
  "variableStoreInitial": {
    "collectionSkip": 0,
    "searchSkip": 0,
    "sortMenuOpen": false,
    "product": {
      "selectedOptions": {},
      "imageIndex": 0
    }
  },
  "searchParamSync": [
    {
      "param": "q",
      "path": "route.q",
      "default": "",
      "variableStorePath": "nav.searchQuery",
      "triggersParamChange": true
    },
    {
      "param": "token",
      "path": "route.token",
      "default": ""
    },
    {
      "param": "sort",
      "path": "route.sort",
      "default": "name-asc",
      "triggersParamChange": true
    },
    {
      "param": "facets",
      "path": "route.facets",
      "type": "array",
      "triggersParamChange": true
    },
    {
      "param": "page",
      "path": "collectionSkip",
      "default": "1",
      "transform": "pageToSkip",
      "pageSize": 12,
      "variableStorePath": "collectionSkip",
      "triggersParamChange": true,
      "routePrefix": "/collection"
    },
    {
      "param": "page",
      "path": "searchSkip",
      "default": "1",
      "transform": "pageToSkip",
      "pageSize": 12,
      "variableStorePath": "searchSkip",
      "triggersParamChange": true,
      "routePrefix": "/search"
    }
  ]
}