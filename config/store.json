{
  "initialData": {
    "auth": {
      "user": null,
      "token": null
    },
    "route": {
      "path": "/",
      "slug": "",
      "q": "",
      "token": "",
      "sort": "name-asc",
      "facets": []
    },
    "collectionPageSize": 12,
    "_workflow": {
      "lastAction": null,
      "lastError": null
    }
  },
  "paths": {
    "authUser": "auth.user",
    "routePath": "route.path",
    "routeSlug": "route.slug"
  },
  "engineConventions": {
    "computedConventionKeys": [
      "sortInputMap",
      "defaultSortInput"
    ],
    "themePath": "d3e4f5a6-b7c8-9012-defa-123456789012",
    "defaultPaginationPath": "a6b7c8d9-e0f1-2345-abcd-456789012345",
    "defaultPaginationFetchAction": "fetchCollection",
    "shareSlugPrefix": "/product",
    "loadingSuffix": "loading",
    "errorSuffix": "error",
    "defaultStoreIn": "data",
    "defaultStoreErrorsIn": "errors",
    "defaultErrorMessagePath": "message",
    "workflowPath": "_workflow",
    "persistPaths": [
      "b3c4d5e6-f7a8-9012-bcde-123456789012"
    ],
    "resetVarsOnNavigate": [
      "e4f5a6b7-c8d9-0123-efab-234567890123"
    ],
    "sortInputMap": {
      "name-asc": {
        "name": "ASC"
      },
      "name-desc": {
        "name": "DESC"
      },
      "price-asc": {
        "price": "ASC"
      },
      "price-desc": {
        "price": "DESC"
      }
    },
    "defaultSortInput": {
      "name": "ASC"
    },
    "graphqlEndpoint": "http://localhost:3000/shop-api",
    "graphqlHeaders": {
      "vendure-token": "__default_channel__"
    },
    "graphqlCredentials": "include"
  },
  "searchParamSync": [
    {
      "param": "q",
      "path": "route.q",
      "default": "",
      "variableStorePath": "f5a6b7c8-d9e0-1234-fabc-345678901234",
      "triggersParamChange": true
    },
    {
      "param": "token",
      "path": "route.token",
      "default": ""
    },
    {
      "param": "sort",
      "path": "route.sort",
      "default": "name-asc",
      "triggersParamChange": true
    },
    {
      "param": "facets",
      "path": "route.facets",
      "type": "array",
      "triggersParamChange": true
    },
    {
      "param": "page",
      "path": "a6b7c8d9-e0f1-2345-abcd-456789012345",
      "default": "1",
      "transform": "pageToSkip",
      "pageSize": 12,
      "variableStorePath": "a6b7c8d9-e0f1-2345-abcd-456789012345",
      "triggersParamChange": true,
      "routePrefix": "/collection"
    },
    {
      "param": "page",
      "path": "b7c8d9e0-f1a2-3456-bcde-567890123456",
      "default": "1",
      "transform": "pageToSkip",
      "pageSize": 12,
      "variableStorePath": "b7c8d9e0-f1a2-3456-bcde-567890123456",
      "triggersParamChange": true,
      "routePrefix": "/search"
    }
  ]
}
