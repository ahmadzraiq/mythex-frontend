{
  "defaultRedirect": "/login",
  "routes": [
    { "path": "/", "redirect": "/login" },
    { "path": "/login", "config": "login", "auth": false, "layout": "centered" },
    { "path": "/signup", "config": "signup", "auth": false, "layout": "centered" },
    { "path": "/dashboard", "config": "dashboard", "auth": true, "layout": "full" },
    { "path": "/dashboard/products", "config": "products", "auth": true, "layout": "full" },
    { "path": "/forgot-password", "config": "forgotPassword", "auth": false, "layout": "centered" },
    { "path": "/reset-password", "config": "resetPassword", "auth": false, "layout": "centered" },
    { "path": "/profile", "config": "profile", "auth": true, "layout": "full" }
  ],
  "screens": {
    "login": {
      "meta": { "title": "Login", "description": "Login to your account" },
      "state": { "form": { "email": "", "password": "" }, "errors": {} },
      "ui": {
        "type": "Box",
        "props": { "className": "flex flex-col items-center justify-center min-h-screen w-full bg-background-50 p-6" },
        "children": [
          {
            "type": "Box",
            "props": { "className": "w-full max-w-md mx-auto" },
            "children": [
              { "type": "Heading", "props": { "size": "xl", "className": "mb-6 text-typography-900" }, "text": "Login" },
              {
                "type": "Box",
                "condition": { "var": "auth.error" },
                "props": { "className": "mb-4 p-3 bg-error-100 rounded-lg" },
                "children": [{ "type": "Text", "props": { "className": "text-error-700 text-sm" }, "text": "{{auth.error}}" }]
              },
              {
                "type": "FormControl",
                "props": { "className": "mb-4" },
                "children": [
                  { "type": "FormControlLabel", "children": [{ "type": "FormControlLabelText", "text": "Email" }] },
                  {
                    "type": "Input",
                    "props": { "placeholder": "you@example.com", "value": "{{form.email}}", "variant": "outline" },
                    "actions": { "change": { "action": "setState", "payload": { "path": "form.email", "value": "$event" } } }
                  }
                ]
              },
              {
                "type": "FormControl",
                "props": { "className": "mb-6" },
                "children": [
                  { "type": "FormControlLabel", "children": [{ "type": "FormControlLabelText", "text": "Password" }] },
                  {
                    "type": "Input",
                    "props": { "placeholder": "••••••••", "value": "{{form.password}}", "variant": "outline", "secureTextEntry": true },
                    "actions": { "change": { "action": "setState", "payload": { "path": "form.password", "value": "$event" } } }
                  }
                ]
              },
              { "type": "Button", "props": { "action": "primary", "className": "w-full mb-2" }, "text": "Login", "actions": { "click": { "action": "login" } } },
              { "type": "Pressable", "props": { "className": "mb-4" }, "actions": { "click": { "action": "navigate", "payload": { "path": "/forgot-password" } } }, "children": [{ "type": "Text", "props": { "className": "text-primary-600 text-sm" }, "text": "Forgot password?" }] },
              {
                "type": "HStack",
                "props": { "className": "justify-center" },
                "children": [
                  { "type": "Text", "props": { "className": "text-typography-600 text-sm" }, "text": "Don't have an account? " },
                  { "type": "Pressable", "actions": { "click": { "action": "navigate", "payload": { "path": "/signup" } } }, "children": [{ "type": "Text", "props": { "className": "text-primary-600 font-medium text-sm" }, "text": "Sign up" }] }
                ]
              }
            ]
          }
        ]
      }
    },
    "signup": {
      "meta": { "title": "Sign Up", "description": "Create your account" },
      "state": { "form": { "name": "", "email": "", "password": "", "confirmPassword": "" }, "errors": {} },
      "ui": {
        "type": "Box",
        "props": { "className": "flex flex-col items-center justify-center min-h-screen w-full bg-background-50 p-6" },
        "children": [
          {
            "type": "Box",
            "props": { "className": "w-full max-w-md mx-auto" },
            "children": [
              { "type": "Heading", "props": { "size": "xl", "className": "mb-6 text-typography-900" }, "text": "Sign Up" },
              {
                "type": "Box",
                "condition": { "var": "auth.error" },
                "props": { "className": "mb-4 p-3 bg-error-100 rounded-lg" },
                "children": [{ "type": "Text", "props": { "className": "text-error-700 text-sm" }, "text": "{{auth.error}}" }]
              },
              {
                "type": "Form",
                "props": {
                  "defaultValues": { "form": { "name": "", "email": "", "password": "", "confirmPassword": "" } },
                  "validationRules": {
                    "form.name": { "required": true },
                    "form.email": { "required": true, "pattern": "email" },
                    "form.password": { "required": true, "minLength": 8 },
                    "form.confirmPassword": { "required": true, "equals": "form.password", "message": "Passwords must match" }
                  },
                  "submitAction": "signup"
                },
                "children": [
                  { "type": "FormInputWithLabel", "props": { "name": "form.name", "label": "Name", "placeholder": "John Doe", "variant": "outline", "className": "mb-4" } },
                  { "type": "FormInputWithLabel", "props": { "name": "form.email", "label": "Email", "placeholder": "you@example.com", "variant": "outline", "className": "mb-4" } },
                  { "type": "FormInputWithLabel", "props": { "name": "form.password", "label": "Password", "placeholder": "••••••••", "variant": "outline", "secureTextEntry": true, "className": "mb-4" } },
                  { "type": "FormInputWithLabel", "props": { "name": "form.confirmPassword", "label": "Confirm Password", "placeholder": "••••••••", "variant": "outline", "secureTextEntry": true, "className": "mb-6" } },
                  { "type": "FormSubmitButton", "props": { "action": "primary", "className": "w-full mb-4" }, "text": "Sign Up" }
                ]
              },
              {
                "type": "HStack",
                "props": { "className": "justify-center" },
                "children": [
                  { "type": "Text", "props": { "className": "text-typography-600 text-sm" }, "text": "Already have an account? " },
                  { "type": "Pressable", "actions": { "click": { "action": "navigate", "payload": { "path": "/login" } } }, "children": [{ "type": "Text", "props": { "className": "text-primary-600 font-medium text-sm" }, "text": "Login" }] }
                ]
              }
            ]
          }
        ]
      }
    },
    "dashboard": {
      "meta": { "title": "Dashboard", "description": "E-commerce Dashboard" },
      "state": { "layout": { "drawerOpen": false } },
      "initActions": [{ "action": "fetchProducts" }],
      "ui": {
        "type": "Box",
        "props": { "className": "min-h-screen w-full flex flex-col bg-background-50" },
        "children": [
          {
            "type": "Box",
            "props": { "className": "flex flex-col flex-1 min-h-0" },
            "children": [
              {
                "type": "Box",
                "props": { "className": "bg-primary-600 px-4 py-4 shadow-sm shrink-0" },
                "children": [
                  {
                    "type": "HStack",
                    "props": { "className": "items-center justify-between" },
                    "children": [
                      { "type": "Pressable", "props": { "className": "p-2 -ml-2 rounded-lg hover:bg-primary-500" }, "actions": { "click": { "action": "openDrawer" } }, "children": [{ "type": "Text", "props": { "className": "text-typography-0 text-xl" }, "text": "☰" }] },
                      { "type": "Text", "props": { "className": "text-typography-0 font-semibold text-lg" }, "text": "Dashboard" },
                      {
                        "type": "HStack",
                        "props": { "className": "items-center gap-4" },
                        "children": [
                          { "type": "Text", "props": { "className": "text-typography-100 text-sm" }, "text": "Hi, {{auth.user.name}}" },
                          { "type": "Button", "props": { "size": "sm", "variant": "outline", "action": "secondary" }, "text": "Logout", "actions": { "click": { "action": "logout" } } }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Box",
                "props": { "className": "p-6 flex-1 overflow-auto" },
                "children": [
                  { "type": "HStack", "props": { "className": "justify-between items-center mb-6" }, "children": [{ "type": "Heading", "props": { "size": "xl", "className": "text-typography-900" }, "text": "Overview" }, { "type": "Pressable", "props": { "className": "py-2 px-4 rounded-lg bg-primary-600" }, "actions": { "click": { "action": "navigate", "payload": { "path": "/dashboard/products" } } }, "children": [{ "type": "Text", "props": { "className": "text-typography-0 font-medium" }, "text": "+ Add Product" }] }] },
                  {
                    "type": "Box",
                    "condition": { "var": "products.loading" },
                    "props": { "className": "flex justify-center py-12" },
                    "children": [{ "type": "Spinner", "props": { "size": "large" } }]
                  },
                  {
                    "type": "Box",
                    "condition": { "!": { "var": "products.loading" } },
                    "props": { "className": "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" },
                    "children": [
                      {
                        "type": "Card",
                        "map": "products.list",
                        "key": "product",
                        "props": { "className": "p-4" },
                        "children": [
                          { "type": "Text", "props": { "className": "font-semibold text-typography-900 mb-2" }, "text": "{{$item.name}}" },
                          { "type": "Text", "props": { "className": "text-primary-600 font-bold mb-1" }, "text": "${{$item.price}}" },
                          { "type": "Text", "props": { "className": "text-typography-600 text-sm" }, "text": "{{$item.category}}" }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Drawer",
            "props": { "isOpen": "{{layout.drawerOpen}}", "onClose": { "action": "closeDrawer" }, "size": "md", "anchor": "left" },
            "children": [
              { "type": "DrawerBackdrop" },
              {
                "type": "DrawerContent",
                "props": { "className": "w-64 max-w-[16rem]" },
                "children": [
                  {
                    "type": "DrawerHeader",
                    "props": { "className": "border-b border-outline-100 pb-4" },
                    "children": [
                      { "type": "Text", "props": { "className": "font-bold text-lg text-typography-900" }, "text": "Admin" },
                      { "type": "DrawerCloseButton" }
                    ]
                  },
                  {
                    "type": "DrawerBody",
                    "props": { "className": "flex flex-col gap-1 pt-4" },
                    "children": [
                      { "type": "Pressable", "props": { "className": "py-3 px-4 rounded-lg hover:bg-primary-50 active:bg-primary-100" }, "actions": { "click": { "action": "navigateToDashboard" } }, "children": [{ "type": "Text", "props": { "className": "text-primary-700 font-semibold" }, "text": "Dashboard" }] },
                      { "type": "Pressable", "props": { "className": "py-3 px-4 rounded-lg hover:bg-primary-50 active:bg-primary-100" }, "actions": { "click": { "action": "navigateToProducts" } }, "children": [{ "type": "Text", "props": { "className": "text-typography-700 font-medium" }, "text": "Products" }] },
                      { "type": "Pressable", "props": { "className": "py-3 px-4 rounded-lg hover:bg-primary-50 active:bg-primary-100" }, "actions": { "click": { "action": "navigateToProfile" } }, "children": [{ "type": "Text", "props": { "className": "text-typography-700 font-medium" }, "text": "Profile" }] }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    "products": {
      "meta": { "title": "Products", "description": "Manage products" },
      "state": { "layout": { "drawerOpen": false }, "modal": { "create": false, "editProduct": null, "deleteProduct": null }, "form": { "product": { "name": "", "price": "", "category": "", "description": "" } } },
      "initActions": [{ "action": "fetchProducts" }],
      "ui": {
        "type": "Box",
        "props": { "className": "min-h-screen w-full flex flex-col bg-background-50" },
        "children": [
          {
            "type": "Box",
            "props": { "className": "flex flex-col flex-1 min-h-0" },
            "children": [
              {
                "type": "Box",
                "props": { "className": "bg-primary-600 px-4 py-4 shadow-sm shrink-0" },
                "children": [
                  {
                    "type": "HStack",
                    "props": { "className": "items-center justify-between" },
                    "children": [
                      { "type": "Pressable", "props": { "className": "p-2 -ml-2 rounded-lg hover:bg-primary-500" }, "actions": { "click": { "action": "openDrawer" } }, "children": [{ "type": "Text", "props": { "className": "text-typography-0 text-xl" }, "text": "☰" }] },
                      { "type": "Text", "props": { "className": "text-typography-0 font-semibold text-lg" }, "text": "Products" },
                      {
                        "type": "HStack",
                        "props": { "className": "items-center gap-4" },
                        "children": [
                          { "type": "Text", "props": { "className": "text-typography-100 text-sm" }, "text": "Hi, {{auth.user.name}}" },
                          { "type": "Button", "props": { "size": "sm", "variant": "outline", "action": "secondary" }, "text": "Logout", "actions": { "click": { "action": "logout" } } }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Box",
                "props": { "className": "p-6 flex-1 overflow-auto" },
                "children": [
              {
                "type": "HStack",
                "props": { "className": "justify-between items-center mb-6" },
                "children": [
                  { "type": "Heading", "props": { "size": "xl", "className": "text-typography-900" }, "text": "Products" },
                  { "type": "Button", "props": { "action": "primary" }, "text": "+ Add Product", "actions": { "click": { "action": "openCreateModal" } } }
                ]
              },
              {
                "type": "Box",
                "condition": { "var": "products.loading" },
                "props": { "className": "flex justify-center py-12" },
                "children": [{ "type": "Spinner", "props": { "size": "large" } }]
              },
              {
                "type": "Box",
                "condition": { "!": { "var": "products.loading" } },
                "props": { "className": "border border-outline-100 rounded-lg overflow-hidden" },
                "children": [
                  {
                    "type": "Table",
                    "props": { "className": "w-full" },
                    "children": [
                      {
                        "type": "TableHeader",
                        "children": [
                          {
                            "type": "TableRow",
                            "children": [
                              { "type": "TableHead", "props": { "className": "p-4 text-left" }, "text": "Name" },
                              { "type": "TableHead", "props": { "className": "p-4 text-left" }, "text": "Price" },
                              { "type": "TableHead", "props": { "className": "p-4 text-left" }, "text": "Category" },
                              { "type": "TableHead", "props": { "className": "p-4 text-right" }, "text": "Actions" }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "TableBody",
                        "children": [
                          {
                            "type": "TableRow",
                            "map": "products.list",
                            "key": "row",
                            "children": [
                              { "type": "TableData", "props": { "className": "p-4" }, "text": "{{$item.name}}" },
                              { "type": "TableData", "props": { "className": "p-4" }, "text": "${{$item.price}}" },
                              { "type": "TableData", "props": { "className": "p-4" }, "text": "{{$item.category}}" },
                              {
                                "type": "TableData",
                                "props": { "className": "p-4 text-right" },
                                "children": [
                                  {
                                    "type": "HStack",
                                    "props": { "className": "justify-end gap-2" },
                                    "children": [
                                      { "type": "Button", "props": { "size": "sm", "variant": "outline" }, "text": "Edit", "actions": { "click": { "action": "setState", "payload": { "path": "modal.editProduct", "value": { "var": "$item" } } } } },
                                      { "type": "Button", "props": { "size": "sm", "variant": "outline" }, "text": "Delete", "actions": { "click": { "action": "setState", "payload": { "path": "modal.deleteProduct", "value": { "var": "$item" } } } } }
                                    ]
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "Drawer",
        "props": { "isOpen": "{{layout.drawerOpen}}", "onClose": { "action": "closeDrawer" }, "size": "md", "anchor": "left" },
        "children": [
          { "type": "DrawerBackdrop" },
          {
            "type": "DrawerContent",
            "props": { "className": "w-64 max-w-[16rem]" },
            "children": [
              {
                "type": "DrawerHeader",
                "props": { "className": "border-b border-outline-100 pb-4" },
                "children": [
                  { "type": "Text", "props": { "className": "font-bold text-lg text-typography-900" }, "text": "Admin" },
                  { "type": "DrawerCloseButton" }
                ]
              },
              {
                "type": "DrawerBody",
                "props": { "className": "flex flex-col gap-1 pt-4" },
                "children": [
                  { "type": "Pressable", "props": { "className": "py-3 px-4 rounded-lg hover:bg-primary-50 active:bg-primary-100" }, "actions": { "click": { "action": "navigateToDashboard" } }, "children": [{ "type": "Text", "props": { "className": "text-typography-700 font-medium" }, "text": "Dashboard" }] },
                  { "type": "Pressable", "props": { "className": "py-3 px-4 rounded-lg hover:bg-primary-50 active:bg-primary-100" }, "actions": { "click": { "action": "navigateToProducts" } }, "children": [{ "type": "Text", "props": { "className": "text-primary-700 font-semibold" }, "text": "Products" }] },
                  { "type": "Pressable", "props": { "className": "py-3 px-4 rounded-lg hover:bg-primary-50 active:bg-primary-100" }, "actions": { "click": { "action": "navigateToProfile" } }, "children": [{ "type": "Text", "props": { "className": "text-typography-700 font-medium" }, "text": "Profile" }] }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "Modal",
        "props": { "isOpen": "{{modal.create}}", "onClose": { "action": "closeCreateModal" }, "closeOnOverlayClick": true },
        "children": [
          { "type": "ModalBackdrop", "actions": { "click": { "action": "closeCreateModal" } } },
          {
            "type": "ModalContent",
            "props": { "size": "md" },
            "children": [
              { "type": "ModalHeader", "children": [{ "type": "Heading", "props": { "size": "lg" }, "text": "Add Product" }, { "type": "ModalCloseButton", "actions": { "click": { "action": "closeCreateModal" } } } ] },
              {
                "type": "ModalBody",
                "children": [
                  {
                    "type": "Form",
                    "props": {
                      "defaultValues": { "form": { "product": { "var": ["form.product", { "name": "", "price": "", "category": "", "description": "" }] } } },
                      "validationRules": { "form.product.name": { "required": true, "minLength": 2 }, "form.product.price": { "required": true, "min": 0, "message": "Must be positive" }, "form.product.category": { "required": true } },
                      "submitAction": "createProduct"
                    },
                    "children": [
                      { "type": "FormInputWithLabel", "props": { "name": "form.product.name", "label": "Name", "placeholder": "Product name", "variant": "outline", "className": "mb-4" } },
                      { "type": "FormInputWithLabel", "props": { "name": "form.product.price", "label": "Price", "placeholder": "0.00", "variant": "outline", "className": "mb-4" } },
                      { "type": "FormInputWithLabel", "props": { "name": "form.product.category", "label": "Category", "placeholder": "Category", "variant": "outline", "className": "mb-4" } },
                      { "type": "FormInputWithLabel", "props": { "name": "form.product.description", "label": "Description", "placeholder": "Optional", "variant": "outline", "className": "mb-6" } },
                      { "type": "ModalFooter", "children": [{ "type": "Button", "props": { "variant": "outline", "className": "mr-2" }, "text": "Cancel", "actions": { "click": { "action": "closeCreateModal" } } }, { "type": "FormSubmitButton", "props": { "action": "primary" }, "text": "Save" } ] }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "Modal",
        "props": { "isOpen": "{{modal.editProduct}}", "onClose": { "action": "closeEditModal" }, "closeOnOverlayClick": true },
        "children": [
          { "type": "ModalBackdrop", "actions": { "click": { "action": "closeEditModal" } } },
          {
            "type": "ModalContent",
            "props": { "size": "md" },
            "children": [
              { "type": "ModalHeader", "children": [{ "type": "Heading", "props": { "size": "lg" }, "text": "Edit Product" }, { "type": "ModalCloseButton", "actions": { "click": { "action": "closeEditModal" } } } ] },
              {
                "type": "ModalBody",
                "children": [
                  {
                    "type": "Form",
                    "props": {
                      "key": "edit-form-{{modal.editProduct.id}}",
                      "defaultValues": { "form": { "product": { "var": ["modal.editProduct", { "name": "", "price": "", "category": "", "description": "" }] } } },
                      "validationRules": { "form.product.name": { "required": true, "minLength": 2 }, "form.product.price": { "required": true, "min": 0, "message": "Must be positive" }, "form.product.category": { "required": true } },
                      "submitAction": "updateProduct"
                    },
                    "children": [
                      { "type": "FormInputWithLabel", "props": { "name": "form.product.name", "label": "Name", "placeholder": "Product name", "variant": "outline", "className": "mb-4" } },
                      { "type": "FormInputWithLabel", "props": { "name": "form.product.price", "label": "Price", "placeholder": "0.00", "variant": "outline", "className": "mb-4" } },
                      { "type": "FormInputWithLabel", "props": { "name": "form.product.category", "label": "Category", "placeholder": "Category", "variant": "outline", "className": "mb-4" } },
                      { "type": "FormInputWithLabel", "props": { "name": "form.product.description", "label": "Description", "placeholder": "Optional", "variant": "outline", "className": "mb-6" } },
                      { "type": "ModalFooter", "children": [{ "type": "Button", "props": { "variant": "outline", "className": "mr-2" }, "text": "Cancel", "actions": { "click": { "action": "closeEditModal" } } }, { "type": "FormSubmitButton", "props": { "action": "primary" }, "text": "Save" } ] }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "Modal",
        "props": { "isOpen": "{{modal.deleteProduct}}", "onClose": { "action": "closeDeleteModal" }, "closeOnOverlayClick": true },
        "children": [
          { "type": "ModalBackdrop", "actions": { "click": { "action": "closeDeleteModal" } } },
          {
            "type": "ModalContent",
            "props": { "size": "sm" },
            "children": [
              { "type": "ModalHeader", "children": [{ "type": "Heading", "props": { "size": "lg" }, "text": "Delete Product" }, { "type": "ModalCloseButton", "actions": { "click": { "action": "closeDeleteModal" } } } ] },
              { "type": "ModalBody", "children": [{ "type": "Text", "props": { "className": "text-typography-700" }, "text": "Are you sure you want to delete this product?" } ] },
              { "type": "ModalFooter", "children": [{ "type": "Button", "props": { "variant": "outline", "className": "mr-2" }, "text": "Cancel", "actions": { "click": { "action": "closeDeleteModal" } } }, { "type": "Button", "props": { "action": "primary", "variant": "outline" }, "text": "Delete", "actions": { "click": { "action": "deleteProduct" } } } ] }
            ]
          }
        ]
      }
    ]
  }
    },
    "forgotPassword": {
      "meta": { "title": "Forgot Password", "description": "Reset your password" },
      "state": { "form": { "email": "" }, "errors": {} },
      "ui": {
        "type": "Box",
        "props": { "className": "flex flex-col items-center justify-center min-h-screen w-full bg-background-50 p-6" },
        "children": [
          {
            "type": "Box",
            "props": { "className": "w-full max-w-md mx-auto" },
            "children": [
              { "type": "Heading", "props": { "size": "xl", "className": "mb-6 text-typography-900" }, "text": "Forgot Password" },
              { "type": "Text", "props": { "className": "text-typography-600 mb-6" }, "text": "Enter your email to receive a reset link." },
              {
                "type": "Form",
                "props": {
                  "defaultValues": { "form": { "email": "" } },
                  "validationRules": { "form.email": { "required": true, "pattern": "email" } },
                  "submitAction": "forgotPassword"
                },
                "children": [
                  { "type": "FormInputWithLabel", "props": { "name": "form.email", "label": "Email", "placeholder": "you@example.com", "variant": "outline", "className": "mb-6" } },
                  { "type": "FormSubmitButton", "props": { "action": "primary", "className": "w-full mb-4" }, "text": "Send Reset Link" }
                ]
              },
              { "type": "Pressable", "actions": { "click": { "action": "navigate", "payload": { "path": "/login" } } }, "children": [{ "type": "Text", "props": { "className": "text-primary-600 text-sm" }, "text": "Back to Login" }] }
            ]
          }
        ]
      }
    },
    "resetPassword": {
      "meta": { "title": "Reset Password", "description": "Set new password" },
      "state": { "form": { "token": "", "password": "", "confirmPassword": "" }, "errors": {} },
      "ui": {
        "type": "Box",
        "props": { "className": "flex flex-col items-center justify-center min-h-screen w-full bg-background-50 p-6" },
        "children": [
          {
            "type": "Box",
            "props": { "className": "w-full max-w-md mx-auto" },
            "children": [
              { "type": "Heading", "props": { "size": "xl", "className": "mb-6 text-typography-900" }, "text": "Reset Password" },
              {
                "type": "Form",
                "props": {
                  "defaultValues": { "form": { "token": "", "password": "", "confirmPassword": "" } },
                  "validationRules": {
                    "form.password": { "required": true, "minLength": 8 },
                    "form.confirmPassword": { "required": true, "equals": "form.password", "message": "Passwords must match" }
                  },
                  "submitAction": "resetPassword"
                },
                "children": [
                  { "type": "FormInputWithLabel", "props": { "name": "form.token", "label": "Reset Token", "placeholder": "Paste token from email", "variant": "outline", "className": "mb-4" } },
                  { "type": "FormInputWithLabel", "props": { "name": "form.password", "label": "New Password", "placeholder": "••••••••", "variant": "outline", "secureTextEntry": true, "className": "mb-4" } },
                  { "type": "FormInputWithLabel", "props": { "name": "form.confirmPassword", "label": "Confirm Password", "placeholder": "••••••••", "variant": "outline", "secureTextEntry": true, "className": "mb-6" } },
                  { "type": "FormSubmitButton", "props": { "action": "primary", "className": "w-full mb-4" }, "text": "Reset Password" }
                ]
              }
            ]
          }
        ]
      }
    },
    "profile": {
      "meta": { "title": "Profile", "description": "Your profile" },
      "state": { "layout": { "drawerOpen": false }, "form": { "name": "", "email": "" } },
      "initActions": [{ "action": "fetchProfile" }],
      "ui": {
        "type": "Box",
        "props": { "className": "min-h-screen w-full flex flex-col bg-background-50" },
        "children": [
          {
            "type": "Box",
            "props": { "className": "flex flex-col flex-1 min-h-0" },
            "children": [
              {
                "type": "Box",
                "props": { "className": "bg-primary-600 px-4 py-4 shadow-sm shrink-0" },
                "children": [
                  {
                    "type": "HStack",
                    "props": { "className": "items-center justify-between" },
                    "children": [
                      { "type": "Pressable", "props": { "className": "p-2 -ml-2 rounded-lg hover:bg-primary-500" }, "actions": { "click": { "action": "openDrawer" } }, "children": [{ "type": "Text", "props": { "className": "text-typography-0 text-xl" }, "text": "☰" }] },
                      { "type": "Text", "props": { "className": "text-typography-0 font-semibold text-lg" }, "text": "Profile" },
                      {
                        "type": "HStack",
                        "props": { "className": "items-center gap-4" },
                        "children": [
                          { "type": "Text", "props": { "className": "text-typography-100 text-sm" }, "text": "Hi, {{auth.user.name}}" },
                          { "type": "Button", "props": { "size": "sm", "variant": "outline", "action": "secondary" }, "text": "Logout", "actions": { "click": { "action": "logout" } } }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Box",
                "props": { "className": "p-6 flex-1 overflow-auto" },
                "children": [
                  {
                    "type": "Box",
                    "props": { "className": "max-w-md mx-auto w-full" },
                    "children": [
              { "type": "Heading", "props": { "size": "xl", "className": "mb-6 text-typography-900" }, "text": "Profile" },
              {
                "type": "Form",
                "props": {
                  "defaultValues": { "form": { "name": "", "email": "" } },
                  "validationRules": { "form.name": { "required": true, "minLength": 2 }, "form.email": { "required": true, "pattern": "email" } },
                  "submitAction": "updateProfile"
                },
                "children": [
                  { "type": "FormInputWithLabel", "props": { "name": "form.name", "label": "Name", "placeholder": "Your name", "variant": "outline", "className": "mb-4" } },
                  { "type": "FormInputWithLabel", "props": { "name": "form.email", "label": "Email", "placeholder": "you@example.com", "variant": "outline", "className": "mb-6" } },
                  { "type": "FormSubmitButton", "props": { "action": "primary", "className": "w-full" }, "text": "Save Changes" }
                ]
              }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Drawer",
            "props": { "isOpen": "{{layout.drawerOpen}}", "onClose": { "action": "closeDrawer" }, "size": "md", "anchor": "left" },
            "children": [
              { "type": "DrawerBackdrop" },
              {
                "type": "DrawerContent",
                "props": { "className": "w-64 max-w-[16rem]" },
                "children": [
                  {
                    "type": "DrawerHeader",
                    "props": { "className": "border-b border-outline-100 pb-4" },
                    "children": [
                      { "type": "Text", "props": { "className": "font-bold text-lg text-typography-900" }, "text": "Admin" },
                      { "type": "DrawerCloseButton" }
                    ]
                  },
                  {
                    "type": "DrawerBody",
                    "props": { "className": "flex flex-col gap-1 pt-4" },
                    "children": [
                      { "type": "Pressable", "props": { "className": "py-3 px-4 rounded-lg hover:bg-primary-50 active:bg-primary-100" }, "actions": { "click": { "action": "navigateToDashboard" } }, "children": [{ "type": "Text", "props": { "className": "text-typography-700 font-medium" }, "text": "Dashboard" }] },
                      { "type": "Pressable", "props": { "className": "py-3 px-4 rounded-lg hover:bg-primary-50 active:bg-primary-100" }, "actions": { "click": { "action": "navigateToProducts" } }, "children": [{ "type": "Text", "props": { "className": "text-typography-700 font-medium" }, "text": "Products" }] },
                      { "type": "Pressable", "props": { "className": "py-3 px-4 rounded-lg hover:bg-primary-50 active:bg-primary-100" }, "actions": { "click": { "action": "navigateToProfile" } }, "children": [{ "type": "Text", "props": { "className": "text-primary-700 font-semibold" }, "text": "Profile" }] }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  },
  "actions": {
    "login": { "type": "fetch", "method": "POST", "url": "/api/auth/login", "body": { "email": { "var": "form.email" }, "password": { "var": "form.password" } }, "storeIn": "auth.user", "responsePath": "user", "onSuccess": { "action": "navigate", "payload": { "path": "/dashboard" } } },
    "validateSignup": { "type": "validate", "rules": { "form.name": { "required": true }, "form.email": { "required": true, "pattern": "email" }, "form.password": { "required": true, "minLength": 8 }, "form.confirmPassword": { "required": true, "equals": "form.password", "message": "Passwords must match" } }, "storeErrorsIn": "errors", "onSuccess": { "action": "signup" } },
    "signup": { "type": "fetch", "method": "POST", "url": "/api/auth/signup", "body": { "name": { "var": "form.name" }, "email": { "var": "form.email" }, "password": { "var": "form.password" } }, "storeIn": "auth.user", "responsePath": "user", "onSuccess": { "action": "navigate", "payload": { "path": "/dashboard" } } },
    "logout": { "type": "set", "path": "auth", "value": { "user": null, "error": null }, "onSuccess": { "action": "navigate", "payload": { "path": "/login" } } },
    "fetchProducts": { "type": "fetch", "url": "/api/products", "storeIn": "products.list" },
    "addToCart": { "type": "append", "path": "ecommerce.cart", "value": { "product": { "var": "$item" }, "quantity": 1 } },
    "forgotPassword": { "type": "fetch", "method": "POST", "url": "/api/auth/forgot-password", "body": { "email": { "var": "form.email" } }, "onSuccess": { "action": "navigate", "payload": { "path": "/login" } } },
    "resetPassword": { "type": "fetch", "method": "POST", "url": "/api/auth/reset-password", "body": { "token": { "var": "form.token" }, "password": { "var": "form.password" }, "confirmPassword": { "var": "form.confirmPassword" } }, "onSuccess": { "action": "navigate", "payload": { "path": "/login" } } },
    "fetchProfile": { "type": "fetch", "url": "/api/profile", "storeIn": "profile" },
    "updateProfile": { "type": "fetch", "method": "PUT", "url": "/api/profile", "body": { "name": { "var": "form.name" }, "email": { "var": "form.email" } }, "storeIn": "profile" },
    "openDrawer": { "action": "setState", "payload": { "path": "layout.drawerOpen", "value": true } },
    "closeDrawer": { "action": "setState", "payload": { "path": "layout.drawerOpen", "value": false } },
    "navigateToDashboard": { "type": "runMultiple", "actions": [{ "action": "closeDrawer" }, { "action": "navigate", "payload": { "path": "/dashboard" } }] },
    "navigateToProducts": { "type": "runMultiple", "actions": [{ "action": "closeDrawer" }, { "action": "navigate", "payload": { "path": "/dashboard/products" } }] },
    "navigateToProfile": { "type": "runMultiple", "actions": [{ "action": "closeDrawer" }, { "action": "navigate", "payload": { "path": "/profile" } }] },
    "openCreateModal": { "action": "setState", "payload": { "path": "modal", "value": { "create": true, "editProduct": null, "deleteProduct": null } } },
    "closeCreateModal": { "action": "setState", "payload": { "path": "modal.create", "value": false } },
    "closeEditModal": { "action": "setState", "payload": { "path": "modal.editProduct", "value": null } },
    "closeDeleteModal": { "action": "setState", "payload": { "path": "modal.deleteProduct", "value": null } },
    "createProduct": { "type": "fetch", "method": "POST", "url": "/api/products", "body": { "name": { "var": "form.product.name" }, "price": { "var": "form.product.price" }, "category": { "var": "form.product.category" }, "description": { "var": "form.product.description" } }, "storeIn": "products.newItem", "onSuccess": [{ "action": "closeCreateModal" }, { "action": "fetchProducts" }] },
    "updateProduct": { "type": "fetch", "method": "PUT", "url": "/api/products/{{modal.editProduct.id}}", "body": { "name": { "var": "form.product.name" }, "price": { "var": "form.product.price" }, "category": { "var": "form.product.category" }, "description": { "var": "form.product.description" } }, "onSuccess": [{ "action": "closeEditModal" }, { "action": "fetchProducts" }] },
    "deleteProduct": { "type": "fetch", "method": "DELETE", "url": "/api/products/{{modal.deleteProduct.id}}", "onSuccess": [{ "action": "closeDeleteModal" }, { "action": "fetchProducts" }] }
  }
}
