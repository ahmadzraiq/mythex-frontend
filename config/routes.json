{
  "defaultRedirect": "/sign-in",
  "routes": [
    {
      "path": "/",
      "config": "home",
      "auth": false,
      "layout": "full"
    },
    {
      "path": "/cart",
      "config": "cart",
      "auth": false,
      "layout": "full"
    },
    {
      "path": "/checkout",
      "config": "checkout",
      "auth": false,
      "layout": "full"
    },
    {
      "path": "/product",
      "config": "product",
      "auth": false,
      "layout": "full",
      "dynamic": true,
      "params": ["slug"]
    },
    {
      "path": "/collection",
      "config": "collection",
      "auth": false,
      "layout": "full",
      "dynamic": true,
      "paramChangeAction": "fetchCollection",
      "params": ["slug"]
    },
    {
      "path": "/search",
      "config": "search",
      "auth": false,
      "layout": "full",
      "paramChangeAction": "fetchSearchResults"
    },
    {
      "path": "/sign-in",
      "config": "signIn",
      "auth": false,
      "layout": "full"
    },
    {
      "path": "/register",
      "config": "register",
      "auth": false,
      "layout": "full"
    },
    {
      "path": "/forgot-password",
      "config": "forgotPassword",
      "auth": false,
      "layout": "full"
    },
    {
      "path": "/reset-password",
      "config": "resetPassword",
      "auth": false,
      "layout": "full"
    },
    {
      "path": "/verify",
      "config": "verify",
      "auth": false,
      "layout": "centered"
    },
    {
      "path": "/verify-pending",
      "config": "verifyPending",
      "auth": false,
      "layout": "centered"
    },
    {
      "path": "/account/orders",
      "config": "accountOrders",
      "auth": true,
      "layout": "full"
    },
    {
      "path": "/account/orders",
      "config": "accountOrderDetail",
      "auth": true,
      "layout": "full",
      "dynamic": true,
      "params": ["id"]
    },
    {
      "path": "/account/addresses",
      "config": "accountAddresses",
      "auth": true,
      "layout": "full"
    },
    {
      "path": "/account/profile",
      "config": "accountProfile",
      "auth": true,
      "layout": "full"
    },
    {
      "path": "/order-confirmation",
      "config": "orderConfirmation",
      "auth": false,
      "layout": "full",
      "dynamic": true,
      "params": ["id"]
    },
    {
      "path": "/not-found",
      "config": "notFound",
      "auth": false,
      "layout": "centered"
    },
    {
      "path": "/workflow-test",
      "config": "workflowTest",
      "auth": false,
      "layout": "full"
    }
  ]
}
