{
  "login": {
    "type": "validate",
    "formId": "e6f7a8b9-c0d1-2345-efab-456789012345",
    "onSuccess": {
      "action": "loginMutation"
    }
  },
  "loginMutation": {
    "type": "graphql",
    "query": "mutation Login($username: String!, $password: String!) { login(username: $username, password: $password) { __typename ... on CurrentUser { id identifier } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "username": "{{variables['e6f7a8b9-c0d1-2345-efab-456789012345'].value.username}}",
      "password": "{{variables['e6f7a8b9-c0d1-2345-efab-456789012345'].value.password}}"
    },
    "storeIn": "auth.user",
    "responsePath": "data.login",
    "storeHeaderIn": {
      "auth.token": "vendure-auth-token"
    },
    "errorMessagePath": "errors[0].message",
    "onSuccess": {
      "action": "navigate",
      "payload": {
        "path": "/"
      }
    },
    "endpoint": "http://localhost:3000/shop-api",
    "headers": {
      "vendure-token": "__default_channel__"
    }
  },
  "logout": {
    "type": "graphql",
    "query": "mutation Logout { logout { __typename ... on Success { success } } }",
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "storeIn": "auth._logoutResult",
    "onSuccess": {
      "type": "runMultiple",
      "actions": [
        {
          "action": "clearAuth"
        },
        {
          "action": "navigate",
          "payload": {
            "path": "/sign-in"
          }
        }
      ]
    },
    "endpoint": "http://localhost:3000/shop-api"
  },
  "clearAuth": {
    "type": "set",
    "path": "auth",
    "value": {
      "user": null,
      "token": null
    }
  },
  "register": {
    "type": "validate",
    "formId": "f7a8b9c0-d1e2-3456-fabc-567890123456",
    "onSuccess": {
      "action": "registerMutation"
    }
  },
  "registerMutation": {
    "type": "graphql",
    "query": "mutation RegisterCustomerAccount($input: RegisterCustomerInput!) { registerCustomerAccount(input: $input) { __typename ... on Success { success } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "input": {
        "emailAddress": "{{variables['f7a8b9c0-d1e2-3456-fabc-567890123456'].value.emailAddress}}",
        "firstName": "{{variables['f7a8b9c0-d1e2-3456-fabc-567890123456'].value.firstName}}",
        "lastName": "{{variables['f7a8b9c0-d1e2-3456-fabc-567890123456'].value.lastName}}",
        "phoneNumber": "{{variables['f7a8b9c0-d1e2-3456-fabc-567890123456'].value.phoneNumber}}",
        "password": "{{variables['e6f7a8b9-c0d1-2345-efab-456789012345'].value.password}}"
      }
    },
    "storeIn": "auth._registerResult",
    "responsePath": "data.registerCustomerAccount",
    "onSuccess": {
      "action": "navigate",
      "payload": {
        "path": "/verify-pending"
      }
    },
    "endpoint": "http://localhost:3000/shop-api",
    "headers": {
      "vendure-token": "__default_channel__"
    }
  },
  "forgotPassword": {
    "action": "forgotPasswordMutation"
  },
  "forgotPasswordMutation": {
    "type": "graphql",
    "query": "mutation RequestPasswordReset($emailAddress: String!) { requestPasswordReset(emailAddress: $emailAddress) { __typename ... on Success { success } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "emailAddress": "{{variables['f7a8b9c0-d1e2-3456-fabc-567890123456'].value.emailAddress}}"
    },
    "storeIn": "auth._forgotPasswordResult",
    "responsePath": "data.requestPasswordReset",
    "endpoint": "http://localhost:3000/shop-api",
    "headers": {
      "vendure-token": "__default_channel__"
    }
  },
  "resetPassword": {
    "type": "validate",
    "formId": "b9c0d1e2-f3a4-5678-bcde-678901234567",
    "onSuccess": {
      "action": "resetPasswordMutation"
    }
  },
  "resetPasswordMutation": {
    "type": "graphql",
    "query": "mutation ResetPassword($token: String!, $password: String!) { resetPassword(token: $token, password: $password) { __typename ... on CurrentUser { id identifier } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "token": "{{route.token}}",
      "password": "{{variables['e6f7a8b9-c0d1-2345-efab-456789012345'].value.password}}"
    },
    "storeIn": "auth.user",
    "responsePath": "data.resetPassword",
    "storeHeaderIn": {
      "auth.token": "vendure-auth-token"
    },
    "onSuccess": {
      "action": "navigate",
      "payload": {
        "path": "/"
      }
    },
    "endpoint": "http://localhost:3000/shop-api",
    "headers": {
      "vendure-token": "__default_channel__"
    }
  },
  "verifyAccount": {
    "type": "graphql",
    "query": "mutation VerifyCustomerAccount($token: String!) { verifyCustomerAccount(token: $token) { __typename ... on CurrentUser { id identifier } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "token": "{{route.q}}"
    },
    "storeIn": "auth.user",
    "responsePath": "data.verifyCustomerAccount",
    "storeHeaderIn": {
      "auth.token": "vendure-auth-token"
    },
    "onSuccess": {
      "action": "navigate",
      "payload": {
        "path": "/"
      }
    },
    "endpoint": "http://localhost:3000/shop-api",
    "headers": {
      "vendure-token": "__default_channel__"
    }
  },
  "setCustomerForOrder": {
    "type": "validate",
    "formId": "d1e2f3a4-b5c6-7890-defa-890123456789",
    "onSuccess": {
      "type": "runMultiple",
      "actions": [
        {
          "action": "setCustomerForOrderMutation"
        },
        {
          "action": "fetchCheckoutOrder"
        },
        {
          "type": "setVar",
          "path": "d9e0f1a2-b3c4-5678-defa-789012345678",
          "value": "shipping"
        },
        {
          "type": "setVar",
          "path": "e0f1a2b3-c4d5-6789-efab-890123456789",
          "value": true
        }
      ]
    }
  },
  "setCustomerForOrderMutation": {
    "type": "graphql",
    "query": "mutation SetCustomerForOrder($input: CreateCustomerInput!) { setCustomerForOrder(input: $input) { __typename ... on Order { id code customer { id firstName lastName emailAddress } } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "input": {
        "emailAddress": "{{variables['f7a8b9c0-d1e2-3456-fabc-567890123456'].value.emailAddress}}",
        "firstName": "{{variables['f7a8b9c0-d1e2-3456-fabc-567890123456'].value.firstName}}",
        "lastName": "{{variables['f7a8b9c0-d1e2-3456-fabc-567890123456'].value.lastName}}"
      }
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "storeIn": "b8c9d0e1-f2a3-4567-bcde-678901234567",
    "responsePath": "data.setCustomerForOrder",
    "endpoint": "http://localhost:3000/shop-api"
  }
}
