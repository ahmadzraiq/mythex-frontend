{
  "7510b401-4eb2-4bf2-ba3c-0f1127b65e22": {
    "name": "login",
    "action": "49c32a35-f663-4d36-9d5a-c1af0268f5c0"
  },
  "49c32a35-f663-4d36-9d5a-c1af0268f5c0": {
    "name": "Login",
    "type": "graphql",
    "query": "mutation Login($username: String!, $password: String!) { login(username: $username, password: $password) { __typename ... on CurrentUser { id identifier } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "username": "{{local.data.form.formData.username}}",
      "password": "{{local.data.form.formData.password}}"
    },
    "endpoint": "http://localhost:3000/shop-api",
    "headers": {
      "vendure-token": "__default_channel__"
    }
  },
  "dcba4c53-5dc4-4b20-aded-4a2bdd76e2ea": {
    "name": "logout",
    "type": "graphql",
    "query": "mutation Logout { logout { __typename ... on Success { success } } }",
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "endpoint": "http://localhost:3000/shop-api"
  },
  "f9a0b1c2-d3e4-5678-fabc-901234567890": {
    "name": "submitLogout",
    "trigger": "click",
    "steps": [
      {
        "id": "step-logout",
        "action": "dcba4c53-5dc4-4b20-aded-4a2bdd76e2ea"
      },
      {
        "id": "step-clear-auth",
        "action": "78fd4a13-2047-4412-8f9e-d5ce54edbee6"
      },
      {
        "id": "step-nav-signin",
        "type": "navigateTo",
        "config": {
          "path": "/sign-in",
          "linkType": "internal"
        }
      }
    ]
  },
  "78fd4a13-2047-4412-8f9e-d5ce54edbee6": {
    "name": "clearAuth",
    "type": "set",
    "path": "auth",
    "value": {
      "user": null,
      "token": null
    }
  },
  "e6f3414c-7815-4825-bc0d-e51207caa7b6": {
    "name": "register",
    "action": "50885d62-b60a-45ea-9c07-d80651ef005b"
  },
  "50885d62-b60a-45ea-9c07-d80651ef005b": {
    "name": "registerMutation",
    "type": "graphql",
    "query": "mutation RegisterCustomerAccount($input: RegisterCustomerInput!) { registerCustomerAccount(input: $input) { __typename ... on Success { success } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "input": {
        "emailAddress": "{{local.data.form.formData.emailAddress}}",
        "firstName": "{{local.data.form.formData.firstName}}",
        "lastName": "{{local.data.form.formData.lastName}}",
        "phoneNumber": "{{local.data.form.formData.phoneNumber}}",
        "password": "{{local.data.form.formData.password}}"
      }
    },
    "endpoint": "http://localhost:3000/shop-api",
    "headers": {
      "vendure-token": "__default_channel__"
    }
  },
  "21d74dc9-f452-49e3-8bd2-75cff5ea35ae": {
    "name": "forgotPassword",
    "action": "48571dd4-deff-467f-9686-733573cbfa92"
  },
  "48571dd4-deff-467f-9686-733573cbfa92": {
    "name": "forgotPasswordMutation",
    "type": "graphql",
    "query": "mutation RequestPasswordReset($emailAddress: String!) { requestPasswordReset(emailAddress: $emailAddress) { __typename ... on Success { success } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "emailAddress": "{{local.data.form.formData.emailAddress}}"
    },
    "endpoint": "http://localhost:3000/shop-api",
    "headers": {
      "vendure-token": "__default_channel__"
    }
  },
  "b87c97c9-c3f8-426d-b96e-b751a83bdaf3": {
    "name": "resetPasswordMutation",
    "type": "graphql",
    "query": "mutation ResetPassword($token: String!, $password: String!) { resetPassword(token: $token, password: $password) { __typename ... on CurrentUser { id identifier } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "token": "{{route.token}}",
      "password": "{{local.data.form.formData.password}}"
    },
    "endpoint": "http://localhost:3000/shop-api",
    "headers": {
      "vendure-token": "__default_channel__"
    }
  },
  "a0b1c2d3-e4f5-6789-abcd-012345678901": {
    "name": "submitResetPassword",
    "trigger": "submit",
    "steps": [
      {
        "id": "step-reset",
        "action": "b87c97c9-c3f8-426d-b96e-b751a83bdaf3"
      },
      {
        "id": "step-nav-home",
        "type": "navigateTo",
        "config": {
          "path": "/",
          "linkType": "internal"
        }
      }
    ]
  },
  "272adf3c-7c7f-4039-b8df-7c5e95b4f973": {
    "name": "verifyAccount",
    "type": "graphql",
    "query": "mutation VerifyCustomerAccount($token: String!) { verifyCustomerAccount(token: $token) { __typename ... on CurrentUser { id identifier } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "token": "{{route.q}}"
    },
    "endpoint": "http://localhost:3000/shop-api",
    "headers": {
      "vendure-token": "__default_channel__"
    }
  },
  "b1c2d3e4-f5a6-7890-bcde-123456789012": {
    "name": "submitContactStep",
    "trigger": "submit",
    "steps": [
      {
        "id": "step-mutation",
        "action": "d0fd5c2b-37c1-4040-8690-d3a04e8c2f36"
      },
      {
        "id": "step-fetch-order",
        "action": "adf68fbe-c9d0-4f2d-b141-e772451e2026"
      },
      {
        "id": "step-set-checkout-step",
        "type": "changeVariableValue",
        "config": {
          "variableName": "d9e0f1a2-b3c4-5678-defa-789012345678",
          "value": "shipping"
        }
      },
      {
        "id": "step-set-contact-done",
        "type": "changeVariableValue",
        "config": {
          "variableName": "e0f1a2b3-c4d5-6789-efab-890123456789",
          "value": true
        }
      }
    ]
  },
  "6f6da384-9f39-4502-a2b9-d39a902438c3": {
    "name": "submitSignIn",
    "trigger": "submit",
    "steps": [
      {
        "id": "step-login",
        "action": "49c32a35-f663-4d36-9d5a-c1af0268f5c0"
      },
      {
        "id": "step-branch",
        "type": "branch",
        "config": {
          "condition": "not(context.workflow['step-login'].result?.login?.errorCode)"
        },
        "trueBranch": [
          {
            "id": "step-nav-home",
            "type": "navigateTo",
            "config": {
              "path": "/",
              "linkType": "internal"
            }
          }
        ],
        "falseBranch": [
          {
            "id": "step-set-error",
            "type": "changeVariableValue",
            "config": {
              "variableName": "f2a3b4c5-d6e7-8901-fabc-012345678901",
              "value": "{{context.workflow['step-login'].result?.login?.message}}"
            }
          }
        ]
      }
    ]
  },
  "926c0ef9-beeb-41d3-924b-034b76b8b7cf": {
    "name": "submitRegister",
    "trigger": "submit",
    "steps": [
      {
        "id": "step-register",
        "action": "50885d62-b60a-45ea-9c07-d80651ef005b"
      },
      {
        "id": "step-nav-verify",
        "type": "navigateTo",
        "config": {
          "path": "/verify-pending",
          "linkType": "internal"
        }
      }
    ]
  },
  "d0fd5c2b-37c1-4040-8690-d3a04e8c2f36": {
    "name": "setCustomerForOrderMutation",
    "type": "graphql",
    "query": "mutation SetCustomerForOrder($input: CreateCustomerInput!) { setCustomerForOrder(input: $input) { __typename ... on Order { id code customer { id firstName lastName emailAddress } } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "input": {
        "emailAddress": "{{local.data.form.formData.emailAddress}}",
        "firstName": "{{local.data.form.formData.firstName}}",
        "lastName": "{{local.data.form.formData.lastName}}"
      }
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "endpoint": "http://localhost:3000/shop-api"
  }
}
