{
  "login": {
    "type": "validate",
    "rules": {
      "form.username": {
        "required": true,
        "pattern": "email",
        "message": "Please enter a valid email address"
      },
      "form.password": {
        "required": true,
        "message": "Please enter your password"
      }
    },
    "storeErrorsIn": "errors",
    "onSuccess": {
      "action": "loginMutation"
    }
  },
  "loginMutation": {
    "type": "graphql",
    "query": "mutation Login($username: String!, $password: String!) { login(username: $username, password: $password) { __typename ... on CurrentUser { id identifier } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "username": "{{form.username}}",
      "password": "{{form.password}}"
    },
    "storeIn": "auth.user",
    "responsePath": "data.login",
    "storeHeaderIn": {
      "auth.token": "vendure-auth-token"
    },
    "errorMessagePath": "errors[0].message",
    "onSuccess": {
      "action": "navigate",
      "payload": {
        "path": "/"
      }
    },
    "endpoint": "http://localhost:3000/shop-api",
    "headers": {
      "vendure-token": "__default_channel__"
    }
  },
  "logout": {
    "type": "graphql",
    "query": "mutation Logout { logout { __typename ... on Success { success } } }",
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "storeIn": "auth._logoutResult",
    "onSuccess": {
      "type": "runMultiple",
      "actions": [
        {
          "action": "clearAuth"
        },
        {
          "action": "navigate",
          "payload": {
            "path": "/sign-in"
          }
        }
      ]
    },
    "endpoint": "http://localhost:3000/shop-api"
  },
  "clearAuth": {
    "type": "set",
    "path": "auth",
    "value": {
      "user": null,
      "token": null
    }
  },
  "register": {
    "type": "validate",
    "rules": {
      "form.emailAddress": {
        "required": true,
        "pattern": "email",
        "message": "Please enter a valid email address"
      },
      "form.firstName": {
        "required": true,
        "message": "Please enter your first name"
      },
      "form.lastName": {
        "required": true,
        "message": "Please enter your last name"
      },
      "form.password": {
        "required": true,
        "minLength": 8,
        "message": "Password must be at least 8 characters"
      },
      "form.confirmPassword": {
        "required": true,
        "equalsField": "form.password",
        "message": "Passwords do not match"
      }
    },
    "storeErrorsIn": "errors",
    "onSuccess": {
      "action": "registerMutation"
    }
  },
  "registerMutation": {
    "type": "graphql",
    "query": "mutation RegisterCustomerAccount($input: RegisterCustomerInput!) { registerCustomerAccount(input: $input) { __typename ... on Success { success } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "input": {
        "emailAddress": "{{form.emailAddress}}",
        "firstName": "{{form.firstName}}",
        "lastName": "{{form.lastName}}",
        "phoneNumber": "{{form.phoneNumber}}",
        "password": "{{form.password}}"
      }
    },
    "storeIn": "auth._registerResult",
    "responsePath": "data.registerCustomerAccount",
    "onSuccess": {
      "action": "navigate",
      "payload": {
        "path": "/verify-pending"
      }
    },
    "endpoint": "http://localhost:3000/shop-api",
    "headers": {
      "vendure-token": "__default_channel__"
    }
  },
  "forgotPassword": {
    "action": "forgotPasswordMutation"
  },
  "forgotPasswordMutation": {
    "type": "graphql",
    "query": "mutation RequestPasswordReset($emailAddress: String!) { requestPasswordReset(emailAddress: $emailAddress) { __typename ... on Success { success } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "emailAddress": "{{form.emailAddress}}"
    },
    "storeIn": "auth._forgotPasswordResult",
    "responsePath": "data.requestPasswordReset",
    "endpoint": "http://localhost:3000/shop-api",
    "headers": {
      "vendure-token": "__default_channel__"
    }
  },
  "resetPassword": {
    "type": "validate",
    "rules": {
      "form.password": {
        "required": true,
        "minLength": 8,
        "message": "Password must be at least 8 characters"
      }
    },
    "storeErrorsIn": "errors",
    "onSuccess": {
      "action": "resetPasswordMutation"
    }
  },
  "resetPasswordMutation": {
    "type": "graphql",
    "query": "mutation ResetPassword($token: String!, $password: String!) { resetPassword(token: $token, password: $password) { __typename ... on CurrentUser { id identifier } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "token": "{{route.token}}",
      "password": "{{form.password}}"
    },
    "storeIn": "auth.user",
    "responsePath": "data.resetPassword",
    "storeHeaderIn": {
      "auth.token": "vendure-auth-token"
    },
    "onSuccess": {
      "action": "navigate",
      "payload": {
        "path": "/"
      }
    },
    "endpoint": "http://localhost:3000/shop-api",
    "headers": {
      "vendure-token": "__default_channel__"
    }
  },
  "verifyAccount": {
    "type": "graphql",
    "query": "mutation VerifyCustomerAccount($token: String!) { verifyCustomerAccount(token: $token) { __typename ... on CurrentUser { id identifier } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "token": "{{route.q}}"
    },
    "storeIn": "auth.user",
    "responsePath": "data.verifyCustomerAccount",
    "storeHeaderIn": {
      "auth.token": "vendure-auth-token"
    },
    "onSuccess": {
      "action": "navigate",
      "payload": {
        "path": "/"
      }
    },
    "endpoint": "http://localhost:3000/shop-api",
    "headers": {
      "vendure-token": "__default_channel__"
    }
  },
  "setCustomerForOrder": {
    "type": "validate",
    "rules": {
      "form.emailAddress": {
        "required": true,
        "pattern": "email",
        "message": "Please enter a valid email address"
      },
      "form.firstName": {
        "required": true,
        "message": "First name is required"
      },
      "form.lastName": {
        "required": true,
        "message": "Last name is required"
      }
    },
    "storeErrorsIn": "errors",
    "onSuccess": {
      "type": "runMultiple",
      "actions": [
        {
          "action": "setCustomerForOrderMutation"
        },
        {
          "action": "fetchCheckoutOrder"
        },
        {
          "type": "set",
          "path": "checkout.step",
          "value": "shipping"
        },
        {
          "type": "set",
          "path": "checkout.contactCompleted",
          "value": true
        }
      ]
    }
  },
  "setCustomerForOrderMutation": {
    "type": "graphql",
    "query": "mutation SetCustomerForOrder($input: CreateCustomerInput!) { setCustomerForOrder(input: $input) { __typename ... on Order { id code customer { id firstName lastName emailAddress } } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "input": {
        "emailAddress": "{{form.emailAddress}}",
        "firstName": "{{form.firstName}}",
        "lastName": "{{form.lastName}}"
      }
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "storeIn": "checkout.order",
    "responsePath": "data.setCustomerForOrder",
    "endpoint": "http://localhost:3000/shop-api"
  }
}
