  },
  "48571dd4-deff-467f-9686-733573cbfa92": {
    "name": "forgotPasswordMutation",
    "type": "fetch",
    "url": "http://localhost:4000/v1/run/cmpfgh9d20003ti913oelf5bs/auth/request-password-reset",
    "method": "POST",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "emailAddress": "{{local.data.form.formData.emailAddress}}"
    }
  },
  "b87c97c9-c3f8-426d-b96e-b751a83bdaf3": {
    "name": "resetPasswordMutation",
    "type": "fetch",
    "url": "http://localhost:4000/v1/run/cmpfgh9d20003ti913oelf5bs/auth/reset-password",
    "method": "POST",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "token": { "formula": "globalContext?.browser?.query?.token" },
      "password": "{{local.data.form.formData.password}}"
    }
  },
  "a0b1c2d3-e4f5-6789-abcd-012345678901": {
