  "5d958b9c-b034-48b7-adf2-85ea363e7a92": {
    "name": "setRegisterConfirmPassword",
    "type": "workflowSteps",
    "trigger": "change",
    "steps": [
      {
        "id": "step-1",
        "type": "setFormField",
        "config": {
          "field": "confirmPassword",
          "value": "$event",
          "validationTrigger": "submit",
          "validationRules": [
            {
              "type": "required",
              "message": "Please confirm your password"
            },
            {
              "type": "formula",
              "formula": {
                "formula": "local.data?.['form']?.['formData']?.['confirmPassword'] === local.data?.['form']?.['formData']?.['password']"
              },
              "message": "Passwords do not match"
            }
          ]
        }
      },
      {
        "id": "step-2",
        "type": "setState",
        "config": {
          "payload": {
            "path": "_workflow.lastError",
            "value": ""
          }
        }
      }
    ]
  },
  "d0fd5c2b-37c1-4040-8690-d3a04e8c2f36": {
    "name": "setCustomerForOrderMutation",
    "type": "graphql",
    "query": "mutation SetCustomerForOrder($input: CreateCustomerInput!) { setCustomerForOrder(input: $input) { __typename ... on Order { id code customer { id firstName lastName emailAddress } } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "input": {
        "emailAddress": "{{local.data.form.formData.emailAddress}}",
        "firstName": "{{local.data.form.formData.firstName}}",
        "lastName": "{{local.data.form.formData.lastName}}"
      }
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "storeIn": "b8c9d0e1-f2a3-4567-bcde-678901234567",
    "responsePath": "data.setCustomerForOrder",
    "endpoint": "http://localhost:3000/shop-api"
  },
