        }
      },
      {
        "id": "step-set-contact-done",
        "type": "changeVariableValue",
        "config": {
          "variableName": "e0f1a2b3-c4d5-6789-efab-890123456789",
          "value": true
        }
      }
    ]
  },
  "8a9b0c1d-e2f3-4567-89ab-cdef01234567": {
    "name": "activeCustomerQuery",
    "type": "fetch",
    "url": "http://localhost:4000/v1/run/cmpfgh9d20003ti913oelf5bs/auth/me",
    "method": "GET",
    "headers": {
      "Authorization": "Bearer {{auth.token}}"
    }
  },
  "9b0c1d2e-f3a4-5678-9abc-def012345678": {
    "name": "restoreSession",
    "trigger": "created",
    "steps": [
      {
        "id": "s1",
        "type": "restoreSession"
      }
    ]
  },
  "6f6da384-9f39-4502-a2b9-d39a902438c3": {
    "name": "submitSignIn",
    "trigger": "submit",
    "steps": [
      {
        "id": "step-login",
        "action": "49c32a35-f663-4d36-9d5a-c1af0268f5c0"
      },
      {
        "id": "step-branch",
        "type": "branch",
        "config": {
          "condition": "!!context.workflow['step-login'].result?.token"
        },
        "trueBranch": [
          {
            "id": "step-authenticate",
            "type": "authenticate",
            "config": {
              "accessToken": {
                "formula": "context?.workflow?.['step-login']?.result?.token"
              },
              "persist": true
            }
          },
          {
            "id": "step-fetch-user",
            "action": "8a9b0c1d-e2f3-4567-89ab-cdef01234567"
          },
          {
            "id": "step-set-user",
            "type": "setUser",
            "config": {
              "user": {
                "formula": "context?.workflow?.['step-fetch-user']?.result?.activeCustomer"
              }
            }
          },
          {
            "id": "step-clear-sign-in-error",
            "type": "changeVariableValue",
            "config": {
              "variableName": "f2a3b4c5-d6e7-8901-fabc-012345678901",
              "value": ""
            }
          },
          {
            "id": "step-nav-after-login",
            "type": "navigateTo",
            "config": {
              "path": {
                "formula": "variables['c1d2e3f4-a5b6-7890-cdef-123456789012'] || '/'"
              },
              "linkType": "internal"
            }
          },
          {
            "id": "step-clear-redirect",
            "type": "changeVariableValue",
            "config": {
              "variableName": "c1d2e3f4-a5b6-7890-cdef-123456789012",
              "value": ""
            }
          }
        ],
        "falseBranch": [
          {
            "id": "step-set-error",
            "type": "changeVariableValue",
            "config": {
              "variableName": "f2a3b4c5-d6e7-8901-fabc-012345678901",
              "value": {
                "formula": "context?.workflow?.['step-login']?.result?.message || 'Login failed'"
              }
            }
          }
        ]
      }
    ]
  },
  "926c0ef9-beeb-41d3-924b-034b76b8b7cf": {
    "name": "submitRegister",
    "trigger": "submit",
    "steps": [
      {
        "id": "step-register",
        "action": "50885d62-b60a-45ea-9c07-d80651ef005b"
      },
      {
        "id": "step-nav-verify",
        "type": "navigateTo",
        "config": {
          "path": "/verify-pending",
          "linkType": "internal"
        }
      }
    ]
  },
  "d0fd5c2b-37c1-4040-8690-d3a04e8c2f36": {
    "name": "setCustomerForOrderMutation",
    "type": "fetch",
    "url": "http://localhost:4000/v1/run/cmpfgh9d20003ti913oelf5bs/auth/me",
    "method": "GET",
    "headers": {
      "Authorization": "Bearer {{auth.token}}"
    }
  }
}
