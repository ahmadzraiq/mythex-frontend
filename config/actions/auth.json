{
  "login": {
    "type": "fetch",
    "method": "POST",
    "url": "/api/auth/login",
    "body": {
      "email": {"var": "form.email"},
      "password": {"var": "form.password"}
    },
    "storeIn": "auth.user",
    "responsePath": "user",
    "onSuccess": {"action": "navigate", "payload": {"path": "/"}}
  },
  "validateSignup": {
    "type": "validate",
    "rules": {
      "form.name": {"required": true},
      "form.email": {"required": true, "pattern": "email"},
      "form.password": {"required": true, "minLength": 8},
      "form.confirmPassword": {
        "required": true,
        "equals": "form.password",
        "message": "Passwords must match"
      }
    },
    "storeErrorsIn": "errors",
    "onSuccess": {"action": "signup"}
  },
  "signup": {
    "type": "fetch",
    "method": "POST",
    "url": "/api/auth/signup",
    "body": {
      "name": {"var": "form.name"},
      "email": {"var": "form.email"},
      "password": {"var": "form.password"}
    },
    "storeIn": "auth.user",
    "responsePath": "user",
    "onSuccess": {"action": "navigate", "payload": {"path": "/"}}
  },
  "logout": {
    "type": "set",
    "path": "auth",
    "value": {"user": null, "error": null},
    "onSuccess": {"action": "navigate", "payload": {"path": "/login"}}
  },
  "forgotPassword": {
    "type": "fetch",
    "method": "POST",
    "url": "/api/auth/forgot-password",
    "body": {"email": {"var": "form.email"}},
    "onSuccess": {"action": "navigate", "payload": {"path": "/login"}}
  },
  "resetPassword": {
    "type": "fetch",
    "method": "POST",
    "url": "/api/auth/reset-password",
    "body": {
      "token": {"var": "form.token"},
      "password": {"var": "form.password"},
      "confirmPassword": {"var": "form.confirmPassword"}
    },
    "onSuccess": {"action": "navigate", "payload": {"path": "/login"}}
  },
  "fetchProfile": {
    "type": "fetch",
    "url": "/api/profile",
    "storeIn": "profile"
  },
  "updateProfile": {
    "type": "fetch",
    "method": "PUT",
    "url": "/api/profile",
    "body": {"name": {"var": "form.name"}, "email": {"var": "form.email"}},
    "storeIn": "profile"
  }
}
