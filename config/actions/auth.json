{
  "login": {
    "type": "validate",
    "rules": {
      "form.username": { "required": true, "pattern": "email", "message": "Valid email required" },
      "form.password": { "required": true, "message": "Password required" }
    },
    "storeErrorsIn": "errors",
    "onSuccess": { "action": "loginMutation" }
  },
  "loginMutation": {
    "type": "graphql",
    "query": "mutation Login($username: String!, $password: String!) { login(username: $username, password: $password) { __typename ... on CurrentUser { id identifier } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "username": { "var": "form.username" },
      "password": { "var": "form.password" }
    },
    "storeIn": "auth.user",
    "responsePath": "data.login",
    "storeHeaderIn": { "auth.token": "vendure-auth-token" },
    "errorMessagePath": "errors[0].message",
    "onSuccess": { "action": "navigate", "payload": { "path": "/" } }
  },
  "logout": {
    "type": "graphql",
    "query": "mutation Logout { logout { __typename ... on Success { success } } }",
    "headers": {
      "Authorization": { "var": ["auth.token", ""] }
    },
    "storeIn": "auth._logoutResult",
    "onSuccess": {
      "type": "runMultiple",
      "actions": [
        { "action": "clearAuth" },
        { "action": "navigate", "payload": { "path": "/sign-in" } }
      ]
    }
  },
  "clearAuth": {
    "type": "set",
    "path": "auth",
    "value": { "user": null, "token": null }
  },
  "register": {
    "type": "validate",
    "rules": {
      "form.emailAddress": { "required": true, "pattern": "email", "message": "Valid email required" },
      "form.firstName": { "required": true, "message": "First name required" },
      "form.lastName": { "required": true, "message": "Last name required" },
      "form.password": { "required": true, "minLength": 8, "message": "Password must be at least 8 characters" }
    },
    "storeErrorsIn": "errors",
    "onSuccess": { "action": "registerMutation" }
  },
  "registerMutation": {
    "type": "graphql",
    "query": "mutation RegisterCustomerAccount($input: RegisterCustomerInput!) { registerCustomerAccount(input: $input) { __typename ... on Success { success } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "input": {
        "emailAddress": { "var": "form.emailAddress" },
        "firstName": { "var": "form.firstName" },
        "lastName": { "var": "form.lastName" },
        "phoneNumber": { "var": ["form.phoneNumber", ""] },
        "password": { "var": "form.password" }
      }
    },
    "storeIn": "auth._registerResult",
    "responsePath": "data.registerCustomerAccount",
    "onSuccess": { "action": "navigate", "payload": { "path": "/verify-pending" } }
  },
  "forgotPassword": {
    "type": "validate",
    "rules": {
      "form.emailAddress": { "required": true, "pattern": "email", "message": "Valid email required" }
    },
    "storeErrorsIn": "errors",
    "onSuccess": { "action": "forgotPasswordMutation" }
  },
  "forgotPasswordMutation": {
    "type": "graphql",
    "query": "mutation RequestPasswordReset($emailAddress: String!) { requestPasswordReset(emailAddress: $emailAddress) { __typename ... on Success { success } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "emailAddress": { "var": "form.emailAddress" }
    },
    "storeIn": "auth._forgotPasswordResult",
    "responsePath": "data.requestPasswordReset"
  },
  "resetPassword": {
    "type": "validate",
    "rules": {
      "form.password": { "required": true, "minLength": 8, "message": "Password must be at least 8 characters" }
    },
    "storeErrorsIn": "errors",
    "onSuccess": { "action": "resetPasswordMutation" }
  },
  "resetPasswordMutation": {
    "type": "graphql",
    "query": "mutation ResetPassword($token: String!, $password: String!) { resetPassword(token: $token, password: $password) { __typename ... on CurrentUser { id identifier } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "token": { "var": "route.token" },
      "password": { "var": "form.password" }
    },
    "storeIn": "auth.user",
    "responsePath": "data.resetPassword",
    "storeHeaderIn": { "auth.token": "vendure-auth-token" },
    "onSuccess": { "action": "navigate", "payload": { "path": "/" } }
  },
  "verifyAccount": {
    "type": "graphql",
    "query": "mutation VerifyCustomerAccount($token: String!) { verifyCustomerAccount(token: $token) { __typename ... on CurrentUser { id identifier } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "token": { "var": "route.q" }
    },
    "storeIn": "auth.user",
    "responsePath": "data.verifyCustomerAccount",
    "storeHeaderIn": { "auth.token": "vendure-auth-token" },
    "onSuccess": { "action": "navigate", "payload": { "path": "/" } }
  },
  "setCustomerForOrder": {
    "type": "validate",
    "rules": {
      "form.emailAddress": { "required": true, "pattern": "email", "message": "Valid email required" },
      "form.firstName": { "required": true, "message": "First name required" },
      "form.lastName": { "required": true, "message": "Last name required" }
    },
    "storeErrorsIn": "errors",
    "onSuccess": { "action": "setCustomerForOrderMutation" }
  },
  "setCustomerForOrderMutation": {
    "type": "graphql",
    "query": "mutation SetCustomerForOrder($input: CreateCustomerInput!) { setCustomerForOrder(input: $input) { __typename ... on Order { id code customer { id firstName lastName emailAddress } } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "input": {
        "emailAddress": { "var": "form.emailAddress" },
        "firstName": { "var": "form.firstName" },
        "lastName": { "var": "form.lastName" }
      }
    },
    "headers": {
      "Authorization": { "var": ["auth.token", ""] }
    },
    "storeIn": "checkout.customer",
    "responsePath": "data.setCustomerForOrder",
    "onSuccess": {
      "type": "set",
      "path": "checkout.step",
      "value": 1
    }
  }
}
