  "a5c546d2-127a-4bdb-8b9f-f2c8a10471d7": {
    "name": "setCustomerForOrder",
    "type": "validate",
    "onSuccess": {
      "type": "runMultiple",
      "actions": [
        {
          "action": "d0fd5c2b-37c1-4040-8690-d3a04e8c2f36"
        },
        {
          "action": "adf68fbe-c9d0-4f2d-b141-e772451e2026"
        },
        {
          "type": "setVar",
          "path": "d9e0f1a2-b3c4-5678-defa-789012345678",
          "value": "shipping"
        },
        {
          "type": "setVar",
          "path": "e0f1a2b3-c4d5-6789-efab-890123456789",
          "value": true
        }
      ]
    }
  },
  "6f6da384-9f39-4502-a2b9-d39a902438c3": {
    "name": "submitSignIn",
    "type": "workflowSteps",
    "trigger": "submit",
    "steps": [
      {
        "id": "step-login",
        "action": "49c32a35-f663-4d36-9d5a-c1af0268f5c0"
      },
      {
        "id": "step-branch",
        "type": "branch",
        "config": {
          "condition": "not(context.workflow['step-login'].result?.login?.errorCode)"
        },
        "trueBranch": [
          {
            "id": "step-nav-home",
            "type": "navigateTo",
            "config": {
              "path": "/",
              "linkType": "internal"
            }
          }
        ],
        "falseBranch": [
          {
            "id": "step-set-error",
            "type": "changeVariableValue",
            "config": {
              "variableName": "f2a3b4c5-d6e7-8901-fabc-012345678901",
              "value": "{{context.workflow['step-login'].result?.login?.message}}"
            }
          }
        ]
      }
    ]
  },
