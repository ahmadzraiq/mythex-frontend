{
  "navigateToShop": {"action": "navigate", "payload": {"path": "/shop"}},
  "addToCart": {
    "type": "append",
    "path": "cart.items",
    "value": {
      "product": {"var": "product"},
      "quantity": {"var": "productQuantity"},
      "variant": {
        "size": {"var": "product.selectedSize"},
        "color": {"var": "product.selectedColor"}
      }
    }
  },
  "addToWishlist": {
    "type": "append",
    "path": "account.wishlist",
    "value": {"var": "$payload.product"}
  },
  "addToWishlistFromProduct": {
    "type": "append",
    "path": "account.wishlist",
    "value": {"var": "product"}
  },
  "addToWishlistFromCard": {
    "type": "append",
    "path": "account.wishlist",
    "value": {"var": "$item"},
    "stopPropagation": true
  },
  "quickAddToCart": {
    "type": "append",
    "path": "cart.items",
    "value": {"product": {"var": "$item"}, "quantity": 1, "variant": {}},
    "stopPropagation": true
  },
  "addToCartFromQuickView": {
    "type": "append",
    "path": "cart.items",
    "value": {
      "product": {"var": "quickViewProduct"},
      "quantity": 1,
      "variant": {}
    }
  },
  "moveToCartFromWishlist": {
    "type": "runMultiple",
    "actions": [
      {"action": "addToCartFromWishlist"},
      {"action": "removeFromWishlist"}
    ]
  },
  "addToCartFromWishlist": {
    "type": "append",
    "path": "cart.items",
    "value": {"product": {"var": "$item"}, "quantity": 1, "variant": {}}
  },
  "removeFromWishlist": {
    "type": "removeAt",
    "path": "account.wishlist",
    "index": {"var": "$index"}
  },
  "removeFromCart": {
    "type": "removeAt",
    "path": "cart.items",
    "index": {"var": "$index"}
  },
  "incrementQuantity": {
    "type": "increment",
    "path": "productQuantity",
    "amount": 1
  },
  "decrementQuantity": {
    "type": "decrement",
    "path": "productQuantity",
    "amount": 1
  },
  "shareProduct": {
    "type": "share",
    "title": {"var": "product.name"},
    "url": {"var": "product.slug"}
  },
  "applyCoupon": {
    "type": "set",
    "path": "cart.coupon",
    "value": {"var": "coupon"}
  },
  "shareWishlist": {
    "type": "share",
    "title": "My Wishlist | SaraZ",
    "url": {"var": "route.path"}
  },
  "placeOrder": {
    "type": "fetch",
    "url": "/api/store/orders",
    "method": "POST",
    "body": {
      "email": {"var": "email"},
      "shippingAddress": {"var": "shippingAddress"},
      "shippingMethod": {"var": "shippingMethod"},
      "paymentMethod": {"var": "paymentMethod"},
      "orderNotes": {"var": "orderNotes"},
      "items": {"var": "cart.items"}
    },
    "storeIn": "order.lastOrder",
    "onSuccess": [
      {"action": "clearCart"},
      {"action": "navigate", "payload": {"path": "/order-confirmation"}}
    ]
  },
  "clearCart": {"type": "set", "path": "cart.items", "value": []},
  "setShippingStandard": {
    "type": "set",
    "path": "shippingMethod",
    "value": "standard"
  },
  "setShippingExpress": {
    "type": "set",
    "path": "shippingMethod",
    "value": "express"
  },
  "setPaymentCard": {"type": "set", "path": "paymentMethod", "value": "card"},
  "setPaymentTabby": {"type": "set", "path": "paymentMethod", "value": "tabby"},
  "setPaymentCOD": {"type": "set", "path": "paymentMethod", "value": "cod"},
  "calculateShipping": {
    "type": "fetch",
    "url": "/api/store/shipping/calculate",
    "method": "POST",
    "body": {"zip": {"var": "shippingZip"}, "area": {"var": "shippingZip"}},
    "storeIn": "cart.shippingEstimate"
  }
}
