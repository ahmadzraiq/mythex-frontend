{
  "openDrawer": {
    "type": "set",
    "path": "layout",
    "value": {"drawerOpen": true}
  },
  "closeDrawer": {
    "type": "set",
    "path": "layout",
    "value": {"drawerOpen": false}
  },
  "dismissAnnouncement": {
    "type": "set",
    "path": "layout.announcementVisible",
    "value": false
  },
  "openMobileNav": {
    "type": "set",
    "path": "layout.mobileNavOpen",
    "value": true
  },
  "closeMobileNav": {
    "type": "set",
    "path": "layout.mobileNavOpen",
    "value": false
  },
  "openSearchDrawer": {
    "type": "set",
    "path": "layout.searchDrawerOpen",
    "value": true
  },
  "closeSearchDrawer": {
    "type": "set",
    "path": "layout.searchDrawerOpen",
    "value": false
  },
  "openCartDrawer": {
    "type": "set",
    "path": "layout.cartDrawerOpen",
    "value": true
  },
  "closeCartDrawer": {
    "type": "set",
    "path": "layout.cartDrawerOpen",
    "value": false
  },
  "openFilterDrawer": {
    "type": "set",
    "path": "layout.filterDrawerOpen",
    "value": true
  },
  "closeFilterDrawer": {
    "type": "set",
    "path": "layout.filterDrawerOpen",
    "value": false
  },
  "closeMobileNavAndNavigate": {
    "type": "runMultiple",
    "actions": [
      {"action": "closeMobileNav"},
      {"action": "navigate", "payload": {"path": "/"}}
    ]
  },
  "closeMobileNavAndGoToShop": {
    "type": "runMultiple",
    "actions": [
      {"action": "closeMobileNav"},
      {"action": "navigate", "payload": {"path": "/shop"}}
    ]
  },
  "closeMobileNavAndGoToShopWomen": {
    "type": "runMultiple",
    "actions": [
      {"action": "closeMobileNav"},
      {"action": "navigate", "payload": {"path": "/shop?category=women"}}
    ]
  },
  "closeMobileNavAndGoToShopMen": {
    "type": "runMultiple",
    "actions": [
      {"action": "closeMobileNav"},
      {"action": "navigate", "payload": {"path": "/shop?category=men"}}
    ]
  },
  "closeMobileNavAndGoToShopKids": {
    "type": "runMultiple",
    "actions": [
      {"action": "closeMobileNav"},
      {"action": "navigate", "payload": {"path": "/shop?category=kids"}}
    ]
  },
  "closeMobileNavAndGoToShopAccessories": {
    "type": "runMultiple",
    "actions": [
      {"action": "closeMobileNav"},
      {"action": "navigate", "payload": {"path": "/shop?category=accessories"}}
    ]
  },
  "closeMobileNavAndGoToSale": {
    "type": "runMultiple",
    "actions": [
      {"action": "closeMobileNav"},
      {"action": "navigate", "payload": {"path": "/shop?sale=true"}}
    ]
  },
  "closeMobileNavAndGoToAccount": {
    "type": "runMultiple",
    "actions": [
      {"action": "closeMobileNav"},
      {"action": "navigate", "payload": {"path": "/account"}}
    ]
  },
  "closeMobileNavAndGoToWishlist": {
    "type": "runMultiple",
    "actions": [
      {"action": "closeMobileNav"},
      {"action": "navigate", "payload": {"path": "/account/wishlist"}}
    ]
  },
  "closeMobileNavAndGoToCart": {
    "type": "runMultiple",
    "actions": [
      {"action": "closeMobileNav"},
      {"action": "navigate", "payload": {"path": "/cart"}}
    ]
  },
  "closeSearchAndNavigate": {
    "type": "runMultiple",
    "actions": [
      {"action": "closeSearchDrawer"},
      {"action": "navigate", "payload": {"path": "/shop"}}
    ]
  },
  "closeSearchAndGoToDresses": {
    "type": "runMultiple",
    "actions": [
      {"action": "closeSearchDrawer"},
      {"action": "navigate", "payload": {"path": "/search?q=dresses"}}
    ]
  },
  "closeSearchAndGoToShoes": {
    "type": "runMultiple",
    "actions": [
      {"action": "closeSearchDrawer"},
      {"action": "navigate", "payload": {"path": "/search?q=shoes"}}
    ]
  },
  "closeSearchAndGoToAccessories": {
    "type": "runMultiple",
    "actions": [
      {"action": "closeSearchDrawer"},
      {"action": "navigate", "payload": {"path": "/search?q=accessories"}}
    ]
  },
  "closeSearchAndGoToSearch": {
    "type": "runMultiple",
    "actions": [
      {"action": "closeSearchDrawer"},
      {"action": "navigate", "payload": {"path": "/search?q={{search.query}}"}}
    ]
  },
  "closeSearchAndGoToSearch": {
    "type": "runMultiple",
    "actions": [
      {"action": "closeSearchDrawer"},
      {"action": "navigate", "payload": {"path": "/search?q={{search.query}}"}}
    ]
  },
  "closeCartAndGoToShop": {
    "type": "runMultiple",
    "actions": [
      {"action": "closeCartDrawer"},
      {"action": "navigate", "payload": {"path": "/shop"}}
    ]
  },
  "closeCartAndGoToCart": {
    "type": "runMultiple",
    "actions": [
      {"action": "closeCartDrawer"},
      {"action": "navigate", "payload": {"path": "/cart"}}
    ]
  },
  "closeDrawerAndGoToShop": {
    "type": "runMultiple",
    "actions": [
      {"action": "closeDrawer"},
      {"action": "navigate", "payload": {"path": "/shop"}}
    ]
  },
  "closeDrawerAndGoToAccount": {
    "type": "runMultiple",
    "actions": [
      {"action": "closeDrawer"},
      {"action": "navigate", "payload": {"path": "/account"}}
    ]
  },
  "openSizeGuide": {
    "type": "set",
    "path": "layout.sizeGuideOpen",
    "value": true
  },
  "closeSizeGuide": {
    "type": "set",
    "path": "layout.sizeGuideOpen",
    "value": false
  },
  "openQuickView": {
    "type": "runMultiple",
    "actions": [
      {
        "action": "setState",
        "payload": {"path": "quickViewProduct", "value": {"var": "$item"}}
      },
      {"action": "openQuickViewModal"}
    ],
    "stopPropagation": true
  },
  "closeQuickView": {
    "type": "runMultiple",
    "actions": [
      {"action": "closeQuickViewModal"},
      {
        "action": "setState",
        "payload": {"path": "quickViewProduct", "value": null}
      }
    ]
  },
  "openQuickViewModal": {
    "type": "set",
    "path": "layout.quickViewOpen",
    "value": true
  },
  "closeQuickViewModal": {
    "type": "set",
    "path": "layout.quickViewOpen",
    "value": false
  },
  "addToCartAndCloseQuickView": {
    "type": "runMultiple",
    "actions": [
      {"action": "addToCartFromQuickView"},
      {"action": "closeQuickView"}
    ]
  },
  "closeQuickViewAndNavigateToProduct": {
    "type": "runMultiple",
    "actions": [
      {"action": "closeQuickView"},
      {
        "action": "navigate",
        "payload": {
          "routeConfig": "product",
          "slug": {"var": "quickViewProduct.slug"}
        }
      }
    ]
  }
}
