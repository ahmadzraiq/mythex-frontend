        "config": {
          "conditionPath": "collections.b8c9d0e1-f2a3-4567-bcde-678901234567.activeOrder.shippingAddress.streetLine1"
        },
        "trueBranch": [
          {
            "id": "step-1a",
            "action": "62c64842-4b76-40b3-87ae-d2f0275cb926"
          }
        ],
        "falseBranch": []
      },
      {
        "id": "step-2",
        "type": "branch",
        "config": {
          "conditionPath": "collections.b8c9d0e1-f2a3-4567-bcde-678901234567.activeOrder.shippingLines.length"
        },
        "trueBranch": [
          {
            "id": "step-2a",
            "action": "5b47500d-b49f-45ba-918f-dd51cc221e7b"
          }
        ],
        "falseBranch": []
      }
    ]
  },
