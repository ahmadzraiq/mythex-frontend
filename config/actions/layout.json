  "82e7ed48-3f76-4130-af0d-8ecb1d2ae52a": {
    "name": "syncCheckoutStep",
    "trigger": "click",
    "steps": [
      {
        "id": "step-1",
        "type": "changeVariableValue",
        "config": {
          "variableName": "d9e0f1a2-b3c4-5678-defa-789012345678",
          "value": {
            "formula": "!(auth?.user || collections['b8c9d0e1-f2a3-4567-bcde-678901234567']?.activeOrder?.customer?.emailAddress || '') ? 'contact' : !(collections['b8c9d0e1-f2a3-4567-bcde-678901234567']?.activeOrder?.shippingAddress?.streetLine1 || '') ? 'shipping' : (collections['b8c9d0e1-f2a3-4567-bcde-678901234567']?.activeOrder?.shippingLines?.length || 0 || 0) <= 0 ? 'delivery' : !(variables['b3c4d5e6-f7a8-9012-bcde-123456789012'] || '') ? 'payment' : 'review'"
          }
        }
      }
    ]
  },
