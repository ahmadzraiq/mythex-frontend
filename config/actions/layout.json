{
  "openDrawer": {
    "type": "setVar",
    "path": "b1c2d3e4-f5a6-7890-bcde-f01234567890",
    "value": true
  },
  "closeDrawer": {
    "type": "setVar",
    "path": "b1c2d3e4-f5a6-7890-bcde-f01234567890",
    "value": false
  },
  "openCartDrawer": {
    "type": "setVar",
    "path": "c2d3e4f5-a6b7-8901-cdef-012345678901",
    "value": true
  },
  "closeCartDrawer": {
    "type": "setVar",
    "path": "c2d3e4f5-a6b7-8901-cdef-012345678901",
    "value": false
  },
  "toggleThemeMenu": {
    "type": "toggle",
    "path": "e4f5a6b7-c8d9-0123-efab-234567890123"
  },
  "closeThemeMenu": {
    "type": "setVar",
    "path": "e4f5a6b7-c8d9-0123-efab-234567890123",
    "value": false
  },
  "applyThemeLight": {
    "type": "setTheme",
    "value": "light"
  },
  "applyThemeDark": {
    "type": "setTheme",
    "value": "dark"
  },
  "applyThemeSystem": {
    "type": "setTheme",
    "value": "system"
  },
  "setThemeLight": {
    "type": "runMultiple",
    "actions": [
      {
        "action": "applyThemeLight"
      },
      {
        "action": "closeThemeMenu"
      }
    ]
  },
  "setThemeDark": {
    "type": "runMultiple",
    "actions": [
      {
        "action": "applyThemeDark"
      },
      {
        "action": "closeThemeMenu"
      }
    ]
  },
  "setThemeSystem": {
    "type": "runMultiple",
    "actions": [
      {
        "action": "applyThemeSystem"
      },
      {
        "action": "closeThemeMenu"
      }
    ]
  },
  "navigateToSearch": {
    "action": "navigate",
    "payload": {
      "path": "/search?q={{variables['f5a6b7c8-d9e0-1234-fabc-345678901234']}}"
    }
  },
  "submitSearch": {
    "action": "navigate",
    "payload": {
      "path": "/search?q={{variables['f5a6b7c8-d9e0-1234-fabc-345678901234']}}"
    }
  },
  "goToCart": {
    "action": "navigate",
    "payload": {
      "path": "/cart"
    }
  },
  "changePassword": {
    "type": "validate",
    "formId": "f3a4b5c6-d7e8-9012-fabc-012345678901",
    "onSuccess": {
      "action": "changePasswordMutation"
    }
  },
  "requestEmailUpdate": {
    "type": "validate",
    "formId": "c6d7e8f9-a0b1-2345-cdef-345678901234",
    "onSuccess": {
      "action": "requestEmailUpdateMutation"
    }
  },
  "createAddress": {
    "type": "validate",
    "formId": "a4b5c6d7-e8f9-0123-abcd-123456789012",
    "onSuccess": {
      "action": "createAddressMutation"
    }
  },
  "syncCheckoutStep": {
    "type": "setVar",
    "path": "d9e0f1a2-b3c4-5678-defa-789012345678",
    "value": {
      "expr": "!({{auth.user}} || {{collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.customer.emailAddress}} || '') ? 'contact' : !({{collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.shippingAddress.streetLine1}} || '') ? 'shipping' : ({{collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.shippingLines.length}} || 0 || 0) <= 0 ? 'delivery' : !({{variables['b3c4d5e6-f7a8-9012-bcde-123456789012']}} || '') ? 'payment' : 'review'"
    }
  },
  "populateCheckoutForm": {
    "type": "runMultiple",
    "actions": [
      {
        "type": "setFormField",
        "formId": "d1e2f3a4-b5c6-7890-defa-890123456789",
        "field": "emailAddress",
        "value": "{{collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.customer.emailAddress}}"
      },
      {
        "type": "setFormField",
        "formId": "d1e2f3a4-b5c6-7890-defa-890123456789",
        "field": "firstName",
        "value": "{{collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.customer.firstName}}"
      },
      {
        "type": "setFormField",
        "formId": "d1e2f3a4-b5c6-7890-defa-890123456789",
        "field": "lastName",
        "value": "{{collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.customer.lastName}}"
      },
      {
        "type": "setFormField",
        "formId": "d1e2f3a4-b5c6-7890-defa-890123456789",
        "field": "fullName",
        "value": "{{collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.shippingAddress.fullName}}"
      },
      {
        "type": "setFormField",
        "formId": "d1e2f3a4-b5c6-7890-defa-890123456789",
        "field": "company",
        "value": "{{collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.shippingAddress.company}}"
      },
      {
        "type": "setFormField",
        "formId": "d1e2f3a4-b5c6-7890-defa-890123456789",
        "field": "streetLine1",
        "value": "{{collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.shippingAddress.streetLine1}}"
      },
      {
        "type": "setFormField",
        "formId": "d1e2f3a4-b5c6-7890-defa-890123456789",
        "field": "streetLine2",
        "value": "{{collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.shippingAddress.streetLine2}}"
      },
      {
        "type": "setFormField",
        "formId": "d1e2f3a4-b5c6-7890-defa-890123456789",
        "field": "city",
        "value": "{{collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.shippingAddress.city}}"
      },
      {
        "type": "setFormField",
        "formId": "d1e2f3a4-b5c6-7890-defa-890123456789",
        "field": "province",
        "value": "{{collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.shippingAddress.province}}"
      },
      {
        "type": "setFormField",
        "formId": "d1e2f3a4-b5c6-7890-defa-890123456789",
        "field": "postalCode",
        "value": "{{collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.shippingAddress.postalCode}}"
      },
      {
        "type": "setFormField",
        "formId": "d1e2f3a4-b5c6-7890-defa-890123456789",
        "field": "countryCode",
        "value": "{{collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.shippingAddress.countryCode}}"
      },
      {
        "type": "setFormField",
        "formId": "d1e2f3a4-b5c6-7890-defa-890123456789",
        "field": "phoneNumber",
        "value": "{{collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.shippingAddress.phoneNumber}}"
      },
      {
        "type": "setVar",
        "path": "a2b3c4d5-e6f7-8901-abcd-012345678901",
        "value": "{{collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.shippingLines.0.shippingMethod.id}}"
      }
    ]
  },
  "fetchCheckoutDependentData": {
    "type": "runMultiple",
    "actions": [
      {
        "condition": "{{collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.shippingAddress.streetLine1}}",
        "action": "fetchShippingMethods"
      },
      {
        "condition": "({{collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.shippingLines.length}} || 0) > 0",
        "action": "fetchPaymentMethods"
      }
    ]
  },
  "clearCartAfterOrder": {
    "type": "set",
    "path": "cart",
    "value": {
      "id": null,
      "code": null,
      "state": null,
      "totalQuantity": 0,
      "subTotalWithTax": 0,
      "shippingWithTax": 0,
      "totalWithTax": 0,
      "currencyCode": "USD",
      "couponCodes": [],
      "discounts": [],
      "lines": []
    }
  },
  "clearCheckoutSessionAndNavigate": {
    "type": "runMultiple",
    "actions": [
      {
        "action": "clearCartAfterOrder"
      },
      {
        "type": "clearPersistedPaths",
        "onSuccess": {
          "action": "navigateToOrderConfirmation"
        }
      }
    ]
  },
  "navigateToOrderConfirmation": {
    "action": "navigate",
    "payload": {
      "routeConfig": "orderConfirmation",
      "slug": "{{collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.code}}"
    }
  },
  "goToCheckoutStep": {
    "type": "setVar",
    "path": "d9e0f1a2-b3c4-5678-defa-789012345678",
    "value": "{{$item}}"
  },
  "selectProductOption": {
    "type": "mergeAtPath",
    "path": "c4d5e6f7-a8b9-0123-cdef-234567890123",
    "key": "{{$parent.id}}",
    "value": "{{context.item.id}}"
  },
  "prevProductImage": {
    "type": "cycleIndex",
    "path": "d5e6f7a8-b9c0-1234-defa-345678901234",
    "arrayPath": "product.assets",
    "direction": "prev"
  },
  "nextProductImage": {
    "type": "cycleIndex",
    "path": "d5e6f7a8-b9c0-1234-defa-345678901234",
    "arrayPath": "product.assets",
    "direction": "next"
  },
  "selectProductImage": {
    "type": "setVar",
    "path": "d5e6f7a8-b9c0-1234-defa-345678901234",
    "value": "{{$index}}"
  }
}
