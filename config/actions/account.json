        "defaultShippingAddress": "{{local.data.form.formData.defaultShippingAddress}}",
        "defaultBillingAddress": "{{local.data.form.formData.defaultBillingAddress}}"
      }
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
