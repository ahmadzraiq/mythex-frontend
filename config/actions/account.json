{
  "updateProfileMutation": {
    "type": "graphql",
    "query": "mutation UpdateCustomer($input: UpdateCustomerInput!) { updateCustomer(input: $input) { __typename id firstName lastName emailAddress } }",
    "variables": {
      "input": {
        "firstName": "{{variables['e2f3a4b5-c6d7-8901-efab-901234567890'].value.firstName}}",
        "lastName": "{{variables['e2f3a4b5-c6d7-8901-efab-901234567890'].value.lastName}}"
      }
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "storeIn": "e7f8a9b0-c1d2-3456-efab-567890123456",
    "responsePath": "data.updateCustomer",
    "onSuccess": {
      "action": "showToast",
      "payload": {
        "message": "Profile updated"
      }
    },
    "endpoint": "http://localhost:3000/shop-api"
  },
  "saveAddress": {
    "type": "validate",
    "formId": "a4b5c6d7-e8f9-0123-abcd-123456789012",
    "onSuccess": {
      "action": "saveAddressMutation"
    }
  },
  "saveAddressMutation": {
    "type": "graphql",
    "query": "mutation CreateCustomerAddress($input: CreateAddressInput!) { createCustomerAddress(input: $input) { id fullName streetLine1 streetLine2 city province postalCode country { code name } phoneNumber defaultShippingAddress defaultBillingAddress } }",
    "variables": {
      "input": {
        "fullName": "{{variables['a4b5c6d7-e8f9-0123-abcd-123456789012'].value.fullName}}",
        "streetLine1": "{{variables['a4b5c6d7-e8f9-0123-abcd-123456789012'].value.streetLine1}}",
        "streetLine2": "{{variables['a4b5c6d7-e8f9-0123-abcd-123456789012'].value.streetLine2}}",
        "city": "{{variables['a4b5c6d7-e8f9-0123-abcd-123456789012'].value.city}}",
        "province": "{{variables['a4b5c6d7-e8f9-0123-abcd-123456789012'].value.province}}",
        "postalCode": "{{variables['a4b5c6d7-e8f9-0123-abcd-123456789012'].value.postalCode}}",
        "countryCode": "{{variables['a4b5c6d7-e8f9-0123-abcd-123456789012'].value.countryCode}}",
        "phoneNumber": "{{variables['a4b5c6d7-e8f9-0123-abcd-123456789012'].value.phoneNumber}}",
        "defaultShippingAddress": "{{variables['a4b5c6d7-e8f9-0123-abcd-123456789012'].value.defaultShippingAddress}}",
        "defaultBillingAddress": "{{variables['a4b5c6d7-e8f9-0123-abcd-123456789012'].value.defaultBillingAddress}}"
      }
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "storeIn": "customer._savedAddress",
    "responsePath": "data.createCustomerAddress",
    "onSuccess": {
      "type": "runMultiple",
      "actions": [
        {
          "action": "fetchActiveCustomer"
        },
        {
          "action": "showToast",
          "payload": {
            "message": "Address saved"
          }
        }
      ]
    },
    "endpoint": "http://localhost:3000/shop-api"
  },
  "changePasswordMutation": {
    "type": "graphql",
    "endpoint": "http://localhost:3000/shop-api",
    "query": "mutation UpdateCustomerPassword($currentPassword: String!, $newPassword: String!) { updateCustomerPassword(currentPassword: $currentPassword, newPassword: $newPassword) { __typename ... on Success { success } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "currentPassword": "{{variables['f3a4b5c6-d7e8-9012-fabc-012345678901'].value.currentPassword}}",
      "newPassword": "{{variables['f3a4b5c6-d7e8-9012-fabc-012345678901'].value.newPassword}}"
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "storeIn": "account._changePasswordResult",
    "responsePath": "data.updateCustomerPassword"
  },
  "requestEmailUpdateMutation": {
    "type": "graphql",
    "endpoint": "http://localhost:3000/shop-api",
    "query": "mutation RequestUpdateCustomerEmailAddress($password: String!, $newEmailAddress: String!) { requestUpdateCustomerEmailAddress(password: $password, newEmailAddress: $newEmailAddress) { __typename ... on Success { success } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "password": "{{variables['c6d7e8f9-a0b1-2345-cdef-345678901234'].value.password}}",
      "newEmailAddress": "{{variables['c6d7e8f9-a0b1-2345-cdef-345678901234'].value.newEmailAddress}}"
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "storeIn": "account._emailUpdateResult",
    "responsePath": "data.requestUpdateCustomerEmailAddress"
  },
  "createAddressMutation": {
    "type": "graphql",
    "endpoint": "http://localhost:3000/shop-api",
    "query": "mutation CreateCustomerAddress($input: CreateAddressInput!) { createCustomerAddress(input: $input) { id fullName streetLine1 city postalCode country { id code name } defaultShippingAddress defaultBillingAddress } }",
    "variables": {
      "input": {
        "fullName": "{{variables['a4b5c6d7-e8f9-0123-abcd-123456789012'].value.fullName}}",
        "streetLine1": "{{variables['a4b5c6d7-e8f9-0123-abcd-123456789012'].value.streetLine1}}",
        "streetLine2": "{{variables['a4b5c6d7-e8f9-0123-abcd-123456789012'].value.streetLine2}}",
        "city": "{{variables['a4b5c6d7-e8f9-0123-abcd-123456789012'].value.city}}",
        "province": "{{variables['a4b5c6d7-e8f9-0123-abcd-123456789012'].value.province}}",
        "postalCode": "{{variables['a4b5c6d7-e8f9-0123-abcd-123456789012'].value.postalCode}}",
        "countryCode": "{{variables['a4b5c6d7-e8f9-0123-abcd-123456789012'].value.countryCode}}",
        "phoneNumber": "{{variables['a4b5c6d7-e8f9-0123-abcd-123456789012'].value.phoneNumber}}",
        "defaultShippingAddress": "{{variables['a4b5c6d7-e8f9-0123-abcd-123456789012'].value.defaultShippingAddress}}",
        "defaultBillingAddress": "{{variables['a4b5c6d7-e8f9-0123-abcd-123456789012'].value.defaultBillingAddress}}"
      }
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "storeIn": "account._createAddressResult",
    "responsePath": "data.createCustomerAddress"
  },
  "deleteAddress": {
    "type": "graphql",
    "endpoint": "http://localhost:3000/shop-api",
    "query": "mutation DeleteCustomerAddress($id: ID!) { deleteCustomerAddress(id: $id) { success } }",
    "variables": {
      "id": "{{context.item.id}}"
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "storeIn": "account._deleteAddressResult",
    "responsePath": "data.deleteCustomerAddress"
  }
}
