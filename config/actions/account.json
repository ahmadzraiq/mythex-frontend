{
  "56642a48-2ec2-4923-9506-cb86ef6b0661": {
    "name": "updateProfileMutation",
    "type": "fetch",
    "url": "http://localhost:4000/v1/run/cmpfgh9d20003ti913oelf5bs/account/me",
    "method": "PATCH",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer {{auth.token}}"
    },
    "body": {
      "first_name": "{{local.data.form.formData.firstName}}",
      "last_name": "{{local.data.form.formData.lastName}}"
    }
  },
  "4d5e6f7a-8b9c-0d1e-2f3a-b4c5d6e7f8a9": {
    "name": "submitUpdateProfile",
    "trigger": "click",
    "steps": [
      {
        "id": "step-mutation",
        "action": "56642a48-2ec2-4923-9506-cb86ef6b0661"
      },
      {
        "id": "step-toast",
        "action": "showToast",
        "payload": {
          "message": "Profile updated"
        }
      }
    ]
  },
  "340318a1-6824-4e30-9880-7c9dcfb9cf3a": {
