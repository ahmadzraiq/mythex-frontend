        "id": "step-mutation",
        "action": "9e4ba82b-c14c-4b8d-9646-559d274fc9c5"
      },
      {
        "id": "step-fetch-customer",
        "action": "25936105-5bba-4563-8105-3e5218489469"
      },
      {
        "id": "step-toast",
        "action": "showToast",
        "payload": {
          "message": "Address saved"
        }
      }
    ]
  },
