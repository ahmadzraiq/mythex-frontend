{
  "56642a48-2ec2-4923-9506-cb86ef6b0661": {
    "name": "updateProfileMutation",
    "type": "graphql",
    "query": "mutation UpdateCustomer($input: UpdateCustomerInput!) { updateCustomer(input: $input) { __typename id firstName lastName emailAddress } }",
    "variables": {
      "input": {
        "firstName": "{{local.data.form.formData.firstName}}",
        "lastName": "{{local.data.form.formData.lastName}}"
      }
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "storeIn": "e7f8a9b0-c1d2-3456-efab-567890123456",
    "responsePath": "data.updateCustomer",
    "onSuccess": {
      "action": "showToast",
      "payload": {
        "message": "Profile updated"
      }
    },
    "endpoint": "http://localhost:3000/shop-api"
  },
  "340318a1-6824-4e30-9880-7c9dcfb9cf3a": {
    "name": "saveAddress",
    "type": "validate",
    "onSuccess": {
      "action": "9e4ba82b-c14c-4b8d-9646-559d274fc9c5"
    }
  },
  "9e4ba82b-c14c-4b8d-9646-559d274fc9c5": {
    "name": "saveAddressMutation",
    "type": "graphql",
    "query": "mutation CreateCustomerAddress($input: CreateAddressInput!) { createCustomerAddress(input: $input) { id fullName streetLine1 streetLine2 city province postalCode country { code name } phoneNumber defaultShippingAddress defaultBillingAddress } }",
    "variables": {
      "input": {
        "fullName": "{{local.data.form.formData.fullName}}",
        "streetLine1": "{{local.data.form.formData.streetLine1}}",
        "streetLine2": "{{local.data.form.formData.streetLine2}}",
        "city": "{{local.data.form.formData.city}}",
        "province": "{{local.data.form.formData.province}}",
        "postalCode": "{{local.data.form.formData.postalCode}}",
        "countryCode": "{{local.data.form.formData.countryCode}}",
        "phoneNumber": "{{local.data.form.formData.phoneNumber}}",
        "defaultShippingAddress": "{{local.data.form.formData.defaultShippingAddress}}",
        "defaultBillingAddress": "{{local.data.form.formData.defaultBillingAddress}}"
      }
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "storeIn": "customer._savedAddress",
    "responsePath": "data.createCustomerAddress",
    "onSuccess": {
      "type": "runMultiple",
      "actions": [
        {
          "action": "25936105-5bba-4563-8105-3e5218489469"
        },
        {
          "action": "showToast",
          "payload": {
            "message": "Address saved"
          }
        }
      ]
    },
    "endpoint": "http://localhost:3000/shop-api"
  },
  "bd9e61f2-7964-4545-8167-4331ff17ec7a": {
    "name": "changePasswordMutation",
    "type": "graphql",
    "endpoint": "http://localhost:3000/shop-api",
    "query": "mutation UpdateCustomerPassword($currentPassword: String!, $newPassword: String!) { updateCustomerPassword(currentPassword: $currentPassword, newPassword: $newPassword) { __typename ... on Success { success } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "currentPassword": "{{local.data.form.formData.currentPassword}}",
      "newPassword": "{{local.data.form.formData.newPassword}}"
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "storeIn": "account._changePasswordResult",
    "responsePath": "data.updateCustomerPassword"
  },
  "a6626679-62d9-4aa5-a842-7ebcc266e658": {
    "name": "requestEmailUpdateMutation",
    "type": "graphql",
    "endpoint": "http://localhost:3000/shop-api",
    "query": "mutation RequestUpdateCustomerEmailAddress($password: String!, $newEmailAddress: String!) { requestUpdateCustomerEmailAddress(password: $password, newEmailAddress: $newEmailAddress) { __typename ... on Success { success } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "password": "{{local.data.form.formData.password}}",
      "newEmailAddress": "{{local.data.form.formData.newEmailAddress}}"
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "storeIn": "account._emailUpdateResult",
    "responsePath": "data.requestUpdateCustomerEmailAddress"
  },
  "9c6e39a6-5495-4c2a-8ea9-fc5bbe0ef052": {
    "name": "createAddressMutation",
    "type": "graphql",
    "endpoint": "http://localhost:3000/shop-api",
    "query": "mutation CreateCustomerAddress($input: CreateAddressInput!) { createCustomerAddress(input: $input) { id fullName streetLine1 city postalCode country { id code name } defaultShippingAddress defaultBillingAddress } }",
