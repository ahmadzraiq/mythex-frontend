  "admin-col-toggle": {
    "name": "admin-col-toggle",
    "trigger": "click",
    "steps": [{ "id": "s1", "type": "changeVariableValue", "config": { "variableName": "adm00013-0000-0000-0000-000000000013", "value": { "js": "const cols=variables['adm00013-0000-0000-0000-000000000013']??[]; const id=context?.item?.data?.id; return cols.map(c=>c.id===id?{...c,visible:!c.visible}:c);" } } }]
