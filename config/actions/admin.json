    "name": "admin-col-drag-start",
    "trigger": "dragStart",
    "steps": [{ "id": "s1", "type": "changeVariableValue", "config": { "variableName": "adm00014-0000-0000-0000-000000000014", "value": { "formula": "{ cardId: context?.item?.data?.id, sourceIndex: context?.item?.data?.index, targetIndex: context?.item?.data?.index }" } } }]
  },
  "admin-col-drag-update": {
    "name": "admin-col-drag-update",
    "trigger": "dragUpdate",
    "steps": [{ "id": "s1", "type": "changeVariableValue", "config": { "variableName": "adm00014-0000-0000-0000-000000000014", "value": { "js": "const drag=variables['adm00014-0000-0000-0000-000000000014']; const cols=variables['adm00013-0000-0000-0000-000000000013']??[]; const slotH=36; const ty=event?.translationY??0; const srcIdx=drag?.sourceIndex??0; const newTgt=Math.max(0,Math.min(cols.length-1,srcIdx+Math.round(ty/slotH))); return {...drag,targetIndex:newTgt};" } } }]
  },
  "admin-col-drag-end": {
    "name": "admin-col-drag-end",
    "trigger": "dragEnd",
    "steps": [
      { "id": "s1", "type": "changeVariableValue", "config": { "variableName": "adm00013-0000-0000-0000-000000000013", "value": { "js": "const cols=variables['adm00013-0000-0000-0000-000000000013']??[]; const drag=variables['adm00014-0000-0000-0000-000000000014']; const srcIdx=drag?.sourceIndex??0; const ty=event?.translationY??0; const slotH=36; const newIdx=Math.max(0,Math.min(cols.length-1,srcIdx+Math.round(ty/slotH))); if(srcIdx===newIdx) return cols; const r=[...cols]; const [m]=r.splice(srcIdx,1); r.splice(newIdx,0,m); return r;" } } },
      { "id": "s2", "type": "changeVariableValue", "config": { "variableName": "adm00014-0000-0000-0000-000000000014", "value": { "formula": "{ cardId: null, sourceIndex: null, targetIndex: null }" } } }
