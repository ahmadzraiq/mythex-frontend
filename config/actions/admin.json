  "admin-login-fetch": {
    "name": "admin-login-fetch",
    "type": "fetch",
    "url": "http://localhost:4000/v1/run/cmpfgh9d20003ti913oelf5bs/admin/auth/login",
    "method": "POST",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "email": "{{local.data.form.formData.email}}",
      "password": "{{local.data.form.formData.password}}"
    }
  },
  "admin-submit-login": {
    "name": "admin-submit-login",
    "trigger": "submit",
    "steps": [
      {
        "id": "step-clear-error",
        "type": "changeVariableValue",
        "config": {
          "variableName": "adm1n2l3-4567-89ab-cdef-012345678901",
          "value": ""
        }
      },
      {
        "id": "step-login",
        "action": "admin-login-fetch"
      },
      {
        "id": "step-branch",
        "type": "branch",
        "config": {
          "condition": "!!context.workflow['step-login'].result?.token"
        },
        "trueBranch": [
          {
            "id": "step-authenticate",
            "type": "authenticate",
            "config": {
              "accessToken": {
                "formula": "context?.workflow?.['step-login']?.result?.token"
              },
              "persist": true
            }
          },
          {
            "id": "step-fetch-user",
            "action": "8a9b0c1d-e2f3-4567-89ab-cdef01234567"
          },
          {
            "id": "step-set-user",
            "type": "setUser",
            "config": {
              "user": {
                "formula": "context?.workflow?.['step-fetch-user']?.result?.activeCustomer"
              }
            }
          },
          {
            "id": "step-nav-admin",
            "type": "navigateTo",
            "config": {
              "path": "/admin",
              "linkType": "internal"
            }
          }
        ],
        "falseBranch": [
          {
            "id": "step-set-error",
            "type": "changeVariableValue",
            "config": {
              "variableName": "adm1n2l3-4567-89ab-cdef-012345678901",
              "value": {
                "formula": "context?.workflow?.['step-login']?.result?.error || 'Login failed. Please check your credentials.'"
              }
            }
          }
        ]
      }
    ]
  },
  "admin-logout": {
