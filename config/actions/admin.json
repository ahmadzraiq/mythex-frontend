  "admin-login-fetch": {
    "name": "admin-login-fetch",
    "type": "fetchData",
    "url": "http://localhost:4000/v1/run/cmpfgh9d20003ti913oelf5bs/admin/auth/login",
    "method": "POST",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "email": "{{local.data.form.formData.email}}",
      "password": "{{local.data.form.formData.password}}"
    }
  },
  "admin-submit-login": {
    "name": "admin-submit-login",
    "trigger": "submit",
    "steps": [
      {
        "id": "step-clear-error",
        "type": "changeVariableValue",
        "config": {
          "variableName": "adm1n2l3-4567-89ab-cdef-012345678901",
          "value": ""
        }
      },
      {
        "id": "step-login",
        "type": "fetchData",
        "config": {
          "url": "http://localhost:4000/v1/run/cmpfgh9d20003ti913oelf5bs/admin/auth/login",
          "method": "POST",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "email": "{{local.data.form.formData.email}}",
            "password": "{{local.data.form.formData.password}}"
          }
        }
      },
      {
        "id": "step-branch",
        "type": "branch",
        "config": {
          "condition": "!!context.workflow['step-login'].result?.token"
        },
        "trueBranch": [
          {
            "id": "step-save-token",
            "type": "changeVariableValue",
            "config": {
              "variableName": "auth0001-a5b6-4000-c000-000000000001",
              "value": {
                "js": "context.workflow['step-login'].result.token"
              }
            }
          },
          {
            "type": "fetchData",
            "config": {
              "url": "http://localhost:4000/v1/run/cmpfgh9d20003ti913oelf5bs/auth/me",
              "method": "GET",
              "headers": {
                "Authorization": {
                  "js": "'Bearer ' + context.workflow['step-login'].result.token"
                }
              }
            },
            "id": "step-fetch-user"
          },
          {
            "id": "step-save-user",
            "type": "changeVariableValue",
            "config": {
              "variableName": "auth0002-a5b6-4000-c000-000000000002",
              "value": {
                "js": "context.workflow['step-fetch-user'].result?.activeCustomer ?? null"
              }
            }
          },
          {
            "id": "step-nav-admin",
            "type": "navigateTo",
            "config": {
              "path": "/admin",
              "linkType": "internal"
            }
          }
        ],
        "falseBranch": [
          {
            "id": "step-set-error",
            "type": "changeVariableValue",
            "config": {
              "variableName": "adm1n2l3-4567-89ab-cdef-012345678901",
              "value": {
                "formula": "context?.workflow?.['step-login']?.result?.error || 'Login failed. Please check your credentials.'"
              }
            }
          }
        ]
      }
    ]
