{
  "_comment": "Example trigger workflows. Each key is a named workflow; 'trigger' sets when it fires.",

  "onAppLoadBefore": {
    "trigger": "appLoadBefore",
    "steps": [
      {
        "id": "s1",
        "type": "changeVariableValue",
        "config": {
          "variableName": "00000001-0000-0000-0000-000000000001",
          "value": "initializing"
        }
      }
    ]
  },

  "onAppLoad": {
    "trigger": "appLoad",
    "steps": [
      {
        "id": "s1",
        "type": "fetchCollectionsParallel",
        "config": {
          "collectionIds": []
        }
      }
    ]
  },

  "onPageLoadBefore": {
    "trigger": "pageLoadBefore",
    "steps": [
      {
        "id": "s1",
        "type": "changeVariableValue",
        "config": {
          "variableName": "00000001-0000-0000-0000-000000000002",
          "value": ""
        }
      }
    ]
  },

  "onPageLoad": {
    "trigger": "pageLoad",
    "steps": [
      {
        "id": "s1",
        "type": "fetchCollection",
        "config": {
          "collectionId": "00000000-0000-0000-0000-000000000000"
        }
      }
    ]
  },

  "onPageUnload": {
    "trigger": "pageUnload",
    "steps": [
      {
        "id": "s1",
        "type": "changeVariableValue",
        "config": {
          "variableName": "00000001-0000-0000-0000-000000000003",
          "value": false
        }
      }
    ]
  },

  "onPageScroll": {
    "trigger": "scroll",
    "steps": [
      {
        "id": "s1",
        "type": "changeVariableValue",
        "config": {
          "variableName": "00000001-0000-0000-0000-000000000004",
          "value": { "formula": "globalContext?.browser?.scroll?.y ?? 0" }
        }
      }
    ]
  },

  "onPageResize": {
    "trigger": "resize",
    "steps": [
      {
        "id": "s1",
        "type": "changeVariableValue",
        "config": {
          "variableName": "00000001-0000-0000-0000-000000000005",
          "value": { "formula": "globalContext?.browser?.viewport?.width ?? 0" }
        }
      }
    ]
  },

  "onKeydown": {
    "trigger": "keydown",
    "steps": [
      {
        "id": "s1",
        "type": "branch",
        "config": {
          "condition": "variables?.['00000001-0000-0000-0000-000000000006'] === 'Escape'"
        },
        "trueBranch": [
          {
            "id": "s1-true-1",
            "type": "changeVariableValue",
            "config": {
              "variableName": "00000001-0000-0000-0000-000000000007",
              "value": false
            }
          }
        ],
        "falseBranch": []
      }
    ]
  },

  "onKeyup": {
    "trigger": "keyup",
    "steps": [
      {
        "id": "s1",
        "type": "changeVariableValue",
        "config": {
          "variableName": "00000001-0000-0000-0000-000000000008",
          "value": { "formula": "Date.now()" }
        }
      }
    ]
  },

  "onCollectionFetchError": {
    "trigger": "collectionFetchError",
    "steps": [
      {
        "id": "s1",
        "type": "changeVariableValue",
        "config": {
          "variableName": "00000001-0000-0000-0000-000000000009",
          "value": { "formula": "variables?.['_workflow']?.lastError ?? 'Unknown error'" }
        }
      }
    ]
  }
}
