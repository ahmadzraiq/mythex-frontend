{
  "counterIncrement": {
    "name": "Counter Increment",
    "trigger": "click",
    "steps": [
      {
        "id": "s1",
        "type": "changeVariableValue",
        "config": {
          "variableName": "c71a0001-0000-0000-0000-000000000001",
          "value": {
            "formula": "Number(variables['c71a0001-0000-0000-0000-000000000001']) + 1"
          }
        }
      }
    ]
  },
  "counterDecrement": {
    "name": "Counter Decrement",
    "trigger": "click",
    "steps": [
      {
        "id": "s1",
        "type": "changeVariableValue",
        "config": {
          "variableName": "c71a0001-0000-0000-0000-000000000001",
          "value": {
            "formula": "max(0, Number(variables['c71a0001-0000-0000-0000-000000000001']) - 1)"
          }
        }
      }
    ]
  },
