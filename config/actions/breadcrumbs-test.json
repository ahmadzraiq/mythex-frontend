{
  "wfOnBreadcrumbItemClick": {
    "name": "On Breadcrumb item click",
    "trigger": "bc-t-on-item-click",
    "steps": [
      {
        "id": "store-label",
        "type": "changeVariableValue",
        "config": {
          "variableName": "breadcrumbs-test-label",
          "value": { "formula": "context?.event?.label || ''" }
        }
      }
    ]
  }
}
