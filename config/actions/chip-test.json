{
  "wfOnChipClick": {
    "name": "On Chip click",
    "trigger": "chip-t-on-click",
    "steps": [
      {
        "id": "incr-clicks",
        "type": "changeVariableValue",
        "config": {
          "variableName": "chip-test-clicks",
          "value": { "formula": "(Number(variables['chip-test-clicks']) || 0) + 1" }
        }
      }
    ]
  },
  "wfOnChipRemove": {
    "name": "On Chip remove",
    "trigger": "chip-t-on-remove",
    "steps": [
      {
        "id": "incr-removes",
        "type": "changeVariableValue",
        "config": {
          "variableName": "chip-test-removes",
          "value": { "formula": "(Number(variables['chip-test-removes']) || 0) + 1" }
        }
      }
    ]
  }
}
