  "c5c43e71-0991-4923-abad-7755eb230f6b": {
    "name": "addToCart",
    "type": "fetch",
    "url": "http://localhost:4000/v1/run/cmpfgh9d20003ti913oelf5bs/cart/add",
    "method": "POST",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer {{auth.token}}",
      "X-Guest-ID": {
        "formula": "(typeof window !== 'undefined' ? (localStorage.getItem('_gid') || (localStorage.setItem('_gid', 'g-' + Math.random().toString(36).slice(2)), localStorage.getItem('_gid'))) : '')"
      }
    },
    "body": {
      "variant_id": {
        "formula": "getKeyValue(findItemById(collections['b2c3d4e5-f6a7-8901-bcde-f12345678901']?.product?.variants, findItemByOptionsMatch(collections['b2c3d4e5-f6a7-8901-bcde-f12345678901']?.product?.variants, collections['b2c3d4e5-f6a7-8901-bcde-f12345678901']?.product?.optionGroups, variables['c4d5e6f7-a8b9-0123-cdef-234567890123'])), 'id')"
      },
      "quantity": 1
    },
    "invalidateCache": [
      "cart"
    ]
  },
