{
  "addToCart": {
    "type": "graphql",
    "query": "mutation AddToCart($variantId: ID!, $quantity: Int!) { addItemToOrder(productVariantId: $variantId, quantity: $quantity) { __typename ... on Order { id totalQuantity } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "variantId": {
        "expr": "getKeyValue(findItemById({{collections.b2c3d4e5-f6a7-8901-bcde-f12345678901.data.product.variants}}, findItemByOptionsMatch({{collections.b2c3d4e5-f6a7-8901-bcde-f12345678901.data.product.variants}}, {{collections.b2c3d4e5-f6a7-8901-bcde-f12345678901.data.product.optionGroups}}, {{variables['c4d5e6f7-a8b9-0123-cdef-234567890123']}})), 'id')"
      },
      "quantity": 1
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "onSuccess": {
      "type": "runMultiple",
      "actions": [
        { "action": "fetchCart" },
        { "action": "showToast", "payload": { "message": "Added to cart" } }
      ]
    },
    "invalidateCache": ["cart"],
    "endpoint": "http://localhost:3000/shop-api"
  },
  "addToCartFromCard": {
    "type": "graphql",
    "query": "mutation AddToCart($variantId: ID!, $quantity: Int!) { addItemToOrder(productVariantId: $variantId, quantity: $quantity) { __typename ... on Order { id totalQuantity } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "variantId": "{{context.item.variantId}}",
      "quantity": 1
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "onSuccess": { "action": "fetchCart" },
    "invalidateCache": ["cart"],
    "endpoint": "http://localhost:3000/shop-api"
  },
  "removeFromCart": {
    "type": "graphql",
    "query": "mutation RemoveFromCart($lineId: ID!) { removeOrderLine(orderLineId: $lineId) { __typename ... on Order { id totalQuantity } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "lineId": "{{context.item.id}}"
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "onSuccess": { "action": "fetchCart" },
    "invalidateCache": ["cart"],
    "endpoint": "http://localhost:3000/shop-api"
  },
  "adjustCartItemQuantity": {
    "type": "graphql",
    "query": "mutation AdjustCartItem($lineId: ID!, $quantity: Int!) { adjustOrderLine(orderLineId: $lineId, quantity: $quantity) { __typename ... on Order { id totalQuantity } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "lineId": "{{context.item.id}}",
      "quantity": "{{context.item.quantity}}"
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "onSuccess": { "action": "fetchCart" },
    "invalidateCache": ["cart"],
    "endpoint": "http://localhost:3000/shop-api"
  },
  "applyPromotionCode": {
    "type": "graphql",
    "query": "mutation ApplyPromotionCode($couponCode: String!) { applyCouponCode(couponCode: $couponCode) { __typename ... on Order { id code totalWithTax couponCodes discounts { description amountWithTax } } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "couponCode": "{{variables['c0d1e2f3-a4b5-6789-cdef-789012345678'].value.couponCode}}"
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "storeIn": "cart._promoResult",
    "responsePath": "data.applyCouponCode",
    "onSuccess": {
      "type": "runMultiple",
      "actions": [
        {
          "action": "fetchCart"
        },
        {
          "type": "resetForm",
          "formId": "c0d1e2f3-a4b5-6789-cdef-789012345678"
        }
      ]
    },
    "invalidateCache": [
      "cart"
    ],
    "endpoint": "http://localhost:3000/shop-api"
  },
  "removePromotionCode": {
    "type": "graphql",
    "query": "mutation RemovePromotionCode($couponCode: String!) { removeCouponCode(couponCode: $couponCode) { id code totalWithTax couponCodes discounts { description amountWithTax } } }",
    "variables": {
      "couponCode": "{{$item}}"
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "storeIn": "cart._removePromoResult",
    "responsePath": "data.removeCouponCode",
    "onSuccess": {
      "action": "fetchCart"
    },
    "invalidateCache": [
      "cart"
    ],
    "endpoint": "http://localhost:3000/shop-api"
  },
  "openCartDrawer": {
    "type": "set",
    "path": "layout.cartDrawerOpen",
    "value": true
  },
  "closeCartDrawer": {
    "type": "set",
    "path": "layout.cartDrawerOpen",
    "value": false
  }
}
