  "wfComplexAll": {
    "type": "workflowSteps",
    "trigger": "click",
    "steps": [
      {
        "id": "reset-grade",
        "type": "changeVariableValue",
        "config": {
          "variableName": "d1e2f3a4-b5c6-7890-defa-111111111105",
          "value": "(evaluating…)"
        }
      },
      {
        "id": "reset-loopCount",
        "type": "changeVariableValue",
        "config": {
          "variableName": "d1e2f3a4-b5c6-7890-defa-111111111106",
          "value": 0
        }
      },
      {
        "id": "reset-retryCount",
        "type": "changeVariableValue",
        "config": {
          "variableName": "d1e2f3a4-b5c6-7890-defa-111111111107",
          "value": 0
        }
      },
      {
        "id": "reset-whileActive",
        "type": "changeVariableValue",
        "config": {
          "variableName": "d1e2f3a4-b5c6-7890-defa-111111111108",
          "value": true
        }
      },
      {
        "id": "reset-items",
        "type": "changeVariableValue",
        "config": {
          "variableName": "d1e2f3a4-b5c6-7890-defa-111111111109",
          "value": [
            "item-A",
            "item-B",
            "item-C"
          ]
        }
      },
      {
        "id": "reset-done",
        "type": "changeVariableValue",
        "config": {
          "variableName": "d1e2f3a4-b5c6-7890-defa-111111111110",
          "value": "(running pipeline…)"
        }
      },
      {
        "id": "delay-300",
        "type": "timeDelay",
        "config": {
          "time": 300
        }
      },
      {
        "id": "branch-outer",
        "type": "branch",
        "config": {
          "condition": "variables['d1e2f3a4-b5c6-7890-defa-111111111102'] >= 60"
        },
        "trueBranch": [
          {
            "id": "grade-pass-base",
            "type": "changeVariableValue",
            "config": {
              "variableName": "d1e2f3a4-b5c6-7890-defa-111111111105",
              "value": "PASS"
            }
          },
          {
            "id": "branch-inner-high",
            "type": "branch",
            "config": {
              "condition": "variables['d1e2f3a4-b5c6-7890-defa-111111111102'] >= 90"
            },
            "trueBranch": [
              {
                "id": "grade-excellent",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "d1e2f3a4-b5c6-7890-defa-111111111105",
                  "value": "EXCELLENT (≥ 90)"
                }
              }
            ],
            "falseBranch": [
              {
                "id": "grade-good",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "d1e2f3a4-b5c6-7890-defa-111111111105",
                  "value": "GOOD (60 – 89)"
                }
              }
            ]
          }
        ],
        "falseBranch": [
          {
            "id": "branch-inner-low",
            "type": "branch",
            "config": {
              "condition": "variables['d1e2f3a4-b5c6-7890-defa-111111111102'] >= 30"
            },
            "trueBranch": [
              {
                "id": "grade-poor",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "d1e2f3a4-b5c6-7890-defa-111111111105",
                  "value": "POOR (30 – 59)"
                }
              }
            ],
            "falseBranch": [
              {
                "id": "grade-fail",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "d1e2f3a4-b5c6-7890-defa-111111111105",
                  "value": "FAIL (< 30)"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "foreach-items",
        "type": "forEach",
        "config": {
          "itemsPath": "d1e2f3a4-b5c6-7890-defa-111111111109"
        },
        "loopBody": [
          {
            "id": "foreach-incr",
            "type": "changeVariableValue",
            "config": {
              "variableName": "d1e2f3a4-b5c6-7890-defa-111111111106",
              "value": {
                "formula": "variables['d1e2f3a4-b5c6-7890-defa-111111111106'] + 1"
              }
            }
          }
        ]
      },
      {
        "id": "while-retry",
        "type": "whileLoop",
        "config": {
          "conditionPath": "d1e2f3a4-b5c6-7890-defa-111111111108"
        },
        "loopBody": [
          {
            "id": "while-incr",
            "type": "changeVariableValue",
            "config": {
              "variableName": "d1e2f3a4-b5c6-7890-defa-111111111107",
              "value": {
                "formula": "variables['d1e2f3a4-b5c6-7890-defa-111111111107'] + 1"
              }
            }
          },
          {
            "id": "while-stop-check",
            "type": "branch",
            "config": {
              "condition": "variables['d1e2f3a4-b5c6-7890-defa-111111111107'] >= 3"
            },
            "trueBranch": [
              {
                "id": "while-stop",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "d1e2f3a4-b5c6-7890-defa-111111111108",
                  "value": false
                }
              }
            ],
            "falseBranch": []
          }
        ]
      },
      {
        "id": "final-done",
        "type": "changeVariableValue",
        "config": {
          "variableName": "d1e2f3a4-b5c6-7890-defa-111111111110",
          "value": "✓ Pipeline complete!"
        }
      }
    ]
  },

