  "waFormSubmit": {
    "type": "workflowSteps",
    "trigger": "submit",
    "steps": [
      {
        "id": "s1",
        "type": "setFormState",
        "config": { "isSubmitting": true }
      },
      {
        "id": "s1b",
        "type": "timeDelay",
        "config": { "delay": 800 }
      },
      {
        "id": "s2",
        "type": "changeVariableValue",
        "config": {
          "variableName": "wa000001-0000-0000-0000-000000000009",
          "value": {
            "formula": "'submitted: ' + (local?.data?.form?.formData?.['wa-email'] || '(empty)') + (local?.data?.form?.formData?.['wa-name'] ? ' / ' + local?.data?.form?.formData?.['wa-name'] : '')"
          }
        }
      },
      {
        "id": "s3",
        "type": "changeVariableValue",
        "config": {
          "variableName": "wa000001-0000-0000-0000-000000000010",
          "value": ""
        }
      },
      {
        "id": "s4",
        "type": "setFormState",
        "config": { "isSubmitting": false, "isSubmitted": true }
      }
    ]
  },
