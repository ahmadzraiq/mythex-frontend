{
  "calcButtonPress": {
    "name": "Calculator Button Press",
    "trigger": "click",
    "steps": [
      {
        "id": "s1",
        "name": "Branch on button type",
        "type": "multiOptionBranch",
        "config": {
          "condition": "context?.item?.data?.type"
        },
        "branches": [
          {
            "label": "digit",
            "steps": [
              {
                "id": "dig-1",
                "name": "Append digit to display",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "ca1c0001-0000-0000-0000-000000000001",
                  "value": {
                    "formula": "variables['ca1c0004-0000-0000-0000-000000000004'] ? String(context?.item?.data?.label) : (String(variables['ca1c0001-0000-0000-0000-000000000001']) === '0' ? String(context?.item?.data?.label) : String(variables['ca1c0001-0000-0000-0000-000000000001']) + String(context?.item?.data?.label))"
                  }
                }
              },
              {
                "id": "dig-2",
                "name": "Clear new-input flag",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "ca1c0004-0000-0000-0000-000000000004",
                  "value": false
                }
              }
            ]
          },
          {
            "label": "operator",
            "steps": [
              {
                "id": "op-1",
                "name": "Chain: compute if pending op and new digits entered",
                "type": "branch",
                "config": {
                  "condition": "variables['ca1c0003-0000-0000-0000-000000000003'] !== '' && !variables['ca1c0004-0000-0000-0000-000000000004']"
                },
                "trueBranch": [
                  {
                    "id": "op-1t1",
                    "name": "Compute intermediate result",
                    "type": "changeVariableValue",
                    "config": {
                      "variableName": "ca1c0001-0000-0000-0000-000000000001",
                      "value": {
                        "formula": "String(parseFloat((variables['ca1c0003-0000-0000-0000-000000000003'] === '+' ? Number(variables['ca1c0002-0000-0000-0000-000000000002']) + Number(variables['ca1c0001-0000-0000-0000-000000000001']) : variables['ca1c0003-0000-0000-0000-000000000003'] === '-' ? Number(variables['ca1c0002-0000-0000-0000-000000000002']) - Number(variables['ca1c0001-0000-0000-0000-000000000001']) : variables['ca1c0003-0000-0000-0000-000000000003'] === '*' ? Number(variables['ca1c0002-0000-0000-0000-000000000002']) * Number(variables['ca1c0001-0000-0000-0000-000000000001']) : variables['ca1c0003-0000-0000-0000-000000000003'] === '/' && Number(variables['ca1c0001-0000-0000-0000-000000000001']) !== 0 ? Number(variables['ca1c0002-0000-0000-0000-000000000002']) / Number(variables['ca1c0001-0000-0000-0000-000000000001']) : Number(variables['ca1c0001-0000-0000-0000-000000000001'])).toPrecision(10)))"
                      }
                    }
                  },
                  {
                    "id": "op-1t2",
                    "name": "Store result as previous",
                    "type": "changeVariableValue",
                    "config": {
                      "variableName": "ca1c0002-0000-0000-0000-000000000002",
                      "value": {
                        "formula": "variables['ca1c0001-0000-0000-0000-000000000001']"
                      }
                    }
                  }
                ],
                "falseBranch": [
                  {
                    "id": "op-1f1",
                    "name": "Store display as previous",
                    "type": "changeVariableValue",
                    "config": {
                      "variableName": "ca1c0002-0000-0000-0000-000000000002",
                      "value": {
                        "formula": "variables['ca1c0001-0000-0000-0000-000000000001']"
                      }
                    }
                  }
                ]
              },
              {
                "id": "op-2",
                "name": "Store operator",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "ca1c0003-0000-0000-0000-000000000003",
                  "value": {
                    "formula": "context?.item?.data?.op"
                  }
                }
              },
              {
                "id": "op-3",
                "name": "Flag new input",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "ca1c0004-0000-0000-0000-000000000004",
                  "value": true
                }
              }
            ]
          },
          {
            "label": "equals",
            "steps": [
              {
                "id": "eq-1",
                "name": "Compute if operator is set",
                "type": "branch",
                "config": {
                  "condition": "variables['ca1c0003-0000-0000-0000-000000000003'] !== '' && variables['ca1c0002-0000-0000-0000-000000000002'] !== ''"
                },
                "trueBranch": [
                  {
                    "id": "eq-1t1",
                    "name": "Compute final result",
                    "type": "changeVariableValue",
                    "config": {
                      "variableName": "ca1c0001-0000-0000-0000-000000000001",
                      "value": {
                        "formula": "String(parseFloat((variables['ca1c0003-0000-0000-0000-000000000003'] === '+' ? Number(variables['ca1c0002-0000-0000-0000-000000000002']) + Number(variables['ca1c0001-0000-0000-0000-000000000001']) : variables['ca1c0003-0000-0000-0000-000000000003'] === '-' ? Number(variables['ca1c0002-0000-0000-0000-000000000002']) - Number(variables['ca1c0001-0000-0000-0000-000000000001']) : variables['ca1c0003-0000-0000-0000-000000000003'] === '*' ? Number(variables['ca1c0002-0000-0000-0000-000000000002']) * Number(variables['ca1c0001-0000-0000-0000-000000000001']) : variables['ca1c0003-0000-0000-0000-000000000003'] === '/' && Number(variables['ca1c0001-0000-0000-0000-000000000001']) !== 0 ? Number(variables['ca1c0002-0000-0000-0000-000000000002']) / Number(variables['ca1c0001-0000-0000-0000-000000000001']) : Number(variables['ca1c0001-0000-0000-0000-000000000001'])).toPrecision(10)))"
                      }
                    }
                  }
                ],
                "falseBranch": []
              },
              {
                "id": "eq-2",
                "name": "Clear previous",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "ca1c0002-0000-0000-0000-000000000002",
                  "value": ""
                }
              },
              {
                "id": "eq-3",
                "name": "Clear operator",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "ca1c0003-0000-0000-0000-000000000003",
                  "value": ""
                }
              },
              {
                "id": "eq-4",
                "name": "Flag new input",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "ca1c0004-0000-0000-0000-000000000004",
                  "value": true
                }
              }
            ]
          },
          {
            "label": "clear",
            "steps": [
              {
                "id": "clr-1",
                "name": "Reset display",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "ca1c0001-0000-0000-0000-000000000001",
                  "value": "0"
                }
              },
              {
                "id": "clr-2",
                "name": "Reset previous",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "ca1c0002-0000-0000-0000-000000000002",
                  "value": ""
                }
              },
              {
                "id": "clr-3",
                "name": "Reset operator",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "ca1c0003-0000-0000-0000-000000000003",
                  "value": ""
                }
              },
              {
                "id": "clr-4",
                "name": "Reset new input flag",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "ca1c0004-0000-0000-0000-000000000004",
                  "value": true
                }
              }
            ]
          },
          {
            "label": "decimal",
            "steps": [
              {
                "id": "dec-1",
                "name": "Append decimal point",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "ca1c0001-0000-0000-0000-000000000001",
                  "value": {
                    "formula": "variables['ca1c0004-0000-0000-0000-000000000004'] ? '0.' : (String(variables['ca1c0001-0000-0000-0000-000000000001']).indexOf('.') === -1 ? String(variables['ca1c0001-0000-0000-0000-000000000001']) + '.' : String(variables['ca1c0001-0000-0000-0000-000000000001']))"
                  }
                }
              },
              {
                "id": "dec-2",
                "name": "Clear new-input flag",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "ca1c0004-0000-0000-0000-000000000004",
                  "value": false
                }
              }
            ]
          },
          {
            "label": "percent",
            "steps": [
              {
                "id": "pct-1",
                "name": "Divide by 100",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "ca1c0001-0000-0000-0000-000000000001",
                  "value": {
                    "formula": "String(Number(variables['ca1c0001-0000-0000-0000-000000000001']) / 100)"
                  }
                }
              },
              {
                "id": "pct-2",
                "name": "Flag new input",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "ca1c0004-0000-0000-0000-000000000004",
                  "value": true
                }
              }
            ]
          },
          {
            "label": "negate",
            "steps": [
              {
                "id": "neg-1",
                "name": "Negate value",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "ca1c0001-0000-0000-0000-000000000001",
                  "value": {
                    "formula": "String(Number(variables['ca1c0001-0000-0000-0000-000000000001']) * -1)"
                  }
                }
              }
            ]
          },
          {
            "label": "backspace",
            "steps": [
              {
                "id": "bs-1",
                "name": "Remove last character",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "ca1c0001-0000-0000-0000-000000000001",
                  "value": {
                    "formula": "String(variables['ca1c0001-0000-0000-0000-000000000001']).length > 1 ? String(variables['ca1c0001-0000-0000-0000-000000000001']).slice(0, -1) : '0'"
                  }
                }
              }
            ]
          }
        ],
        "defaultBranch": []
      }
    ]
  }
}
