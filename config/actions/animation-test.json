{
  "animHide": {
    "trigger": "click",
    "steps": [
      { "id": "s1", "type": "changeVariableValue", "config": { "variableName": "anim-0000-0000-0000-000000000001", "value": false } }
    ]
  },
  "animShow": {
    "trigger": "click",
    "steps": [
      { "id": "s1", "type": "changeVariableValue", "config": { "variableName": "anim-0000-0000-0000-000000000001", "value": true } }
    ]
  },
  "animLayoutAdd": {
    "trigger": "click",
    "steps": [
      {
        "id": "s1",
        "type": "changeVariableValue",
        "config": {
          "variableName": "anim-0000-0000-0000-000000000002",
          "value": {
            "formula": "(variables?.['anim-0000-0000-0000-000000000002'] || []).concat([{ id: 'li-' + Date.now(), label: 'Item ' + ((variables?.['anim-0000-0000-0000-000000000002'] || []).length + 1) }])"
          }
        }
      }
    ]
  },
  "animLayoutRemove": {
    "trigger": "click",
    "steps": [
      {
        "id": "s1",
        "type": "changeVariableValue",
        "config": {
          "variableName": "anim-0000-0000-0000-000000000002",
          "value": {
            "formula": "slice(variables?.['anim-0000-0000-0000-000000000002'] || [], 0, -1)"
          }
        }
      }
    ]
  },
  "animTriggerShake": {
    "trigger": "click",
    "steps": [
      {
        "id": "s1",
        "type": "changeVariableValue",
        "config": { "variableName": "anim-0000-0000-0000-000000000004", "value": { "formula": "Date.now()" } }
      }
    ]
  },
  "cycleP11State": {
    "trigger": "click",
    "steps": [
      {
        "id": "s1",
        "type": "changeVariableValue",
        "config": {
          "variableName": "anim-0000-0000-0000-00000000p011",
          "value": {
            "formula": "variables?.['anim-0000-0000-0000-00000000p011'] === 'idle' ? 'loading' : variables?.['anim-0000-0000-0000-00000000p011'] === 'loading' ? 'success' : variables?.['anim-0000-0000-0000-00000000p011'] === 'success' ? 'error' : 'idle'"
          }
        }
      }
    ]
  },
  "carouselNext": {
    "trigger": "click",
    "steps": [
      {
        "id": "s1",
        "type": "changeVariableValue",
        "config": {
          "variableName": "anim-0000-0000-0000-00000000p017",
          "value": {
            "formula": "((variables?.['anim-0000-0000-0000-00000000p017'] ?? 0) + 1) % 4"
          }
        }
      }
    ]
  },
  "carouselPrev": {
    "trigger": "click",
    "steps": [
      {
        "id": "s1",
        "type": "changeVariableValue",
        "config": {
          "variableName": "anim-0000-0000-0000-00000000p017",
          "value": {
            "formula": "((variables?.['anim-0000-0000-0000-00000000p017'] ?? 0) + 3) % 4"
          }
        }
      }
    ]
  }
}
