  "1f273bc6-2270-47f2-84ba-8ce62eb8b06c": {
    "name": "addPaymentToOrder",
    "type": "graphql",
    "query": "mutation AddPaymentToOrder($input: PaymentInput!) { addPaymentToOrder(input: $input) { __typename ... on Order { id code state payments { id method amount state } } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "input": {
        "method": "{{variables['b3c4d5e6-f7a8-9012-bcde-123456789012']}}",
