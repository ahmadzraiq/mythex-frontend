{
  "setShippingAddress": {
    "type": "validate",
    "formId": "d1e2f3a4-b5c6-7890-defa-890123456789",
    "onSuccess": {
      "action": "setShippingAddressMutation"
    }
  },
  "setShippingAddressMutation": {
    "type": "graphql",
    "query": "mutation SetOrderShippingAddress($input: CreateAddressInput!) { setOrderShippingAddress(input: $input) { __typename ... on Order { id code shippingAddress { fullName streetLine1 city postalCode country } } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "input": {
        "fullName": "{{variables['d1e2f3a4-b5c6-7890-defa-890123456789'].value.fullName}}",
        "company": "{{variables['d1e2f3a4-b5c6-7890-defa-890123456789'].value.company}}",
        "streetLine1": "{{variables['d1e2f3a4-b5c6-7890-defa-890123456789'].value.streetLine1}}",
        "streetLine2": "{{variables['d1e2f3a4-b5c6-7890-defa-890123456789'].value.streetLine2}}",
        "city": "{{variables['d1e2f3a4-b5c6-7890-defa-890123456789'].value.city}}",
        "province": "{{variables['d1e2f3a4-b5c6-7890-defa-890123456789'].value.province}}",
        "postalCode": "{{variables['d1e2f3a4-b5c6-7890-defa-890123456789'].value.postalCode}}",
        "countryCode": "{{variables['d1e2f3a4-b5c6-7890-defa-890123456789'].value.countryCode}}",
        "phoneNumber": "{{variables['d1e2f3a4-b5c6-7890-defa-890123456789'].value.phoneNumber}}"
      }
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "storeIn": "checkout._shippingAddressResult",
    "responsePath": "data.setOrderShippingAddress",
    "onSuccess": {
      "type": "runMultiple",
      "actions": [
        {
          "action": "fetchShippingMethods"
        },
        {
          "action": "syncCheckoutStep"
        }
      ]
    },
    "endpoint": "http://localhost:3000/shop-api"
  },
  "setShippingMethod": {
    "type": "validate",
    "rules": {
      "variables.a2b3c4d5-e6f7-8901-abcd-012345678901": {
        "required": true,
        "message": "Please select a shipping method"
      }
    },
    "storeErrorsIn": "errors",
    "onSuccess": {
      "action": "setShippingMethodMutation"
    }
  },
  "addPaymentToOrder": {
    "type": "graphql",
    "query": "mutation AddPaymentToOrder($input: PaymentInput!) { addPaymentToOrder(input: $input) { __typename ... on Order { id code state payments { id method amount state } } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "input": {
        "method": "{{variables['b3c4d5e6-f7a8-9012-bcde-123456789012']}}",
        "metadata": {
          "shouldDecline": false,
          "shouldError": false,
          "shouldErrorOnSettle": false
        }
      }
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "storeIn": "checkout.completedOrder",
    "responsePath": "data.addPaymentToOrder",
    "onSuccess": {
      "action": "navigate",
      "payload": {
        "path": "/checkout/confirmation",
        "query": {
          "code": "{{checkout.completedOrder.code}}"
        }
      }
    },
    "endpoint": "http://localhost:3000/shop-api"
  },
  "transitionToArrangingPayment": {
    "type": "graphql",
    "query": "mutation TransitionOrderToState($state: String!) { transitionOrderToState(state: $state) { __typename ... on Order { id code state } ... on OrderStateTransitionError { errorCode message transitionError fromState toState } } }",
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "storeIn": "checkout._transitionResult",
    "responsePath": "data.transitionOrderToState",
    "onSuccess": {
      "type": "runMultiple",
      "actions": [
        {
          "action": "fetchPaymentMethods"
        },
        {
          "type": "setVar",
          "path": "d9e0f1a2-b3c4-5678-defa-789012345678",
          "value": "payment"
        }
      ]
    },
    "endpoint": "http://localhost:3000/shop-api",
    "variables": {
      "state": "ArrangingPayment"
    }
  },
  "goToShipping": {
    "type": "setVar",
    "path": "d9e0f1a2-b3c4-5678-defa-789012345678",
    "value": "shipping"
  },
  "goToDelivery": {
    "type": "runMultiple",
    "condition": "({{collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.shippingLines.length}} || 0) > 0",
    "actions": [
      {
        "type": "setVar",
        "path": "d9e0f1a2-b3c4-5678-defa-789012345678",
        "value": "delivery"
      }
    ]
  },
  "goToPayment": {
    "action": "transitionToArrangingPayment"
  },
  "goToReview": {
    "type": "setVar",
    "path": "d9e0f1a2-b3c4-5678-defa-789012345678",
    "value": "review"
  },
  "placeOrder": {
    "type": "validate",
    "rules": {
      "variables.b3c4d5e6-f7a8-9012-bcde-123456789012": {
        "required": true,
        "message": "Please select a payment method"
      }
    },
    "storeErrorsIn": "errors",
    "onSuccess": {
      "action": "transitionToArrangingPayment"
    }
  },
  "setOrderBillingAddressMutation": {
    "type": "graphql",
    "endpoint": "http://localhost:3000/shop-api",
    "query": "mutation SetOrderBillingAddress($input: CreateAddressInput!) { setOrderBillingAddress(input: $input) { __typename ... on Order { id code billingAddress { fullName streetLine1 city postalCode country } } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "input": {
        "fullName": "{{variables['d1e2f3a4-b5c6-7890-defa-890123456789'].value.fullName}}",
        "company": "{{variables['d1e2f3a4-b5c6-7890-defa-890123456789'].value.company}}",
        "streetLine1": "{{variables['d1e2f3a4-b5c6-7890-defa-890123456789'].value.streetLine1}}",
        "streetLine2": "{{variables['d1e2f3a4-b5c6-7890-defa-890123456789'].value.streetLine2}}",
        "city": "{{variables['d1e2f3a4-b5c6-7890-defa-890123456789'].value.city}}",
        "province": "{{variables['d1e2f3a4-b5c6-7890-defa-890123456789'].value.province}}",
        "postalCode": "{{variables['d1e2f3a4-b5c6-7890-defa-890123456789'].value.postalCode}}",
        "countryCode": "{{variables['d1e2f3a4-b5c6-7890-defa-890123456789'].value.countryCode}}",
        "phoneNumber": "{{variables['d1e2f3a4-b5c6-7890-defa-890123456789'].value.phoneNumber}}"
      }
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "storeIn": "checkout._billingAddressResult",
    "responsePath": "data.setOrderBillingAddress"
  },
  "setShippingMethodMutation": {
    "type": "graphql",
    "endpoint": "http://localhost:3000/shop-api",
    "query": "mutation SetOrderShippingMethod($shippingMethodId: [ID!]!) { setOrderShippingMethod(shippingMethodId: $shippingMethodId) { __typename ... on Order { id code shippingWithTax totalWithTax shippingLines { shippingMethod { id name description } priceWithTax } } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "shippingMethodId": [
        "{{variables['a2b3c4d5-e6f7-8901-abcd-012345678901']}}"
      ]
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "storeIn": "checkout._shippingMethodResult",
    "responsePath": "data.setOrderShippingMethod"
  }
}
