    "rules": {
      "variables.a2b3c4d5-e6f7-8901-abcd-012345678901": {
        "required": true,
        "message": "Please select a shipping method"
      }
    },
    "storeErrorsIn": "errors",
    "onSuccess": {
      "action": "2fbd7cd8-f41d-48c2-b0d2-4ca9ad3ad3af"
    }
  },
  "1f273bc6-2270-47f2-84ba-8ce62eb8b06c": {
    "name": "addPaymentToOrder",
    "type": "graphql",
    "query": "mutation AddPaymentToOrder($input: PaymentInput!) { addPaymentToOrder(input: $input) { __typename ... on Order { id code state payments { id method amount state } } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "input": {
        "method": "{{variables['b3c4d5e6-f7a8-9012-bcde-123456789012']}}",
        "metadata": {
          "shouldDecline": false,
          "shouldError": false,
          "shouldErrorOnSettle": false
        }
      }
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "storeIn": "checkout.completedOrder",
    "responsePath": "data.addPaymentToOrder",
    "onSuccess": {
      "action": "f867ff1e-dc6b-4694-8dca-44d6e1a23756"
    },
    "endpoint": "http://localhost:3000/shop-api"
  },
  "d9ff335b-ba80-420c-9b0f-45ee893498dd": {
    "name": "transitionToArrangingPayment",
    "type": "graphql",
    "query": "mutation TransitionOrderToState($state: String!) { transitionOrderToState(state: $state) { __typename ... on Order { id code state } ... on OrderStateTransitionError { errorCode message transitionError fromState toState } } }",
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "storeIn": "checkout._transitionResult",
    "responsePath": "data.transitionOrderToState",
    "onSuccess": {
      "type": "workflowSteps",
      "steps": [
        {
          "id": "step-1",
          "action": "5b47500d-b49f-45ba-918f-dd51cc221e7b"
        },
        {
          "id": "step-2",
          "type": "changeVariableValue",
          "config": {
            "variableName": "d9e0f1a2-b3c4-5678-defa-789012345678",
            "value": "payment"
          }
        }
      ]
    },
    "endpoint": "http://localhost:3000/shop-api",
    "variables": {
      "state": "ArrangingPayment"
    }
  },
