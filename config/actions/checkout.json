  "d791c0b3-13d3-4ab0-9c06-0c31de94a4bc": {
    "name": "setShippingAddressMutation",
    "type": "graphql",
    "query": "mutation SetOrderShippingAddress($input: CreateAddressInput!) { setOrderShippingAddress(input: $input) { __typename ... on Order { id code shippingAddress { fullName streetLine1 city postalCode country } } ... on ErrorResult { errorCode message } } }",
    "variables": {
      "input": {
        "fullName": "{{local.data.form.formData.fullName}}",
        "company": "{{local.data.form.formData.company}}",
        "streetLine1": "{{local.data.form.formData.streetLine1}}",
        "streetLine2": "{{local.data.form.formData.streetLine2}}",
        "city": "{{local.data.form.formData.city}}",
        "province": "{{local.data.form.formData.province}}",
        "postalCode": "{{local.data.form.formData.postalCode}}",
        "countryCode": "{{local.data.form.formData.countryCode}}",
        "phoneNumber": "{{local.data.form.formData.phoneNumber}}"
      }
    },
    "headers": {
      "Authorization": "{{auth.token}}",
      "vendure-token": "__default_channel__"
    },
    "storeIn": "checkout._shippingAddressResult",
    "responsePath": "data.setOrderShippingAddress",
    "onSuccess": {
      "type": "workflowSteps",
      "steps": [
        {
          "id": "step-1",
          "action": "62c64842-4b76-40b3-87ae-d2f0275cb926"
        },
        {
          "id": "step-2",
          "action": "82e7ed48-3f76-4130-af0d-8ecb1d2ae52a"
        }
      ]
    },
    "endpoint": "http://localhost:3000/shop-api"
  },
  "8d925e49-6061-4cf6-a5d8-6ff3e54a52ce": {
    "name": "setShippingMethod",
