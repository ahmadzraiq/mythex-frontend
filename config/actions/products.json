    "type": "workflowSteps",
    "trigger": "click",
    "steps": [
      {
        "id": "step-1",
        "type": "navigateTo",
        "config": {
          "path": "{{route.path}}",
          "queryParams": {
            "facets": {
              "expr": "toggleInArray(route?.facets || [], context?.item?.data?.facetValue?.id)"
            },
            "page": "1"
          }
        }
      }
    ]
  },
