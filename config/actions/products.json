  "5f0b09fc-9aed-4a27-a60d-d44a3b5a37c9": {
    "name": "collectionPrevPage",
    "type": "workflowSteps",
    "trigger": "click",
    "steps": [
      {
        "id": "step-1",
        "type": "decrement",
        "config": {
          "path": "a6b7c8d9-e0f1-2345-abcd-456789012345",
          "amount": "{{variables['fa000001-0000-0000-0000-000000000001']}}"
        }
      },
      {
        "id": "step-2",
        "action": "e36a0249-ae5c-4482-b7f0-8b481f23605d"
      },
      {
        "id": "step-3",
        "type": "navigateTo",
        "config": {
          "path": {
            "expr": "cat(route?.path, '?page=', max(1, max(1, floor((variables['a6b7c8d9-e0f1-2345-abcd-456789012345'] || 0) / (variables?.['fa000001-0000-0000-0000-000000000001'] || 12) + 1)) - 1))"
          }
        }
      }
    ]
  },
  "184bea54-8bde-4fd0-a4fd-e3f6766d99b8": {
