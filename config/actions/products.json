  "09ddb966-e64d-45b4-af68-b17ff0dfc4bc": {
    "name": "writeReview",
    "type": "appendToPath",
    "targetPath": "product.reviews",
    "value": {
      "id": "_timestamp",
      "author": "{{local.data.form.formData.name}}",
      "rating": "{{local.data.form.formData.rating}}",
      "comment": "{{local.data.form.formData.review}}",
      "date": "_date"
    },
    "resetFormPath": "local.data.form.formData",
    "resetFormValue": {
      "name": "",
      "rating": 5,
      "review": ""
    }
  },
  "10b4a7ed-330e-4827-951f-5a0535458f2e": {
    "name": "clearFacets",
    "type": "workflowSteps",
    "trigger": "click",
    "steps": [
      {
        "id": "step-1",
        "type": "navigateTo",
        "config": {
          "path": "{{route.path}}",
          "queryParams": {
            "facets": [],
            "page": "1"
          }
        }
      }
    ]
  },
  "b7236203-c516-4e10-8ff7-b4afb84ce314": {
