  "dp1ComputeGrid": {
    "trigger": "click",
    "steps": [
      {
        "id": "grid",
        "type": "changeVariableValue",
        "config": {
          "variableName": "dp-test-0000-0000-0000-000000000004",
          "value": { "formula": "Array.from({length:42},(_,i)=>{const yr=variables['dp-test-0000-0000-0000-000000000001'];const mo=variables['dp-test-0000-0000-0000-000000000002'];const fd=new Date(yr,mo,1).getDay();const dim=new Date(yr,mo+1,0).getDate();const dn=i-fd+1;const inM=dn>=1&&dn<=dim;const d=dn<1?new Date(yr,mo,0).getDate()+dn:(dn>dim?dn-dim:dn);const ds=inM?yr+'-'+String(mo+1).padStart(2,'0')+'-'+String(d).padStart(2,'0'):'';return{day:d,inMonth:inM,dateStr:ds,idx:i}})" }
        }
      }
    ]
  },
