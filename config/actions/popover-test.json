        "config": {
          "variableName": "dp-test-0000-0000-0000-000000000002",
          "value": { "formula": "variables['dp-test-0000-0000-0000-000000000002']===0 ? 11 : variables['dp-test-0000-0000-0000-000000000002']-1" }
        }
      },
      {
        "id": "grid",
        "type": "runProjectWorkflow",
        "config": { "workflowId": "dp1ComputeGrid" }
      }
    ]
  },
