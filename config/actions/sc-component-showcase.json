  "kanban-drag-start": {
    "id": "kanban-drag-start",
    "name": "Kanban: Drag start",
    "trigger": "dragStart",
    "steps": [
      {
        "id": "s1",
        "type": "changeVariableValue",
        "config": {
          "variableName": "showcase-kanban-drag",
          "value": {
            "formula": "{ cardId: context?.item?.data?.id, sourceCol: context?.item?.data?.col, targetCol: context?.item?.data?.col, targetIndex: context?.item?.data?.index ?? 0 }"
          }
        }
      }
    ]
  },
  "kanban-drag-update": {
    "id": "kanban-drag-update",
    "name": "Kanban: Drag update",
    "trigger": "dragUpdate",
    "steps": [
      {
        "id": "s1",
        "type": "changeVariableValue",
        "config": {
          "variableName": "showcase-kanban-drag",
          "value": {
            "js": "const cols=['todo','doing','done']; const src=variables['showcase-kanban-drag']?.sourceCol??'todo'; const ci=cols.indexOf(src); const cw=Math.max(event?.containerWidth??200,1); const tx=event?.translationX??0; const ty=event?.translationY??0; const colDelta=Math.round(tx/cw); const ni=Math.max(0,Math.min(2,ci+colDelta)); const targetCol=cols[ni]; const allCards=variables['showcase-kanban-cards']??[]; const srcCards=allCards.filter(c=>c.col===src); const srcIdx=srcCards.findIndex(c=>c.id===variables['showcase-kanban-drag']?.cardId); const slotH=70; let ti; if(targetCol===src){ ti=Math.max(0,Math.min(srcCards.length-1,srcIdx+Math.round(ty/slotH))); } else { const tgtCards=allCards.filter(c=>c.col===targetCol); ti=Math.max(0,Math.min(tgtCards.length,srcIdx+Math.round(ty/slotH))); } return { cardId: variables['showcase-kanban-drag']?.cardId, sourceCol: src, targetCol, targetIndex: ti };"
          }
        }
      }
    ]
  },
  "kanban-drag-end": {
    "id": "kanban-drag-end",
    "name": "Kanban: Drag end",
    "trigger": "dragEnd",
    "steps": [
      {
        "id": "s1",
        "type": "changeVariableValue",
        "config": {
          "variableName": "showcase-kanban-cards",
          "value": {
            "js": "const kd=variables['showcase-kanban-drag']; const cardId=kd?.cardId; const sourceCol=kd?.sourceCol; const targetCol=kd?.targetCol??sourceCol; const targetIndex=kd?.targetIndex??0; const allCards=variables['showcase-kanban-cards']??[]; if(!cardId) return allCards; if(targetCol!==sourceCol){ const without=allCards.filter(c=>c.id!==cardId); const newTgt=without.filter(c=>c.col===targetCol); const updated={...allCards.find(c=>c.id===cardId),col:targetCol}; newTgt.splice(targetIndex,0,updated); return [...without.filter(c=>c.col!==targetCol),...newTgt]; } const colCards=allCards.filter(c=>c.col===sourceCol); const curIdx=colCards.findIndex(c=>c.id===cardId); if(curIdx===targetIndex) return allCards; const reordered=[...colCards]; const [moved]=reordered.splice(curIdx,1); reordered.splice(targetIndex,0,moved); return [...allCards.filter(c=>c.col!==sourceCol),...reordered];"
          }
        }
      },
      {
        "id": "s2",
        "type": "changeVariableValue",
        "config": {
          "variableName": "showcase-kanban-drag",
          "value": {
            "formula": "{ cardId: null, sourceCol: null, targetCol: null }"
          }
        }
      }
    ]
  },
