{
  "calc2ButtonPress": {
    "name": "Calculator 2 — Button Press",
    "trigger": "click",
    "steps": [
      {
        "id": "s1",
        "name": "Dispatch on button type",
        "type": "multiOptionBranch",
        "config": {
          "condition": "context?.item?.data?.type"
        },
        "branches": [
          {
            "label": "number",
            "steps": [
              {
                "id": "num-1",
                "name": "Update display — replace or append",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "9e89c88b-6dd3-4901-a71e-d1ad974a486e",
                  "value": {
                    "formula": "variables['d250e309-af3d-48e2-828e-df062def88bc'] ? String(context?.item?.data?.label) : (String(variables['9e89c88b-6dd3-4901-a71e-d1ad974a486e']) === '0' ? String(context?.item?.data?.label) : String(variables['9e89c88b-6dd3-4901-a71e-d1ad974a486e']) + String(context?.item?.data?.label))"
                  }
                }
              },
              {
                "id": "num-2",
                "name": "Clear replace flag",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "d250e309-af3d-48e2-828e-df062def88bc",
                  "value": false
                }
              }
            ]
          },
          {
            "label": "operator",
            "steps": [
              {
                "id": "op-chain",
                "name": "Chain: compute intermediate result if pending op and new digits entered",
                "type": "branch",
                "config": {
                  "condition": "variables['6734e106-cb9f-4669-a889-b193d7038900'] !== '' && !variables['d250e309-af3d-48e2-828e-df062def88bc']"
                },
                "trueBranch": [
                  {
                    "id": "op-chain-1",
                    "name": "Compute intermediate result",
                    "type": "changeVariableValue",
                    "config": {
                      "variableName": "9e89c88b-6dd3-4901-a71e-d1ad974a486e",
                      "value": {
                        "formula": "String(parseFloat((variables['6734e106-cb9f-4669-a889-b193d7038900'] === '+' ? Number(variables['7ad35376-8982-470b-bdd6-8ae3af7d9bc0']) + Number(variables['9e89c88b-6dd3-4901-a71e-d1ad974a486e']) : variables['6734e106-cb9f-4669-a889-b193d7038900'] === '-' ? Number(variables['7ad35376-8982-470b-bdd6-8ae3af7d9bc0']) - Number(variables['9e89c88b-6dd3-4901-a71e-d1ad974a486e']) : variables['6734e106-cb9f-4669-a889-b193d7038900'] === '*' ? Number(variables['7ad35376-8982-470b-bdd6-8ae3af7d9bc0']) * Number(variables['9e89c88b-6dd3-4901-a71e-d1ad974a486e']) : variables['6734e106-cb9f-4669-a889-b193d7038900'] === '/' && Number(variables['9e89c88b-6dd3-4901-a71e-d1ad974a486e']) !== 0 ? Number(variables['7ad35376-8982-470b-bdd6-8ae3af7d9bc0']) / Number(variables['9e89c88b-6dd3-4901-a71e-d1ad974a486e']) : Number(variables['9e89c88b-6dd3-4901-a71e-d1ad974a486e'])).toPrecision(10)))"
                      }
                    }
                  },
                  {
                    "id": "op-chain-2",
                    "name": "Store result as pending value",
                    "type": "changeVariableValue",
                    "config": {
                      "variableName": "7ad35376-8982-470b-bdd6-8ae3af7d9bc0",
                      "value": {
                        "formula": "variables['9e89c88b-6dd3-4901-a71e-d1ad974a486e']"
                      }
                    }
                  }
                ],
                "falseBranch": [
                  {
                    "id": "op-chain-f1",
                    "name": "Store display as pending value",
                    "type": "changeVariableValue",
                    "config": {
                      "variableName": "7ad35376-8982-470b-bdd6-8ae3af7d9bc0",
                      "value": {
                        "formula": "variables['9e89c88b-6dd3-4901-a71e-d1ad974a486e']"
                      }
                    }
                  }
                ]
              },
              {
                "id": "op-2",
                "name": "Store ASCII operator as pending operation",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "6734e106-cb9f-4669-a889-b193d7038900",
                  "value": {
                    "formula": "context?.item?.data?.op"
                  }
                }
              },
              {
                "id": "op-4",
                "name": "Set replace flag so next digit replaces display",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "d250e309-af3d-48e2-828e-df062def88bc",
                  "value": true
                }
              },
              {
                "id": "op-5",
                "name": "Clear decimal flag",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "c366dc58-3f00-4b0b-92b9-d9df5005d8e0",
                  "value": false
                }
              }
            ]
          },
          {
            "label": "decimal",
            "steps": [
              {
                "id": "dec-branch",
                "name": "Only append decimal if not already present",
                "type": "branch",
                "config": {
                  "condition": "!variables['c366dc58-3f00-4b0b-92b9-d9df5005d8e0']"
                },
                "trueBranch": [
                  {
                    "id": "dec-1",
                    "name": "Append decimal point (or start 0. if replacing)",
                    "type": "changeVariableValue",
                    "config": {
                      "variableName": "9e89c88b-6dd3-4901-a71e-d1ad974a486e",
                      "value": {
                        "formula": "variables['d250e309-af3d-48e2-828e-df062def88bc'] ? '0.' : (String(variables['9e89c88b-6dd3-4901-a71e-d1ad974a486e']) + '.')"
                      }
                    }
                  },
                  {
                    "id": "dec-2",
                    "name": "Set decimal flag",
                    "type": "changeVariableValue",
                    "config": {
                      "variableName": "c366dc58-3f00-4b0b-92b9-d9df5005d8e0",
                      "value": true
                    }
                  },
                  {
                    "id": "dec-3",
                    "name": "Clear replace flag",
                    "type": "changeVariableValue",
                    "config": {
                      "variableName": "d250e309-af3d-48e2-828e-df062def88bc",
                      "value": false
                    }
                  }
                ],
                "falseBranch": []
              }
            ]
          },
          {
            "label": "equals",
            "steps": [
              {
                "id": "eq-1",
                "name": "Compute result if a pending operation exists",
                "type": "branch",
                "config": {
                  "condition": "variables['6734e106-cb9f-4669-a889-b193d7038900'] !== ''"
                },
                "trueBranch": [
                  {
                    "id": "eq-1t1",
                    "name": "Compute: pendingValue op displayValue",
                    "type": "changeVariableValue",
                    "config": {
                      "variableName": "9e89c88b-6dd3-4901-a71e-d1ad974a486e",
                      "value": {
                        "formula": "String(parseFloat((variables['6734e106-cb9f-4669-a889-b193d7038900'] === '+' ? Number(variables['7ad35376-8982-470b-bdd6-8ae3af7d9bc0']) + Number(variables['9e89c88b-6dd3-4901-a71e-d1ad974a486e']) : variables['6734e106-cb9f-4669-a889-b193d7038900'] === '-' ? Number(variables['7ad35376-8982-470b-bdd6-8ae3af7d9bc0']) - Number(variables['9e89c88b-6dd3-4901-a71e-d1ad974a486e']) : variables['6734e106-cb9f-4669-a889-b193d7038900'] === '*' ? Number(variables['7ad35376-8982-470b-bdd6-8ae3af7d9bc0']) * Number(variables['9e89c88b-6dd3-4901-a71e-d1ad974a486e']) : variables['6734e106-cb9f-4669-a889-b193d7038900'] === '/' && Number(variables['9e89c88b-6dd3-4901-a71e-d1ad974a486e']) !== 0 ? Number(variables['7ad35376-8982-470b-bdd6-8ae3af7d9bc0']) / Number(variables['9e89c88b-6dd3-4901-a71e-d1ad974a486e']) : Number(variables['9e89c88b-6dd3-4901-a71e-d1ad974a486e'])).toPrecision(10)))"
                      }
                    }
                  }
                ],
                "falseBranch": []
              },
              {
                "id": "eq-2",
                "name": "Clear pending value",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "7ad35376-8982-470b-bdd6-8ae3af7d9bc0",
                  "value": ""
                }
              },
              {
                "id": "eq-3",
                "name": "Clear pending operation",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "6734e106-cb9f-4669-a889-b193d7038900",
                  "value": ""
                }
              },
              {
                "id": "eq-4",
                "name": "Set replace flag",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "d250e309-af3d-48e2-828e-df062def88bc",
                  "value": true
                }
              },
              {
                "id": "eq-5",
                "name": "Clear decimal flag",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "c366dc58-3f00-4b0b-92b9-d9df5005d8e0",
                  "value": false
                }
              }
            ]
          },
          {
            "label": "clear",
            "steps": [
              {
                "id": "clr-1",
                "name": "Reset display",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "9e89c88b-6dd3-4901-a71e-d1ad974a486e",
                  "value": "0"
                }
              },
              {
                "id": "clr-2",
                "name": "Reset pending value",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "7ad35376-8982-470b-bdd6-8ae3af7d9bc0",
                  "value": "0"
                }
              },
              {
                "id": "clr-3",
                "name": "Reset pending operation",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "6734e106-cb9f-4669-a889-b193d7038900",
                  "value": ""
                }
              },
              {
                "id": "clr-4",
                "name": "Reset replace flag",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "d250e309-af3d-48e2-828e-df062def88bc",
                  "value": false
                }
              },
              {
                "id": "clr-5",
                "name": "Reset decimal flag",
                "type": "changeVariableValue",
                "config": {
                  "variableName": "c366dc58-3f00-4b0b-92b9-d9df5005d8e0",
                  "value": false
                }
              }
            ]
          },
          {
            "label": "unary",
            "steps": [
              {
                "id": "unary-dispatch",
                "name": "Dispatch on button label (+/− or %)",
                "type": "multiOptionBranch",
                "config": {
                  "condition": "context?.item?.data?.label"
                },
                "branches": [
                  {
                    "label": "+/−",
                    "steps": [
                      {
                        "id": "neg-1",
                        "name": "Toggle sign",
                        "type": "changeVariableValue",
                        "config": {
                          "variableName": "9e89c88b-6dd3-4901-a71e-d1ad974a486e",
                          "value": {
                            "formula": "String(Number(variables['9e89c88b-6dd3-4901-a71e-d1ad974a486e']) * -1)"
                          }
                        }
                      }
                    ]
                  },
                  {
                    "label": "%",
                    "steps": [
                      {
                        "id": "pct-1",
                        "name": "Divide by 100",
                        "type": "changeVariableValue",
                        "config": {
                          "variableName": "9e89c88b-6dd3-4901-a71e-d1ad974a486e",
                          "value": {
                            "formula": "String(Number(variables['9e89c88b-6dd3-4901-a71e-d1ad974a486e']) / 100)"
                          }
                        }
                      }
                    ]
                  }
                ],
                "defaultBranch": []
              }
            ]
          }
        ],
        "defaultBranch": []
      }
    ]
  }
}
