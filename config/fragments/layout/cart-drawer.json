{
  "type": "Drawer",
  "props": {
    "anchor": "right"
  },
  "condition": "{{variables['c2d3e4f5-a6b7-8901-cdef-012345678901']}}",
  "children": [
    {
      "type": "DrawerBackdrop",
      "actions": {
        "click": {
          "action": "closeCartDrawer"
        }
      }
    },
    {
      "type": "DrawerContent",
      "props": {
        "className": "w-full max-w-sm"
      },
      "children": [
        {
          "type": "DrawerHeader",
          "props": {
            "className": "border-b border-[var(--theme-border)] pb-4"
          },
          "children": [
            {
              "type": "Box",
              "props": {
                "className": "flex items-center justify-between flex-row"
              },
              "children": [
                {
                  "type": "Heading",
                  "props": {
                    "className": "text-lg font-bold"
                  },
                  "text": "Shopping Cart"
                },
                {
                  "type": "DrawerCloseButton",
                  "props": {
                    "className": "h-8 w-8 rounded-md border-0 bg-transparent hover:bg-[var(--theme-hero-bg)] flex items-center justify-center"
                  },
                  "actions": {
                    "click": {
                      "action": "closeCartDrawer"
                    }
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "DrawerBody",
          "props": {
            "className": "overflow-y-auto flex-1 py-4"
          },
          "children": [
            {
              "type": "Box",
              "props": {
                "className": "flex flex-col items-center justify-center py-12 text-center"
              },
              "condition": "({{collections.a1b2c3d4-e5f6-7890-abcd-ef1234567890.data.activeOrder.totalQuantity}} || 0) === 0",
              "children": [
                {
                  "type": "NavIcon",
                  "props": {
                    "icon": "ShoppingBag",
                    "className": "h-12 w-12 text-[var(--theme-muted-foreground)] mb-4"
                  }
                },
                {
                  "type": "Text",
                  "props": {
                    "className": "text-[var(--theme-muted-foreground)]"
                  },
                  "text": "Your cart is empty"
                }
              ]
            },
            {
              "type": "Box",
              "props": {
                "className": "space-y-3 flex flex-col"
              },
              "condition": "{{collections.a1b2c3d4-e5f6-7890-abcd-ef1234567890.data.activeOrder.totalQuantity}} > 0",
              "map": "collections.a1b2c3d4-e5f6-7890-abcd-ef1234567890.data.activeOrder.lines",
              "key": "drawerLine",
              "children": [
                {
                  "type": "Box",
                  "props": {
                    "className": "flex gap-3 items-start flex-row"
                  },
                  "children": [
                    {
                      "type": "NextImage",
                      "props": {
                        "src": "{{context.item.productVariant.product.featuredAsset.preview}}",
                        "alt": "{{context.item.productVariant.product.name}}",
                        "width": 64,
                        "height": 64,
                        "className": "rounded-md object-cover w-16 h-16 flex-shrink-0 border border-[var(--theme-border)]"
                      }
                    },
                    {
                      "type": "Box",
                      "props": {
                        "className": "flex-1 min-w-0"
                      },
                      "children": [
                        {
                          "type": "Text",
                          "props": {
                            "className": "text-sm font-medium truncate"
                          },
                          "text": "{{context.item.productVariant.product.name}}"
                        },
                        {
                          "type": "Text",
                          "props": {
                            "className": "text-xs text-[var(--theme-muted-foreground)] mt-0.5"
                          },
                          "text": "{{context.item.productVariant.name}}"
                        },
                        {
                          "type": "Box",
                          "props": {
                            "className": "flex items-center justify-between mt-2 flex-row"
                          },
                          "children": [
                            {
                              "type": "Text",
                              "props": {
                                "className": "text-sm"
                              },
                              "text": "Qty: {{context.item.quantity}}"
                            },
                            {
                              "type": "Text",
                              "props": {
                                "className": "text-sm font-medium"
                              },
                              "text": {
                                "expr": "formatCurrency({{context.item.linePriceWithTax}} / 100, {{collections.a1b2c3d4-e5f6-7890-abcd-ef1234567890.data.activeOrder.currencyCode}} || 'USD')"
                              }
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "Pressable",
                      "props": {
                        "className": "text-[var(--theme-muted-foreground)] hover:text-red-500 transition-colors p-1"
                      },
                      "actions": {
                        "click": {
                          "action": "removeFromCart"
                        }
                      },
                      "children": [
                        {
                          "type": "Text",
                          "props": {
                            "className": "text-sm"
                          },
                          "text": "✕"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "DrawerFooter",
          "props": {
            "className": "border-t border-[var(--theme-border)] pt-4 space-y-3"
          },
          "condition": "{{collections.a1b2c3d4-e5f6-7890-abcd-ef1234567890.data.activeOrder.totalQuantity}} > 0",
          "children": [
            {
              "type": "Box",
              "props": {
                "className": "flex justify-between items-center mb-2 flex-row"
              },
              "children": [
                {
                  "type": "Text",
                  "props": {
                    "className": "text-sm text-[var(--theme-muted-foreground)]"
                  },
                  "text": "Subtotal"
                },
                {
                  "type": "Text",
                  "props": {
                    "className": "font-semibold"
                  },
                  "text": {
                    "expr": "formatCurrency({{collections.a1b2c3d4-e5f6-7890-abcd-ef1234567890.data.activeOrder.subTotalWithTax}} / 100, {{collections.a1b2c3d4-e5f6-7890-abcd-ef1234567890.data.activeOrder.currencyCode}} || 'USD')"
                  }
                }
              ]
            },
            {
              "type": "Pressable",
              "props": {
                "className": "w-full bg-[var(--theme-shop-button)] text-white hover:bg-[var(--theme-shop-buttonHover)] h-11 font-medium flex flex-row items-center justify-center rounded-md"
              },
              "children": [
                {
                  "type": "Text",
                  "props": {
                    "className": "text-white"
                  },
                  "text": "View Cart"
                }
              ],
              "actions": {
                "click": {
                  "action": "goToCart"
                }
              }
            },
            {
              "type": "Pressable",
              "props": {
                "className": "w-full border border-[var(--theme-border)] bg-[var(--theme-content-bg)] text-[var(--theme-foreground)] hover:bg-[var(--theme-hero-bg)] h-10 flex flex-row items-center justify-center rounded-md"
              },
              "children": [
                {
                  "type": "Text",
                  "props": {
                    "className": "text-[var(--theme-foreground)]"
                  },
                  "text": "Checkout"
                }
              ],
              "actions": {
                "click": {
                  "action": "navigate",
                  "payload": {
                    "path": "/checkout"
                  }
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
