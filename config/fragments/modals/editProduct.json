{
  "type": "Modal",
  "props": {
    "isOpen": "{{modal.editProduct}}",
    "onClose": {
      "action": "closeEditModal"
    },
    "closeOnOverlayClick": true
  },
  "children": [
    {
      "type": "ModalBackdrop",
      "actions": {
        "click": {
          "action": "closeEditModal"
        }
      }
    },
    {
      "type": "ModalContent",
      "props": {
        "size": "md"
      },
      "children": [
        {
          "type": "ModalHeader",
          "children": [
            {
              "type": "Heading",
              "props": {
                "size": "lg"
              },
              "text": "Edit Product"
            },
            {
              "type": "ModalCloseButton",
              "actions": {
                "click": {
                  "action": "closeEditModal"
                }
              }
            }
          ]
        },
        {
          "type": "Form",
          "props": {
            "key": "edit-form-{{modal.editProduct.id}}",
            "defaultValues": {
              "form": {
                "product": {
                  "var": [
                    "modal.editProduct",
                    {
                      "name": "",
                      "price": "",
                      "category": "",
                      "description": ""
                    }
                  ]
                }
              }
            },
            "validationRules": {
              "form.product.name": {
                "required": true,
                "minLength": 2
              },
              "form.product.price": {
                "required": true,
                "min": 0,
                "message": "Must be positive"
              },
              "form.product.category": {
                "required": true
              }
            },
            "submitAction": "updateProduct"
          },
          "children": [
            {
              "type": "ModalBody",
              "children": [
                {
                  "type": "FormInputWithLabel",
                  "props": {
                    "name": "form.product.name",
                    "label": "Name",
                    "placeholder": "Product name",
                    "variant": "outline",
                    "className": "mb-4"
                  }
                },
                {
                  "type": "FormInputWithLabel",
                  "props": {
                    "name": "form.product.price",
                    "label": "Price",
                    "placeholder": "0.00",
                    "variant": "outline",
                    "className": "mb-4"
                  }
                },
                {
                  "type": "FormInputWithLabel",
                  "props": {
                    "name": "form.product.category",
                    "label": "Category",
                    "placeholder": "Category",
                    "variant": "outline",
                    "className": "mb-4"
                  }
                },
                {
                  "type": "FormInputWithLabel",
                  "props": {
                    "name": "form.product.description",
                    "label": "Description",
                    "placeholder": "Optional",
                    "variant": "outline",
                    "className": "mb-6"
                  }
                }
              ]
            },
            {
              "type": "ModalFooter",
              "children": [
                {
                  "type": "Button",
                  "props": {
                    "variant": "outline",
                    "className": "mr-2"
                  },
                  "text": "Cancel",
                  "actions": {
                    "click": {
                      "action": "closeEditModal"
                    }
                  }
                },
                {
                  "type": "FormSubmitButton",
                  "props": {
                    "action": "primary"
                  },
                  "text": "Save"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
