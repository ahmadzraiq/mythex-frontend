{
  "type": "Box",
  "props": {
    "className": "space-y-6 flex flex-col"
  },
  "children": [
    {
      "type": "Box",
      "children": [
        {
          "type": "Heading",
          "props": {
            "className": "text-3xl font-bold"
          },
          "text": "{{product.name}}"
        },
        {
          "type": "Text",
          "condition": {
            "var": "product.selectedVariant"
          },
          "props": {
            "className": "text-2xl font-bold mt-2"
          },
          "text": {
            "expr": {
              "formatCurrency": [
                {
                  "/": [
                    {
                      "var": "product.selectedVariant.priceWithTax"
                    },
                    100
                  ]
                },
                {
                  "var": [
                    "cart.currencyCode",
                    "USD"
                  ]
                }
              ]
            }
          }
        }
      ]
    },
    {
      "type": "HtmlContent",
      "condition": {
        "var": "product.description"
      },
      "props": {
        "html": "{{product.description}}",
        "className": "prose prose-sm max-w-none text-[var(--theme-muted-foreground)]"
      }
    },
    {
      "type": "Box",
      "condition": {
        ">": [
          {
            "var": [
              "product.optionGroups.length",
              0
            ]
          },
          0
        ]
      },
      "props": {
        "className": "space-y-4"
      },
      "children": [
        {
          "type": "Box",
          "map": "product.optionGroups",
          "key": "optionGroup",
          "props": {
            "className": "space-y-3"
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "className": "text-base font-semibold"
              },
              "text": "{{$item.name}}"
            },
            {
              "type": "Box",
              "props": {
                "className": "grid grid-cols-2 sm:grid-cols-3 gap-3"
              },
              "children": [
                {
                  "type": "Box",
                  "map": "$item.options",
                  "key": "variantOption",
                  "props": {
                    "className": "contents"
                  },
                  "children": [
                    {
                      "type": "Pressable",
                      "condition": {
                        "==": [
                          {
                            "getFromMap": [
                              {
                                "var": "product.selectedOptions"
                              },
                              {
                                "var": "$parent.id"
                              }
                            ]
                          },
                          {
                            "var": "$item.id"
                          }
                        ]
                      },
                      "props": {
                        "className": "flex items-center justify-center rounded-md border-2 border-[var(--theme-shop-button)] bg-[var(--theme-shop-button)]/5 px-4 py-3 transition-colors"
                      },
                      "actions": {
                        "click": {
                          "action": "selectProductOption"
                        }
                      },
                      "children": [
                        {
                          "type": "Text",
                          "text": "{{$item.name}}"
                        }
                      ]
                    },
                    {
                      "type": "Pressable",
                      "condition": {
                        "!=": [
                          {
                            "getFromMap": [
                              {
                                "var": "product.selectedOptions"
                              },
                              {
                                "var": "$parent.id"
                              }
                            ]
                          },
                          {
                            "var": "$item.id"
                          }
                        ]
                      },
                      "props": {
                        "className": "flex items-center justify-center rounded-md border-2 border-[var(--theme-border)] bg-[var(--theme-hero-bg)] px-4 py-3 hover:bg-[var(--theme-content-bg)] transition-colors"
                      },
                      "actions": {
                        "click": {
                          "action": "selectProductOption"
                        }
                      },
                      "children": [
                        {
                          "type": "Text",
                          "text": "{{$item.name}}"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Box",
      "condition": {
        "var": "product.selectedVariant"
      },
      "children": [
        {
          "type": "Text",
          "condition": {
            "!=": [
              {
                "var": "product.selectedVariant.stockLevel"
              },
              "OUT_OF_STOCK"
            ]
          },
          "props": {
            "className": "text-sm text-green-600 font-medium"
          },
          "text": "In Stock"
        },
        {
          "type": "Text",
          "condition": {
            "==": [
              {
                "var": "product.selectedVariant.stockLevel"
              },
              "OUT_OF_STOCK"
            ]
          },
          "props": {
            "className": "text-sm text-red-600 font-medium"
          },
          "text": "Out of Stock"
        }
      ]
    },
    {
      "type": "Box",
      "props": {
        "className": "pt-4"
      },
      "children": [
        {
          "type": "Pressable",
          "condition": {
            "and": [
              {
                "var": "product.selectedVariant"
              },
              {
                "!=": [
                  {
                    "var": "product.selectedVariant.stockLevel"
                  },
                  "OUT_OF_STOCK"
                ]
              }
            ]
          },
          "props": {
            "className": "w-full !bg-[var(--theme-shop-button)] hover:!bg-[var(--theme-shop-buttonHover)] !text-white flex flex-row items-center justify-center py-3 rounded-md"
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "className": "text-white"
              },
              "text": "Add to Cart"
            }
          ],
          "actions": {
            "click": {
              "action": "addToCart"
            }
          }
        },
        {
          "type": "Pressable",
          "condition": {
            "or": [
              {
                "!": [
                  {
                    "var": "product.selectedVariant"
                  }
                ]
              },
              {
                "==": [
                  {
                    "var": "product.selectedVariant.stockLevel"
                  },
                  "OUT_OF_STOCK"
                ]
              }
            ]
          },
          "props": {
            "className": "w-full !bg-[var(--theme-border)] !text-[var(--theme-muted-foreground)] cursor-not-allowed flex flex-row items-center justify-center py-3 rounded-md",
            "disabled": true
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "className": "text-[var(--theme-muted-foreground)]"
              },
              "text": {
                "expr": {
                  "if": [
                    {
                      "!": [
                        {
                          "var": "product.selectedVariant"
                        }
                      ]
                    },
                    "Select Options",
                    "Out of Stock"
                  ]
                }
              }
            }
          ]
        }
      ]
    },
    {
      "type": "Box",
      "condition": {
        "and": [
          {
            "var": "product.selectedVariant"
          },
          {
            "var": "product.selectedVariant.sku"
          }
        ]
      },
      "children": [
        {
          "type": "Text",
          "props": {
            "className": "text-xs text-[var(--theme-muted-foreground)]"
          },
          "text": {
            "expr": {
              "cat": [
                "SKU: ",
                {
                  "var": "product.selectedVariant.sku"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
