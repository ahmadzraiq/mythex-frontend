{
  "type": "Box",
  "props": {
    "className": "w-full border-t border-[var(--theme-border)] pt-8 flex flex-row items-center justify-center gap-2 flex-wrap"
  },
  "condition": "{{search.totalItems}} > {{collectionPageSize}}",
  "children": [
    {
      "type": "Box",
      "props": {
        "className": "flex items-center justify-center h-9 w-9 rounded-md border border-[var(--theme-border)] bg-[var(--theme-hero-bg)] cursor-not-allowed pointer-events-none flex-shrink-0"
      },
      "condition": "{{searchCurrentPage}} <= 1",
      "children": [
        {
          "type": "NavIcon",
          "props": {
            "icon": "ChevronLeft",
            "size": 16,
            "color": "#6b7280"
          }
        }
      ]
    },
    {
      "type": "Pressable",
      "props": {
        "className": "flex items-center justify-center h-9 w-9 rounded-md border border-[var(--theme-border)] bg-[var(--theme-content-bg)] hover:bg-[var(--theme-hero-bg)] transition-colors flex-shrink-0"
      },
      "condition": "{{searchCurrentPage}} > 1",
      "children": [
        {
          "type": "NavIcon",
          "props": {
            "icon": "ChevronLeft",
            "size": 16,
            "color": "#374151"
          }
        }
      ],
      "actions": {
        "click": {
          "type": "runMultiple",
          "actions": [
            {
              "type": "decrement",
              "path": "searchSkip",
              "amount": "{{collectionPageSize}}"
            },
            {
              "action": "fetchSearchResults"
            },
            {
              "action": "navigate",
              "payload": {
                "path": "{{route.path}}?page={{searchPrevPage}}"
              }
            }
          ]
        }
      }
    },
    {
      "type": "Box",
      "props": {
        "className": "contents"
      },
      "map": "searchPaginationPages",
      "children": [
        {
          "type": "Text",
          "props": {
            "className": "px-2 text-sm text-[var(--theme-muted-foreground)] flex-shrink-0"
          },
          "condition": "{{$item}} === '...'",
          "text": "..."
        },
        {
          "type": "Pressable",
          "props": {
            "className": "flex items-center justify-center h-9 w-9 rounded-md border border-[var(--theme-shop-button)] bg-[var(--theme-shop-button)] text-white pointer-events-none flex-shrink-0"
          },
          "condition": "{{$item}} !== '...' && {{$item}} === {{searchCurrentPage}}",
          "children": [
            {
              "type": "Text",
              "props": {
                "className": "text-sm font-medium text-white"
              },
              "text": "{{$item}}"
            }
          ]
        },
        {
          "type": "Pressable",
          "props": {
            "className": "flex items-center justify-center h-9 w-9 rounded-md border border-[var(--theme-border)] bg-[var(--theme-content-bg)] hover:bg-[var(--theme-hero-bg)] transition-colors flex-shrink-0"
          },
          "condition": "{{$item}} !== '...' && {{$item}} !== {{searchCurrentPage}}",
          "children": [
            {
              "type": "Text",
              "props": {
                "className": "text-sm font-medium text-[var(--theme-foreground)]"
              },
              "text": "{{$item}}"
            }
          ],
          "actions": {
            "click": {
              "type": "runMultiple",
              "actions": [
                {
                  "type": "goToPage",
                  "path": "searchSkip",
                  "page": "{{$item}}",
                  "pageSize": "{{collectionPageSize}}",
                  "fetchAction": "fetchSearchResults"
                },
                {
                  "action": "fetchSearchResults"
                },
                {
                  "action": "navigate",
                  "payload": {
                    "path": "{{route.path}}?page={{$item}}"
                  }
                }
              ]
            }
          }
        }
      ]
    },
    {
      "type": "Box",
      "props": {
        "className": "flex items-center justify-center h-9 w-9 rounded-md border border-[var(--theme-border)] bg-[var(--theme-hero-bg)] cursor-not-allowed pointer-events-none flex-shrink-0"
      },
      "condition": "{{searchCurrentPage}} >= {{searchTotalPages}}",
      "children": [
        {
          "type": "NavIcon",
          "props": {
            "icon": "ChevronRight",
            "size": 16,
            "color": "#6b7280"
          }
        }
      ]
    },
    {
      "type": "Pressable",
      "props": {
        "className": "flex items-center justify-center h-9 w-9 rounded-md border border-[var(--theme-border)] bg-[var(--theme-content-bg)] hover:bg-[var(--theme-hero-bg)] transition-colors flex-shrink-0"
      },
      "condition": "{{searchCurrentPage}} < {{searchTotalPages}}",
      "children": [
        {
          "type": "NavIcon",
          "props": {
            "icon": "ChevronRight",
            "size": 16,
            "color": "#374151"
          }
        }
      ],
      "actions": {
        "click": {
          "type": "runMultiple",
          "actions": [
            {
              "type": "increment",
              "path": "searchSkip",
              "amount": "{{collectionPageSize}}"
            },
            {
              "action": "fetchSearchResults"
            },
            {
              "action": "navigate",
              "payload": {
                "path": "{{route.path}}?page={{searchNextPage}}"
              }
            }
          ]
        }
      }
    }
  ]
}
