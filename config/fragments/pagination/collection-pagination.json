{
  "type": "Box",
  "props": {
    "className": "w-full border-t border-[var(--theme-border)] pt-8 flex flex-row items-center justify-center gap-2 flex-wrap"
  },
  "condition": {
    ">": [
      {
        "var": [
          "collection.search.totalItems",
          0
        ]
      },
      {
        "var": [
          "collectionPageSize",
          12
        ]
      }
    ]
  },
  "children": [
    {
      "type": "Box",
      "props": {
        "className": "flex items-center justify-center h-9 w-9 rounded-md border border-[var(--theme-border)] bg-[var(--theme-hero-bg)] cursor-not-allowed pointer-events-none flex-shrink-0"
      },
      "condition": {
        "<=": [
          {
            "var": [
              "collectionCurrentPage",
              1
            ]
          },
          1
        ]
      },
      "children": [
        {
          "type": "NavIcon",
          "props": {
            "icon": "ChevronLeft",
            "size": 16,
            "color": "#6b7280"
          }
        }
      ]
    },
    {
      "type": "Pressable",
      "props": {
        "className": "flex items-center justify-center h-9 w-9 rounded-md border border-[var(--theme-border)] bg-[var(--theme-content-bg)] hover:bg-[var(--theme-hero-bg)] transition-colors flex-shrink-0"
      },
      "condition": {
        ">": [
          {
            "var": [
              "collectionCurrentPage",
              1
            ]
          },
          1
        ]
      },
      "children": [
        {
          "type": "NavIcon",
          "props": {
            "icon": "ChevronLeft",
            "size": 16,
            "color": "#374151"
          }
        }
      ],
      "actions": {
        "click": {
          "type": "runMultiple",
          "actions": [
            {
              "type": "decrement",
              "path": "collectionSkip",
              "amount": {
                "var": [
                  "collectionPageSize",
                  12
                ]
              }
            },
            {
              "action": "fetchCollection"
            },
            {
              "action": "navigate",
              "payload": {
                "path": "{{route.path}}?page={{collectionPrevPage}}"
              }
            }
          ]
        }
      }
    },
    {
      "type": "Box",
      "props": {
        "className": "contents"
      },
      "map": "collectionPaginationPages",
      "children": [
        {
          "type": "Text",
          "props": {
            "className": "px-2 text-sm text-[var(--theme-muted-foreground)] flex-shrink-0"
          },
          "condition": {
            "==": [
              {
                "var": "$item"
              },
              "..."
            ]
          },
          "text": "..."
        },
        {
          "type": "Pressable",
          "props": {
            "className": "flex items-center justify-center h-9 w-9 rounded-md border border-[var(--theme-shop-button)] bg-[var(--theme-shop-button)] text-white pointer-events-none flex-shrink-0"
          },
          "condition": {
            "and": [
              {
                "!=": [
                  {
                    "var": "$item"
                  },
                  "..."
                ]
              },
              {
                "==": [
                  {
                    "var": "$item"
                  },
                  {
                    "var": [
                      "collectionCurrentPage",
                      1
                    ]
                  }
                ]
              }
            ]
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "className": "text-sm font-medium text-white"
              },
              "text": {
                "var": "$item"
              }
            }
          ]
        },
        {
          "type": "Pressable",
          "props": {
            "className": "flex items-center justify-center h-9 w-9 rounded-md border border-[var(--theme-border)] bg-[var(--theme-content-bg)] hover:bg-[var(--theme-hero-bg)] transition-colors flex-shrink-0"
          },
          "condition": {
            "and": [
              {
                "!=": [
                  {
                    "var": "$item"
                  },
                  "..."
                ]
              },
              {
                "!=": [
                  {
                    "var": "$item"
                  },
                  {
                    "var": [
                      "collectionCurrentPage",
                      1
                    ]
                  }
                ]
              }
            ]
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "className": "text-sm font-medium text-[var(--theme-foreground)]"
              },
              "text": {
                "var": "$item"
              }
            }
          ],
          "actions": {
            "click": {
              "type": "runMultiple",
              "actions": [
                {
                  "type": "goToPage",
                  "page": {
                    "var": "$item"
                  },
                  "pageSize": {
                    "var": [
                      "collectionPageSize",
                      12
                    ]
                  }
                },
                {
                  "action": "navigate",
                  "payload": {
                    "path": "{{route.path}}?page={{$item}}"
                  }
                }
              ]
            }
          }
        }
      ]
    },
    {
      "type": "Box",
      "props": {
        "className": "flex items-center justify-center h-9 w-9 rounded-md border border-[var(--theme-border)] bg-[var(--theme-hero-bg)] cursor-not-allowed pointer-events-none flex-shrink-0"
      },
      "condition": {
        ">=": [
          {
            "var": [
              "collectionCurrentPage",
              1
            ]
          },
          {
            "var": [
              "collectionTotalPages",
              1
            ]
          }
        ]
      },
      "children": [
        {
          "type": "NavIcon",
          "props": {
            "icon": "ChevronRight",
            "size": 16,
            "color": "#6b7280"
          }
        }
      ]
    },
    {
      "type": "Pressable",
      "props": {
        "className": "flex items-center justify-center h-9 w-9 rounded-md border border-[var(--theme-border)] bg-[var(--theme-content-bg)] hover:bg-[var(--theme-hero-bg)] transition-colors flex-shrink-0"
      },
      "condition": {
        "<": [
          {
            "var": [
              "collectionCurrentPage",
              1
            ]
          },
          {
            "var": [
              "collectionTotalPages",
              1
            ]
          }
        ]
      },
      "children": [
        {
          "type": "NavIcon",
          "props": {
            "icon": "ChevronRight",
            "size": 16,
            "color": "#374151"
          }
        }
      ],
      "actions": {
        "click": {
          "type": "runMultiple",
          "actions": [
            {
              "type": "increment",
              "path": "collectionSkip",
              "amount": {
                "var": [
                  "collectionPageSize",
                  12
                ]
              }
            },
            {
              "action": "fetchCollection"
            },
            {
              "action": "navigate",
              "payload": {
                "path": "{{route.path}}?page={{collectionNextPage}}"
              }
            }
          ]
        }
      }
    }
  ]
}