{
  "type": "Drawer",
  "props": {
    "isOpen": "{{layout.searchDrawerOpen}}",
    "onClose": { "action": "closeSearchDrawer" },
    "size": "full",
    "anchor": "top"
  },
  "children": [
    { "type": "DrawerBackdrop" },
    {
      "type": "DrawerContent",
      "props": { "className": "max-h-[80vh] rounded-b-2xl" },
      "children": [
        {
          "type": "DrawerHeader",
          "props": { "className": "border-b border-gray-200 pb-4" },
          "children": [
            { "type": "HStack", "props": { "className": "items-center gap-3 flex-1" }, "children": [
              { "type": "Input", "props": { "className": "flex-1", "placeholder": "Search products...", "value": "{{search.query}}" }, "actions": { "change": { "action": "setState", "payload": { "path": "search.query", "value": "$event" } } } },
              { "type": "Pressable", "props": { "className": "rounded-lg bg-[var(--theme-header-accent)] px-4 py-2 text-sm font-medium text-[var(--theme-header-accentForeground)]" }, "actions": { "click": { "action": "closeSearchAndGoToSearch" } }, "children": [{ "type": "Text", "text": "Search" }] },
              { "type": "DrawerCloseButton", "props": { "onPress": { "action": "closeSearchDrawer" } } }
            ] }
          ]
        },
        {
          "type": "DrawerBody",
          "props": { "className": "py-4" },
          "children": [
            { "type": "Text", "props": { "className": "text-xs font-semibold uppercase tracking-wider text-gray-500 mb-2" }, "text": "Popular Searches" },
            { "type": "HStack", "props": { "className": "flex-wrap gap-2" }, "children": [
              { "type": "Pressable", "props": { "className": "px-3 py-1.5 rounded-full bg-gray-100 text-sm text-gray-700 hover:bg-gray-200" }, "actions": { "click": { "action": "closeSearchAndGoToDresses" } }, "children": [{ "type": "Text", "text": "Dresses" }] },
              { "type": "Pressable", "props": { "className": "px-3 py-1.5 rounded-full bg-gray-100 text-sm text-gray-700 hover:bg-gray-200" }, "actions": { "click": { "action": "closeSearchAndGoToShoes" } }, "children": [{ "type": "Text", "text": "Shoes" }] },
              { "type": "Pressable", "props": { "className": "px-3 py-1.5 rounded-full bg-gray-100 text-sm text-gray-700 hover:bg-gray-200" }, "actions": { "click": { "action": "closeSearchAndGoToAccessories" } }, "children": [{ "type": "Text", "text": "Accessories" }] }
            ] }
          ]
        }
      ]
    }
  ]
}
