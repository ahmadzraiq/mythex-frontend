{
  "type": "Drawer",
  "props": {
    "isOpen": "{{layout.drawerOpen}}",
    "onClose": {
      "action": "closeDrawer"
    },
    "size": "md",
    "anchor": "left"
  },
  "children": [
    {
      "type": "DrawerBackdrop"
    },
    {
      "type": "DrawerContent",
      "props": {
        "className": "w-64 max-w-[16rem]"
      },
      "children": [
        {
          "type": "DrawerHeader",
          "props": {
            "className": "border-b border-outline-100 pb-4"
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "className": "font-bold text-lg text-typography-900"
              },
              "text": "Admin"
            },
            {
              "type": "DrawerCloseButton"
            }
          ]
        },
        {
          "type": "DrawerBody",
          "props": {
            "className": "flex flex-col gap-1 pt-4"
          },
          "children": [
            {
              "type": "Pressable",
              "condition": {
                "==": [{ "var": "route.path" }, "/dashboard"]
              },
              "props": {
                "className": "py-3 px-4 rounded-lg bg-primary-50"
              },
              "actions": {
                "click": {
                  "action": "navigateToDashboard"
                }
              },
              "children": [
                {
                  "type": "Text",
                  "props": {
                    "className": "text-primary-700 font-semibold"
                  },
                  "text": "Dashboard"
                }
              ]
            },
            {
              "type": "Pressable",
              "condition": {
                "!=": [{ "var": "route.path" }, "/dashboard"]
            },
              "props": {
                "className": "py-3 px-4 rounded-lg hover:bg-primary-50 active:bg-primary-100"
              },
              "actions": {
                "click": {
                  "action": "navigateToDashboard"
                }
              },
              "children": [
                {
                  "type": "Text",
                  "props": {
                    "className": "text-typography-700 font-medium"
                  },
                  "text": "Dashboard"
                }
              ]
            },
            {
              "type": "Pressable",
              "condition": {
                "==": [{ "var": "route.path" }, "/dashboard/products"]
              },
              "props": {
                "className": "py-3 px-4 rounded-lg bg-primary-50"
              },
              "actions": {
                "click": {
                  "action": "navigateToProducts"
                }
              },
              "children": [
                {
                  "type": "Text",
                  "props": {
                    "className": "text-primary-700 font-semibold"
                  },
                  "text": "Products"
                }
              ]
            },
            {
              "type": "Pressable",
              "condition": {
                "!=": [{ "var": "route.path" }, "/dashboard/products"]
              },
              "props": {
                "className": "py-3 px-4 rounded-lg hover:bg-primary-50 active:bg-primary-100"
              },
              "actions": {
                "click": {
                  "action": "navigateToProducts"
                }
              },
              "children": [
                {
                  "type": "Text",
                  "props": {
                    "className": "text-typography-700 font-medium"
                  },
                  "text": "Products"
                }
              ]
            },
            {
              "type": "Pressable",
              "condition": {
                "==": [{ "var": "route.path" }, "/profile"]
              },
              "props": {
                "className": "py-3 px-4 rounded-lg bg-primary-50"
              },
              "actions": {
                "click": {
                  "action": "navigateToProfile"
                }
              },
              "children": [
                {
                  "type": "Text",
                  "props": {
                    "className": "text-primary-700 font-semibold"
                  },
                  "text": "Profile"
                }
              ]
            },
            {
              "type": "Pressable",
              "condition": {
                "!=": [{ "var": "route.path" }, "/profile"]
              },
              "props": {
                "className": "py-3 px-4 rounded-lg hover:bg-primary-50 active:bg-primary-100"
              },
              "actions": {
                "click": {
                  "action": "navigateToProfile"
                }
              },
              "children": [
                {
                  "type": "Text",
                  "props": {
                    "className": "text-typography-700 font-medium"
                  },
                  "text": "Profile"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
