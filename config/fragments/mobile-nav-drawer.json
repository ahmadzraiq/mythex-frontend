{
  "type": "Drawer",
  "props": {
    "isOpen": "{{layout.mobileNavOpen}}",
    "onClose": { "action": "closeMobileNav" },
    "size": "full",
    "anchor": "left"
  },
  "children": [
    { "type": "DrawerBackdrop" },
    {
      "type": "DrawerContent",
      "props": { "className": "w-80 max-w-[20rem]" },
      "children": [
        {
          "type": "DrawerHeader",
          "props": { "className": "border-b border-gray-200 pb-4" },
          "children": [
            { "type": "Text", "props": { "className": "font-bold text-lg text-gray-900" }, "text": "Menu" },
            { "type": "DrawerCloseButton", "props": { "onPress": { "action": "closeMobileNav" } } }
          ]
        },
        {
          "type": "DrawerBody",
          "props": { "className": "flex flex-col gap-1 pt-4" },
          "children": [
            { "type": "Pressable", "props": { "className": "py-3 px-4 rounded-lg hover:bg-gray-100 text-gray-900 font-medium" }, "actions": { "click": { "action": "closeMobileNavAndNavigate" } }, "children": [{ "type": "Text", "text": "Home" }] },
            { "type": "Pressable", "props": { "className": "py-3 px-4 rounded-lg hover:bg-gray-100 text-gray-900 font-medium" }, "actions": { "click": { "action": "closeMobileNavAndGoToShop" } }, "children": [{ "type": "Text", "text": "Shop All" }] },
            { "type": "Pressable", "props": { "className": "py-3 px-4 rounded-lg hover:bg-gray-100 text-gray-900 font-medium" }, "actions": { "click": { "action": "closeMobileNavAndGoToShopWomen" } }, "children": [{ "type": "Text", "text": "Women" }] },
            { "type": "Pressable", "props": { "className": "py-3 px-4 rounded-lg hover:bg-gray-100 text-gray-900 font-medium" }, "actions": { "click": { "action": "closeMobileNavAndGoToShopMen" } }, "children": [{ "type": "Text", "text": "Men" }] },
            { "type": "Pressable", "props": { "className": "py-3 px-4 rounded-lg hover:bg-gray-100 text-gray-900 font-medium" }, "actions": { "click": { "action": "closeMobileNavAndGoToShopKids" } }, "children": [{ "type": "Text", "text": "Kids" }] },
            { "type": "Pressable", "props": { "className": "py-3 px-4 rounded-lg hover:bg-gray-100 text-gray-900 font-medium" }, "actions": { "click": { "action": "closeMobileNavAndGoToShopAccessories" } }, "children": [{ "type": "Text", "text": "Accessories" }] },
            { "type": "Pressable", "props": { "className": "py-3 px-4 rounded-lg hover:bg-gray-100 text-[var(--theme-header-accent)] font-semibold" }, "actions": { "click": { "action": "closeMobileNavAndGoToSale" } }, "children": [{ "type": "Text", "text": "Sale" }] },
            { "type": "Divider", "props": { "className": "my-2" } },
            { "type": "Pressable", "props": { "className": "py-3 px-4 rounded-lg hover:bg-gray-100 text-gray-900 font-medium" }, "actions": { "click": { "action": "closeMobileNavAndGoToAccount" } }, "children": [{ "type": "Text", "text": "Account" }] },
            { "type": "Pressable", "props": { "className": "py-3 px-4 rounded-lg hover:bg-gray-100 text-gray-900 font-medium" }, "actions": { "click": { "action": "closeMobileNavAndGoToWishlist" } }, "children": [{ "type": "Text", "text": "Wishlist" }] },
            { "type": "Pressable", "props": { "className": "py-3 px-4 rounded-lg hover:bg-gray-100 text-gray-900 font-medium" }, "actions": { "click": { "action": "closeMobileNavAndGoToCart" } }, "children": [{ "type": "Text", "text": "Cart" }] }
          ]
        }
      ]
    }
  ]
}
