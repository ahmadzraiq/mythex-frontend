{
  "type": "Pressable",
  "props": { "className": "group h-full" },
  "actions": {
    "click": {
      "action": "navigate",
      "payload": { "routeConfig": "product", "slug": { "var": "$item.slug" } }
    }
  },
  "children": [
    {
      "type": "Card",
      "props": {
        "className": "overflow-hidden border-0 shadow-soft-1 hover:shadow-soft-2 transition-all duration-300 h-full flex flex-row"
      },
      "children": [
        {
          "type": "Box",
          "props": {
            "className": "w-32 sm:w-40 aspect-square shrink-0 bg-background-100 relative overflow-hidden"
          },
          "children": [
            {
              "type": "NextImage",
              "props": {
                "src": "{{$item.image}}",
                "alt": "{{$item.name}}",
                "fill": true,
                "className": "object-cover group-hover:scale-105 transition-transform duration-500"
              }
            },
            {
              "type": "Badge",
              "condition": { "var": "$item.badge" },
              "props": {
                "size": "sm",
                "className": "absolute top-2 left-2 bg-[var(--theme-shop-button)]/90 text-white border-0"
              },
              "children": [{ "type": "BadgeText", "text": "{{$item.badge}}" }]
            }
          ]
        },
        {
          "type": "Box",
          "props": { "className": "p-4 flex-1 flex flex-col justify-center min-w-0" },
          "children": [
            {
              "type": "Text",
              "props": {
                "className": "font-medium text-[var(--theme-shop-text)] text-sm leading-snug line-clamp-2"
              },
              "text": "{{$item.name}}"
            },
            {
              "type": "HStack",
              "props": { "className": "items-baseline gap-2 mt-2" },
              "children": [
                {
                  "type": "Text",
                  "props": { "className": "font-semibold text-[var(--theme-shop-text)]" },
                  "text": "{{$item.price}}"
                },
                {
                  "type": "Text",
                  "condition": { "var": "$item.originalPrice" },
                  "props": {
                    "className": "text-[var(--theme-shop-textMuted)] line-through text-sm"
                  },
                  "text": "{{$item.originalPrice}}"
                }
              ]
            },
            {
              "type": "HStack",
              "props": { "className": "gap-2 mt-3" },
              "children": [
                {
                  "type": "Pressable",
                  "props": {
                    "className": "p-2 rounded-full bg-[var(--theme-content-bgAlt)] hover:bg-[var(--theme-shop-border)] flex items-center justify-center size-8 transition-colors"
                  },
                  "actions": { "click": { "action": "addToWishlistFromCard" } },
                  "children": [{ "type": "NavIcon", "props": { "icon": "Favourite", "className": "size-4 text-[var(--theme-shop-accent)]" } }]
                },
                {
                  "type": "Button",
                  "props": {
                    "size": "sm",
                    "className": "!bg-[var(--theme-shop-button)] !text-white hover:!bg-[var(--theme-shop-buttonHover)]"
                  },
                  "text": "Quick Add",
                  "actions": { "click": { "action": "quickAddToCart" } }
                },
                {
                  "type": "Button",
                  "props": {
                    "size": "sm",
                    "variant": "outline"
                  },
                  "text": "Quick View",
                  "actions": { "click": { "action": "openQuickView" } }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
