{
  "type": "Drawer",
  "props": {
    "isOpen": "{{layout.filterDrawerOpen}}",
    "onClose": { "action": "closeFilterDrawer" },
    "size": "full",
    "anchor": "right"
  },
  "children": [
    { "type": "DrawerBackdrop" },
    {
      "type": "DrawerContent",
      "props": { "className": "w-80 max-w-[20rem]" },
      "children": [
        {
          "type": "DrawerHeader",
          "props": { "className": "border-b border-gray-200 pb-4" },
          "children": [
            { "type": "Text", "props": { "className": "font-bold text-lg text-gray-900" }, "text": "Filters" },
            { "type": "DrawerCloseButton", "props": { "onPress": { "action": "closeFilterDrawer" } } }
          ]
        },
        {
          "type": "DrawerBody",
          "props": { "className": "flex flex-col gap-4 pt-4" },
          "children": [
            {
              "type": "VStack",
              "props": { "className": "gap-2" },
              "children": [
                { "type": "Text", "props": { "className": "text-sm font-semibold text-gray-900" }, "text": "Category" },
                { "type": "Pressable", "props": { "className": "py-2 px-3 rounded-lg hover:bg-gray-100 text-gray-700 text-sm" }, "actions": { "click": { "action": "closeFilterDrawer" } }, "children": [{ "type": "Text", "text": "Women" }] },
                { "type": "Pressable", "props": { "className": "py-2 px-3 rounded-lg hover:bg-gray-100 text-gray-700 text-sm" }, "actions": { "click": { "action": "closeFilterDrawer" } }, "children": [{ "type": "Text", "text": "Men" }] },
                { "type": "Pressable", "props": { "className": "py-2 px-3 rounded-lg hover:bg-gray-100 text-gray-700 text-sm" }, "actions": { "click": { "action": "closeFilterDrawer" } }, "children": [{ "type": "Text", "text": "Kids" }] },
                { "type": "Pressable", "props": { "className": "py-2 px-3 rounded-lg hover:bg-gray-100 text-gray-700 text-sm" }, "actions": { "click": { "action": "closeFilterDrawer" } }, "children": [{ "type": "Text", "text": "Accessories" }] }
              ]
            },
            {
              "type": "VStack",
              "props": { "className": "gap-2" },
              "children": [
                { "type": "Text", "props": { "className": "text-sm font-semibold text-gray-900" }, "text": "Size" },
                { "type": "HStack", "props": { "className": "flex-wrap gap-2" }, "children": [
                  { "type": "Pressable", "props": { "className": "w-10 h-10 rounded border border-gray-200 flex items-center justify-center text-sm hover:border-[var(--theme-shop-button)]" }, "children": [{ "type": "Text", "text": "XS" }] },
                  { "type": "Pressable", "props": { "className": "w-10 h-10 rounded border border-gray-200 flex items-center justify-center text-sm hover:border-[var(--theme-shop-button)]" }, "children": [{ "type": "Text", "text": "S" }] },
                  { "type": "Pressable", "props": { "className": "w-10 h-10 rounded border border-gray-200 flex items-center justify-center text-sm hover:border-[var(--theme-shop-button)]" }, "children": [{ "type": "Text", "text": "M" }] },
                  { "type": "Pressable", "props": { "className": "w-10 h-10 rounded border border-gray-200 flex items-center justify-center text-sm hover:border-[var(--theme-shop-button)]" }, "children": [{ "type": "Text", "text": "L" }] },
                  { "type": "Pressable", "props": { "className": "w-10 h-10 rounded border border-gray-200 flex items-center justify-center text-sm hover:border-[var(--theme-shop-button)]" }, "children": [{ "type": "Text", "text": "XL" }] }
                ]}
              ]
            },
            {
              "type": "VStack",
              "props": { "className": "gap-2" },
              "children": [
                { "type": "Text", "props": { "className": "text-sm font-semibold text-gray-900" }, "text": "Price" },
                { "type": "Text", "props": { "className": "text-xs text-gray-500" }, "text": "Price range filter (placeholder)" }
              ]
            },
            {
              "type": "Button",
              "props": { "className": "w-full mt-4 bg-[var(--theme-shop-button)] text-[var(--theme-shop-buttonText)]" },
              "text": "Apply Filters",
              "actions": { "click": { "action": "closeFilterDrawer" } }
            }
          ]
        }
      ]
    }
  ]
}
