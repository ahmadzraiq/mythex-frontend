{
  "type": "Box",
  "props": {
    "className": "space-y-4"
  },
  "children": [
    {
      "type": "Box",
      "props": {
        "className": "relative aspect-square bg-[var(--theme-hero-bg)] rounded-lg overflow-hidden group"
      },
      "children": [
        {
          "type": "Box",
          "condition": "{{product.assets}}",
          "props": {
            "className": "w-full h-full relative"
          },
          "children": [
            {
              "type": "NextImage",
              "condition": { "expr": "at({{product.assets}}, {{product.imageIndex}} || 0)" },
              "props": {
                "src": { "expr": "getKeyValue(at({{product.assets}}, {{product.imageIndex}} || 0), 'source')" },
                "alt": "{{product.name}}",
                "fill": true,
                "className": "object-cover",
                "sizes": "(max-width: 1024px) 100vw, 50vw",
                "priority": true
              }
            },
            {
              "type": "Box",
              "condition": "{{product.assets.length}} > 1",
              "props": {
                "className": "absolute left-2 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-opacity"
              },
              "children": [
                {
                  "type": "Pressable",
                  "props": {
                    "className": "h-10 w-10 rounded-full bg-[var(--theme-content-bg)]/80 hover:bg-[var(--theme-content-bg)] border border-[var(--theme-border)] flex flex-row items-center justify-center"
                  },
                  "actions": {
                    "click": {
                      "action": "prevProductImage"
                    }
                  },
                  "children": [
                    {
                      "type": "NavIcon",
                      "props": {
                        "icon": "ChevronLeft",
                        "size": 24
                      }
                    }
                  ]
                }
              ]
            },
            {
              "type": "Box",
              "condition": "{{product.assets.length}} > 1",
              "props": {
                "className": "absolute right-2 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-opacity"
              },
              "children": [
                {
                  "type": "Pressable",
                  "props": {
                    "className": "h-10 w-10 rounded-full bg-[var(--theme-content-bg)]/80 hover:bg-[var(--theme-content-bg)] border border-[var(--theme-border)] flex flex-row items-center justify-center"
                  },
                  "actions": {
                    "click": {
                      "action": "nextProductImage"
                    }
                  },
                  "children": [
                    {
                      "type": "NavIcon",
                      "props": {
                        "icon": "ChevronRight",
                        "size": 24
                      }
                    }
                  ]
                }
              ]
            },
            {
              "type": "Box",
              "condition": "{{product.assets.length}} > 1",
              "props": {
                "className": "absolute bottom-4 left-1/2 -translate-x-1/2 bg-[var(--theme-content-bg)]/80 px-3 py-1 rounded-full text-sm"
              },
              "children": [
                {
                  "type": "Text",
                  "text": {
                    "expr": "({{product.imageIndex}} || 0) + 1 + ' / ' + ({{product.assets.length}} || 0)"
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "Box",
          "condition": "!{{product.assets}}",
          "props": {
            "className": "w-full h-full flex items-center justify-center"
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "className": "text-[var(--theme-muted-foreground)]"
              },
              "text": "No images available"
            }
          ]
        }
      ]
    },
    {
      "type": "Box",
      "condition": "{{product.assets.length}} > 1",
      "props": {
        "className": "grid grid-cols-4 gap-2"
      },
      "children": [
        {
          "type": "Box",
          "map": "product.assets",
          "key": "assetThumb",
          "props": {
            "className": "contents"
          },
          "children": [
            {
              "type": "Pressable",
              "props": {
                "className": "aspect-square relative rounded-lg overflow-hidden border-2 transition-colors"
              },
              "actions": {
                "click": {
                  "action": "selectProductImage"
                }
              },
              "children": [
                {
                  "type": "NextImage",
                  "props": {
                    "src": "{{$item.preview}}",
                    "alt": "{{product.name}}",
                    "fill": true,
                    "className": "object-cover w-full h-full",
                    "sizes": "25vw"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
