{
  "type": "Box",
  "props": {
    "className": "space-y-4"
  },
  "children": [
    {
      "type": "Box",
      "props": {
        "className": "relative aspect-square bg-[var(--theme-hero-bg)] rounded-lg overflow-hidden group"
      },
      "children": [
        {
          "type": "Box",
          "condition": "collections['b2c3d4e5-f6a7-8901-bcde-f12345678901']?.data?.product?.assets",
          "props": {
            "className": "w-full h-full relative"
          },
          "children": [
            {
              "type": "Image",
              "condition": {
                "expr": "at(collections['b2c3d4e5-f6a7-8901-bcde-f12345678901']?.data?.product?.assets, variables['d5e6f7a8-b9c0-1234-defa-345678901234'] || 0)"
              },
              "props": {
                "src": {
                  "expr": "getKeyValue(at(collections['b2c3d4e5-f6a7-8901-bcde-f12345678901']?.data?.product?.assets, variables['d5e6f7a8-b9c0-1234-defa-345678901234'] || 0), 'source')"
                },
                "alt": "{{collections.b2c3d4e5-f6a7-8901-bcde-f12345678901.data.product.name}}",
                "fill": true,
                "className": "object-cover",
                "sizes": "(max-width: 1024px) 100vw, 50vw",
                "priority": true
              }
            },
            {
              "type": "Box",
              "condition": "collections['b2c3d4e5-f6a7-8901-bcde-f12345678901']?.data?.product?.assets?.length > 1",
              "props": {
                "className": "absolute left-2 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-opacity"
              },
              "children": [
                {
                  "type": "Pressable",
                  "props": {
                    "className": "h-10 w-10 rounded-full bg-[var(--theme-content-bg)]/80 hover:bg-[var(--theme-content-bg)] border border-[var(--theme-border)] flex flex-row items-center justify-center"
                  },
                  "actions": [
                    {
                      "action": "84c5de07-4f71-44a3-904a-020758146a5f"
                    }
                  ],
                  "children": [
                    {
                      "type": "Icon",
                      "props": {
                        "icon": "lucide:chevron-left",
                        "size": 24
                      }
                    }
                  ]
                }
              ]
            },
            {
              "type": "Box",
              "condition": "collections['b2c3d4e5-f6a7-8901-bcde-f12345678901']?.data?.product?.assets?.length > 1",
              "props": {
                "className": "absolute right-2 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-opacity"
              },
              "children": [
                {
                  "type": "Pressable",
                  "props": {
                    "className": "h-10 w-10 rounded-full bg-[var(--theme-content-bg)]/80 hover:bg-[var(--theme-content-bg)] border border-[var(--theme-border)] flex flex-row items-center justify-center"
                  },
                  "actions": [
                    {
                      "action": "b5760629-bb22-4ace-a567-406e1afe14d1"
                    }
                  ],
                  "children": [
                    {
                      "type": "Icon",
                      "props": {
                        "icon": "lucide:chevron-right",
                        "size": 24
                      }
                    }
                  ]
                }
              ]
            },
            {
              "type": "Box",
              "condition": "collections['b2c3d4e5-f6a7-8901-bcde-f12345678901']?.data?.product?.assets?.length > 1",
              "props": {
                "className": "absolute bottom-4 left-1/2 -translate-x-1/2 bg-[var(--theme-content-bg)]/80 px-3 py-1 rounded-full text-sm"
              },
              "children": [
                {
                  "type": "Text",
                  "text": {
                    "expr": "(variables['d5e6f7a8-b9c0-1234-defa-345678901234'] || 0) + 1 + ' / ' + (collections['b2c3d4e5-f6a7-8901-bcde-f12345678901']?.data?.product?.assets?.length || 0)"
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "Box",
          "condition": "!collections['b2c3d4e5-f6a7-8901-bcde-f12345678901']?.data?.product?.assets",
          "props": {
            "className": "w-full h-full flex items-center justify-center"
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "className": "text-[var(--theme-muted-foreground)]"
              },
              "text": "No images available"
            }
          ]
        }
      ]
    },
    {
      "type": "Box",
      "condition": "collections['b2c3d4e5-f6a7-8901-bcde-f12345678901']?.data?.product?.assets?.length > 1",
      "props": {
        "className": "grid grid-cols-4 gap-2"
      },
      "children": [
        {
          "type": "Box",
          "map": "collections.b2c3d4e5-f6a7-8901-bcde-f12345678901.data.product.assets",
          "key": "assetThumb",
          "props": {
            "className": "contents"
          },
          "children": [
            {
              "type": "Pressable",
              "props": {
                "className": "aspect-square relative rounded-lg overflow-hidden border-2 transition-colors"
              },
              "actions": [
                {
                  "action": "59bc7c99-d110-4e01-8563-de6371d2147e"
                }
              ],
              "children": [
                {
                  "type": "Image",
                  "props": {
                    "src": "{{context.item.data.preview}}",
                    "alt": "{{collections.b2c3d4e5-f6a7-8901-bcde-f12345678901.data.product.name}}",
                    "fill": true,
                    "className": "object-cover w-full h-full",
                    "sizes": "25vw"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
