{
  "type": "Pressable",
  "props": {
    "className": "group block bg-[var(--theme-content-bg)] rounded-lg overflow-hidden border border-[var(--border)] hover:shadow-lg transition-shadow"
  },
  "actions": {
    "click": {
      "action": "navigate",
      "payload": {
        "routeConfig": "product",
        "slug": "{{context.item.slug}}"
      }
    }
  },
  "children": [
    {
      "type": "Box",
      "props": {
        "className": "aspect-square relative bg-[var(--theme-hero-bg)]"
      },
      "children": [
        {
          "type": "NextImage",
          "props": {
            "src": "{{context.item.productAsset.preview}}",
            "alt": "{{context.item.productName}}",
            "fill": true,
            "className": "object-cover group-hover:scale-105 transition-transform duration-300",
            "sizes": "(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
          }
        },
        {
          "type": "Box",
          "props": {
            "className": "w-full h-full flex items-center justify-center text-[var(--theme-content-textMuted)]"
          },
          "condition": "!{{context.item.productAsset}}",
          "children": [
            {
              "type": "Text",
              "text": "No image"
            }
          ]
        }
      ]
    },
    {
      "type": "Box",
      "props": {
        "className": "p-4 space-y-2"
      },
      "children": [
        {
          "type": "Text",
          "props": {
            "className": "font-medium line-clamp-2 group-hover:opacity-80 transition-colors text-[var(--theme-content-text)]"
          },
          "text": "{{context.item.productName}}"
        },
        {
          "type": "Text",
          "props": {
            "className": "text-lg font-bold text-[var(--theme-content-text)]"
          },
          "text": {
            "expr": "{{context.item.priceWithTax.__typename}} === 'SinglePrice' ? formatCurrency({{context.item.priceWithTax.value}} / 100, {{context.item.currencyCode}} || 'USD') : 'from ' + formatCurrency({{context.item.priceWithTax.min}} / 100, {{context.item.currencyCode}} || 'USD')"
          }
        }
      ]
    }
  ]
}
