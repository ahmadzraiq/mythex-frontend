{
  "type": "Box",
  "props": {
    "className": "group block bg-[var(--theme-card)] rounded-lg overflow-hidden border border-[var(--border)] hover:shadow-lg transition-shadow"
  },
  "actions": [
    {
      "action": "f6046c33-0164-45b5-86aa-0710fc408247"
    }
  ],
  "children": [
    {
      "type": "Box",
      "props": {
        "className": "aspect-square relative bg-[var(--theme-muted)]"
      },
      "children": [
        {
          "type": "Image",
          "props": {
            "src": "{{context.item.data.productAsset.preview}}",
            "alt": "{{context.item.data.productName}}",
            "fill": true,
            "className": "object-cover group-hover:scale-105 transition-transform duration-300",
            "sizes": "(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
          }
        },
        {
          "type": "Box",
          "props": {
            "className": "w-full h-full flex items-center justify-center text-[var(--theme-muted-foreground)]"
          },
          "condition": "!context?.item?.data?.productAsset",
          "children": [
            {
              "type": "Text",
              "text": "No image"
            }
          ]
        }
      ]
    },
    {
      "type": "Box",
      "props": {
        "className": "p-4 space-y-2"
      },
      "children": [
        {
          "type": "Text",
          "props": {
            "className": "font-medium line-clamp-2 group-hover:opacity-80 transition-colors text-[var(--theme-card-foreground)]"
          },
          "text": "{{context.item.data.productName}}"
        },
        {
          "type": "Text",
          "props": {
            "className": "text-lg font-bold text-[var(--theme-card-foreground)]"
          },
          "text": {
            "expr": "context?.item?.data?.priceWithTax?.__typename === 'SinglePrice' ? formatCurrency(context?.item?.data?.priceWithTax?.value / 100, context?.item?.data?.currencyCode || 'USD') : 'from ' + formatCurrency(context?.item?.data?.priceWithTax?.min / 100, context?.item?.data?.currencyCode || 'USD')"
          }
        }
      ]
    }
  ]
}
