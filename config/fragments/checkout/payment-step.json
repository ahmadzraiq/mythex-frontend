{
  "type": "Box",
  "props": {
    "className": "border rounded-lg px-6 bg-[var(--theme-content-bg)]"
  },
  "children": [
    {
      "type": "Pressable",
      "props": {
        "className": "{{checkout.paymentStepHeaderClassName}}"
      },
      "children": [
        {
          "type": "Box",
          "props": {
            "className": "flex flex-row items-center gap-3 flex-1 min-w-0"
          },
          "children": [
            {
              "type": "Box",
              "props": {
                "className": "{{checkout.paymentStepIndicatorClassName}}"
              },
              "children": [
                {
                  "type": "NavIcon",
                  "props": {
                    "icon": "Check",
                    "size": 16,
                    "className": "!text-white"
                  },
                  "condition": {
                    "var": [
                      "checkout.selectedPaymentMethodCode"
                    ]
                  }
                },
                {
                  "type": "Text",
                  "props": {
                    "className": "font-semibold text-sm !text-white"
                  },
                  "condition": {
                    "and": [
                      {
                        "!": [
                          {
                            "var": [
                              "checkout.selectedPaymentMethodCode"
                            ]
                          }
                        ]
                      },
                      {
                        "==": [
                          {
                            "var": "checkout.step"
                          },
                          "payment"
                        ]
                      }
                    ]
                  },
                  "text": "4"
                },
                {
                  "type": "Text",
                  "props": {
                    "className": "font-semibold text-sm !text-[var(--theme-muted-foreground)]"
                  },
                  "condition": {
                    "and": [
                      {
                        "!": [
                          {
                            "var": [
                              "checkout.selectedPaymentMethodCode"
                            ]
                          }
                        ]
                      },
                      {
                        "!=": [
                          {
                            "var": "checkout.step"
                          },
                          "payment"
                        ]
                      }
                    ]
                  },
                  "text": "4"
                }
              ]
            },
            {
              "type": "Text",
              "props": {
                "className": "text-lg font-semibold"
              },
              "text": "Payment Method"
            }
          ]
        },
        {
          "type": "Box",
          "props": {
            "className": "ml-auto shrink-0"
          },
          "children": [
            {
              "type": "NavIcon",
              "props": {
                "icon": "ChevronUp",
                "size": 16,
                "className": "!text-[var(--theme-muted-foreground)]"
              },
              "condition": {
                "==": [
                  {
                    "var": "checkout.step"
                  },
                  "payment"
                ]
              }
            },
            {
              "type": "NavIcon",
              "props": {
                "icon": "ChevronDown",
                "size": 16,
                "className": "!text-[var(--theme-muted-foreground)]"
              },
              "condition": {
                "!=": [
                  {
                    "var": "checkout.step"
                  },
                  "payment"
                ]
              }
            }
          ]
        }
      ],
      "actions": {
        "click": {
          "type": "set",
          "path": "checkout.step",
          "value": "payment"
        }
      }
    },
    {
      "type": "Box",
      "props": {
        "className": "pb-6 space-y-3"
      },
      "condition": {
        "==": [
          {
            "var": "checkout.step"
          },
          "payment"
        ]
      },
      "children": [
        {
          "type": "Text",
          "props": {
            "className": "text-sm text-[var(--theme-muted-foreground)]"
          },
          "text": "Select payment method"
        },
        {
          "type": "Box",
          "props": {
            "className": "flex flex-row flex-wrap gap-4"
          },
          "map": "checkout.paymentMethods",
          "key": "paymentOpt",
          "children": [
            {
              "type": "Pressable",
              "props": {
                "className": {
                  "expr": {
                    "cat": [
                      "flex flex-row items-center gap-3 p-4 border-2 rounded-lg w-full cursor-pointer transition-colors ",
                      {
                        "if": [
                          {
                            "==": [
                              {
                                "var": "checkout.selectedPaymentMethodCode"
                              },
                              {
                                "var": "$item.code"
                              }
                            ]
                          },
                          "border-[var(--theme-shop-button)] bg-[var(--theme-hero-bg)]",
                          "border-[var(--theme-border)] hover:border-[var(--theme-shop-button)]"
                        ]
                      }
                    ]
                  }
                }
              },
              "children": [
                {
                  "type": "Box",
                  "props": {
                    "className": {
                      "expr": {
                        "cat": [
                          "w-5 h-5 min-w-5 min-h-5 rounded-full border-2 flex items-center justify-center shrink-0 ",
                          {
                            "if": [
                              {
                                "==": [
                                  {
                                    "var": "checkout.selectedPaymentMethodCode"
                                  },
                                  {
                                    "var": "$item.code"
                                  }
                                ]
                              },
                              "border-[var(--theme-shop-button)] bg-[var(--theme-shop-button)]",
                              "border-[var(--theme-border)]"
                            ]
                          }
                        ]
                      }
                    }
                  },
                  "children": [
                    {
                      "type": "Box",
                      "props": {
                        "className": "w-2 h-2 rounded-full bg-white pointer-events-none"
                      },
                      "condition": {
                        "==": [
                          {
                            "var": "checkout.selectedPaymentMethodCode"
                          },
                          {
                            "var": "$item.code"
                          }
                        ]
                      }
                    }
                  ]
                },
                {
                  "type": "NavIcon",
                  "props": {
                    "icon": "CircleDollarSign",
                    "size": 20,
                    "className": "!text-[var(--theme-muted-foreground)] shrink-0"
                  }
                },
                {
                  "type": "Box",
                  "props": {
                    "className": "gap-0.5 text-left flex-1 min-w-0 flex flex-col"
                  },
                  "children": [
                    {
                      "type": "Text",
                      "props": {
                        "className": "font-medium text-sm text-[var(--theme-foreground)]"
                      },
                      "text": "{{$item.name}}"
                    },
                    {
                      "type": "Text",
                      "props": {
                        "className": "text-xs text-[var(--theme-muted-foreground)]"
                      },
                      "text": "{{$item.description}}"
                    }
                  ]
                }
              ],
              "actions": {
                "click": {
                  "type": "runMultiple",
                  "actions": [
                    {
                      "type": "set",
                      "path": "checkout.selectedPaymentMethodCode",
                      "value": {
                        "var": "$item.code"
                      }
                    },
                    {
                      "action": "setState",
                      "payload": {
                        "path": "screens.checkout.errors.checkout.selectedPaymentMethodCode",
                        "value": ""
                      }
                    }
                  ]
                }
              }
            }
          ]
        },
        {
          "type": "Pressable",
          "props": {
            "className": {
              "expr": {
                "cat": [
                  "w-full flex flex-row items-center justify-center py-3 rounded-md ",
                  "bg-[var(--theme-shop-button)] text-white hover:bg-[var(--theme-shop-buttonHover)] mt-2 ",
                  {
                    "if": [
                      {
                        "var": [
                          "checkout.selectedPaymentMethodCode",
                          ""
                        ]
                      },
                      "",
                      "opacity-50 pointer-events-none cursor-not-allowed"
                    ]
                  }
                ]
              }
            }
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "className": "text-white"
              },
              "text": "Continue to review"
            }
          ],
          "actions": {
            "click": {
              "type": "set",
              "path": "checkout.step",
              "value": "review"
            }
          }
        }
      ]
    }
  ]
}
