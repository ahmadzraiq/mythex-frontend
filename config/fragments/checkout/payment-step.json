{
  "type": "Box",
  "props": {
    "className": "border rounded-lg px-6 bg-[var(--theme-content-bg)]"
  },
  "children": [
    {
      "type": "Pressable",
      "props": {
        "className": { "expr": "'flex flex-row items-center justify-between w-full py-4 ' + (({{collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.shippingLines.length}} || 0) > 0 || {{variables['b3c4d5e6-f7a8-9012-bcde-123456789012']}} ? '' : 'opacity-50 pointer-events-none cursor-not-allowed')" }
      },
      "children": [
        {
          "type": "Box",
          "props": {
            "className": "flex flex-row items-center gap-3 flex-1 min-w-0"
          },
          "children": [
            {
              "type": "Box",
              "props": {
                "className": { "expr": "'flex items-center justify-center w-8 h-8 min-w-8 min-h-8 rounded-full overflow-hidden shrink-0 ' + ({{variables['b3c4d5e6-f7a8-9012-bcde-123456789012']}} ? 'bg-green-500 !text-white' : ({{variables['d9e0f1a2-b3c4-5678-defa-789012345678']}} === 'payment' ? 'bg-[var(--theme-shop-button)] !text-white' : 'bg-[var(--theme-hero-bg)] !text-[var(--theme-muted-foreground)]'))" }
              },
              "children": [
                {
                  "type": "NavIcon",
                  "props": {
                    "icon": "Check",
                    "size": 16,
                    "className": "!text-white"
                  },
                  "condition": "{{variables['b3c4d5e6-f7a8-9012-bcde-123456789012']}}"
                },
                {
                  "type": "Text",
                  "props": {
                    "className": "font-semibold text-sm !text-white"
                  },
                  "condition": "!{{variables['b3c4d5e6-f7a8-9012-bcde-123456789012']}} && {{variables['d9e0f1a2-b3c4-5678-defa-789012345678']}} === 'payment'",
                  "text": "4"
                },
                {
                  "type": "Text",
                  "props": {
                    "className": "font-semibold text-sm !text-[var(--theme-muted-foreground)]"
                  },
                  "condition": "!{{variables['b3c4d5e6-f7a8-9012-bcde-123456789012']}} && {{variables['d9e0f1a2-b3c4-5678-defa-789012345678']}} !== 'payment'",
                  "text": "4"
                }
              ]
            },
            {
              "type": "Text",
              "props": {
                "className": "text-lg font-semibold"
              },
              "text": "Payment Method"
            }
          ]
        },
        {
          "type": "Box",
          "props": {
            "className": "ml-auto shrink-0"
          },
          "children": [
            {
              "type": "NavIcon",
              "props": {
                "icon": "ChevronUp",
                "size": 16,
                "className": "!text-[var(--theme-muted-foreground)]"
              },
              "condition": "{{variables['d9e0f1a2-b3c4-5678-defa-789012345678']}} === 'payment'"
            },
            {
              "type": "NavIcon",
              "props": {
                "icon": "ChevronDown",
                "size": 16,
                "className": "!text-[var(--theme-muted-foreground)]"
              },
              "condition": "{{variables['d9e0f1a2-b3c4-5678-defa-789012345678']}} !== 'payment'"
            }
          ]
        }
      ],
      "actions": {
        "click": {
          "type": "setVar",
          "path": "d9e0f1a2-b3c4-5678-defa-789012345678",
          "value": "payment"
        }
      }
    },
    {
      "type": "Box",
      "props": {
        "className": "pb-6 space-y-3"
      },
      "condition": "{{variables['d9e0f1a2-b3c4-5678-defa-789012345678']}} === 'payment'",
      "children": [
        {
          "type": "Text",
          "props": {
            "className": "text-sm text-[var(--theme-muted-foreground)]"
          },
          "text": "Select payment method"
        },
        {
          "type": "Box",
          "props": {
            "className": "flex flex-row flex-wrap gap-4"
          },
          "map": "checkout.paymentMethods",
          "key": "paymentOpt",
          "children": [
            {
              "type": "Pressable",
              "props": {
                "className": "flex flex-row items-center gap-3 p-4 border-2 rounded-lg w-full cursor-pointer transition-colors {{checkout.selectedPaymentMethodCode === $item.code ? 'border-[var(--theme-shop-button)] bg-[var(--theme-hero-bg)]' : 'border-[var(--theme-border)] hover:border-[var(--theme-shop-button)]'}}"
              },
              "children": [
                {
                  "type": "Box",
                  "props": {
                    "className": "w-5 h-5 min-w-5 min-h-5 rounded-full border-2 flex items-center justify-center shrink-0 {{checkout.selectedPaymentMethodCode === $item.code ? 'border-[var(--theme-shop-button)] bg-[var(--theme-shop-button)]' : 'border-[var(--theme-border)]'}}"
                  },
                  "children": [
                    {
                      "type": "Box",
                      "props": {
                        "className": "w-2 h-2 rounded-full bg-white pointer-events-none"
                      },
                      "condition": "{{variables['b3c4d5e6-f7a8-9012-bcde-123456789012']}} === {{context.item.code}}"
                    }
                  ]
                },
                {
                  "type": "NavIcon",
                  "props": {
                    "icon": "CircleDollarSign",
                    "size": 20,
                    "className": "!text-[var(--theme-muted-foreground)] shrink-0"
                  }
                },
                {
                  "type": "Box",
                  "props": {
                    "className": "gap-0.5 text-left flex-1 min-w-0 flex flex-col"
                  },
                  "children": [
                    {
                      "type": "Text",
                      "props": {
                        "className": "font-medium text-sm text-[var(--theme-foreground)]"
                      },
                      "text": "{{context.item.name}}"
                    },
                    {
                      "type": "Text",
                      "props": {
                        "className": "text-xs text-[var(--theme-muted-foreground)]"
                      },
                      "text": "{{context.item.description}}"
                    }
                  ]
                }
              ],
              "actions": {
                "click": {
                  "type": "runMultiple",
                  "actions": [
                    {
                      "type": "setVar",
                      "path": "b3c4d5e6-f7a8-9012-bcde-123456789012",
                      "value": "{{context.item.code}}"
                    },
                    {
                      "action": "setState",
                      "payload": {
                        "path": "screens.checkout.errors.checkout.selectedPaymentMethodCode",
                        "value": ""
                      }
                    }
                  ]
                }
              }
            }
          ]
        },
        {
          "type": "Pressable",
          "props": {
            "className": "w-full flex flex-row items-center justify-center py-3 rounded-md bg-[var(--theme-shop-button)] text-white hover:bg-[var(--theme-shop-buttonHover)] mt-2 {{checkout.selectedPaymentMethodCode ? '' : 'opacity-50 pointer-events-none cursor-not-allowed'}}"
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "className": "text-white"
              },
              "text": "Continue to review"
            }
          ],
          "actions": {
            "click": {
              "type": "setVar",
              "path": "d9e0f1a2-b3c4-5678-defa-789012345678",
              "value": "review"
            }
          }
        }
      ]
    }
  ]
}
