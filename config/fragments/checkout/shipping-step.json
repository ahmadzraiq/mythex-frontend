{
  "type": "Box",
  "props": {
    "className": "border rounded-lg px-6 bg-[var(--theme-content-bg)]"
  },
  "children": [
    {
      "type": "Pressable",
      "props": {
        "className": "{{checkout.shippingStepHeaderClassName}}"
      },
      "actions": {
        "click": {
          "type": "set",
          "path": "checkout.step",
          "value": "shipping"
        }
      },
      "children": [
        {
          "type": "Box",
          "props": {
            "className": "flex flex-row items-center gap-3 flex-1 min-w-0"
          },
          "children": [
            {
              "type": "Box",
              "props": {
                "className": "{{checkout.shippingStepIndicatorClassName}}"
              },
              "children": [
                {
                  "type": "NavIcon",
                  "props": {
                    "icon": "Check",
                    "size": 16,
                    "className": "!text-white"
                  },
                  "condition": "{{checkout.order.shippingAddress.streetLine1}}"
                },
                {
                  "type": "Text",
                  "props": {
                    "className": "font-semibold text-sm !text-white"
                  },
                  "text": "2",
                  "condition": "!{{checkout.order.shippingAddress.streetLine1}} && {{checkout.step}} === 'shipping'"
                },
                {
                  "type": "Text",
                  "props": {
                    "className": "font-semibold text-sm !text-[var(--theme-muted-foreground)]"
                  },
                  "text": "2",
                  "condition": "!{{checkout.order.shippingAddress.streetLine1}} && {{checkout.step}} !== 'shipping'"
                }
              ]
            },
            {
              "type": "Text",
              "props": {
                "className": "text-lg font-semibold"
              },
              "text": "Shipping Address"
            }
          ]
        },
        {
          "type": "Box",
          "props": {
            "className": "ml-auto shrink-0"
          },
          "children": [
            {
              "type": "NavIcon",
              "props": {
                "icon": "ChevronUp",
                "size": 16,
                "className": "!text-[var(--theme-muted-foreground)]"
              },
              "condition": "{{checkout.step}} === 'shipping'"
            },
            {
              "type": "NavIcon",
              "props": {
                "icon": "ChevronDown",
                "size": 16,
                "className": "!text-[var(--theme-muted-foreground)]"
              },
              "condition": "{{checkout.step}} !== 'shipping'"
            }
          ]
        }
      ]
    },
    {
      "type": "Box",
      "props": {
        "className": "pb-6"
      },
      "condition": "{{checkout.step}} === 'shipping'",
      "children": [
        {
          "type": "Box",
          "props": {
            "className": "space-y-4 flex flex-col"
          },
          "children": [
            {
              "type": "Box",
              "props": {
                "className": "space-y-2"
              },
              "children": [
                {
                  "type": "Text",
                  "props": {
                    "className": "text-sm font-medium"
                  },
                  "text": "Full name"
                },
                {
                  "type": "Input",
                  "children": [
                    {
                      "type": "InputField",
                      "props": {
                        "placeholder": "Jane Doe",
                        "value": "{{form.fullName}}"
                      },
                      "actions": {
                        "change": {
                          "action": "setState",
                          "payload": {
                            "path": "screens.checkout.form.fullName",
                            "value": "$event"
                          }
                        }
                      }
                    }
                  ]
                }
              ]
            },
            {
              "type": "Box",
              "props": {
                "className": "space-y-2"
              },
              "children": [
                {
                  "type": "Text",
                  "props": {
                    "className": "text-sm font-medium"
                  },
                  "text": "Company"
                },
                {
                  "type": "Input",
                  "children": [
                    {
                      "type": "InputField",
                      "props": {
                        "placeholder": "Acme Inc",
                        "value": "{{form.company}}"
                      },
                      "actions": {
                        "change": {
                          "action": "setState",
                          "payload": {
                            "path": "screens.checkout.form.company",
                            "value": "$event"
                          }
                        }
                      }
                    }
                  ]
                }
              ]
            },
            {
              "type": "Box",
              "props": {
                "className": "space-y-2"
              },
              "children": [
                {
                  "type": "Text",
                  "props": {
                    "className": "text-sm font-medium"
                  },
                  "text": "Street address *"
                },
                {
                  "type": "Input",
                  "children": [
                    {
                      "type": "InputField",
                      "props": {
                        "placeholder": "123 Main St",
                        "value": "{{form.streetLine1}}"
                      },
                      "actions": {
                        "change": {
                          "type": "runMultiple",
                          "actions": [
                            {
                              "action": "setState",
                              "payload": {
                                "path": "screens.checkout.form.streetLine1",
                                "value": "$event"
                              }
                            },
                            {
                              "action": "setState",
                              "payload": {
                                "path": "screens.checkout.errors.form.streetLine1",
                                "value": ""
                              }
                            }
                          ]
                        }
                      }
                    }
                  ]
                },
                {
                  "type": "Box",
                  "props": {
                    "className": "min-h-[20px]"
                  },
                  "condition": "{{screens.checkout.errors.form.streetLine1}}",
                  "children": [
                    {
                      "type": "Text",
                      "props": {
                        "className": "text-sm text-red-500 dark:text-red-400"
                      },
                      "text": "{{errors.form.streetLine1}}"
                    }
                  ]
                }
              ]
            },
            {
              "type": "Box",
              "props": {
                "className": "space-y-2"
              },
              "children": [
                {
                  "type": "Text",
                  "props": {
                    "className": "text-sm font-medium"
                  },
                  "text": "Apartment, suite, etc."
                },
                {
                  "type": "Input",
                  "children": [
                    {
                      "type": "InputField",
                      "props": {
                        "placeholder": "Apt 4",
                        "value": "{{form.streetLine2}}"
                      },
                      "actions": {
                        "change": {
                          "action": "setState",
                          "payload": {
                            "path": "screens.checkout.form.streetLine2",
                            "value": "$event"
                          }
                        }
                      }
                    }
                  ]
                }
              ]
            },
            {
              "type": "Box",
              "props": {
                "className": "grid grid-cols-2 gap-4"
              },
              "children": [
                {
                  "type": "Box",
                  "props": {
                    "className": "space-y-2"
                  },
                  "children": [
                    {
                      "type": "Text",
                      "props": {
                        "className": "text-sm font-medium"
                      },
                      "text": "City"
                    },
                    {
                      "type": "Input",
                      "children": [
                        {
                          "type": "InputField",
                          "props": {
                            "placeholder": "New York",
                            "value": "{{form.city}}"
                          },
                          "actions": {
                            "change": {
                              "action": "setState",
                              "payload": {
                                "path": "screens.checkout.form.city",
                                "value": "$event"
                              }
                            }
                          }
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "Box",
                  "props": {
                    "className": "space-y-2"
                  },
                  "children": [
                    {
                      "type": "Text",
                      "props": {
                        "className": "text-sm font-medium"
                      },
                      "text": "State/Province"
                    },
                    {
                      "type": "Input",
                      "children": [
                        {
                          "type": "InputField",
                          "props": {
                            "placeholder": "NY",
                            "value": "{{form.province}}"
                          },
                          "actions": {
                            "change": {
                              "action": "setState",
                              "payload": {
                                "path": "screens.checkout.form.province",
                                "value": "$event"
                              }
                            }
                          }
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "Box",
                  "props": {
                    "className": "space-y-2"
                  },
                  "children": [
                    {
                      "type": "Text",
                      "props": {
                        "className": "text-sm font-medium"
                      },
                      "text": "Postal code"
                    },
                    {
                      "type": "Input",
                      "children": [
                        {
                          "type": "InputField",
                          "props": {
                            "placeholder": "10001",
                            "value": "{{form.postalCode}}"
                          },
                          "actions": {
                            "change": {
                              "action": "setState",
                              "payload": {
                                "path": "screens.checkout.form.postalCode",
                                "value": "$event"
                              }
                            }
                          }
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "Box",
                  "props": {
                    "className": "space-y-2"
                  },
                  "children": [
                    {
                      "type": "Text",
                      "props": {
                        "className": "text-sm font-medium"
                      },
                      "text": "Country *"
                    },
                    {
                      "type": "Select",
                      "props": {
                        "selectedValue": "{{form.countryCode}}",
                        "className": "w-full"
                      },
                      "actions": {
                        "valueChange": {
                          "type": "runMultiple",
                          "actions": [
                            {
                              "action": "setState",
                              "payload": {
                                "path": "screens.checkout.form.countryCode",
                                "value": "$event"
                              }
                            },
                            {
                              "action": "setState",
                              "payload": {
                                "path": "screens.checkout.errors.form.countryCode",
                                "value": ""
                              }
                            }
                          ]
                        }
                      },
                      "children": [
                        {
                          "type": "SelectTrigger",
                          "props": {
                            "className": "w-full !rounded-md !border-[var(--theme-border)] !bg-[var(--theme-content-bg)] min-h-[40px]"
                          },
                          "children": [
                            {
                              "type": "SelectInput",
                              "props": {
                                "placeholder": "Select country...",
                                "className": "!text-[var(--theme-foreground)]"
                              }
                            },
                            {
                              "type": "SelectIcon",
                              "children": [
                                {
                                  "type": "NavIcon",
                                  "props": {
                                    "icon": "ChevronDown",
                                    "size": 16,
                                    "color": "#6b7280"
                                  }
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "SelectPortal",
                          "children": [
                            {
                              "type": "SelectBackdrop"
                            },
                            {
                              "type": "SelectContent",
                              "props": {
                                "className": "max-h-[300px]"
                              },
                              "children": [
                                {
                                  "type": "SelectDragIndicatorWrapper",
                                  "children": [
                                    {
                                      "type": "SelectDragIndicator"
                                    }
                                  ]
                                },
                                {
                                  "type": "Box",
                                  "map": "checkout.countries",
                                  "key": "country",
                                  "props": {
                                    "className": "contents"
                                  },
                                  "children": [
                                    {
                                      "type": "SelectItem",
                                      "props": {
                                        "label": "{{$item.name}}",
                                        "value": "{{$item.code}}"
                                      }
                                    }
                                  ]
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "Box",
                      "props": {
                        "className": "min-h-[20px]"
                      },
                      "condition": "{{screens.checkout.errors.form.countryCode}}",
                      "children": [
                        {
                          "type": "Text",
                          "props": {
                            "className": "text-sm text-red-500 dark:text-red-400"
                          },
                          "text": "{{errors.form.countryCode}}"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "Box",
              "props": {
                "className": "space-y-2"
              },
              "children": [
                {
                  "type": "Text",
                  "props": {
                    "className": "text-sm font-medium"
                  },
                  "text": "Phone number"
                },
                {
                  "type": "Input",
                  "children": [
                    {
                      "type": "InputField",
                      "props": {
                        "type": "tel",
                        "placeholder": "+1 234 567 8900",
                        "value": "{{form.phoneNumber}}"
                      },
                      "actions": {
                        "change": {
                          "action": "setState",
                          "payload": {
                            "path": "screens.checkout.form.phoneNumber",
                            "value": "$event"
                          }
                        }
                      }
                    }
                  ]
                }
              ]
            },
            {
              "type": "Pressable",
              "props": {
                "className": "flex flex-row items-center gap-2 py-2"
              },
              "actions": {
                "click": {
                  "type": "toggle",
                  "path": "checkout.useSameForBilling"
                }
              },
              "children": [
                {
                  "type": "Box",
                  "props": {
                    "className": "w-4 h-4 rounded border flex items-center justify-center {{checkout.useSameForBilling ? 'bg-[var(--theme-shop-button)] border-[var(--theme-shop-button)]' : 'border-[var(--theme-border)]'}}"
                  },
                  "children": [
                    {
                      "type": "Text",
                      "props": {
                        "className": "text-white text-xs font-bold"
                      },
                      "condition": "{{checkout.useSameForBilling}}",
                      "text": "✓"
                    }
                  ]
                },
                {
                  "type": "Text",
                  "props": {
                    "className": "text-sm"
                  },
                  "text": "Use same address for billing"
                }
              ]
            },
            {
              "type": "Pressable",
              "props": {
                "className": "bg-[var(--theme-shop-button)] text-white hover:bg-[var(--theme-shop-buttonHover)] flex flex-row items-center justify-center py-3 px-4 rounded-md"
              },
              "children": [
                {
                  "type": "Text",
                  "props": {
                    "className": "text-white"
                  },
                  "text": "Continue"
                }
              ],
              "actions": {
                "click": {
                  "action": "setShippingAddress"
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
