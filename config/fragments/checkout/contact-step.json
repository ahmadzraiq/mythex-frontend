{
  "type": "Box",
  "props": {
    "className": "border rounded-lg px-6 bg-[var(--theme-content-bg)]"
  },
  "condition": "{{auth.user}} === null",
  "children": [
    {
      "type": "Pressable",
      "props": {
        "className": "flex flex-row items-center justify-between w-full py-4"
      },
      "actions": [
        {
          "action": "e89bedc2-a39c-4c83-861b-7fd20bcc63cd"
        }
      ],
      "children": [
        {
          "type": "Box",
          "props": {
            "className": "flex flex-row items-center gap-3 flex-1"
          },
          "children": [
            {
              "type": "Box",
              "props": {
                "className": {
                  "expr": "'flex items-center justify-center w-8 h-8 min-w-8 min-h-8 rounded-full overflow-hidden shrink-0 ' + (({{auth.user}} || {{collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.customer.emailAddress}}) ? 'bg-green-500 !text-white' : ({{variables['d9e0f1a2-b3c4-5678-defa-789012345678']}} === 'contact' ? 'bg-[var(--theme-shop-button)] !text-white' : 'bg-[var(--theme-hero-bg)] !text-[var(--theme-muted-foreground)]'))"
                }
              },
              "children": [
                {
                  "type": "NavIcon",
                  "props": {
                    "icon": "Check",
                    "size": 16,
                    "className": "!text-white"
                  },
                  "condition": "{{auth.user}} || {{collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.customer.emailAddress}}"
                },
                {
                  "type": "Text",
                  "props": {
                    "className": "font-semibold text-sm !text-white"
                  },
                  "text": "1",
                  "condition": "!({{auth.user}} || {{collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.customer.emailAddress}}) && {{variables['d9e0f1a2-b3c4-5678-defa-789012345678']}} === 'contact'"
                },
                {
                  "type": "Text",
                  "props": {
                    "className": "font-semibold text-sm !text-[var(--theme-muted-foreground)]"
                  },
                  "text": "1",
                  "condition": "!({{auth.user}} || {{collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.customer.emailAddress}}) && {{variables['d9e0f1a2-b3c4-5678-defa-789012345678']}} !== 'contact'"
                }
              ]
            },
            {
              "type": "Text",
              "props": {
                "className": "text-lg font-semibold"
              },
              "text": "Contact Information"
            }
          ]
        },
        {
          "type": "Box",
          "props": {
            "className": "ml-auto shrink-0"
          },
          "children": [
            {
              "type": "NavIcon",
              "props": {
                "icon": "ChevronUp",
                "size": 16,
                "className": "!text-[var(--theme-muted-foreground)]"
              },
              "condition": "{{variables['d9e0f1a2-b3c4-5678-defa-789012345678']}} === 'contact'"
            },
            {
              "type": "NavIcon",
              "props": {
                "icon": "ChevronDown",
                "size": 16,
                "className": "!text-[var(--theme-muted-foreground)]"
              },
              "condition": "{{variables['d9e0f1a2-b3c4-5678-defa-789012345678']}} !== 'contact'"
            }
          ]
        }
      ]
    },
    {
      "type": "Box",
      "props": {
        "className": "pb-6"
      },
      "condition": "{{variables['d9e0f1a2-b3c4-5678-defa-789012345678']}} === 'contact'",
      "children": [
        {
          "type": "Box",
          "props": {
            "className": "space-y-4 flex flex-col"
          },
          "children": [
            {
              "type": "Box",
              "props": {
                "className": "flex flex-row items-center gap-1 text-sm"
              },
              "children": [
                {
                  "type": "Text",
                  "props": {
                    "className": "text-[var(--theme-muted-foreground)]"
                  },
                  "text": "Already have an account? "
                },
                {
                  "type": "Link",
                  "props": {
                    "href": "/sign-in",
                    "className": "text-blue-600 hover:underline font-medium"
                  },
                  "children": [
                    {
                      "type": "LinkText",
                      "text": "Sign in"
                    }
                  ]
                }
              ]
            },
            {
              "type": "Box",
              "props": {
                "className": "space-y-2"
              },
              "children": [
                {
                  "type": "Text",
                  "props": {
                    "className": "text-sm font-medium"
                  },
                  "text": "Email Address *"
                },
                {
                  "type": "Input",
                  "children": [
                    {
                      "type": "InputField",
                      "props": {
                        "type": "email",
                        "placeholder": "you@example.com",
                        "value": "{{local.data.form.formData.emailAddress}}"
                      },
                      "actions": [
                        {
                          "action": "5c58aa71-3ce1-41d2-bb5a-843420fd1f64"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "Box",
                  "props": {
                    "className": "min-h-[20px]"
                  },
                  "condition": "{{local.data.form.fields.emailAddress.isValid}}",
                  "children": [
                    {
                      "type": "Text",
                      "props": {
                        "className": "text-sm text-red-500 dark:text-red-400"
                      },
                      "text": "{{local.data.form.fields.emailAddress.isValid}}"
                    }
                  ]
                }
              ]
            },
            {
              "type": "Box",
              "props": {
                "className": "grid grid-cols-2 gap-4"
              },
              "children": [
                {
                  "type": "Box",
                  "props": {
                    "className": "space-y-2"
                  },
                  "children": [
                    {
                      "type": "Text",
                      "props": {
                        "className": "text-sm font-medium"
                      },
                      "text": "First Name *"
                    },
                    {
                      "type": "Input",
                      "children": [
                        {
                          "type": "InputField",
                          "props": {
                            "placeholder": "Jane",
                            "value": "{{local.data.form.formData.firstName}}"
                          },
                          "actions": [
                            {
                              "action": "c0a77baf-974c-4d07-b006-4f4b4f5a6a15"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "Box",
                      "props": {
                        "className": "min-h-[20px]"
                      },
                      "condition": "{{local.data.form.fields.firstName.isValid}}",
                      "children": [
                        {
                          "type": "Text",
                          "props": {
                            "className": "text-sm text-red-500 dark:text-red-400"
                          },
                          "text": "{{local.data.form.fields.firstName.isValid}}"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "Box",
                  "props": {
                    "className": "space-y-2"
                  },
                  "children": [
                    {
                      "type": "Text",
                      "props": {
                        "className": "text-sm font-medium"
                      },
                      "text": "Last Name *"
                    },
                    {
                      "type": "Input",
                      "children": [
                        {
                          "type": "InputField",
                          "props": {
                            "placeholder": "Doe",
                            "value": "{{local.data.form.formData.lastName}}"
                          },
                          "actions": [
                            {
                              "action": "a6836452-b059-47c2-932c-c60504eef105"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "Box",
                      "props": {
                        "className": "min-h-[20px]"
                      },
                      "condition": "{{local.data.form.fields.lastName.isValid}}",
                      "children": [
                        {
                          "type": "Text",
                          "props": {
                            "className": "text-sm text-red-500 dark:text-red-400"
                          },
                          "text": "{{local.data.form.fields.lastName.isValid}}"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "Pressable",
              "props": {
                "className": "bg-[var(--theme-shop-button)] text-white hover:bg-[var(--theme-shop-buttonHover)] flex flex-row items-center justify-center py-3 px-4 rounded-md"
              },
              "children": [
                {
                  "type": "Text",
                  "props": {
                    "className": "text-white"
                  },
                  "text": "Continue"
                }
              ],
              "actions": [
                {
                  "action": "a5c546d2-127a-4bdb-8b9f-f2c8a10471d7"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
