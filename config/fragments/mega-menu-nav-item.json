{
  "type": "Box",
  "props": {
    "className": "relative group"
  },
  "children": [
    {
      "type": "Pressable",
      "condition": { "!": [{ "var": ["$item.accent", false] }] },
      "props": {
        "className": "px-3 py-2 text-sm font-medium text-[var(--theme-header-textMuted)] hover:text-[var(--theme-header-text)] transition-colors flex items-center gap-0.5"
      },
      "actions": {
        "click": {
          "action": "navigate",
          "payload": { "path": "{{$item.path}}" }
        }
      },
      "children": [
        { "type": "Text", "text": "{{$item.label}}" }
      ]
    },
    {
      "type": "Pressable",
      "condition": { "var": ["$item.accent", false] },
      "props": {
        "className": "px-3 py-2 text-sm font-semibold text-[var(--theme-header-accent)] hover:opacity-80 transition-colors flex items-center gap-0.5"
      },
      "actions": {
        "click": {
          "action": "navigate",
          "payload": { "path": "{{$item.path}}" }
        }
      },
      "children": [
        { "type": "Text", "text": "{{$item.label}}" }
      ]
    },
    {
      "type": "Box",
      "condition": { "var": ["$item.megaMenu", false] },
      "props": {
        "className": "absolute left-0 top-full pt-0 hidden group-hover:block z-50 min-w-[200px]"
      },
      "children": [
        {
          "type": "Box",
          "props": {
            "className": "mt-0 rounded-b-lg border border-[var(--theme-header-border)] bg-[var(--theme-header-bg)] shadow-lg py-2"
          },
          "children": [
            {
              "type": "VStack",
              "props": { "className": "gap-0" },
              "map": "$item.subcategories",
              "key": "path",
              "children": [
                {
                  "type": "Pressable",
                  "props": {
                    "className": "px-4 py-2.5 text-sm text-[var(--theme-header-textMuted)] hover:bg-[var(--theme-header-bgMuted)] hover:text-[var(--theme-header-text)] transition-colors text-left"
                  },
                  "actions": {
                    "click": {
                      "action": "navigate",
                      "payload": { "path": "{{$item.path}}" }
                    }
                  },
                  "children": [
                    { "type": "Text", "text": "{{$item.label}}" }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
