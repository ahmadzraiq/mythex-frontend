{
  "type": "Pressable",
  "props": { "className": "group block bg-white rounded-lg overflow-hidden border border-gray-200 hover:shadow-lg transition-shadow" },
  "actions": {
    "click": { "action": "navigate", "payload": { "routeConfig": "product", "slug": { "var": "$item.slug" } } }
  },
  "children": [
    {
      "type": "Box",
      "props": { "className": "aspect-square relative bg-gray-100" },
      "children": [
        {
          "type": "NextImage",
          "props": {
            "src": "{{$item.productAsset.preview}}",
            "alt": "{{$item.productName}}",
            "fill": true,
            "className": "object-cover group-hover:scale-105 transition-transform duration-300",
            "sizes": "(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
          }
        },
        {
          "type": "Box",
          "props": { "className": "w-full h-full flex items-center justify-center text-gray-500" },
          "condition": { "==": [{ "var": "$item.productAsset" }, null] },
          "children": [
            { "type": "Text", "text": "No image" }
          ]
        }
      ]
    },
    {
      "type": "Box",
      "props": { "className": "p-4 space-y-2" },
      "children": [
        {
          "type": "Text",
          "props": { "className": "font-medium line-clamp-2 group-hover:text-[#1e293b] transition-colors" },
          "text": "{{$item.productName}}"
        },
        {
          "type": "Text",
          "props": { "className": "text-lg font-bold" },
          "text": {
            "expr": {
              "if": [
                { "==": [{ "var": "$item.priceWithTax.__typename" }, "SinglePrice"] },
                { "formatCurrency": [{ "/": [{ "var": "$item.priceWithTax.value" }, 100] }, { "var": "$item.currencyCode" }] },
                {
                  "if": [
                    { "!=": [{ "var": "$item.priceWithTax.min" }, { "var": "$item.priceWithTax.max" }] },
                    {
                      "cat": [
                        "from ",
                        { "formatCurrency": [{ "/": [{ "var": "$item.priceWithTax.min" }, 100] }, { "var": "$item.currencyCode" }] }
                      ]
                    },
                    { "formatCurrency": [{ "/": [{ "var": "$item.priceWithTax.min" }, 100] }, { "var": "$item.currencyCode" }] }
                  ]
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
