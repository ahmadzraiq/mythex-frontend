{
  "type": "VStack",
  "props": { "className": "gap-4" },
  "children": [
    {
      "type": "Box",
      "props": {
        "className": "aspect-square bg-[var(--theme-shop-border)] rounded-xl overflow-hidden relative group"
      },
      "children": [
        {
          "type": "Box",
          "props": {
            "className": "absolute inset-0 transition-transform duration-300 group-hover:scale-110"
          },
          "children": [
            {
              "type": "NextImage",
              "props": {
                "src": "{{product.selectedImage}}",
                "alt": "{{product.name}}",
                "fill": true,
                "className": "object-cover"
              }
            }
          ]
        }
      ]
    },
    {
      "type": "HStack",
      "condition": { ">": [{ "var": ["product.images.length", 1] }, 1] },
      "props": { "className": "gap-2 overflow-x-auto pb-2" },
      "children": [
        {
          "type": "Box",
          "map": "product.images",
          "key": "$index",
          "children": [
            {
              "type": "Pressable",
              "condition": { "!=": [{ "var": "$item" }, { "var": "product.selectedImage" }] },
              "props": {
                "className": "w-16 h-16 shrink-0 rounded-lg overflow-hidden border-2 border-transparent hover:border-[var(--theme-shop-border)]"
              },
              "actions": {
                "click": {
                  "action": "setState",
                  "payload": { "path": "product.selectedImage", "value": { "var": "$item" } }
                }
              },
              "children": [
                {
                  "type": "NextImage",
                  "props": {
                    "src": "{{$item}}",
                    "alt": "{{product.name}}",
                    "width": 64,
                    "height": 64,
                    "className": "object-cover w-full h-full"
                  }
                }
              ]
            },
            {
              "type": "Pressable",
              "condition": { "==": [{ "var": "$item" }, { "var": "product.selectedImage" }] },
              "props": {
                "className": "w-16 h-16 shrink-0 rounded-lg overflow-hidden border-2 border-[var(--theme-shop-accent)]"
              },
              "actions": {
                "click": {
                  "action": "setState",
                  "payload": { "path": "product.selectedImage", "value": { "var": "$item" } }
                }
              },
              "children": [
                {
                  "type": "NextImage",
                  "props": {
                    "src": "{{$item}}",
                    "alt": "{{product.name}}",
                    "width": 64,
                    "height": 64,
                    "className": "object-cover w-full h-full"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
