{
  "type": "Box",
  "props": {
    "className": "py-12 md:py-16"
  },
  "children": [
    {
      "type": "Box",
      "props": {
        "className": "container mx-auto px-8"
      },
      "children": [
        {
          "type": "Heading",
          "props": {
            "className": "text-3xl md:text-4xl font-bold mb-8 text-[var(--theme-card-foreground)]"
          },
          "text": "Featured Products"
        },
        {
          "type": "Box",
          "props": {
            "className": "flex flex-col items-center gap-4 py-20"
          },
          "condition": "!collections['c3d4e5f6-a7b8-9012-cdef-123456789012']?.data?.search?.items?.0",
          "children": [
            {
              "type": "Text",
              "props": {
                "className": "text-5xl"
              },
              "text": "🛍️"
            },
            {
              "type": "Heading",
              "props": {
                "size": "xl",
                "className": "font-semibold text-center text-[var(--theme-card-foreground)]"
              },
              "text": "No products yet"
            },
            {
              "type": "Text",
              "props": {
                "className": "text-center text-[var(--theme-muted-foreground)] max-w-sm"
              },
              "text": "Connect your store to start displaying featured products here."
            }
          ]
        },
        {
          "type": "Carousel",
          "condition": "!!collections['c3d4e5f6-a7b8-9012-cdef-123456789012']?.data?.search?.items?.0",
          "props": {
            "loop": true,
            "align": "start",
            "showArrows": true
          },
          "children": [
            {
              "type": "CarouselSlide",
              "map": "collections.c3d4e5f6-a7b8-9012-cdef-123456789012.data.search.items",
              "props": {
                "className": "basis-full sm:basis-1/2 lg:basis-1/3 xl:basis-1/4"
              },
              "children": [
                {
                  "type": "Box",
                  "props": {
                    "className": "group w-full text-left bg-[var(--theme-card)] rounded-lg overflow-hidden border border-[var(--border)] hover:shadow-lg transition-shadow duration-150"
                  },
                  "actions": [
                    {
                      "action": "f6046c33-0164-45b5-86aa-0710fc408247"
                    }
                  ],
                  "children": [
                    {
                      "type": "Box",
                      "props": {
                        "className": "aspect-square relative overflow-hidden bg-[var(--theme-muted)]"
                      },
                      "children": [
                        {
                          "type": "Image",
                          "props": {
                            "src": "{{context.item.data.productAsset.preview}}",
                            "alt": "{{context.item.data.productName}}",
                            "fill": true,
                            "className": "object-cover group-hover:scale-105 transition-transform duration-300"
                          },
                          "condition": "!!context?.item?.data?.productAsset?.preview"
                        },
                        {
                          "type": "Box",
                          "props": {
                            "className": "w-full h-full flex items-center justify-center"
                          },
                          "condition": "!context?.item?.data?.productAsset?.preview",
                          "children": [
                            {
                              "type": "Text",
                              "props": {
                                "className": "text-[var(--theme-muted-foreground)] text-sm"
                              },
                              "text": "No image"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "Box",
                      "props": {
                        "className": "p-4 space-y-2"
                      },
                      "children": [
                        {
                          "type": "Heading",
                          "props": {
                            "size": "sm",
                            "className": "font-medium text-[var(--theme-card-foreground)] line-clamp-2 group-hover:opacity-80 transition-colors"
                          },
                          "text": "{{context.item.data.productName}}"
                        },
                        {
                          "type": "Text",
                          "props": {
                            "className": "text-lg font-bold text-[var(--theme-card-foreground)]"
                          },
                          "text": {
                            "expr": "context?.item?.data?.priceWithTax?.__typename === 'SinglePrice' ? formatCurrency(context?.item?.data?.priceWithTax?.value, context?.item?.data?.currencyCode) : 'from ' + formatCurrency(context?.item?.data?.priceWithTax?.min, context?.item?.data?.currencyCode)"
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
