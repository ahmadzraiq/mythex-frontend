{
  "type": "Box",
  "props": {
    "className": "py-12 md:py-16"
  },
  "children": [
    {
      "type": "Box",
      "props": {
        "className": "container mx-auto px-8"
      },
      "children": [
        {
          "type": "Heading",
          "props": {
            "className": "text-3xl md:text-4xl font-bold mb-8 text-[var(--theme-content-text)]"
          },
          "text": "Featured Products"
        },
        {
          "type": "Box",
          "props": { "className": "flex flex-col items-center gap-4 py-20" },
          "condition": { "!": [{ "var": "featured.products.0" }] },
          "children": [
            {
              "type": "Text",
              "props": { "className": "text-5xl" },
              "text": "🛍️"
            },
            {
              "type": "Heading",
              "props": { "size": "xl", "className": "font-semibold text-center text-[var(--theme-content-text)]" },
              "text": "No products yet"
            },
            {
              "type": "Text",
              "props": { "className": "text-center text-[var(--theme-muted-foreground)] max-w-sm" },
              "text": "Connect your store to start displaying featured products here."
            }
          ]
        },
        {
          "type": "Carousel",
          "condition": { "!!": [{ "var": "featured.products.0" }] },
          "props": {
            "loop": true,
            "align": "start",
            "showArrows": true
          },
          "children": [
            {
              "type": "CarouselSlide",
              "map": "featured.products",
              "props": {
                "className": "basis-full sm:basis-1/2 lg:basis-1/3 xl:basis-1/4"
              },
              "children": [
                {
                  "type": "Pressable",
                  "props": {
                    "className": "group w-full text-left bg-[var(--theme-content-bg)] rounded-lg overflow-hidden border border-[var(--border)] hover:shadow-lg transition-shadow duration-150"
                  },
                  "actions": {
                    "click": {
                      "action": "navigate",
                      "payload": {
                        "routeConfig": "product",
                        "slug": {
                          "var": "$item.slug"
                        }
                      }
                    }
                  },
                  "children": [
                    {
                      "type": "Box",
                      "props": {
                        "className": "aspect-square relative overflow-hidden bg-[var(--theme-hero-bg)]"
                      },
                      "children": [
                        {
                          "type": "NextImage",
                          "props": {
                            "src": "{{$item.productAsset.preview}}",
                            "alt": "{{$item.productName}}",
                            "fill": true,
                            "className": "object-cover group-hover:scale-105 transition-transform duration-300"
                          },
                          "condition": {
                            "!!": [
                              {
                                "var": "$item.productAsset.preview"
                              }
                            ]
                          }
                        },
                        {
                          "type": "Box",
                          "props": {
                            "className": "w-full h-full flex items-center justify-center"
                          },
                          "condition": {
                            "!": [
                              {
                                "var": "$item.productAsset.preview"
                              }
                            ]
                          },
                          "children": [
                            {
                              "type": "Text",
                              "props": {
                                "className": "text-[var(--theme-muted-foreground)] text-sm"
                              },
                              "text": "No image"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "Box",
                      "props": {
                        "className": "p-4 space-y-2"
                      },
                      "children": [
                        {
                          "type": "Heading",
                          "props": {
                            "size": "sm",
                            "className": "font-medium text-[var(--theme-content-text)] line-clamp-2 group-hover:opacity-80 transition-colors"
                          },
                          "text": "{{$item.productName}}"
                        },
                        {
                          "type": "Text",
                          "props": {
                            "className": "text-lg font-bold text-[var(--theme-content-text)]"
                          },
                          "text": {
                            "expr": {
                              "if": [
                                {
                                  "==": [
                                    {
                                      "var": "$item.priceWithTax.__typename"
                                    },
                                    "SinglePrice"
                                  ]
                                },
                                {
                                  "formatCurrency": [
                                    {
                                      "var": "$item.priceWithTax.value"
                                    },
                                    {
                                      "var": "$item.currencyCode"
                                    }
                                  ]
                                },
                                {
                                  "cat": [
                                    "from ",
                                    {
                                      "formatCurrency": [
                                        {
                                          "var": "$item.priceWithTax.min"
                                        },
                                        {
                                          "var": "$item.currencyCode"
                                        }
                                      ]
                                    }
                                  ]
                                }
                              ]
                            }
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
