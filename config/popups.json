          "id": "popup-test-stacked-stack",
          "name": "StackContainer",
          "props": {
            "className": "flex flex-col gap-2 pointer-events-none"
          },
          "children": [
        {
          "type": "Box",
          "id": "popup-test-stacked-card",
          "name": "Toast",
          "animation": {
            "enter": { "type": "slideInRight", "duration": 200 },
            "exit": { "type": "slideOutRight", "duration": 180 }
          },
          "actions": [{ "action": "autoCloseToast" }],
          "props": {
            "className": "pointer-events-auto bg-white dark:bg-gray-800 rounded-xl shadow-lg px-4 py-3 flex flex-row items-start gap-3 min-w-72 max-w-sm border border-gray-100 dark:border-gray-700",
            "data-testid": "popup-stacked-card"
          },
          "children": [
            {
              "type": "Box",
              "id": "stacked-icon-box",
              "props": {
                "className": "w-8 h-8 rounded-full bg-blue-100 dark:bg-blue-900/30 items-center justify-center flex shrink-0 mt-0.5"
              },
              "children": [
                {
                  "type": "NavIcon",
                  "id": "stacked-icon",
                  "props": { "icon": "Bell", "size": 16, "color": "#3b82f6" }
                }
              ]
            },
            {
              "type": "Box",
              "id": "stacked-text-box",
              "props": { "className": "flex-1 flex flex-col gap-0.5" },
              "children": [
                {
                  "type": "Text",
                  "id": "stacked-title",
                  "props": { "className": "text-sm font-semibold text-gray-900 dark:text-white" },
                  "text": { "expr": "context.component?.props?.['title'] || 'Notification'" }
                },
                {
                  "type": "Text",
                  "id": "stacked-message",
                  "props": { "className": "text-xs text-gray-500 dark:text-gray-400 leading-relaxed" },
                  "text": { "expr": "context.component?.props?.['message'] || 'Something happened.'" }
                }
              ]
            },
            {
              "type": "Pressable",
              "id": "stacked-close-btn",
              "actions": [{ "action": "closePopup" }],
              "props": {
                "className": "shrink-0 mt-0.5 p-1 rounded hover:bg-gray-100 dark:hover:bg-gray-700"
