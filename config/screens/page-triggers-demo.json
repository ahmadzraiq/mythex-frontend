{
  "meta": {
    "title": "Page Triggers Demo"
  },
  "state": {},
  "workflows": {
    "wf-app-trigger-1": {
      "id": "wf-app-trigger-1",
      "name": "App Trigger: On Load (all pages)",
      "isTrigger": true,
      "isAppTrigger": true,
      "trigger": {
        "event": "onLoad"
      },
      "actions": [
        {
          "type": "log",
          "payload": {
            "msg": "App trigger fired on load"
          }
        }
      ]
    },
    "wf-app-trigger-2": {
      "id": "wf-app-trigger-2",
      "name": "App Trigger: On Scroll (all pages)",
      "isTrigger": true,
      "isAppTrigger": true,
      "trigger": {
        "event": "onScroll"
      },
      "actions": [
        {
          "type": "log",
          "payload": {
            "msg": "App trigger: scroll"
          }
        }
      ]
    },
    "wf-page-trigger-1": {
      "id": "wf-page-trigger-1",
      "name": "Page Trigger: This Page Only",
      "isTrigger": true,
      "isAppTrigger": false,
      "pageScope": "/page-triggers-demo",
      "trigger": {
        "event": "onLoad"
      },
      "actions": [
        {
          "type": "log",
          "payload": {
            "msg": "Page trigger: fired only on /page-triggers-demo"
          }
        }
      ]
    },
    "wf-legacy-empty-scope": {
      "id": "wf-legacy-empty-scope",
      "name": "Legacy: empty pageScope (should migrate to isAppTrigger=true)",
      "isTrigger": true,
      "pageScope": "",
      "trigger": {
        "event": "onLoad"
      },
      "actions": [
        {
          "type": "log",
          "payload": {
            "msg": "Legacy trigger — migrated to app scope"
          }
        }
      ]
    }
  },
