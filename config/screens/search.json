{
  "meta": { "title": "Search Products" },
  "state": { "searchQuery": "", "currentPage": 1 },
  "layout": "store",
  "initActions": [{ "action": "fetchNavCollections" }, { "action": "fetchSearchResults" }],
  "content": {
    "type": "Box",
    "props": { "className": "w-full max-w-screen-xl mx-auto px-4 py-8" },
    "children": [
      {
        "type": "Box",
        "props": { "className": "mb-8" },
        "children": [
          {
            "type": "Heading",
            "props": { "className": "text-3xl font-bold mb-2" },
            "text": { "expr": { "if": [{ "!=": [{ "var": "searchQuery" }, ""] }, { "cat": ["Search results for \"", { "var": "searchQuery" }, "\""] }, "Search Products"] } }
          },
          {
            "type": "Box",
            "props": { "className": "flex items-center gap-2 mt-4 max-w-xl" },
            "children": [
              {
                "type": "Input",
                "props": { "className": "flex-1" },
                "children": [
                  {
                    "type": "InputField",
                    "props": { "placeholder": "Search for products...", "value": "{{searchQuery}}" },
                    "actions": { "change": { "action": "setState", "payload": { "path": "searchQuery", "value": "$event" } } }
                  }
                ]
              },
              {
                "type": "Button",
                "props": { "className": "bg-[#1e293b] text-white hover:bg-[#334155] px-4" },
                "children": [{ "type": "ButtonText", "props": { "className": "!text-white" }, "text": "Search" }],
                "actions": { "click": { "action": "fetchSearchResults" } }
              }
            ]
          }
        ]
      },
      {
        "type": "Box",
        "props": { "className": "text-center py-12" },
        "condition": { "==": [{ "var": ["searchResults.totalItems", 0] }, 0] },
        "children": [
          { "type": "Text", "props": { "className": "text-gray-500 text-lg" }, "text": "No products found" },
          { "type": "Text", "props": { "className": "text-sm text-gray-500 mt-2" }, "text": "Try adjusting your search terms" }
        ]
      },
      {
        "type": "Box",
        "props": { "className": "space-y-8" },
        "condition": { ">": [{ "var": ["searchResults.totalItems", 0] }, 0] },
        "children": [
          {
            "type": "Box",
            "props": { "className": "flex items-center justify-between" },
            "children": [
              {
                "type": "Text",
                "props": { "className": "text-sm text-gray-500" },
                "text": { "expr": { "var": ["searchResults.totalItems", 0] }, "suffix": " products" }
              }
            ]
          },
          {
            "type": "Box",
            "props": { "className": "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" },
            "children": [
              {
                "type": "Box",
                "map": "searchResults.items",
                "key": "searchProduct",
                "props": { "className": "contents" },
                "children": [{ "$ref": "fragments/product-card" }]
              }
            ]
          }
        ]
      }
    ]
  }
}
