{
  "meta": {
    "title": "Search Products"
  },
  "state": {},
  "layout": "store",
  "initActions": [
    {
      "action": "fetchSearchResults"
    }
  ],
  "content": {
    "type": "Box",
    "props": {
      "className": "container mx-auto px-4 py-8"
    },
    "children": [
      {
        "$ref": "fragments/sections/search-loading-skeleton"
      },
      {
        "type": "Box",
        "_meta": {
          "section": "search-grid",
          "description": "Search heading + filters sidebar + sort bar + product grid"
        },
        "props": {
          "className": "grid grid-cols-1 lg:grid-cols-4 gap-8"
        },
        "condition": "!{{search.loading}}",
        "children": [
          {
            "type": "Box",
            "props": {
              "className": "mb-6 lg:mb-0 lg:col-span-4"
            },
            "children": [
              {
                "type": "Heading",
                "props": {
                  "className": "text-3xl font-bold"
                },
                "text": { "expr": "({{route.q}} || '') !== '' ? 'Search results for \"' + ({{route.q}} || '') + '\"' : 'Search'" }
              }
            ]
          },
          {
            "type": "Box",
            "props": {
              "className": "lg:col-span-1"
            },
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "space-y-8"
                },
                "children": [
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex flex-row items-center justify-between"
                    },
                    "children": [
                      {
                        "type": "Heading",
                        "props": {
                          "className": "font-semibold text-lg text-[var(--theme-foreground)]"
                        },
                        "text": "Filters"
                      },
                      {
                        "type": "Pressable",
                        "condition": "arrayLength({{route.facets}} || []) > 0",
                        "props": {
                          "className": "text-sm text-[var(--theme-muted-foreground)] hover:text-[var(--theme-foreground)] transition-colors"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-sm text-[var(--theme-muted-foreground)]"
                            },
                            "text": "Clear all"
                          }
                        ],
                        "actions": {
                          "click": {
                            "type": "navigateWithQuery",
                            "path": "{{route.path}}",
                            "queryParams": {
                              "facets": [],
                              "page": "1"
                            }
                          }
                        }
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "map": { "expr": "groupBy({{search.facetValues}} || [], 'facetValue.facet.name', 'facetValue.facet.id')" },
                    "key": "$item.id",
                    "props": {
                      "className": "flex flex-col gap-5"
                    },
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": "space-y-4"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "font-medium text-sm text-[var(--theme-foreground)] capitalize"
                            },
                            "text": "{{$item.key}}"
                          },
                          {
                            "type": "Box",
                            "props": {
                              "className": "flex flex-col gap-2"
                            },
                            "children": [
                              {
                                "type": "Box",
                                "map": "$item.items",
                                "key": "$item.facetValue.id",
                                "props": {
                                  "className": "contents"
                                },
                                "children": [
                              {
                                "type": "Pressable",
                                "props": {
                                  "className": "flex flex-row items-center gap-2 cursor-pointer group"
                                },
                                "actions": {
                  "click": {
                    "type": "navigateWithQuery",
                    "path": "{{route.path}}",
                    "queryParams": {
                      "facets": {
                        "expr": "toggleInArray({{route.facets}} || [], {{$item.facetValue.id}})"
                      },
                      "page": "1"
                    }
                  }
                                },
                                "children": [
                                  {
                                    "type": "Box",
                                    "props": {
                                      "className": "w-4 h-4 rounded border flex items-center justify-center flex-shrink-0 transition-colors border-[var(--theme-border)]"
                                    },
                                    "condition": "!arrayIncludes({{route.facets}} || [], {{$item.facetValue.id}})",
                                    "children": []
                                  },
                                  {
                                    "type": "Box",
                                    "props": {
                                      "className": "w-4 h-4 rounded border flex items-center justify-center flex-shrink-0 transition-colors bg-[var(--theme-shop-button)] border-[var(--theme-shop-button)]"
                                    },
                                    "condition": "arrayIncludes({{route.facets}} || [], {{$item.facetValue.id}})",
                                    "children": [
                                      {
                                        "type": "NavIcon",
                                        "props": {
                                          "icon": "Check",
                                          "size": 10,
                                          "className": "!text-white"
                                        }
                                      }
                                    ]
                                  },
                                  {
                                    "type": "Text",
                                    "props": {
                                      "className": "text-sm text-[var(--theme-foreground)] transition-colors"
                                    },
                                    "text": "{{$item.facetValue.name}}"
                                  },
                                  {
                                    "type": "Text",
                                    "props": {
                                      "className": "text-xs text-[var(--theme-muted-foreground)]"
                                    },
                                    "text": "({{$item.count}})"
                                  }
                                ]
                              }
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Box",
            "props": {
              "className": "lg:col-span-3 space-y-8"
            },
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "relative z-10 w-full flex flex-row items-center justify-between"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm text-[var(--theme-muted-foreground)]"
                    },
                    "text": { "expr": "({{search.totalItems}} || 0) === 1 ? '1 product' : ({{search.totalItems}} || 0) + ' products'" }
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "relative flex-shrink-0"
                    },
                    "children": [
                      {
                        "type": "Pressable",
                        "props": {
                          "className": "fixed inset-0 z-[9998]"
                        },
                        "condition": "{{sortMenuOpen}}",
                        "actions": {
                          "click": {
                            "type": "setVar",
                            "path": "sortMenuOpen",
                            "value": false
                          }
                        }
                      },
                      {
                        "type": "Pressable",
                        "props": {
                          "className": "relative z-50 flex flex-row items-center gap-2 h-9 px-3 rounded-md border border-[var(--theme-border)] bg-[var(--theme-content-bg)] hover:bg-[var(--theme-hero-bg)] min-w-[180px] justify-between"
                        },
                        "actions": {
                          "click": {
                            "type": "toggle",
                            "path": "sortMenuOpen"
                          }
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-sm text-[var(--theme-foreground)]"
                            },
                            "text": {
                              "expr": "{{route.sort}} === 'name-asc' ? 'Name: A to Z' : {{route.sort}} === 'name-desc' ? 'Name: Z to A' : {{route.sort}} === 'price-asc' ? 'Price: Low to High' : 'Price: High to Low'"
                            }
                          },
                          {
                            "type": "NavIcon",
                            "props": {
                              "icon": "ChevronDown",
                              "size": 14,
                              "color": "#6b7280"
                            }
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "condition": "{{sortMenuOpen}}",
                        "props": {
                          "className": "absolute right-0 top-full mt-1 min-w-[180px] rounded-md border border-[var(--theme-border)] bg-[var(--theme-content-bg)] shadow-md z-[9999] py-1"
                        },
                        "children": [
                          {
                            "type": "Pressable",
                            "props": {
                              "className": "flex flex-row items-center justify-between w-full px-3 py-2 hover:bg-[var(--theme-hero-bg)]"
                            },
                            "actions": {
                              "click": {
                                "type": "runMultiple",
                                "actions": [
                                  {
                                    "type": "setVar",
                                    "path": "sortMenuOpen",
                                    "value": false
                                  },
                                  {
                                    "type": "set",
                                    "path": "route.sort",
                                    "value": "name-asc"
                                  },
                                  {
                                    "type": "setVar",
                                    "path": "searchSkip",
                                    "value": 0
                                  },
                                  {
                                    "action": "fetchSearchResults"
                                  },
                                  {
                                    "action": "navigate",
                                    "payload": {
                                      "path": "{{route.path}}?q={{route.q}}&sort=name-asc&page=1"
                                    }
                                  }
                                ]
                              }
                            },
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "className": "text-sm text-[var(--theme-foreground)]"
                                },
                                "text": "Name: A to Z"
                              },
                              {
                                "type": "NavIcon",
                                "props": {
                                  "icon": "Check",
                                  "size": 14,
                                  "color": "#7c3aed"
                                },
                                "condition": "{{route.sort}} === 'name-asc'"
                              }
                            ]
                          },
                          {
                            "type": "Pressable",
                            "props": {
                              "className": "flex flex-row items-center justify-between w-full px-3 py-2 hover:bg-[var(--theme-hero-bg)]"
                            },
                            "actions": {
                              "click": {
                                "type": "runMultiple",
                                "actions": [
                                  {
                                    "type": "setVar",
                                    "path": "sortMenuOpen",
                                    "value": false
                                  },
                                  {
                                    "type": "set",
                                    "path": "route.sort",
                                    "value": "name-desc"
                                  },
                                  {
                                    "type": "setVar",
                                    "path": "searchSkip",
                                    "value": 0
                                  },
                                  {
                                    "action": "fetchSearchResults"
                                  },
                                  {
                                    "action": "navigate",
                                    "payload": {
                                      "path": "{{route.path}}?q={{route.q}}&sort=name-desc&page=1"
                                    }
                                  }
                                ]
                              }
                            },
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "className": "text-sm text-[var(--theme-foreground)]"
                                },
                                "text": "Name: Z to A"
                              },
                              {
                                "type": "NavIcon",
                                "props": {
                                  "icon": "Check",
                                  "size": 14,
                                  "color": "#7c3aed"
                                },
                                "condition": "{{route.sort}} === 'name-desc'"
                              }
                            ]
                          },
                          {
                            "type": "Pressable",
                            "props": {
                              "className": "flex flex-row items-center justify-between w-full px-3 py-2 hover:bg-[var(--theme-hero-bg)]"
                            },
                            "actions": {
                              "click": {
                                "type": "runMultiple",
                                "actions": [
                                  {
                                    "type": "setVar",
                                    "path": "sortMenuOpen",
                                    "value": false
                                  },
                                  {
                                    "type": "set",
                                    "path": "route.sort",
                                    "value": "price-asc"
                                  },
                                  {
                                    "type": "setVar",
                                    "path": "searchSkip",
                                    "value": 0
                                  },
                                  {
                                    "action": "fetchSearchResults"
                                  },
                                  {
                                    "action": "navigate",
                                    "payload": {
                                      "path": "{{route.path}}?q={{route.q}}&sort=price-asc&page=1"
                                    }
                                  }
                                ]
                              }
                            },
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "className": "text-sm text-[var(--theme-foreground)]"
                                },
                                "text": "Price: Low to High"
                              },
                              {
                                "type": "NavIcon",
                                "props": {
                                  "icon": "Check",
                                  "size": 14,
                                  "color": "#7c3aed"
                                },
                                "condition": "{{route.sort}} === 'price-asc'"
                              }
                            ]
                          },
                          {
                            "type": "Pressable",
                            "props": {
                              "className": "flex flex-row items-center justify-between w-full px-3 py-2 hover:bg-[var(--theme-hero-bg)]"
                            },
                            "actions": {
                              "click": {
                                "type": "runMultiple",
                                "actions": [
                                  {
                                    "type": "setVar",
                                    "path": "sortMenuOpen",
                                    "value": false
                                  },
                                  {
                                    "type": "set",
                                    "path": "route.sort",
                                    "value": "price-desc"
                                  },
                                  {
                                    "type": "setVar",
                                    "path": "searchSkip",
                                    "value": 0
                                  },
                                  {
                                    "action": "fetchSearchResults"
                                  },
                                  {
                                    "action": "navigate",
                                    "payload": {
                                      "path": "{{route.path}}?q={{route.q}}&sort=price-desc&page=1"
                                    }
                                  }
                                ]
                              }
                            },
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "className": "text-sm text-[var(--theme-foreground)]"
                                },
                                "text": "Price: High to Low"
                              },
                              {
                                "type": "NavIcon",
                                "props": {
                                  "icon": "Check",
                                  "size": 14,
                                  "color": "#7c3aed"
                                },
                                "condition": "{{route.sort}} === 'price-desc'"
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Box",
                "condition": "({{search.totalItems}} || 0) === 0",
                "props": {
                  "className": "text-center py-12"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-[var(--theme-muted-foreground)]"
                    },
                    "text": "No products found"
                  }
                ]
              },
              {
                "type": "Box",
                "condition": "{{search.totalItems}} > 0",
                "props": {
                  "className": "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6"
                },
                "children": [
                  {
                    "type": "Box",
                    "map": "search.items",
                    "key": "searchProduct",
                    "props": {
                      "className": "contents"
                    },
                    "children": [
                      {
                        "$ref": "fragments/cards/product-card"
                      }
                    ]
                  }
                ]
              },
              {
                "$ref": "fragments/pagination/search-pagination"
              }
            ]
          }
        ]
      }
    ]
  }
}
