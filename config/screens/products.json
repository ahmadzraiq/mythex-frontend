{
  "meta": {
    "title": "Products",
    "description": "Manage products"
  },
  "state": {
    "modal": {
      "create": false,
      "editProduct": null,
      "deleteProduct": null
    },
    "form": {
      "product": {
        "name": "",
        "price": "",
        "category": "",
        "description": ""
      }
    }
  },
  "layout": "authenticated",
  "content": [
    {
      "type": "Box",
      "props": {
        "className": "flex-1 min-h-0 flex flex-col overflow-hidden"
      },
      "children": [
        {
          "type": "Box",
          "props": {
            "className": "p-6 flex-1 overflow-auto"
          },
          "children": [
            {
              "type": "HStack",
              "props": {
                "className": "justify-between items-center mb-6"
              },
              "children": [
                {
                  "type": "Heading",
                  "props": {
                    "size": "xl",
                    "className": "text-typography-900"
                  },
                  "text": "Products"
                },
                {
                  "type": "Button",
                  "props": {
                    "action": "primary"
                  },
                  "text": "+ Add Product",
                  "actions": {
                    "click": {
                      "action": "openCreateModal"
                    }
                  }
                }
              ]
            },
            {
              "type": "Box",
              "condition": {
                "var": "products.loading"
              },
              "props": {
                "className": "flex justify-center py-12"
              },
              "children": [
                {
                  "type": "Spinner",
                  "props": {
                    "size": "large"
                  }
                }
              ]
            },
            {
              "type": "Box",
              "condition": {
                "!": {
                  "var": "products.loading"
                }
              },
              "props": {
                "className": "border border-outline-100 rounded-lg overflow-hidden"
              },
              "children": [
                {
                  "type": "Table",
                  "props": {
                    "className": "w-full"
                  },
                  "children": [
                    {
                      "type": "TableHeader",
                      "children": [
                        {
                          "type": "TableRow",
                          "children": [
                            {
                              "type": "TableHead",
                              "props": {
                                "className": "p-4 text-left"
                              },
                              "text": "Name"
                            },
                            {
                              "type": "TableHead",
                              "props": {
                                "className": "p-4 text-left"
                              },
                              "text": "Price"
                            },
                            {
                              "type": "TableHead",
                              "props": {
                                "className": "p-4 text-left"
                              },
                              "text": "Category"
                            },
                            {
                              "type": "TableHead",
                              "props": {
                                "className": "p-4 text-right"
                              },
                              "text": "Actions"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "TableBody",
                      "children": [
                        {
                          "type": "TableRow",
                          "map": "products.list",
                          "key": "row",
                          "children": [
                            {
                              "type": "TableData",
                              "props": {
                                "className": "p-4"
                              },
                              "text": "{{$item.name}}"
                            },
                            {
                              "type": "TableData",
                              "props": {
                                "className": "p-4"
                              },
                              "text": "${{$item.price}}"
                            },
                            {
                              "type": "TableData",
                              "props": {
                                "className": "p-4"
                              },
                              "text": "{{$item.category}}"
                            },
                            {
                              "type": "TableData",
                              "props": {
                                "className": "p-4 text-right"
                              },
                              "children": [
                                {
                                  "type": "HStack",
                                  "props": {
                                    "className": "justify-end gap-2"
                                  },
                                  "children": [
                                    {
                                      "type": "Button",
                                      "props": {
                                        "size": "sm",
                                        "variant": "outline"
                                      },
                                      "text": "Edit",
                                      "actions": {
                                        "click": {
                                          "action": "setState",
                                          "payload": {
                                            "path": "modal.editProduct",
                                            "value": {
                                              "var": "$item"
                                            }
                                          }
                                        }
                                      }
                                    },
                                    {
                                      "type": "Button",
                                      "props": {
                                        "size": "sm",
                                        "variant": "outline"
                                      },
                                      "text": "Delete",
                                      "actions": {
                                        "click": {
                                          "action": "setState",
                                          "payload": {
                                            "path": "modal.deleteProduct",
                                            "value": {
                                              "var": "$item"
                                            }
                                          }
                                        }
                                      }
                                    }
                                  ]
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "$ref": "fragments/modals/createProduct"
    },
    {
      "$ref": "fragments/modals/editProduct"
    },
    {
      "$ref": "fragments/modals/deleteProduct"
    }
  ],
  "initActions": [
    {
      "action": "fetchProducts"
    }
  ]
}
