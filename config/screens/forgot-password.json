{
  "meta": {
    "title": "Forgot Password"
  },
  "layout": "store",
  "content": {
    "type": "Box",
    "props": {
      "className": "flex flex-1 w-full items-center justify-center px-4"
    },
    "children": [
      {
        "type": "Box",
        "props": {
          "className": "w-full max-w-md min-w-0 space-y-6 flex flex-col"
        },
        "children": [
          {
            "type": "Box",
            "props": {
              "className": "space-y-2 text-center"
            },
            "children": [
              {
                "type": "Heading",
                "props": {
                  "className": "text-3xl font-bold text-center"
                },
                "text": "Reset Password"
              },
              {
                "type": "Text",
                "props": {
                  "className": "text-[var(--theme-muted-foreground)] text-center"
                },
                "text": "Enter your email and we'll send a reset link."
              }
            ]
          },
          {
            "type": "Box",
            "props": {
              "className": "bg-green-50 border border-green-200 rounded-lg px-4 py-3 dark:bg-green-900/20 dark:border-green-800"
            },
            "condition": "{{_workflow.lastAction}} === 'forgotPasswordMutation'",
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "text-sm text-green-700 dark:text-green-300"
                },
                "text": "If that email exists, a reset link has been sent."
              }
            ]
          },
          {
            "type": "Card",
            "props": {
              "className": "w-full !rounded-xl !border !border-[var(--theme-border)] !bg-[var(--theme-content-bg)] !py-6 !shadow-sm"
            },
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "px-6 space-y-4"
                },
                "children": [
                  {
                    "type": "Box",
                    "props": {
                      "className": "space-y-2"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-sm font-medium leading-none"
                        },
                        "text": "Email"
                      },
                      {
                        "type": "Input",
                        "props": {
                          "variant": "outline",
                          "size": "sm",
                          "className": "w-full !rounded-md !border-[var(--theme-border)] !bg-[var(--theme-content-bg)]"
                        },
                        "children": [
                          {
                            "type": "InputField",
                            "props": {
                              "type": "email",
                              "placeholder": "you@example.com",
                              "placeholderTextColor": "#9ca3af",
                              "value": "{{local.data.form.formData.emailAddress}}",
                              "className": "!text-[var(--theme-foreground)]"
                            },
                            "actions": [
                              {
                                "action": "e30fd51c-3868-4e3e-a186-4f8653ba6225"
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Pressable",
                    "props": {
                      "className": "w-full !bg-[var(--theme-shop-button)] hover:!bg-[var(--theme-shop-buttonHover)] !text-white flex flex-row items-center justify-center py-3 rounded-md"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-white"
                        },
                        "text": "Send Reset Link"
                      }
                    ],
                    "actions": [
                      {
                        "action": "21d74dc9-f452-49e3-8bd2-75cff5ea35ae"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Box",
                "props": {
                  "className": "px-6 mt-6 flex flex-row items-center justify-center"
                },
                "children": [
                  {
                    "type": "Pressable",
                    "actions": [
                      {
                        "action": "3517ed88-9e35-42fd-8d44-650cb590d210"
                      }
                    ],
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-sm text-[var(--theme-shop-button)] underline hover:opacity-80"
                        },
                        "text": "← Back to Sign In"
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "initActions": []
}
