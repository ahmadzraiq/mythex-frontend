{
  "meta": {
    "title": "Forgot Password"
  },
  "state": {
    "form": {
      "emailAddress": ""
    },
    "errors": {}
  },
  "ui": {
    "type": "Box",
    "props": {
      "className": "flex min-h-screen items-center justify-center px-4"
    },
    "children": [
      {
        "type": "Box",
        "props": {
          "className": "w-full max-w-md space-y-6"
        },
        "children": [
          {
            "type": "Box",
            "props": {
              "className": "space-y-2 text-center"
            },
            "children": [
              {
                "type": "Heading",
                "props": {
                  "className": "text-3xl font-bold"
                },
                "text": "Reset Password"
              },
              {
                "type": "Text",
                "props": {
                  "className": "text-gray-500"
                },
                "text": "Enter your email and we'll send a reset link."
              }
            ]
          },
          {
            "type": "Box",
            "props": {
              "className": "bg-green-50 border border-green-200 rounded-lg px-4 py-3"
            },
            "condition": {
              "==": [
                {
                  "var": "_workflow.lastAction"
                },
                "forgotPasswordMutation"
              ]
            },
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "text-sm text-green-700"
                },
                "text": "If that email exists, a reset link has been sent."
              }
            ]
          },
          {
            "type": "Card",
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "p-6 space-y-4"
                },
                "children": [
                  {
                    "type": "Box",
                    "props": {
                      "className": "space-y-2"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-sm font-medium"
                        },
                        "text": "Email"
                      },
                      {
                        "type": "Input",
                        "children": [
                          {
                            "type": "InputField",
                            "props": {
                              "type": "email",
                              "placeholder": "you@example.com",
                              "value": "{{form.emailAddress}}"
                            },
                            "actions": {
                              "change": {
                                "action": "setState",
                                "payload": {
                                  "path": "form.emailAddress",
                                  "value": "$event"
                                }
                              }
                            }
                          }
                        ]
                      },
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-sm text-red-500"
                        },
                        "condition": {
                          "!=": [
                            {
                              "var": "errors.form.emailAddress"
                            },
                            null
                          ]
                        },
                        "text": "{{errors.form.emailAddress}}"
                      }
                    ]
                  },
                  {
                    "type": "Button",
                    "props": {
                      "className": "w-full bg-[#1e293b] text-white hover:bg-[#334155]"
                    },
                    "children": [{ "type": "ButtonText", "props": { "className": "!text-white" }, "text": "Send Reset Link" }],
                    "actions": {
                      "click": {
                        "action": "forgotPasswordMutation"
                      }
                    }
                  }
                ]
              },
              {
                "type": "Box",
                "props": {
                  "className": "px-6 pb-6 text-center"
                },
                "children": [
                  {
                    "type": "Pressable",
                    "actions": {
                      "click": {
                        "action": "navigate",
                        "payload": {
                          "path": "/sign-in"
                        }
                      }
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-sm text-[#1e293b] hover:underline"
                        },
                        "text": "\u2190 Back to Sign In"
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "initActions": [
    {
      "action": "fetchNavCollections"
    }
  ]
}