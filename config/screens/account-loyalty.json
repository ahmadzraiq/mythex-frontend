{
  "meta": {
    "title": "Loyalty | SaraZ",
    "description": "Your loyalty points"
  },
  "state": {
    "loyaltyPoints": 1240,
    "tier": "Silver",
    "history": [
      { "date": "Feb 15, 2025", "description": "Order ORD-2847", "points": 60 },
      { "date": "Feb 10, 2025", "description": "Order ORD-2841", "points": 43 },
      { "date": "Feb 5, 2025", "description": "Order ORD-2835", "points": 90 }
    ]
  },
  "layout": "account",
  "content": {
    "type": "Box",
    "props": {
      "className": "w-full px-4 sm:px-6 py-8 md:py-12"
    },
    "children": [
      {
        "type": "Text",
        "props": { "className": "text-[var(--theme-shop-textMuted)] text-xs font-medium tracking-widest uppercase mb-2" },
        "text": "Rewards"
      },
      {
        "type": "Heading",
        "props": { "size": "2xl", "className": "mb-8 font-light" },
        "text": "Loyalty"
      },
      {
        "type": "Box",
        "props": { "className": "p-6 bg-[var(--theme-content-bg)] rounded-xl border border-[var(--theme-shop-border)] mb-8" },
        "children": [
          { "type": "Text", "props": { "className": "text-xs font-medium tracking-widest text-[var(--theme-shop-textMuted)] uppercase mb-2" }, "text": "Current balance" },
          { "type": "Heading", "props": { "size": "xl", "className": "text-[var(--theme-shop-heading)] font-light" }, "text": "{{loyaltyPoints}} points" },
          { "type": "Badge", "props": { "size": "sm", "className": "mt-2 bg-[var(--theme-shop-button)] text-white" }, "children": [{ "type": "BadgeText", "text": "{{tier}}" }] },
          { "type": "Text", "props": { "className": "text-sm text-[var(--theme-shop-textMuted)] mt-4" }, "text": "Redeem at checkout. 1 point = AED 0.10" }
        ]
      },
      {
        "type": "Text",
        "props": { "className": "text-xs font-medium tracking-widest text-[var(--theme-shop-textMuted)] uppercase mb-4" },
        "text": "Recent activity"
      },
      {
        "type": "VStack",
        "props": { "className": "gap-4" },
        "children": [
          {
            "type": "Box",
            "map": "history",
            "key": "$item.date",
            "props": { "className": "p-4 bg-[var(--theme-content-bg)] rounded-lg border border-[var(--theme-shop-border)] flex justify-between items-center" },
            "children": [
              { "type": "VStack", "props": { "className": "gap-0" }, "children": [
                { "type": "Text", "props": { "className": "font-medium" }, "text": "{{$item.description}}" },
                { "type": "Text", "props": { "className": "text-sm text-[var(--theme-shop-textMuted)]" }, "text": "{{$item.date}}" }
              ]},
              { "type": "Text", "props": { "className": "font-semibold text-[var(--theme-shop-button)]" }, "text": "+{{$item.points}}" }
            ]
          }
        ]
      }
    ]
  }
}
