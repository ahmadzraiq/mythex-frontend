{
  "meta": { "title": "Popup System Test" },
  "layout": "store",
  "content": {
    "type": "Box",
    "props": { "className": "w-full max-w-3xl mx-auto px-4 py-10 flex flex-col gap-6" },
    "children": [

      {
        "type": "Box",
        "props": { "className": "flex flex-col gap-1" },
        "children": [
          {
            "type": "Heading",
            "props": { "size": "2xl", "className": "font-bold text-gray-900 dark:text-gray-100" },
            "text": "Popup System"
          },
          {
            "type": "Text",
            "props": { "className": "text-sm text-gray-500 dark:text-gray-400" },
            "text": "WeWeb-style popup engine — open modals, sheets, and alerts via workflow actions. Content is composed from generic Box/Text/Button containers."
          }
        ]
      },

      {
        "type": "Box",
        "props": { "className": "w-full rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 overflow-hidden" },
        "children": [
          {
            "type": "Box",
            "props": { "className": "px-5 py-4 border-b border-gray-100 dark:border-gray-800 flex flex-row items-center gap-2" },
            "children": [
              { "type": "NavIcon", "props": { "icon": "Layers", "size": 15, "color": "#6366f1" } },
              { "type": "Text", "props": { "className": "text-sm font-semibold text-gray-900 dark:text-white" }, "text": "Popup Types" }
            ]
          },
          {
            "type": "Box",
            "props": { "className": "p-5 flex flex-col gap-4" },
            "children": [
              {
                "type": "Box",
                "props": { "className": "flex flex-row flex-wrap gap-3" },
                "children": [
                  {
                    "type": "Button",
                    "props": { "action": "primary", "size": "sm", "data-testid": "open-modal-btn" },
                    "actions": [{ "action": "openTestModal" }],
                    "children": [
                      { "type": "NavIcon", "props": { "icon": "SquareX", "size": 14 } },
                      { "type": "ButtonText", "text": "Open Modal" }
                    ]
                  },
                  {
                    "type": "Button",
                    "props": { "action": "primary", "size": "sm", "data-testid": "open-sheet-btn" },
                    "actions": [{ "action": "openTestSheet" }],
                    "children": [
                      { "type": "NavIcon", "props": { "icon": "PanelRight", "size": 14 } },
                      { "type": "ButtonText", "text": "Open Sheet" }
                    ]
                  },
                  {
                    "type": "Button",
                    "props": { "action": "primary", "size": "sm", "data-testid": "open-alert-btn" },
                    "actions": [{ "action": "openTestAlert" }],
                    "children": [
                      { "type": "NavIcon", "props": { "icon": "AlertTriangle", "size": 14 } },
                      { "type": "ButtonText", "text": "Open Alert" }
                    ]
                  },
                  {
                    "type": "Button",
                    "props": { "action": "outline", "size": "sm", "data-testid": "close-all-btn" },
                    "actions": [{ "action": "closeAllTestPopups" }],
                    "children": [
                      { "type": "NavIcon", "props": { "icon": "X", "size": 14 } },
                      { "type": "ButtonText", "text": "Close All" }
                    ]
                  }
                ]
              },
              {
                "type": "Box",
                "props": { "className": "bg-gray-50 dark:bg-gray-800/50 rounded-xl p-4 flex flex-col gap-2" },
                "children": [
                  { "type": "Text", "props": { "className": "text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide" }, "text": "How it works" },
                  { "type": "Text", "props": { "className": "text-xs text-gray-500 dark:text-gray-400 leading-relaxed" }, "text": "Each popup is a JSON node tree stored in config/popups.json. Content uses standard Box/Text/Button containers — no Gluestack Modal components. Close buttons dispatch the closeAllPopups workflow action." }
                ]
              }
            ]
          }
        ]
      },

      {
        "type": "Box",
        "props": { "className": "w-full rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 overflow-hidden" },
        "children": [
          {
            "type": "Box",
            "props": { "className": "px-5 py-4 border-b border-gray-100 dark:border-gray-800 flex flex-row items-center gap-2" },
            "children": [
              { "type": "NavIcon", "props": { "icon": "Clock", "size": 15, "color": "#6366f1" } },
              { "type": "Text", "props": { "className": "text-sm font-semibold text-gray-900 dark:text-white" }, "text": "Wait Close Event" }
            ]
          },
          {
            "type": "Box",
            "props": { "className": "p-5 flex flex-col gap-4" },
            "children": [
              {
                "type": "Text",
                "props": { "className": "text-sm text-gray-500 dark:text-gray-400" },
                "text": "When waitClose=true the workflow suspends at the openPopup step and only continues after the popup is dismissed. The next step runs once the popup closes."
              },
              {
                "type": "Box",
                "props": { "className": "flex flex-row flex-wrap gap-3 items-center" },
                "children": [
                  {
                    "type": "Button",
                    "props": { "action": "primary", "size": "sm", "data-testid": "open-wait-btn" },
                    "actions": [{ "action": "openAndWaitClose" }],
                    "children": [
                      { "type": "NavIcon", "props": { "icon": "Play", "size": 14 } },
                      { "type": "ButtonText", "text": "Open & Wait" }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": { "className": "flex flex-row gap-2 items-center" },
                    "children": [
                      { "type": "Text", "props": { "className": "text-xs text-gray-400 dark:text-gray-500" }, "text": "Result:" },
                      {
                        "type": "Box",
                        "props": { "className": "bg-gray-100 dark:bg-gray-800 rounded-lg px-3 py-1" },
                        "children": [{
                          "type": "Text",
                          "props": { "className": "text-xs font-mono text-indigo-600 dark:text-indigo-400", "data-testid": "wait-result-text" },
                          "text": "{{variables['popup-test-0000-0000-0000-wait-result'] || '(waiting…)'}}"
                        }]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }

    ]
  }
}
