{
  "meta": {
    "title": "Reset Password"
  },
  "layout": "store",
  "content": {
    "type": "Box",
    "props": {
      "className": "flex flex-1 w-full items-center justify-center px-4"
    },
    "children": [
      {
        "type": "Box",
        "props": {
          "className": "w-full max-w-md min-w-0 space-y-6 flex flex-col"
        },
        "children": [
          {
            "type": "Box",
            "props": {
              "className": "space-y-2 text-center"
            },
            "children": [
              {
                "type": "Heading",
                "props": {
                  "className": "text-3xl font-bold text-center"
                },
                "text": "Set New Password"
              },
              {
                "type": "Text",
                "props": {
                  "className": "text-[var(--theme-muted-foreground)] text-center"
                },
                "text": "Choose a strong new password for your account."
              }
            ]
          },
          {
            "type": "Card",
            "props": {
              "className": "w-full !rounded-xl !border !border-[var(--theme-border)] !bg-[var(--theme-content-bg)] !py-6 !shadow-sm"
            },
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "px-6 space-y-4"
                },
                "children": [
                  {
                    "type": "Box",
                    "props": {
                      "className": "space-y-2"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-sm font-medium leading-none"
                        },
                        "text": "New Password"
                      },
                      {
                        "type": "Input",
                        "props": {
                          "variant": "outline",
                          "size": "sm",
                          "className": "w-full !rounded-md !border-[var(--theme-border)] !bg-[var(--theme-content-bg)]"
                        },
                        "children": [
                          {
                            "type": "InputField",
                            "props": {
                              "type": "password",
                              "placeholder": "••••••••",
                              "placeholderTextColor": "#9ca3af",
                              "value": "{{variables['b9c0d1e2-f3a4-5678-bcde-678901234567'].value.password}}",
                              "className": "!text-[var(--theme-foreground)]"
                            },
                            "actions": {
                              "change": {
                                "action": "setState",
                                "payload": {
                                  "path": "b9c0d1e2-f3a4-5678-bcde-678901234567.value.password",
                                  "value": "$event"
                                }
                              }
                            }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "space-y-2"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-sm font-medium leading-none"
                        },
                        "text": "Confirm Password"
                      },
                      {
                        "type": "Input",
                        "props": {
                          "variant": "outline",
                          "size": "sm",
                          "className": "w-full !rounded-md !border-[var(--theme-border)] !bg-[var(--theme-content-bg)]"
                        },
                        "children": [
                          {
                            "type": "InputField",
                            "props": {
                              "type": "password",
                              "placeholder": "••••••••",
                              "placeholderTextColor": "#9ca3af",
                              "value": "{{variables['b9c0d1e2-f3a4-5678-bcde-678901234567'].value.confirmPassword}}",
                              "className": "!text-[var(--theme-foreground)]"
                            },
                            "actions": {
                              "change": {
                                "action": "setState",
                                "payload": {
                                  "path": "b9c0d1e2-f3a4-5678-bcde-678901234567.value.confirmPassword",
                                  "value": "$event"
                                }
                              }
                            }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "text-sm text-red-500"
                    },
                    "condition": "{{_workflow.lastError}}",
                    "children": [
                      {
                        "type": "Text",
                        "text": "{{_workflow.lastError}}"
                      }
                    ]
                  },
                  {
                    "type": "Pressable",
                    "props": {
                      "className": "w-full !bg-[var(--theme-shop-button)] hover:!bg-[var(--theme-shop-buttonHover)] !text-white flex flex-row items-center justify-center py-3 rounded-md"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-white"
                        },
                        "text": "Reset Password"
                      }
                    ],
                    "actions": {
                      "click": {
                        "action": "resetPassword"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "initActions": []
}
