{
  "meta": {
    "title": "Reset Password"
  },
  "state": {
    "form": {
      "newPassword": "",
      "confirmPassword": ""
    },
    "errors": {}
  },
  "ui": {
    "type": "Box",
    "props": {
      "className": "flex min-h-screen items-center justify-center px-4"
    },
    "children": [
      {
        "type": "Box",
        "props": {
          "className": "w-full max-w-md space-y-6"
        },
        "children": [
          {
            "type": "Box",
            "props": {
              "className": "space-y-2 text-center"
            },
            "children": [
              {
                "type": "Heading",
                "props": {
                  "className": "text-3xl font-bold"
                },
                "text": "Set New Password"
              },
              {
                "type": "Text",
                "props": {
                  "className": "text-gray-500"
                },
                "text": "Choose a strong new password for your account."
              }
            ]
          },
          {
            "type": "Card",
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "p-6 space-y-4"
                },
                "children": [
                  {
                    "type": "Box",
                    "props": {
                      "className": "space-y-2"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-sm font-medium"
                        },
                        "text": "New Password"
                      },
                      {
                        "type": "Input",
                        "children": [
                          {
                            "type": "InputField",
                            "props": {
                              "type": "password",
                              "placeholder": "\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022",
                              "value": "{{form.newPassword}}"
                            },
                            "actions": {
                              "change": {
                                "action": "setState",
                                "payload": {
                                  "path": "form.newPassword",
                                  "value": "$event"
                                }
                              }
                            }
                          }
                        ]
                      },
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-sm text-red-500"
                        },
                        "condition": {
                          "!=": [
                            {
                              "var": "errors.form.newPassword"
                            },
                            null
                          ]
                        },
                        "text": "{{errors.form.newPassword}}"
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "space-y-2"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-sm font-medium"
                        },
                        "text": "Confirm Password"
                      },
                      {
                        "type": "Input",
                        "children": [
                          {
                            "type": "InputField",
                            "props": {
                              "type": "password",
                              "placeholder": "\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022",
                              "value": "{{form.confirmPassword}}"
                            },
                            "actions": {
                              "change": {
                                "action": "setState",
                                "payload": {
                                  "path": "form.confirmPassword",
                                  "value": "$event"
                                }
                              }
                            }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "text-sm text-red-500"
                    },
                    "condition": {
                      "!=": [
                        {
                          "var": "_workflow.lastError"
                        },
                        null
                      ]
                    },
                    "children": [
                      {
                        "type": "Text",
                        "text": "{{_workflow.lastError}}"
                      }
                    ]
                  },
                  {
                    "type": "Button",
                    "props": {
                      "className": "w-full bg-[#1e293b] text-white hover:bg-[#334155]"
                    },
                    "children": [{ "type": "ButtonText", "props": { "className": "!text-white" }, "text": "Reset Password" }],
                    "actions": {
                      "click": {
                        "action": "resetPasswordMutation"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "initActions": [
    {
      "action": "fetchNavCollections"
    }
  ]
}