{
  "meta": { "title": "Reset Password" },
  "layout": "store",
  "state": { "form": { "password": "", "confirmPassword": "" }, "errors": {} },
  "content": {
    "type": "Box",
    "props": { "className": "flex flex-1 w-full items-center justify-center px-4" },
    "children": [
      {
        "type": "Box",
        "props": { "className": "w-full max-w-md min-w-0 space-y-6 flex flex-col" },
        "children": [
          {
            "type": "Box",
            "props": { "className": "space-y-2 text-center" },
            "children": [
              { "type": "Heading", "props": { "className": "text-3xl font-bold text-center" }, "text": "Set New Password" },
              { "type": "Text", "props": { "className": "text-gray-500 dark:text-gray-400 text-center" }, "text": "Choose a strong new password for your account." }
            ]
          },
          {
            "type": "Card",
            "props": { "className": "w-full !rounded-xl !border !border-gray-200 !bg-white !py-6 !shadow-sm dark:!border-gray-700 dark:!bg-[#1e293b]" },
            "children": [
              {
                "type": "Box",
                "props": { "className": "px-6 space-y-4" },
                "children": [
                  {
                    "type": "Box",
                    "props": { "className": "space-y-2" },
                    "children": [
                      { "type": "Text", "props": { "className": "text-sm font-medium leading-none" }, "text": "New Password" },
                      {
                        "type": "Input",
                        "props": { "variant": "outline", "size": "sm", "className": "w-full !rounded-md !border-gray-200 !bg-white dark:!border-gray-700 dark:!bg-gray-900" },
                        "children": [
                          {
                            "type": "InputField",
                            "props": {
                              "type": "password",
                              "placeholder": "••••••••",
                              "placeholderTextColor": "#9ca3af",
                              "value": "{{form.password}}",
                              "className": "!text-gray-900 dark:!text-gray-100"
                            },
                            "actions": { "change": { "action": "setState", "payload": { "path": "screens.resetPassword.form.password", "value": "$event" } } }
                          }
                        ]
                      },
                      {
                        "type": "Text",
                        "props": { "className": "text-sm text-red-500" },
                        "condition": { "and": [{ "var": ["errors.form.password"] }, { "!=": [{ "var": ["errors.form.password"] }, ""] }] },
                        "text": "{{errors.form.password}}"
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": { "className": "space-y-2" },
                    "children": [
                      { "type": "Text", "props": { "className": "text-sm font-medium leading-none" }, "text": "Confirm Password" },
                      {
                        "type": "Input",
                        "props": { "variant": "outline", "size": "sm", "className": "w-full !rounded-md !border-gray-200 !bg-white dark:!border-gray-700 dark:!bg-gray-900" },
                        "children": [
                          {
                            "type": "InputField",
                            "props": {
                              "type": "password",
                              "placeholder": "••••••••",
                              "placeholderTextColor": "#9ca3af",
                              "value": "{{form.confirmPassword}}",
                              "className": "!text-gray-900 dark:!text-gray-100"
                            },
                            "actions": { "change": { "action": "setState", "payload": { "path": "screens.resetPassword.form.confirmPassword", "value": "$event" } } }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": { "className": "text-sm text-red-500" },
                    "condition": { "and": [{ "var": ["_workflow.lastError"] }, { "!=": [{ "var": ["_workflow.lastError"] }, ""] }] },
                    "children": [{ "type": "Text", "text": "{{_workflow.lastError}}" }]
                  },
                  {
                    "type": "Button",
                    "props": { "className": "w-full !bg-[#1e293b] hover:!bg-[#334155] !text-white" },
                    "children": [{ "type": "ButtonText", "props": { "className": "!text-white" }, "text": "Reset Password" }],
                    "actions": { "click": { "action": "resetPassword" } }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "initActions": [{ "action": "fetchNavCollections" }]
}
