{
  "meta": {
    "title": "Collection"
  },
  "state": {},
  "layout": "store",
  "content": {
    "type": "Box",
    "props": {
      "className": "container mx-auto px-4 py-8"
    },
    "children": [
      {
        "$ref": "fragments/sections/collection-loading-skeleton"
      },
      {
        "type": "Box",
        "_meta": {
          "section": "collection-grid",
          "description": "Filters sidebar + sort bar + product grid"
        },
        "props": {
          "className": "grid grid-cols-1 lg:grid-cols-4 gap-8"
        },
        "condition": "!collections['d4e5f6a7-b8c9-0123-defa-234567890123']?.loading",
        "children": [
          {
            "type": "Box",
            "props": {
              "className": "lg:col-span-1"
            },
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "space-y-6"
                },
                "children": [
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex flex-row items-center justify-between"
                    },
                    "children": [
                      {
                        "type": "Heading",
                        "props": {
                          "className": "font-semibold text-lg text-[var(--theme-foreground)]"
                        },
                        "text": "Filters"
                      },
                      {
                        "type": "Pressable",
                        "condition": "arrayLength(route?.facets || []) > 0",
                        "props": {
                          "className": "text-sm text-[var(--theme-muted-foreground)] hover:text-[var(--theme-foreground)] transition-colors"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-sm text-[var(--theme-muted-foreground)]"
                            },
                            "text": "Clear all"
                          }
                        ],
                        "actions": [
                          {
                            "action": "10b4a7ed-330e-4827-951f-5a0535458f2e"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "map": {
                      "expr": "groupBy(collections['d4e5f6a7-b8c9-0123-defa-234567890123']?.data?.search?.facetValues || [], 'facetValue.facet.name', 'facetValue.facet.id')"
                    },
                    "key": "context.item.data.id",
                    "props": {
                      "className": "flex flex-col gap-5"
                    },
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": "space-y-4"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "font-medium text-sm text-[var(--theme-foreground)] capitalize"
                            },
                            "text": "{{context.item.data.key}}"
                          },
                          {
                            "type": "Box",
                            "props": {
                              "className": "flex flex-col gap-2"
                            },
                            "children": [
                              {
                                "type": "Box",
                                "map": "context.item.data.items",
                                "key": "context.item.data.facetValue.id",
                                "props": {
                                  "className": "contents"
                                },
                                "children": [
                                  {
                                    "type": "Pressable",
                                    "props": {
                                      "className": "flex flex-row items-center gap-2 cursor-pointer group"
                                    },
                                    "actions": [
                                      {
                                        "action": "b7236203-c516-4e10-8ff7-b4afb84ce314"
                                      }
                                    ],
                                    "children": [
                                      {
                                        "type": "Box",
                                        "props": {
                                          "className": "w-4 h-4 rounded border flex items-center justify-center flex-shrink-0 transition-colors border-[var(--theme-border)]"
                                        },
                                        "condition": "!arrayIncludes(route?.facets || [], context?.item?.data?.facetValue?.id)",
                                        "children": []
                                      },
                                      {
                                        "type": "Box",
                                        "props": {
                                          "className": "w-4 h-4 rounded border flex items-center justify-center flex-shrink-0 transition-colors bg-[var(--theme-shop-button)] border-[var(--theme-shop-button)]"
                                        },
                                        "condition": "arrayIncludes(route?.facets || [], context?.item?.data?.facetValue?.id)",
                                        "children": [
                                          {
                                            "type": "NavIcon",
                                            "props": {
                                              "icon": "Check",
                                              "size": 10,
                                              "className": "!text-white"
                                            }
                                          }
                                        ]
                                      },
                                      {
                                        "type": "Text",
                                        "props": {
                                          "className": "text-sm text-[var(--theme-foreground)] transition-colors"
                                        },
                                        "text": "{{context.item.data.facetValue.name}}"
                                      },
                                      {
                                        "type": "Text",
                                        "props": {
                                          "className": "text-xs text-[var(--theme-muted-foreground)]"
                                        },
                                        "text": "({{context.item.data.count}})"
                                      }
                                    ]
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Box",
            "props": {
              "className": "lg:col-span-3 space-y-8"
            },
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "relative z-10 w-full flex flex-row items-center justify-between"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm text-[var(--theme-muted-foreground)]"
                    },
                    "text": {
                      "expr": "(collections['d4e5f6a7-b8c9-0123-defa-234567890123']?.data?.search?.totalItems || 0) === 1 ? '1 product' : (collections['d4e5f6a7-b8c9-0123-defa-234567890123']?.data?.search?.totalItems || 0) + ' products'"
                    }
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "relative flex-shrink-0"
                    },
                    "children": [
                      {
                        "type": "Pressable",
                        "props": {
                          "className": "fixed inset-0 z-[9998]"
                        },
                        "condition": "variables['c8d9e0f1-a2b3-4567-cdef-678901234567']",
                        "actions": [
                          {
                            "action": "25891c7a-a8fa-42ea-a028-d7405419f9d3"
                          }
                        ]
                      },
                      {
                        "type": "Pressable",
                        "props": {
                          "className": "relative z-50 flex flex-row items-center gap-2 h-9 px-3 rounded-md border border-[var(--theme-border)] bg-[var(--theme-content-bg)] hover:bg-[var(--theme-hero-bg)] min-w-[180px] justify-between"
                        },
                        "actions": [
                          {
                            "action": "4d563f4b-2df1-4231-94b1-3e77b84b000a"
                          }
                        ],
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-sm text-[var(--theme-foreground)]"
                            },
                            "text": {
                              "expr": "route?.sort === 'name-asc' ? 'Name: A to Z' : route?.sort === 'name-desc' ? 'Name: Z to A' : route?.sort === 'price-asc' ? 'Price: Low to High' : 'Price: High to Low'"
                            }
                          },
                          {
                            "type": "NavIcon",
                            "props": {
                              "icon": "ChevronDown",
                              "size": 14,
                              "color": "#6b7280"
                            }
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "condition": "variables['c8d9e0f1-a2b3-4567-cdef-678901234567']",
                        "props": {
                          "className": "absolute right-0 top-full mt-1 min-w-[180px] rounded-md border border-[var(--theme-border)] bg-[var(--theme-content-bg)] shadow-md z-[9999] py-1"
                        },
                        "children": [
                          {
                            "type": "Pressable",
                            "props": {
                              "className": "flex flex-row items-center justify-between w-full px-3 py-2 hover:bg-[var(--theme-hero-bg)]"
                            },
                            "actions": [
                              {
                                "action": "a24be295-33bc-4961-8114-a35e5f3ede70"
                              }
                            ],
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "className": "text-sm text-[var(--theme-foreground)]"
                                },
                                "text": "Name: A to Z"
                              },
                              {
                                "type": "NavIcon",
                                "props": {
                                  "icon": "Check",
                                  "size": 14,
                                  "color": "#7c3aed"
                                },
                                "condition": "route?.sort === 'name-asc'"
                              }
                            ]
                          },
                          {
                            "type": "Pressable",
                            "props": {
                              "className": "flex flex-row items-center justify-between w-full px-3 py-2 hover:bg-[var(--theme-hero-bg)]"
                            },
                            "actions": [
                              {
                                "action": "340aee01-272a-470c-8865-5500192ef4fa"
                              }
                            ],
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "className": "text-sm text-[var(--theme-foreground)]"
                                },
                                "text": "Name: Z to A"
                              },
                              {
                                "type": "NavIcon",
                                "props": {
                                  "icon": "Check",
                                  "size": 14,
                                  "color": "#7c3aed"
                                },
                                "condition": "route?.sort === 'name-desc'"
                              }
                            ]
                          },
                          {
                            "type": "Pressable",
                            "props": {
                              "className": "flex flex-row items-center justify-between w-full px-3 py-2 hover:bg-[var(--theme-hero-bg)]"
                            },
                            "actions": [
                              {
                                "action": "608a5750-a7a9-4504-bfb2-5bd165105e98"
                              }
                            ],
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "className": "text-sm text-[var(--theme-foreground)]"
                                },
                                "text": "Price: Low to High"
                              },
                              {
                                "type": "NavIcon",
                                "props": {
                                  "icon": "Check",
                                  "size": 14,
                                  "color": "#7c3aed"
                                },
                                "condition": "route?.sort === 'price-asc'"
                              }
                            ]
                          },
                          {
                            "type": "Pressable",
                            "props": {
                              "className": "flex flex-row items-center justify-between w-full px-3 py-2 hover:bg-[var(--theme-hero-bg)]"
                            },
                            "actions": [
                              {
                                "action": "667e6b12-a953-4635-967b-7ef4e0779cbe"
                              }
                            ],
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "className": "text-sm text-[var(--theme-foreground)]"
                                },
                                "text": "Price: High to Low"
                              },
                              {
                                "type": "NavIcon",
                                "props": {
                                  "icon": "Check",
                                  "size": 14,
                                  "color": "#7c3aed"
                                },
                                "condition": "route?.sort === 'price-desc'"
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Box",
                "condition": "(collections['d4e5f6a7-b8c9-0123-defa-234567890123']?.data?.search?.totalItems || 0) === 0",
                "props": {
                  "className": "text-center py-12"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-[var(--theme-muted-foreground)]"
                    },
                    "text": "No products found"
                  }
                ]
              },
              {
                "type": "Box",
                "condition": "collections['d4e5f6a7-b8c9-0123-defa-234567890123']?.data?.search?.totalItems > 0",
                "props": {
                  "className": "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6"
                },
                "children": [
                  {
                    "type": "Box",
                    "map": "collections.d4e5f6a7-b8c9-0123-defa-234567890123.data.search.items",
                    "props": {
                      "className": "contents"
                    },
                    "children": [
                      {
                        "$ref": "fragments/cards/product-card"
                      }
                    ]
                  }
                ]
              },
              {
                "$ref": "fragments/pagination/collection-pagination"
              }
            ]
          }
        ]
      }
    ]
  }
}
