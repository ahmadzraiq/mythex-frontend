{
  "meta": {
    "title": "Infinite Scroll Test"
  },
  "ui": {
    "type": "Box",
    "props": {
      "className": "flex flex-col min-h-screen bg-[#0f172a] w-full"
    },
    "children": [
      {
        "type": "Box",
        "props": {
          "className": "flex flex-col w-full px-[24px] py-[32px] gap-[8px] border-b border-[#1e293b]"
        },
        "children": [
          {
            "type": "Text",
            "props": {
              "className": "text-[28px] font-bold text-white"
            },
            "text": "Infinite Scroll Test"
          },
          {
            "type": "Text",
            "props": {
              "className": "text-[14px] text-[#94a3b8]"
            },
            "text": {
              "js": "(variables['iscroll-items-0000-0000-0000-000000000001']?.length ?? 0) + ' products loaded — scroll down to load more'"
            }
          },
          {
            "type": "Box",
            "props": {
              "className": "mt-[16px]",
              "cursor": "pointer"
            },
            "popover": {
              "trigger": "click",
              "placement": "bottom-start",
              "offset": 6,
              "closeOnOutsideClick": true,
              "closeOnEscape": true,
              "matchTriggerWidth": false
            },
            "actions": [
              {
                "workflowId": "isd-wf-open-dropdown",
                "trigger": "click"
              }
            ],
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "inline-flex flex-row items-center gap-[8px] px-[14px] py-[9px] bg-[#1e293b] hover:bg-[#334155] rounded-[8px] border border-[#334155] cursor-pointer"
                },
                "children": [
                  {
                    "type": "Icon",
                    "props": {
                      "icon": "lucide:list",
                      "size": 16,
                      "color": "#94a3b8"
                    }
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-[14px] font-medium text-white"
                    },
                    "text": "Browse products"
                  },
                  {
                    "type": "Icon",
                    "props": {
                      "icon": "lucide:chevron-down",
                      "size": 14,
                      "color": "#64748b"
                    }
                  }
                ]
              },
              {
                "type": "Box",
                "_popoverContent": true,
                "props": {
                  "className": "bg-[#1e293b] border border-[#334155] shadow-xl",
                  "style": {
                    "width": "340px",
                    "height": "380px",
                    "borderRadius": "12px",
                    "display": "flex",
                    "flexDirection": "column",
                    "overflow": "hidden"
                  }
                },
                "children": [
                  {
                    "type": "Box",
                    "props": {
                      "className": "border-b border-[#334155]",
                      "style": {
                        "flexShrink": "0",
                        "display": "flex",
                        "flexDirection": "row",
                        "alignItems": "center",
                        "justifyContent": "space-between",
                        "padding": "12px 16px"
                      }
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[14px] font-semibold text-white"
                        },
                        "text": "Products"
                      },
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[12px] text-[#64748b]"
                        },
                        "text": {
                          "js": "(variables['isd00002-0000-4000-a000-000000000001']?.length ?? 0) + ' loaded'"
                        }
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "style": {
                        "flex": "1",
                        "minHeight": "0",
                        "overflowY": "auto",
                        "overflowX": "hidden",
                        "display": "flex",
                        "flexDirection": "column"
                      }
                    },
                    "actions": [
                      {
                        "workflowId": "isd-wf-load-more-dropdown",
                        "trigger": "reachEnd",
                        "config": {
                          "scrollTarget": "element",
                          "threshold": 80
                        }
                      }
                    ],
                    "children": [
                      {
                        "type": "Box",
                        "map": {
                          "js": "variables['isd00002-0000-4000-a000-000000000001']"
                        },
                        "props": {
                          "className": "flex flex-row items-center gap-[12px] px-[16px] py-[10px] border-b border-[#0f172a] cursor-pointer",
                          "style": {
                            "flexShrink": "0"
                          }
                        },
                        "children": [
                          {
                            "type": "Image",
                            "props": {
                              "src": {
                                "js": "context?.item?.data?.productAsset?.preview"
                              },
                              "className": "rounded-[6px] object-cover bg-[#0f172a]",
                              "style": {
                                "width": "40px",
                                "height": "40px",
                                "flexShrink": "0"
                              }
                            }
                          },
                          {
                            "type": "Box",
                            "props": {
                              "className": "flex flex-col gap-[2px]",
                              "style": {
                                "flex": "1",
                                "minWidth": "0"
                              }
                            },
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "className": "text-[13px] font-medium text-white truncate"
                                },
                                "text": {
                                  "js": "context?.item?.data?.productName ?? '—'"
                                }
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "className": "text-[11px] text-[#64748b] truncate"
                                },
                                "text": {
                                  "js": "context?.item?.data?.slug ?? ''"
                                }
                              }
                            ]
                          },
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-[13px] font-semibold text-[#38bdf8]",
                              "style": {
                                "flexShrink": "0"
                              }
                            },
                            "text": {
                              "js": "context?.item?.data?.priceWithTax?.value != null ? '$' + (context.item.data.priceWithTax.value / 100).toFixed(2) : ''"
                            }
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "condition": "variables['isd00003-0000-4000-a000-000000000001'] === true",
                        "props": {
                          "className": "flex flex-row items-center justify-center gap-[8px] py-[12px]"
                        },
                        "children": [
                          {
                            "type": "Box",
                            "props": {
                              "animation": {
                                "loop": {
                                  "type": "spin",
                                  "duration": 800,
                                  "repeatCount": -1
                                }
                              }
                            },
                            "children": [
                              {
                                "type": "Icon",
                                "props": {
                                  "icon": "lucide:loader-circle",
                                  "size": 16,
                                  "color": "#38bdf8"
                                }
                              }
                            ]
                          },
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-[12px] text-[#64748b]"
                            },
                            "text": "Loading…"
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "condition": "variables['isd00004-0000-4000-a000-000000000001'] === false && (variables['isd00002-0000-4000-a000-000000000001']?.length ?? 0) > 0",
                        "props": {
                          "className": "flex flex-row items-center justify-center gap-[6px] py-[12px]"
                        },
                        "children": [
                          {
                            "type": "Icon",
                            "props": {
                              "icon": "lucide:check",
                              "size": 14,
                              "color": "#22c55e"
                            }
                          },
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-[12px] text-[#64748b]"
                            },
                            "text": "All products loaded"
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "Box",
        "props": {
          "className": "grid grid-cols-3 md:grid-cols-2 sm:grid-cols-1 gap-[20px] w-full max-w-[1200px] mx-auto px-[24px] py-[32px]"
        },
        "children": [
          {
            "type": "Box",
            "map": {
              "js": "variables['iscroll-items-0000-0000-0000-000000000001']"
            },
            "props": {
              "className": "flex flex-col bg-[#1e293b] rounded-[12px] overflow-hidden border border-[#334155] cursor-pointer"
            },
            "children": [
              {
                "type": "Image",
                "props": {
                  "src": {
                    "js": "context?.item?.data?.productAsset?.preview"
                  },
                  "className": "w-full h-[200px] object-cover bg-[#0f172a]"
                }
              },
              {
                "type": "Box",
                "props": {
                  "className": "flex flex-col gap-[8px] p-[16px]"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-[15px] font-semibold text-white leading-tight"
                    },
                    "text": {
                      "js": "context?.item?.data?.productName ?? '—'"
                    }
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-[12px] text-[#64748b] truncate"
                    },
                    "text": {
                      "js": "context?.item?.data?.slug ?? ''"
                    }
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex flex-row items-center justify-between mt-[4px]"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[14px] font-semibold text-[#38bdf8]"
                        },
                        "text": {
                          "js": "context?.item?.data?.priceWithTax?.value != null ? '$' + (context.item.data.priceWithTax.value / 100).toFixed(2) : ''"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[11px] text-[#475569]"
                        },
                        "text": {
                          "js": "context?.item?.data?.inStock ? 'In stock' : 'Out of stock'"
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "Box",
        "condition": "variables['iscroll-loading-000-0000-0000-000000000001'] === true",
        "props": {
          "className": "flex flex-col w-full py-[32px] items-center gap-[12px]"
        },
        "children": [
          {
            "type": "Box",
            "props": {
              "animation": {
                "loop": {
                  "type": "spin",
                  "duration": 800,
                  "repeatCount": -1
                }
              }
            },
            "children": [
              {
                "type": "Icon",
                "props": {
                  "icon": "lucide:loader-circle",
                  "size": 32,
                  "color": "#38bdf8"
                }
              }
            ]
          },
          {
            "type": "Text",
            "props": {
              "className": "text-[13px] text-[#64748b]"
            },
            "text": "Loading more products…"
          }
        ]
      },
      {
        "type": "Box",
        "condition": "variables['iscroll-hasmore-000-0000-0000-000000000001'] === false && (variables['iscroll-items-0000-0000-0000-000000000001']?.length ?? 0) > 0",
        "props": {
          "className": "flex flex-col w-full py-[40px] items-center gap-[8px]"
        },
        "children": [
          {
            "type": "Icon",
            "props": {
              "icon": "lucide:check-circle",
              "size": 24,
              "color": "#22c55e"
            }
          },
          {
            "type": "Text",
            "props": {
              "className": "text-[13px] text-[#64748b]"
            },
            "text": {
              "js": "'All ' + (variables['iscroll-items-0000-0000-0000-000000000001']?.length ?? 0) + ' products loaded'"
            }
          }
        ]
      }
    ]
  }
}