{
  "meta": {
    "title": "Reset Password",
    "description": "Set new password"
  },
  "state": {
    "form": {
      "token": "",
      "password": "",
      "confirmPassword": ""
    },
    "errors": {}
  },
  "ui": {
    "type": "Box",
    "props": {
      "className": "flex flex-col items-center justify-center min-h-screen w-full bg-background-50 p-6"
    },
    "children": [
      {
        "type": "Box",
        "props": {
          "className": "w-full max-w-md mx-auto"
        },
        "children": [
          {
            "type": "Heading",
            "props": {
              "size": "xl",
              "className": "mb-6 text-[var(--theme-content-heading)]"
            },
            "text": "Reset Password"
          },
          {
            "type": "Form",
            "props": {
              "defaultValues": {
                "form": {
                  "token": "",
                  "password": "",
                  "confirmPassword": ""
                }
              },
              "validationRules": {
                "form.password": {
                  "required": true,
                  "minLength": 8
                },
                "form.confirmPassword": {
                  "required": true,
                  "equals": "form.password",
                  "message": "Passwords must match"
                }
              },
              "submitAction": "resetPassword"
            },
            "children": [
              {
                "type": "FormInputWithLabel",
                "props": {
                  "name": "form.token",
                  "label": "Reset Token",
                  "placeholder": "Paste token from email",
                  "variant": "outline",
                  "className": "mb-4"
                }
              },
              {
                "type": "FormInputWithLabel",
                "props": {
                  "name": "form.password",
                  "label": "New Password",
                  "placeholder": "••••••••",
                  "variant": "outline",
                  "secureTextEntry": true,
                  "className": "mb-4"
                }
              },
              {
                "type": "FormInputWithLabel",
                "props": {
                  "name": "form.confirmPassword",
                  "label": "Confirm Password",
                  "placeholder": "••••••••",
                  "variant": "outline",
                  "secureTextEntry": true,
                  "className": "mb-6"
                }
              },
              {
                "type": "FormSubmitButton",
                "props": {
                  "action": "primary",
                  "className": "w-full mb-4"
                },
                "text": "Reset Password"
              }
            ]
          }
        ]
      }
    ]
  }
}