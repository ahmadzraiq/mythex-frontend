{
  "meta": {
    "title": "Shopping Cart"
  },
  "state": {
    "form": {
      "couponCode": ""
    }
  },
  "layout": "store",
  "initActions": [
    {
      "action": "fetchNavCollections"
    },
    {
      "action": "fetchCart"
    }
  ],
  "content": {
    "type": "Box",
    "props": {
      "className": "container mx-auto px-4 py-20"
    },
    "children": [
      {
        "type": "Heading",
        "props": {
          "className": "text-3xl font-bold mb-8"
        },
        "text": "Shopping Cart"
      },
      {
        "type": "Box",
        "props": {
          "className": "text-center py-16"
        },
        "condition": {
          "==": [
            {
              "var": [
                "cart.totalQuantity",
                0
              ]
            },
            0
          ]
        },
        "children": [
          {
            "type": "Heading",
            "props": {
              "className": "text-3xl font-bold mb-4"
            },
            "text": "Your Cart is Empty"
          },
          {
            "type": "Text",
            "props": {
              "className": "text-gray-500 mb-8"
            },
            "text": "Add some items to your cart to get started"
          },
          {
            "type": "Button",
            "props": {
              "className": "!bg-[#1e293b] hover:!bg-[#334155] px-6"
            },
            "children": [
              {
                "type": "ButtonText",
                "props": {
                  "className": "!text-white"
                },
                "text": "Continue Shopping"
              }
            ],
            "actions": {
              "click": {
                "action": "navigate",
                "payload": {
                  "path": "/"
                }
              }
            }
          }
        ]
      },
      {
        "type": "Box",
        "props": {
          "className": "grid lg:grid-cols-3 gap-8"
        },
        "condition": {
          ">": [
            {
              "var": [
                "cart.totalQuantity",
                0
              ]
            },
            0
          ]
        },
        "children": [
          {
            "type": "Box",
            "_meta": {
              "section": "cart-line-list",
              "description": "Cart line items with quantity controls"
            },
            "props": {
              "className": "lg:col-span-2 space-y-4"
            },
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "contents"
                },
                "map": "cart.lines",
                "key": "cartLine",
                "children": [
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex flex-col sm:flex-row gap-4 p-4 border border-gray-200 rounded-lg !bg-white"
                    },
                    "children": [
                      {
                        "type": "Pressable",
                        "props": {
                          "className": "flex-shrink-0"
                        },
                        "actions": {
                          "click": {
                            "action": "navigate",
                            "payload": {
                              "routeConfig": "product",
                              "slug": {
                                "var": "$item.productVariant.product.slug"
                              }
                            }
                          }
                        },
                        "children": [
                          {
                            "type": "NextImage",
                            "props": {
                              "src": "{{$item.productVariant.product.featuredAsset.preview}}",
                              "alt": "{{$item.productVariant.name}}",
                              "width": 120,
                              "height": 120,
                              "className": "rounded-md object-cover w-full sm:w-[120px] h-[120px]"
                            }
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex-grow min-w-0"
                        },
                        "children": [
                          {
                            "type": "Pressable",
                            "props": {
                              "className": "font-semibold hover:underline block"
                            },
                            "actions": {
                              "click": {
                                "action": "navigate",
                                "payload": {
                                  "routeConfig": "product",
                                  "slug": {
                                    "var": "$item.productVariant.product.slug"
                                  }
                                }
                              }
                            },
                            "children": [
                              {
                                "type": "Text",
                                "text": "{{$item.productVariant.product.name}}"
                              }
                            ]
                          },
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-sm text-gray-500 mt-1"
                            },
                            "text": "{{$item.productVariant.name}}",
                            "condition": {
                              "!=": [
                                {
                                  "var": "$item.productVariant.name"
                                },
                                {
                                  "var": "$item.productVariant.product.name"
                                }
                              ]
                            }
                          },
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-sm text-gray-500 mt-1"
                            },
                            "text": {
                              "expr": {
                                "var": "$item.productVariant.sku"
                              },
                              "prefix": "SKU: "
                            }
                          },
                          {
                            "type": "HStack",
                            "props": {
                              "className": "flex items-center gap-3 mt-4 flex-wrap"
                            },
                            "children": [
                              {
                                "type": "HStack",
                                "props": {
                                  "className": "flex items-center gap-2 border rounded-md"
                                },
                                "children": [
                                  {
                                    "type": "Button",
                                    "props": {
                                      "className": "h-9 w-9 p-0 flex items-center justify-center border-0 !bg-transparent hover:!bg-gray-100 rounded-none disabled:opacity-50"
                                    },
                                    "condition": {
                                      ">": [
                                        {
                                          "var": [
                                            "$item.quantity",
                                            0
                                          ]
                                        },
                                        1
                                      ]
                                    },
                                    "children": [
                                      {
                                        "type": "ButtonText",
                                        "props": {
                                          "className": "!text-gray-900"
                                        },
                                        "text": "−"
                                      }
                                    ],
                                    "actions": {
                                      "click": {
                                        "action": "adjustCartItemQuantity",
                                        "payload": {
                                          "lineId": {
                                            "var": "$item.id"
                                          },
                                          "quantity": {
                                            "expr": {
                                              "-": [
                                                {
                                                  "var": [
                                                    "$item.quantity",
                                                    1
                                                  ]
                                                },
                                                1
                                              ]
                                            }
                                          }
                                        }
                                      }
                                    }
                                  },
                                  {
                                    "type": "Button",
                                    "props": {
                                      "className": "h-9 w-9 p-0 flex items-center justify-center border-0 !bg-transparent hover:!bg-gray-100 rounded-none disabled:opacity-50"
                                    },
                                    "condition": {
                                      "==": [
                                        {
                                          "var": [
                                            "$item.quantity",
                                            0
                                          ]
                                        },
                                        1
                                      ]
                                    },
                                    "children": [
                                      {
                                        "type": "ButtonText",
                                        "props": {
                                          "className": "!text-gray-900"
                                        },
                                        "text": "−"
                                      }
                                    ],
                                    "actions": {
                                      "click": {
                                        "action": "removeFromCart",
                                        "stopPropagation": true
                                      }
                                    }
                                  },
                                  {
                                    "type": "Text",
                                    "props": {
                                      "className": "w-12 text-center font-medium text-sm"
                                    },
                                    "text": {
                                      "expr": {
                                        "var": "$item.quantity"
                                      }
                                    }
                                  },
                                  {
                                    "type": "Button",
                                    "props": {
                                      "className": "h-9 w-9 p-0 flex items-center justify-center border-0 !bg-transparent hover:!bg-gray-100 rounded-none"
                                    },
                                    "children": [
                                      {
                                        "type": "ButtonText",
                                        "props": {
                                          "className": "!text-gray-900"
                                        },
                                        "text": "+"
                                      }
                                    ],
                                    "actions": {
                                      "click": {
                                        "action": "adjustCartItemQuantity",
                                        "payload": {
                                          "lineId": {
                                            "var": "$item.id"
                                          },
                                          "quantity": {
                                            "expr": {
                                              "+": [
                                                {
                                                  "var": [
                                                    "$item.quantity",
                                                    0
                                                  ]
                                                },
                                                1
                                              ]
                                            }
                                          }
                                        }
                                      }
                                    }
                                  },
                                  {
                                    "type": "Button",
                                    "props": {
                                      "className": "h-9 w-9 p-0 flex items-center justify-center !bg-transparent border-0 hover:!bg-red-50 rounded-none"
                                    },
                                    "children": [
                                      {
                                        "type": "ButtonText",
                                        "props": {
                                          "className": "!text-red-500"
                                        },
                                        "text": "✕"
                                      }
                                    ],
                                    "actions": {
                                      "click": {
                                        "action": "removeFromCart",
                                        "stopPropagation": true
                                      }
                                    }
                                  }
                                ]
                              },
                              {
                                "type": "VStack",
                                "props": {
                                  "className": "sm:hidden ml-auto gap-0 items-end"
                                },
                                "children": [
                                  {
                                    "type": "Text",
                                    "props": {
                                      "className": "font-semibold text-lg"
                                    },
                                    "text": {
                                      "expr": {
                                        "formatCurrency": [
                                          {
                                            "/": [
                                              {
                                                "var": "$item.linePriceWithTax"
                                              },
                                              100
                                            ]
                                          },
                                          {
                                            "var": [
                                              "cart.currencyCode",
                                              "USD"
                                            ]
                                          }
                                        ]
                                      }
                                    }
                                  },
                                  {
                                    "type": "Text",
                                    "props": {
                                      "className": "text-sm text-gray-500 mt-1"
                                    },
                                    "text": {
                                      "expr": {
                                        "formatCurrency": [
                                          {
                                            "/": [
                                              {
                                                "var": "$item.unitPriceWithTax"
                                              },
                                              100
                                            ]
                                          },
                                          {
                                            "var": [
                                              "cart.currencyCode",
                                              "USD"
                                            ]
                                          }
                                        ]
                                      },
                                      "suffix": " each"
                                    }
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "hidden sm:flex sm:flex-col sm:items-end text-right flex-shrink-0"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "font-semibold text-lg"
                            },
                            "text": {
                              "expr": {
                                "formatCurrency": [
                                  {
                                    "/": [
                                      {
                                        "var": "$item.linePriceWithTax"
                                      },
                                      100
                                    ]
                                  },
                                  {
                                    "var": [
                                      "cart.currencyCode",
                                      "USD"
                                    ]
                                  }
                                ]
                              }
                            }
                          },
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-sm text-gray-500 mt-1"
                            },
                            "text": {
                              "expr": {
                                "formatCurrency": [
                                  {
                                    "/": [
                                      {
                                        "var": "$item.unitPriceWithTax"
                                      },
                                      100
                                    ]
                                  },
                                  {
                                    "var": [
                                      "cart.currencyCode",
                                      "USD"
                                    ]
                                  }
                                ]
                              },
                              "suffix": " each"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Box",
            "props": {
              "className": "lg:col-span-1 space-y-4"
            },
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "border rounded-lg p-6 bg-white sticky top-4 h-fit"
                },
                "children": [
                  {
                    "type": "Heading",
                    "props": {
                      "className": "text-xl font-bold mb-4"
                    },
                    "text": "Order Summary"
                  },
                  {
                    "type": "VStack",
                    "props": {
                      "className": "space-y-2 mb-4"
                    },
                    "children": [
                      {
                        "type": "HStack",
                        "props": {
                          "className": "flex justify-between text-sm"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-gray-500"
                            },
                            "text": "Subtotal"
                          },
                          {
                            "type": "Text",
                            "text": {
                              "expr": {
                                "formatCurrency": [
                                  {
                                    "/": [
                                      {
                                        "var": "cart.subTotalWithTax"
                                      },
                                      100
                                    ]
                                  },
                                  {
                                    "var": [
                                      "cart.currencyCode",
                                      "USD"
                                    ]
                                  }
                                ]
                              }
                            }
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "contents"
                        },
                        "map": "cart.discounts",
                        "key": "discount",
                        "condition": {
                          ">": [
                            {
                              "var": [
                                "cart.discounts.length",
                                0
                              ]
                            },
                            0
                          ]
                        },
                        "children": [
                          {
                            "type": "HStack",
                            "props": {
                              "className": "flex justify-between text-sm text-green-600"
                            },
                            "children": [
                              {
                                "type": "Text",
                                "text": "{{$item.description}}"
                              },
                              {
                                "type": "Text",
                                "text": {
                                  "expr": {
                                    "formatCurrency": [
                                      {
                                        "/": [
                                          {
                                            "var": "$item.amountWithTax"
                                          },
                                          100
                                        ]
                                      },
                                      {
                                        "var": [
                                          "cart.currencyCode",
                                          "USD"
                                        ]
                                      }
                                    ]
                                  }
                                }
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "HStack",
                        "props": {
                          "className": "flex justify-between text-sm"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-gray-500"
                            },
                            "text": "Shipping"
                          },
                          {
                            "type": "Text",
                            "text": {
                              "expr": {
                                "if": [
                                  {
                                    ">": [
                                      {
                                        "var": "cart.shippingWithTax"
                                      },
                                      0
                                    ]
                                  },
                                  {
                                    "formatCurrency": [
                                      {
                                        "/": [
                                          {
                                            "var": "cart.shippingWithTax"
                                          },
                                          100
                                        ]
                                      },
                                      {
                                        "var": [
                                          "cart.currencyCode",
                                          "USD"
                                        ]
                                      }
                                    ]
                                  },
                                  "Calculated at checkout"
                                ]
                              }
                            }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "border-t pt-4 mb-6"
                    },
                    "children": [
                      {
                        "type": "HStack",
                        "props": {
                          "className": "flex justify-between font-bold text-lg"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "text": "Total"
                          },
                          {
                            "type": "Text",
                            "text": {
                              "expr": {
                                "formatCurrency": [
                                  {
                                    "/": [
                                      {
                                        "var": "cart.totalWithTax"
                                      },
                                      100
                                    ]
                                  },
                                  {
                                    "var": [
                                      "cart.currencyCode",
                                      "USD"
                                    ]
                                  }
                                ]
                              }
                            }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Button",
                    "props": {
                      "className": "w-full !bg-[#1e293b] hover:!bg-[#334155] h-11 text-base font-medium"
                    },
                    "children": [
                      {
                        "type": "ButtonText",
                        "props": {
                          "className": "!text-white"
                        },
                        "text": "Proceed to Checkout"
                      }
                    ],
                    "actions": {
                      "click": {
                        "action": "navigate",
                        "payload": {
                          "path": "/checkout"
                        }
                      }
                    }
                  },
                  {
                    "type": "Button",
                    "props": {
                      "className": "w-full mt-2 border border-gray-200 !bg-white hover:!bg-gray-100 h-10"
                    },
                    "children": [
                      {
                        "type": "ButtonText",
                        "props": {
                          "className": "!text-gray-900"
                        },
                        "text": "Continue Shopping"
                      }
                    ],
                    "actions": {
                      "click": {
                        "action": "navigate",
                        "payload": {
                          "path": "/"
                        }
                      }
                    }
                  }
                ]
              },
              {
                "type": "Box",
                "props": {
                  "className": "border rounded-lg p-6 bg-white"
                },
                "children": [
                  {
                    "type": "HStack",
                    "props": {
                      "className": "flex items-center gap-2 mb-2"
                    },
                    "children": [
                      {
                        "type": "NavIcon",
                        "props": {
                          "icon": "Tag",
                          "size": 20,
                          "className": "text-gray-500"
                        }
                      },
                      {
                        "type": "Heading",
                        "props": {
                          "className": "text-lg"
                        },
                        "text": "Promotion Code"
                      }
                    ]
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm text-gray-500 mb-4"
                    },
                    "text": "Enter your discount code below"
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "space-y-2"
                    },
                    "condition": {
                      ">": [
                        {
                          "var": [
                            "cart.couponCodes.length",
                            0
                          ]
                        },
                        0
                      ]
                    },
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": "contents"
                        },
                        "map": "cart.couponCodes",
                        "key": "code",
                        "children": [
                          {
                            "type": "HStack",
                            "props": {
                              "className": "flex items-center justify-between p-3 border rounded-md bg-green-50"
                            },
                            "children": [
                              {
                                "type": "HStack",
                                "props": {
                                  "className": "flex items-center gap-2"
                                },
                                "children": [
                                  {
                                    "type": "NavIcon",
                                    "props": {
                                      "icon": "Tag",
                                      "size": 16,
                                      "className": "text-green-600"
                                    }
                                  },
                                  {
                                    "type": "Text",
                                    "props": {
                                      "className": "font-medium text-sm"
                                    },
                                    "text": "{{$item}}"
                                  }
                                ]
                              },
                              {
                                "type": "Button",
                                "props": {
                                  "className": "h-8 !bg-transparent hover:!bg-red-50"
                                },
                                "children": [
                                  {
                                    "type": "ButtonText",
                                    "props": {
                                      "className": "!text-red-500"
                                    },
                                    "text": "Remove"
                                  }
                                ],
                                "actions": {
                                  "click": {
                                    "action": "removePromotionCode",
                                    "payload": {
                                      "couponCode": {
                                        "var": "$item"
                                      }
                                    }
                                  }
                                }
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "HStack",
                    "props": {
                      "className": "flex gap-2"
                    },
                    "condition": {
                      "==": [
                        {
                          "var": [
                            "cart.couponCodes.length",
                            0
                          ]
                        },
                        0
                      ]
                    },
                    "children": [
                      {
                        "type": "Input",
                        "props": {
                          "variant": "outline",
                          "size": "sm",
                          "className": "flex-1 !rounded-md !border-gray-200 !bg-white"
                        },
                        "children": [
                          {
                            "type": "InputField",
                            "props": {
                              "placeholder": "Enter code",
                              "value": "{{form.couponCode}}",
                              "className": "!text-gray-900"
                            },
                            "actions": {
                              "change": {
                                "action": "setState",
                                "payload": {
                                  "path": "screens.cart.form.couponCode",
                                  "value": "$event"
                                }
                              }
                            }
                          }
                        ]
                      },
                      {
                        "type": "Button",
                        "props": {
                          "className": "!bg-[#1e293b] hover:!bg-[#334155] px-4"
                        },
                        "children": [
                          {
                            "type": "ButtonText",
                            "props": {
                              "className": "!text-white"
                            },
                            "text": "Apply"
                          }
                        ],
                        "actions": {
                          "click": {
                            "action": "applyPromotionCode"
                          }
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
