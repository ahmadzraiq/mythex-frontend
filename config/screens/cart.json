{
  "meta": {
    "title": "Shopping Cart"
  },
  "state": {
    "form": {
      "couponCode": ""
    }
  },
  "layout": "store",
  "initActions": [
    {
      "action": "fetchNavCollections"
    },
    {
      "action": "fetchCart"
    }
  ],
  "content": {
    "type": "Box",
    "props": {
      "className": "container mx-auto px-4 py-20"
    },
    "children": [
      {
        "type": "Heading",
        "props": {
          "className": "text-3xl font-bold mb-8"
        },
        "text": "Shopping Cart"
      },
      {
        "type": "Box",
        "props": {
          "className": "text-center py-16"
        },
        "condition": "({{cart.totalQuantity}} || 0) === 0",
        "children": [
          {
            "type": "Heading",
            "props": {
              "className": "text-3xl font-bold mb-4"
            },
            "text": "Your Cart is Empty"
          },
          {
            "type": "Text",
            "props": {
              "className": "text-[var(--theme-muted-foreground)] mb-8"
            },
            "text": "Add some items to your cart to get started"
          },
          {
            "type": "Pressable",
            "props": {
              "className": "!bg-[var(--theme-shop-button)] hover:!bg-[var(--theme-shop-buttonHover)] px-6 flex flex-row items-center justify-center py-3 rounded-md"
            },
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "text-white"
                },
                "text": "Continue Shopping"
              }
            ],
            "actions": {
              "click": {
                "action": "navigate",
                "payload": {
                  "path": "/"
                }
              }
            }
          }
        ]
      },
      {
        "type": "Box",
        "props": {
          "className": "grid lg:grid-cols-3 gap-8"
        },
        "condition": "{{cart.totalQuantity}} > 0",
        "children": [
          {
            "type": "Box",
            "_meta": {
              "section": "cart-line-list",
              "description": "Cart line items with quantity controls"
            },
            "props": {
              "className": "lg:col-span-2 flex flex-col gap-6"
            },
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "flex flex-col gap-4 w-full"
                },
                "map": "cart.lines",
                "key": "cartLine",
                "children": [
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex flex-col sm:flex-row gap-4 p-4 border border-[var(--theme-border)] rounded-lg !bg-[var(--theme-content-bg)]"
                    },
                    "children": [
                      {
                        "type": "Pressable",
                        "props": {
                          "className": "flex-shrink-0"
                        },
                        "actions": {
                          "click": {
                            "action": "navigate",
                            "payload": {
                              "routeConfig": "product",
                              "slug": "{{$item.productVariant.product.slug}}"
                            }
                          }
                        },
                        "children": [
                          {
                            "type": "NextImage",
                            "props": {
                              "src": "{{$item.productVariant.product.featuredAsset.preview}}",
                              "alt": "{{$item.productVariant.name}}",
                              "width": 120,
                              "height": 120,
                              "className": "rounded-md object-cover w-full sm:w-[120px] h-[120px]"
                            }
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex-grow min-w-0"
                        },
                        "children": [
                          {
                            "type": "Pressable",
                            "props": {
                              "className": "font-semibold hover:underline block"
                            },
                            "actions": {
                              "click": {
                                "action": "navigate",
                                "payload": {
                                  "routeConfig": "product",
                                  "slug": "{{$item.productVariant.product.slug}}"
                                }
                              }
                            },
                            "children": [
                              {
                                "type": "Text",
                                "text": "{{$item.productVariant.product.name}}"
                              }
                            ]
                          },
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-sm text-[var(--theme-muted-foreground)] mt-1"
                            },
                            "text": "{{$item.productVariant.name}}",
                            "condition": "{{$item.productVariant.name}} !== {{$item.productVariant.product.name}}"
                          },
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-sm text-[var(--theme-muted-foreground)] mt-1"
                            },
                            "text": "SKU: {{$item.productVariant.sku}}"
                          },
                          {
                            "type": "Box",
                            "props": {
                              "className": "flex items-center gap-3 mt-4 flex-wrap flex-row"
                            },
                            "children": [
                              {
                                "type": "Box",
                                "props": {
                                  "className": "flex items-center gap-2 border rounded-md flex-row"
                                },
                                "children": [
                                  {
                                    "type": "Pressable",
                                    "props": {
                                      "className": "h-9 w-9 p-0 flex items-center justify-center border-0 !bg-transparent hover:!bg-[var(--theme-hero-bg)] rounded-none disabled:opacity-50 flex-row"
                                    },
                                    "condition": "{{$item.quantity}} > 1",
                                    "children": [
                                      {
                                        "type": "Text",
                                        "props": {
                                          "className": "text-[var(--theme-foreground)]"
                                        },
                                        "text": "−"
                                      }
                                    ],
                                    "actions": {
                                      "click": {
                                        "action": "adjustCartItemQuantity",
                                        "payload": {
                                          "lineId": "{{$item.id}}",
                                          "quantity": {
                                            "expr": "{{$item.quantity}} - 1"
                                          }
                                        }
                                      }
                                    }
                                  },
                                  {
                                    "type": "Pressable",
                                    "props": {
                                      "className": "h-9 w-9 p-0 flex items-center justify-center border-0 !bg-transparent hover:!bg-[var(--theme-hero-bg)] rounded-none disabled:opacity-50 flex-row"
                                    },
                                    "condition": "({{$item.quantity}} || 0) === 1",
                                    "children": [
                                      {
                                        "type": "Text",
                                        "props": {
                                          "className": "text-[var(--theme-foreground)]"
                                        },
                                        "text": "−"
                                      }
                                    ],
                                    "actions": {
                                      "click": {
                                        "action": "removeFromCart",
                                        "stopPropagation": true
                                      }
                                    }
                                  },
                                  {
                                    "type": "Text",
                                    "props": {
                                      "className": "w-12 text-center font-medium text-sm"
                                    },
                                    "text": "{{$item.quantity}}"
                                  },
                                  {
                                    "type": "Pressable",
                                    "props": {
                                      "className": "h-9 w-9 p-0 flex items-center justify-center border-0 !bg-transparent hover:!bg-[var(--theme-hero-bg)] rounded-none flex-row"
                                    },
                                    "children": [
                                      {
                                        "type": "Text",
                                        "props": {
                                          "className": "text-[var(--theme-foreground)]"
                                        },
                                        "text": "+"
                                      }
                                    ],
                                    "actions": {
                                      "click": {
                                        "action": "adjustCartItemQuantity",
                                        "payload": {
                                          "lineId": "{{$item.id}}",
                                          "quantity": {
                                            "expr": "{{$item.quantity}} + 1"
                                          }
                                        }
                                      }
                                    }
                                  },
                                  {
                                    "type": "Pressable",
                                    "props": {
                                      "className": "h-9 w-9 p-0 flex items-center justify-center !bg-transparent border-0 hover:!bg-red-50 rounded-none flex-row"
                                    },
                                    "children": [
                                      {
                                        "type": "Text",
                                        "props": {
                                          "className": "text-red-500"
                                        },
                                        "text": "✕"
                                      }
                                    ],
                                    "actions": {
                                      "click": {
                                        "action": "removeFromCart",
                                        "stopPropagation": true
                                      }
                                    }
                                  }
                                ]
                              },
                              {
                                "type": "Box",
                                "props": {
                                  "className": "sm:hidden ml-auto gap-0 items-end flex flex-col"
                                },
                                "children": [
                                  {
                                    "type": "Text",
                                    "props": {
                                      "className": "font-semibold text-lg"
                                    },
                                    "text": {
                                      "expr": "formatCurrency({{$item.linePriceWithTax}} / 100, {{cart.currencyCode}} || 'USD')"
                                    }
                                  },
                                  {
                                    "type": "Text",
                                    "props": {
                                      "className": "text-sm text-[var(--theme-muted-foreground)] mt-1"
                                    },
                                    "text": {
                                      "expr": "formatCurrency({{$item.unitPriceWithTax}} / 100, {{cart.currencyCode}} || 'USD') + ' each'"
                                    }
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "hidden sm:flex sm:flex-col sm:items-end text-right flex-shrink-0"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "font-semibold text-lg"
                            },
                            "text": {
                              "expr": "formatCurrency({{$item.linePriceWithTax}} / 100, {{cart.currencyCode}} || 'USD')"
                            }
                          },
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-sm text-[var(--theme-muted-foreground)] mt-1"
                            },
                            "text": {
                              "expr": "formatCurrency({{$item.unitPriceWithTax}} / 100, {{cart.currencyCode}} || 'USD') + ' each'"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Box",
            "props": {
              "className": "lg:col-span-1 space-y-4"
            },
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "border border-[var(--theme-border)] rounded-lg p-6 bg-[var(--theme-content-bg)] sticky top-4 h-fit"
                },
                "children": [
                  {
                    "type": "Heading",
                    "props": {
                      "className": "text-xl font-bold mb-4"
                    },
                    "text": "Order Summary"
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "space-y-2 mb-4 flex flex-col"
                    },
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex justify-between text-sm flex-row"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-[var(--theme-muted-foreground)]"
                            },
                            "text": "Subtotal"
                          },
                          {
                            "type": "Text",
                            "text": {
                              "expr": "formatCurrency({{cart.subTotalWithTax}} / 100, {{cart.currencyCode}} || 'USD')"
                            }
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "contents"
                        },
                        "map": "cart.discounts",
                        "key": "discount",
                        "condition": "{{cart.discounts.length}} > 0",
                        "children": [
                          {
                            "type": "Box",
                            "props": {
                              "className": "flex justify-between text-sm text-green-600 flex-row"
                            },
                            "children": [
                              {
                                "type": "Text",
                                "text": "{{$item.description}}"
                              },
                              {
                                "type": "Text",
                                "text": {
                                  "expr": "formatCurrency({{$item.amountWithTax}} / 100, {{cart.currencyCode}} || 'USD')"
                                }
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex justify-between text-sm flex-row"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-[var(--theme-muted-foreground)]"
                            },
                            "text": "Shipping"
                          },
                          {
                            "type": "Text",
                            "text": {
                              "expr": "{{cart.shippingWithTax}} > 0 ? formatCurrency({{cart.shippingWithTax}} / 100, {{cart.currencyCode}} || 'USD') : 'Calculated at checkout'"
                            }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "border-t pt-4 mb-6"
                    },
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex justify-between font-bold text-lg flex-row"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "text": "Total"
                          },
                          {
                            "type": "Text",
                            "text": {
                              "expr": "formatCurrency({{cart.totalWithTax}} / 100, {{cart.currencyCode}} || 'USD')"
                            }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Pressable",
                    "props": {
                      "className": "w-full !bg-[var(--theme-shop-button)] hover:!bg-[var(--theme-shop-buttonHover)] h-11 text-base font-medium flex flex-row items-center justify-center rounded-md"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-white"
                        },
                        "text": "Proceed to Checkout"
                      }
                    ],
                    "actions": {
                      "click": {
                        "action": "navigate",
                        "payload": {
                          "path": "/checkout"
                        }
                      }
                    }
                  },
                  {
                    "type": "Pressable",
                    "props": {
                      "className": "w-full mt-2 border border-[var(--theme-border)] !bg-[var(--theme-content-bg)] hover:!bg-[var(--theme-hero-bg)] h-10 flex flex-row items-center justify-center rounded-md"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[var(--theme-foreground)]"
                        },
                        "text": "Continue Shopping"
                      }
                    ],
                    "actions": {
                      "click": {
                        "action": "navigate",
                        "payload": {
                          "path": "/"
                        }
                      }
                    }
                  }
                ]
              },
              {
                "type": "Box",
                "props": {
                  "className": "border border-[var(--theme-border)] rounded-lg p-6 bg-[var(--theme-content-bg)]"
                },
                "children": [
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex items-center gap-2 mb-2 flex-row"
                    },
                    "children": [
                      {
                        "type": "NavIcon",
                        "props": {
                          "icon": "Tag",
                          "size": 20,
                          "className": "text-[var(--theme-muted-foreground)]"
                        }
                      },
                      {
                        "type": "Heading",
                        "props": {
                          "className": "text-lg"
                        },
                        "text": "Promotion Code"
                      }
                    ]
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm text-[var(--theme-muted-foreground)] mb-4"
                    },
                    "text": "Enter your discount code below"
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "space-y-2"
                    },
                    "condition": "{{cart.couponCodes.length}} > 0",
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": "contents"
                        },
                        "map": "cart.couponCodes",
                        "key": "code",
                        "children": [
                          {
                            "type": "Box",
                            "props": {
                              "className": "flex items-center justify-between p-3 border rounded-md bg-green-50 flex-row"
                            },
                            "children": [
                              {
                                "type": "Box",
                                "props": {
                                  "className": "flex items-center gap-2 flex-row"
                                },
                                "children": [
                                  {
                                    "type": "NavIcon",
                                    "props": {
                                      "icon": "Tag",
                                      "size": 16,
                                      "className": "text-green-600"
                                    }
                                  },
                                  {
                                    "type": "Text",
                                    "props": {
                                      "className": "font-medium text-sm"
                                    },
                                    "text": "{{$item}}"
                                  }
                                ]
                              },
                              {
                                "type": "Pressable",
                                "props": {
                                  "className": "h-8 !bg-transparent hover:!bg-red-50 flex flex-row items-center justify-center px-4 rounded-md"
                                },
                                "children": [
                                  {
                                    "type": "Text",
                                    "props": {
                                      "className": "text-red-500"
                                    },
                                    "text": "Remove"
                                  }
                                ],
                                "actions": {
                                  "click": {
                                    "action": "removePromotionCode",
                                    "payload": {
                                      "couponCode": "{{$item}}"
                                    }
                                  }
                                }
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex gap-2 flex-row"
                    },
                    "condition": "({{cart.couponCodes.length}} || 0) === 0",
                    "children": [
                      {
                        "type": "Input",
                        "props": {
                          "variant": "outline",
                          "size": "sm",
                          "className": "flex-1 !rounded-md !border-[var(--theme-border)] !bg-[var(--theme-content-bg)]"
                        },
                        "children": [
                          {
                            "type": "InputField",
                            "props": {
                              "placeholder": "Enter code",
                              "value": "{{form.couponCode}}",
                              "className": "!text-[var(--theme-foreground)]"
                            },
                            "actions": {
                              "change": {
                                "action": "setState",
                                "payload": {
                                  "path": "screens.cart.form.couponCode",
                                  "value": "$event"
                                }
                              }
                            }
                          }
                        ]
                      },
                      {
                        "type": "Pressable",
                        "props": {
                          "className": "!bg-[var(--theme-shop-button)] hover:!bg-[var(--theme-shop-buttonHover)] px-4 flex flex-row items-center justify-center py-3 rounded-md"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-white"
                            },
                            "text": "Apply"
                          }
                        ],
                        "actions": {
                          "click": {
                            "action": "applyPromotionCode"
                          }
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
