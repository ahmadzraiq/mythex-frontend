{
  "meta": {
    "title": "Shopping Cart"
  },
  "layout": "store",
  "content": {
    "type": "Box",
    "props": {
      "className": "container mx-auto px-4 py-20"
    },
    "children": [
      {
        "type": "Heading",
        "props": {
          "className": "text-3xl font-bold mb-8"
        },
        "text": "Shopping Cart"
      },
      {
        "type": "Box",
        "props": {
          "className": "text-center py-16"
        },
        "condition": "(collections['a1b2c3d4-e5f6-7890-abcd-ef1234567890']?.data?.activeOrder?.totalQuantity || 0) === 0",
        "children": [
          {
            "type": "Heading",
            "props": {
              "className": "text-3xl font-bold mb-4"
            },
            "text": "Your Cart is Empty"
          },
          {
            "type": "Text",
            "props": {
              "className": "text-[var(--theme-muted-foreground)] mb-8"
            },
            "text": "Add some items to your cart to get started"
          },
          {
            "type": "Box",
            "props": {
              "className": "!bg-[var(--theme-primary)] hover:!bg-[var(--theme-primary)] px-6 flex flex-row items-center justify-center py-3 rounded-md"
            },
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "text-white"
                },
                "text": "Continue Shopping"
              }
            ],
            "actions": [
              {
                "action": "9e33ef0a-706f-4555-b2ee-60fd95ebf416"
              }
            ]
          }
        ]
      },
      {
        "type": "Box",
        "props": {
          "className": "grid lg:grid-cols-3 gap-8"
        },
        "condition": "collections['a1b2c3d4-e5f6-7890-abcd-ef1234567890']?.data?.activeOrder?.totalQuantity > 0",
        "children": [
          {
            "type": "Box",
            "_meta": {
              "section": "cart-line-list",
              "description": "Cart line items with quantity controls"
            },
            "props": {
              "className": "lg:col-span-2 flex flex-col gap-6"
            },
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "flex flex-col gap-4 w-full"
                },
                "map": "collections.a1b2c3d4-e5f6-7890-abcd-ef1234567890.data.activeOrder.lines",
                "key": "cartLine",
                "children": [
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex flex-col sm:flex-row gap-4 p-4 border border-[var(--theme-border)] rounded-lg !bg-[var(--theme-card)]"
                    },
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex-shrink-0"
                        },
                        "actions": [
                          {
                            "action": "85a454be-bb92-4878-a266-b54e35d2d4d5"
                          }
                        ],
                        "children": [
                          {
                            "type": "Image",
                            "props": {
                              "src": "{{context.item.data.productVariant.product.featuredAsset.preview}}",
                              "alt": "{{context.item.data.productVariant.name}}",
                              "width": 120,
                              "height": 120,
                              "className": "rounded-md object-cover w-full sm:w-[120px] h-[120px]"
                            }
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex-grow min-w-0"
                        },
                        "children": [
                          {
                            "type": "Box",
                            "props": {
                              "className": "font-semibold hover:underline block"
                            },
                            "actions": [
                              {
                                "action": "85a454be-bb92-4878-a266-b54e35d2d4d5"
                              }
                            ],
                            "children": [
                              {
                                "type": "Text",
                                "text": "{{context.item.data.productVariant.product.name}}"
                              }
                            ]
                          },
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-sm text-[var(--theme-muted-foreground)] mt-1"
                            },
                            "text": "{{context.item.data.productVariant.name}}",
                            "condition": "context?.item?.data?.productVariant?.name !== context?.item?.data?.productVariant?.product?.name"
                          },
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-sm text-[var(--theme-muted-foreground)] mt-1"
                            },
                            "text": "SKU: {{context.item.data.productVariant.sku}}"
                          },
                          {
                            "type": "Box",
                            "props": {
                              "className": "flex items-center gap-3 mt-4 flex-wrap flex-row"
                            },
                            "children": [
                              {
                                "type": "Box",
                                "props": {
                                  "className": "flex items-center gap-2 border rounded-md flex-row"
                                },
                                "children": [
                                  {
                                    "type": "Box",
                                    "props": {
                                      "className": "h-9 w-9 p-0 flex items-center justify-center border-0 !bg-transparent hover:!bg-[var(--theme-muted)] rounded-none disabled:opacity-50 flex-row"
                                    },
                                    "condition": "context?.item?.data?.quantity > 1",
                                    "children": [
                                      {
                                        "type": "Text",
                                        "props": {
                                          "className": "text-[var(--theme-foreground)]"
                                        },
                                        "text": "−"
                                      }
                                    ],
                                    "actions": [
                                      {
                                        "action": "aa100004-0000-0000-0000-000000000004"
                                      }
                                    ]
                                  },
                                  {
                                    "type": "Box",
                                    "props": {
                                      "className": "h-9 w-9 p-0 flex items-center justify-center border-0 !bg-transparent hover:!bg-[var(--theme-muted)] rounded-none disabled:opacity-50 flex-row"
                                    },
                                    "condition": "(context?.item?.data?.quantity || 0) === 1",
                                    "children": [
                                      {
                                        "type": "Text",
                                        "props": {
                                          "className": "text-[var(--theme-foreground)]"
                                        },
                                        "text": "−"
                                      }
                                    ],
                                    "actions": [
                                      {
                                        "action": "aa100003-0000-0000-0000-000000000003"
                                      }
                                    ]
                                  },
                                  {
                                    "type": "Text",
                                    "props": {
                                      "className": "w-12 text-center font-medium text-sm"
                                    },
                                    "text": "{{context.item.data.quantity}}"
                                  },
                                  {
                                    "type": "Box",
                                    "props": {
                                      "className": "h-9 w-9 p-0 flex items-center justify-center border-0 !bg-transparent hover:!bg-[var(--theme-muted)] rounded-none flex-row"
                                    },
                                    "children": [
                                      {
                                        "type": "Text",
                                        "props": {
                                          "className": "text-[var(--theme-foreground)]"
                                        },
                                        "text": "+"
                                      }
                                    ],
                                    "actions": [
                                      {
                                        "action": "aa100005-0000-0000-0000-000000000005"
                                      }
                                    ]
                                  },
                                  {
                                    "type": "Box",
                                    "props": {
                                      "className": "h-9 w-9 p-0 flex items-center justify-center !bg-transparent border-0 hover:!bg-red-50 rounded-none flex-row"
                                    },
                                    "children": [
                                      {
                                        "type": "Text",
                                        "props": {
                                          "className": "text-red-500"
                                        },
                                        "text": "✕"
                                      }
                                    ],
                                    "actions": [
                                      {
                                        "action": "aa100003-0000-0000-0000-000000000003"
                                      }
                                    ]
                                  }
                                ]
                              },
                              {
                                "type": "Box",
                                "props": {
                                  "className": "sm:hidden ml-auto gap-0 items-end flex flex-col"
                                },
                                "children": [
                                  {
                                    "type": "Text",
                                    "props": {
                                      "className": "font-semibold text-lg"
                                    },
                                    "text": {
                                      "expr": "formatCurrency(context?.item?.data?.linePriceWithTax / 100, collections['a1b2c3d4-e5f6-7890-abcd-ef1234567890']?.data?.activeOrder?.currencyCode || 'USD')"
                                    }
                                  },
                                  {
                                    "type": "Text",
                                    "props": {
                                      "className": "text-sm text-[var(--theme-muted-foreground)] mt-1"
                                    },
                                    "text": {
                                      "expr": "formatCurrency(context?.item?.data?.unitPriceWithTax / 100, collections['a1b2c3d4-e5f6-7890-abcd-ef1234567890']?.data?.activeOrder?.currencyCode || 'USD') + ' each'"
                                    }
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "hidden sm:flex sm:flex-col sm:items-end text-right flex-shrink-0"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "font-semibold text-lg"
                            },
                            "text": {
                              "expr": "formatCurrency(context?.item?.data?.linePriceWithTax / 100, collections['a1b2c3d4-e5f6-7890-abcd-ef1234567890']?.data?.activeOrder?.currencyCode || 'USD')"
                            }
                          },
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-sm text-[var(--theme-muted-foreground)] mt-1"
                            },
                            "text": {
                              "expr": "formatCurrency(context?.item?.data?.unitPriceWithTax / 100, collections['a1b2c3d4-e5f6-7890-abcd-ef1234567890']?.data?.activeOrder?.currencyCode || 'USD') + ' each'"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Box",
            "props": {
              "className": "lg:col-span-1 space-y-4"
            },
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "border border-[var(--theme-border)] rounded-lg p-6 bg-[var(--theme-card)] sticky top-4 h-fit"
                },
                "children": [
                  {
                    "type": "Heading",
                    "props": {
                      "className": "text-xl font-bold mb-4"
                    },
                    "text": "Order Summary"
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "space-y-2 mb-4 flex flex-col"
                    },
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex justify-between text-sm flex-row"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-[var(--theme-muted-foreground)]"
                            },
                            "text": "Subtotal"
                          },
                          {
                            "type": "Text",
                            "text": {
                              "expr": "formatCurrency(collections['a1b2c3d4-e5f6-7890-abcd-ef1234567890']?.data?.activeOrder?.subTotalWithTax / 100, collections['a1b2c3d4-e5f6-7890-abcd-ef1234567890']?.data?.activeOrder?.currencyCode || 'USD')"
                            }
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "contents"
                        },
                        "map": "collections.a1b2c3d4-e5f6-7890-abcd-ef1234567890.data.activeOrder.discounts",
                        "key": "discount",
                        "condition": "collections['a1b2c3d4-e5f6-7890-abcd-ef1234567890']?.data?.activeOrder?.discounts?.length > 0",
                        "children": [
                          {
                            "type": "Box",
                            "props": {
                              "className": "flex justify-between text-sm text-green-600 flex-row"
                            },
                            "children": [
                              {
                                "type": "Text",
                                "text": "{{context.item.data.description}}"
                              },
                              {
                                "type": "Text",
                                "text": {
                                  "expr": "formatCurrency(context?.item?.data?.amountWithTax / 100, collections['a1b2c3d4-e5f6-7890-abcd-ef1234567890']?.data?.activeOrder?.currencyCode || 'USD')"
                                }
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex justify-between text-sm flex-row"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-[var(--theme-muted-foreground)]"
                            },
                            "text": "Shipping"
                          },
                          {
                            "type": "Text",
                            "text": {
                              "expr": "collections['a1b2c3d4-e5f6-7890-abcd-ef1234567890']?.data?.activeOrder?.shippingWithTax > 0 ? formatCurrency(collections['a1b2c3d4-e5f6-7890-abcd-ef1234567890']?.data?.activeOrder?.shippingWithTax / 100, collections['a1b2c3d4-e5f6-7890-abcd-ef1234567890']?.data?.activeOrder?.currencyCode || 'USD') : 'Calculated at checkout'"
                            }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "border-t pt-4 mb-6"
                    },
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex justify-between font-bold text-lg flex-row"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "text": "Total"
                          },
                          {
                            "type": "Text",
                            "text": {
                              "expr": "formatCurrency(collections['a1b2c3d4-e5f6-7890-abcd-ef1234567890']?.data?.activeOrder?.totalWithTax / 100, collections['a1b2c3d4-e5f6-7890-abcd-ef1234567890']?.data?.activeOrder?.currencyCode || 'USD')"
                            }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "w-full !bg-[var(--theme-primary)] hover:!bg-[var(--theme-primary)] h-11 text-base font-medium flex flex-row items-center justify-center rounded-md"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-white"
                        },
                        "text": "Proceed to Checkout"
                      }
                    ],
                    "actions": [
                      {
                        "action": "13a93f84-964f-4116-84da-d2af7cc3bc81"
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "w-full mt-2 border border-[var(--theme-border)] !bg-[var(--theme-card)] hover:!bg-[var(--theme-muted)] h-10 flex flex-row items-center justify-center rounded-md"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[var(--theme-foreground)]"
                        },
                        "text": "Continue Shopping"
                      }
                    ],
                    "actions": [
                      {
                        "action": "9e33ef0a-706f-4555-b2ee-60fd95ebf416"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Box",
                "props": {
                  "className": "border border-[var(--theme-border)] rounded-lg p-6 bg-[var(--theme-card)]"
                },
                "children": [
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex items-center gap-2 mb-2 flex-row"
                    },
                    "children": [
                      {
                        "type": "Icon",
                        "props": {
                          "icon": "lucide:tag",
                          "size": 20,
                          "className": "text-[var(--theme-muted-foreground)]"
                        }
                      },
                      {
                        "type": "Heading",
                        "props": {
                          "className": "text-lg"
                        },
                        "text": "Promotion Code"
                      }
                    ]
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm text-[var(--theme-muted-foreground)] mb-4"
                    },
                    "text": "Enter your discount code below"
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "space-y-2"
                    },
                    "condition": "collections['a1b2c3d4-e5f6-7890-abcd-ef1234567890']?.data?.activeOrder?.couponCodes?.length > 0",
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": "contents"
                        },
                        "map": "collections.a1b2c3d4-e5f6-7890-abcd-ef1234567890.data.activeOrder.couponCodes",
                        "key": "code",
                        "children": [
                          {
                            "type": "Box",
                            "props": {
                              "className": "flex items-center justify-between p-3 border rounded-md bg-green-50 flex-row"
                            },
                            "children": [
                              {
                                "type": "Box",
                                "props": {
                                  "className": "flex items-center gap-2 flex-row"
                                },
                                "children": [
                                  {
                                    "type": "Icon",
                                    "props": {
                                      "icon": "lucide:tag",
                                      "size": 16,
                                      "className": "text-green-600"
                                    }
                                  },
                                  {
                                    "type": "Text",
                                    "props": {
                                      "className": "font-medium text-sm"
                                    },
                                    "text": "{{$item}}"
                                  }
                                ]
                              },
                              {
                                "type": "Box",
                                "props": {
                                  "className": "h-8 !bg-transparent hover:!bg-red-50 flex flex-row items-center justify-center px-4 rounded-md"
                                },
                                "children": [
                                  {
                                    "type": "Text",
                                    "props": {
                                      "className": "text-red-500"
                                    },
                                    "text": "Remove"
                                  }
                                ],
                                "actions": [
                                  {
                                    "action": "aa100007-0000-0000-0000-000000000007"
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex gap-2 flex-row"
                    },
                    "condition": "(collections['a1b2c3d4-e5f6-7890-abcd-ef1234567890']?.data?.activeOrder?.couponCodes?.length || 0) === 0",
                    "children": [
                      {
                        "type": "Input",
                        "id": "835d52a6-ac9f-4c42-90ef-90f286617010",
                        "props": {
                          "variant": "outline",
                          "size": "sm",
                          "className": "!text-[var(--theme-foreground)]",
                          "placeholder": "Enter code",
                          "value": "{{local.data.form.formData.couponCode}}"
                        }
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "!bg-[var(--theme-primary)] hover:!bg-[var(--theme-primary)] px-4 flex flex-row items-center justify-center py-3 rounded-md"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-white"
                            },
                            "text": "Apply"
                          }
                        ],
                        "actions": [
                          {
                            "action": "aa100006-0000-0000-0000-000000000006"
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
