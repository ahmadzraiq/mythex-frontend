{
  "meta": {"title": "Cart | SaraZ", "description": "Your shopping cart"},
  "state": {"coupon": "", "shippingZip": ""},
  "layout": "cart",
  "initActions": [{"action": "fetchCartUpsell"}],
  "content": {
    "type": "Box",
    "props": {"className": "w-full px-4 sm:px-6 py-8 md:py-12"},
    "children": [
      {
        "type": "Text",
        "props": {
          "className": "text-[var(--theme-shop-textMuted)] text-xs font-medium tracking-widest uppercase mb-2"
        },
        "text": "Your bag"
      },
      {
        "type": "Heading",
        "props": {"size": "2xl", "className": "mb-8 font-light"},
        "text": "Shopping Cart"
      },
      {
        "type": "Box",
        "condition": {">": [{"var": ["cart.items.length", 0]}, 0]},
        "props": {"className": "grid grid-cols-1 lg:grid-cols-3 gap-8"},
        "children": [
          {
            "type": "VStack",
            "props": {"className": "gap-4 flex-1"},
            "children": [
              {
                "type": "Box",
                "map": "cart.items",
                "key": "$item.product.id",
                "props": {
                  "className": "flex gap-6 p-6 bg-[var(--theme-content-bg)] rounded-xl border border-[var(--theme-shop-border)]"
                },
                "children": [
                  {
                    "type": "Box",
                    "props": {
                      "className": "w-24 h-24 md:w-28 md:h-28 bg-[var(--theme-content-bgAlt)] rounded-lg shrink-0 overflow-hidden"
                    },
                    "children": [
                      {
                        "type": "NextImage",
                        "props": {
                          "src": "{{$item.product.image}}",
                          "alt": "{{$item.product.name}}",
                          "width": 112,
                          "height": 112,
                          "className": "object-cover w-full h-full"
                        }
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {"className": "flex-1 min-w-0"},
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "font-medium text-[var(--theme-shop-heading)]"
                        },
                        "text": "{{$item.product.name}}"
                      },
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-sm text-[var(--theme-shop-textMuted)] mt-1"
                        },
                        "text": "{{$item.product.price}} × {{$item.quantity}}"
                      },
                      {
                        "type": "Text",
                        "condition": {"var": "$item.variant"},
                        "props": {
                          "className": "text-xs text-[var(--theme-shop-textMuted)] mt-0.5"
                        },
                        "text": "{{$item.variant.size}} {{$item.variant.color}}"
                      }
                    ]
                  },
                  {
                    "type": "VStack",
                    "props": {"className": "items-end gap-2"},
                    "children": [
                      {
                        "type": "Text",
                        "props": {"className": "font-semibold"},
                        "text": "{{$item.product.price}} × {{$item.quantity}}"
                      },
                      {
                        "type": "Pressable",
                        "props": {
                          "className": "text-[var(--theme-shop-textMuted)] hover:text-error-600 text-sm"
                        },
                        "actions": {"click": {"action": "removeFromCart"}},
                        "children": [{"type": "Text", "text": "Remove"}]
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Box",
            "condition": {">": [{"var": ["cart.upsell.length", 0]}, 0]},
            "props": {"className": "mt-8"},
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "text-xs font-medium tracking-widest text-[var(--theme-shop-textMuted)] uppercase mb-4"
                },
                "text": "You might also like"
              },
              {
                "type": "Box",
                "props": {"className": "grid grid-cols-2 md:grid-cols-4 gap-4"},
                "children": [
                  {
                    "type": "Box",
                    "map": "cart.upsell",
                    "key": "$item.id",
                    "children": [{"$ref": "fragments/product-card"}]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "Box",
        "props": {"className": "lg:col-span-1"},
        "children": [
          {
            "type": "Box",
            "props": {
              "className": "p-6 bg-[var(--theme-content-bg)] rounded-xl border border-[var(--theme-shop-border)] sticky top-24"
            },
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "text-xs font-medium tracking-widest text-[var(--theme-shop-textMuted)] uppercase mb-4"
                },
                "text": "Order Summary"
              },
              {
                "type": "Box",
                "props": {"className": "gap-2 mb-4"},
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm font-medium text-[var(--theme-shop-heading)]"
                    },
                    "text": "Coupon"
                  },
                  {
                    "type": "Input",
                    "props": {
                      "placeholder": "Enter code",
                      "value": "{{coupon}}",
                      "className": "mb-2"
                    },
                    "actions": {
                      "change": {
                        "action": "setState",
                        "payload": {"path": "coupon", "value": "$event"}
                      }
                    }
                  }
                ]
              },
              {
                "type": "Button",
                "props": {"variant": "outline", "className": "w-full mb-6"},
                "text": "Apply",
                "actions": {"click": {"action": "applyCoupon"}}
              },
              {
                "type": "Box",
                "props": {"className": "gap-2 mb-4"},
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm font-medium text-[var(--theme-shop-heading)]"
                    },
                    "text": "Shipping"
                  },
                  {
                    "type": "Input",
                    "props": {
                      "placeholder": "Enter area or postal code",
                      "value": "{{shippingZip}}",
                      "className": "mb-2"
                    },
                    "actions": {
                      "change": {
                        "action": "setState",
                        "payload": {"path": "shippingZip", "value": "$event"}
                      }
                    }
                  }
                ]
              },
              {
                "type": "Button",
                "props": {"variant": "outline", "className": "w-full mb-6"},
                "text": "Calculate",
                "actions": {"click": {"action": "calculateShipping"}}
              },
              {
                "type": "Divider",
                "props": {"className": "my-4"},
                "condition": {"var": "cart.items"}
              },
              {
                "type": "HStack",
                "props": {"className": "justify-between mb-2 text-sm"},
                "children": [
                  {"type": "Text", "text": "Subtotal"},
                  {
                    "type": "Text",
                    "text": {
                      "expr": {
                        "formatCurrency": [
                          {
                            "reduce": [
                              {"var": "cart.items"},
                              {
                                "+": [
                                  {"var": "accumulator"},
                                  {
                                    "*": [
                                      {"var": ["current.product.price", 0]},
                                      {"var": ["current.quantity", 1]}
                                    ]
                                  }
                                ]
                              },
                              0
                            ]
                          },
                          "AED"
                        ]
                      }
                    }
                  }
                ]
              },
              {
                "type": "HStack",
                "props": {"className": "justify-between mb-2 text-sm"},
                "children": [
                  {"type": "Text", "text": "Shipping"},
                  {
                    "type": "Text",
                    "text": {
                      "expr": {
                        "if": [
                          {
                            "==": [
                              {
                                "reduce": [
                                  {"var": "cart.items"},
                                  {"+": [{"var": "accumulator"}, 1]},
                                  0
                                ]
                              },
                              0
                            ]
                          },
                          "—",
                          {"var": ["cart.shippingEstimate.label", "Free"]}
                        ]
                      }
                    }
                  }
                ]
              },
              {
                "type": "HStack",
                "props": {"className": "justify-between mb-2 text-sm"},
                "children": [
                  {"type": "Text", "text": "Tax (5%)"},
                  {
                    "type": "Text",
                    "text": {
                      "expr": {
                        "formatCurrency": [
                          {
                            "*": [
                              {
                                "reduce": [
                                  {"var": "cart.items"},
                                  {
                                    "+": [
                                      {"var": "accumulator"},
                                      {
                                        "*": [
                                          {"var": ["current.product.price", 0]},
                                          {"var": ["current.quantity", 1]}
                                        ]
                                      }
                                    ]
                                  },
                                  0
                                ]
                              },
                              0.05
                            ]
                          },
                          "AED"
                        ]
                      }
                    }
                  }
                ]
              },
              {
                "type": "Divider",
                "props": {"className": "my-4"},
                "condition": {"var": "cart.items"}
              },
              {
                "type": "HStack",
                "props": {"className": "justify-between font-semibold mb-6"},
                "children": [
                  {"type": "Text", "text": "Total"},
                  {
                    "type": "Text",
                    "text": {
                      "expr": {
                        "formatCurrency": [
                          {
                            "*": [
                              {
                                "reduce": [
                                  {"var": "cart.items"},
                                  {
                                    "+": [
                                      {"var": "accumulator"},
                                      {
                                        "*": [
                                          {"var": ["current.product.price", 0]},
                                          {"var": ["current.quantity", 1]}
                                        ]
                                      }
                                    ]
                                  },
                                  0
                                ]
                              },
                              1.05
                            ]
                          },
                          "AED"
                        ]
                      }
                    }
                  }
                ]
              },
              {
                "type": "Button",
                "props": {"action": "primary", "className": "w-full py-3.5"},
                "text": "Proceed to Checkout",
                "actions": {
                  "click": {
                    "action": "navigate",
                    "payload": {"path": "/checkout"}
                  }
                }
              }
            ]
          }
        ]
      },
      {
        "type": "Box",
        "condition": {"==": [{"var": ["cart.items.length", 0]}, 0]},
        "props": {
          "className": "flex flex-col items-center justify-center py-20 text-center"
        },
        "children": [
          {
            "type": "Text",
            "props": {"className": "text-4xl mb-4"},
            "text": "🛒"
          },
          {
            "type": "Heading",
            "props": {
              "size": "lg",
              "className": "text-[var(--theme-shop-heading)] mb-2"
            },
            "text": "Your cart is empty"
          },
          {
            "type": "Text",
            "props": {"className": "text-[var(--theme-shop-textMuted)] mb-6"},
            "text": "Add items to get started"
          },
          {
            "type": "Button",
            "props": {
              "action": "primary",
              "className": "bg-[var(--theme-shop-button)]"
            },
            "text": "Continue Shopping",
            "actions": {
              "click": {"action": "navigate", "payload": {"path": "/shop"}}
            }
          }
        ]
      }
    ]
  }
}
