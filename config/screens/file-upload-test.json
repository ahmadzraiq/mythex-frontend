{
  "meta": {
    "title": "FileUpload System Component Demo"
  },
  "state": {},
  "ui": {
    "type": "Box",
    "props": {
      "className": "w-full min-h-screen bg-gray-50 dark:bg-gray-950"
    },
    "children": [
      {
        "type": "Box",
        "props": {
          "className": "max-w-[640px] mx-auto flex flex-col gap-[24px] py-[48px] px-[24px]"
        },
        "children": [
          {
            "type": "Text",
            "props": {
              "className": "text-[24px] font-bold text-gray-900 dark:text-white"
            },
            "text": "FileUpload — Custom Trigger Demo"
          },
          {
            "type": "Text",
            "props": {
              "className": "text-[14px] text-gray-500 dark:text-gray-400"
            },
            "text": "Click the dropzone below. The FileUpload SC opens the OS file picker via the `pickFile` workflow step, stores the picked files, and fires its `On files selected` custom trigger with payload `{ files }`. A page-level workflow listens for that trigger and writes the first filename into a variable shown at the bottom."
          },

          {
            "type": "Box",
            "props": {
              "className": "flex flex-col gap-[12px] p-[20px] rounded-[12px] bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800"
            },
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "text-[12px] font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400"
                },
                "text": "1. The FileUpload (system component instance)"
              },
              {
                "type": "Box",
                "_system": { "id": "sys-file-upload", "name": "File upload" },
                "_overrides": [],
                "props": {
                  "className": "relative flex flex-col items-center justify-center gap-[8px] w-full px-[16px] py-[24px] rounded-[8px] border-2 border-dashed border-border bg-muted/40 hover:border-primary hover:bg-primary/5 cursor-pointer",
                  "label": "Click to upload",
                  "accept": "",
                  "multiple": false,
                  "data-testid": "file-upload-dropzone"
                },
                "actions": [
                  { "action": "fu-wf-on-click" },
                  { "action": "wfOnFilesSelected" }
                ],
                "children": [
                  { "type": "Icon", "props": { "icon": "lucide:upload-cloud", "size": 28, "color": "#6b7280" } },
                  {
                    "type": "Text",
                    "props": { "className": "text-[14px] font-medium text-foreground" },
                    "text": {
                      "formula": "context?.component?.variables?.['fu-v-filename-uuid'] || context?.component?.props?.label || 'Click to upload'"
                    }
                  },
                  {
                    "type": "Text",
                    "props": { "className": "text-[12px] text-muted-foreground" },
                    "text": {
                      "formula": "context?.component?.props?.accept ? 'Accepted: ' + context.component.props.accept : 'Any file type'"
                    }
                  }
                ]
              }
            ]
          },

          {
            "type": "Box",
            "props": {
              "className": "flex flex-col gap-[12px] p-[20px] rounded-[12px] bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800"
            },
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "text-[12px] font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400"
                },
                "text": "2. Page-level listener output"
              },
              {
                "type": "Box",
                "props": { "className": "flex flex-row items-center gap-[8px]" },
                "children": [
                  {
                    "type": "Text",
                    "props": { "className": "text-[12px] font-mono text-gray-400 uppercase tracking-wider" },
                    "text": "context.event.files[0].name →"
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-[14px] font-medium text-gray-900 dark:text-gray-100",
                      "data-testid": "out-picked-filename"
                    },
                    "text": {
                      "formula": "'File: ' + (variables['fu-test-name'] || '(none)')"
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
