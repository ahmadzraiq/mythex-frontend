                            "type": "Box",
                            "props": {
                              "className": "flex-1 h-2 bg-[var(--theme-shop-border)] rounded-full overflow-hidden"
                            },
                            "children": [
                              {
                                "type": "Box",
                                "props": {
                                  "className": "h-full bg-[var(--theme-shop-accent)] rounded-full",
                                  "style": { "width": "{{$item.pct}}%" }
                                }
                              }
                            ]
                          },
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-sm text-[var(--theme-shop-textMuted)] w-8"
                            },
                            "text": "{{$item.count}}"
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "VStack",
                "props": {
                  "className": "gap-4"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "font-medium text-[var(--theme-shop-heading)]"
                    },
                    "text": "Reviews"
                  },
                  {
                    "type": "VStack",
                    "condition": {
                      "var": "product.reviews"
                    },
                    "map": "product.reviews",
                    "key": "$item.id",
                    "props": {
                      "className": "gap-2 py-4 border-b border-[var(--theme-shop-border)] last:border-0"
                    },
                    "children": [
                      {
                        "type": "HStack",
                        "props": {
                          "className": "gap-2 items-center"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "font-medium text-sm text-[var(--theme-shop-heading)]"
                            },
                            "text": "{{$item.author}}"
                          },
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-sm text-[var(--theme-shop-textMuted)]"
                            },
                            "text": "{{$item.rating}} ★"
                          },
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-xs text-[var(--theme-shop-textMuted)]"
                            },
                            "text": "{{$item.date}}"
                          }
                        ]
                      },
                      {
                        "type": "Text",
                        "props": {
                          "className": "font-medium text-sm text-[var(--theme-shop-heading)]"
                        },
                        "text": "{{$item.title}}"
                      },
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-sm text-[var(--theme-shop-text)]"
                        },
                        "text": "{{$item.body}}"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "VStack",
                "props": {
                  "className": "gap-4 p-6 border border-[var(--theme-shop-border)] rounded-xl"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "font-medium text-[var(--theme-shop-heading)]"
                    },
                    "text": "Write a review"
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm text-[var(--theme-shop-textMuted)]"
                    },
                    "text": "Your rating"
                  },
                  {
                    "type": "HStack",
                    "props": {
                      "className": "gap-1"
                    },
                    "children": [
                      {
                        "type": "Pressable",
                        "map": [1, 2, 3, 4, 5],
                        "key": "$index",
                        "props": {
                          "className": "text-2xl text-[var(--theme-shop-textMuted)] hover:text-[var(--theme-shop-accent)]"
                        },
                        "condition": {
                          ">": [{ "var": "$item" }, { "var": "reviewForm.rating" }]
                        },
                        "actions": {
                          "click": {
                            "action": "setState",
                            "payload": { "path": "reviewForm.rating", "value": { "var": "$item" } }
                          }
                        },
                        "children": [{ "type": "Text", "text": "★" }]
                      },
                      {
                        "type": "Pressable",
                        "map": [1, 2, 3, 4, 5],
                        "key": "$index",
                        "props": {
                          "className": "text-2xl text-[var(--theme-shop-accent)]"
                        },
                        "condition": {
                          "<=": [{ "var": "$item" }, { "var": "reviewForm.rating" }]
                        },
                        "actions": {
                          "click": {
                            "action": "setState",
                            "payload": { "path": "reviewForm.rating", "value": { "var": "$item" } }
                          }
                        },
                        "children": [{ "type": "Text", "text": "★" }]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "gap-2"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-sm font-medium text-[var(--theme-shop-heading)]"
                        },
                        "text": "Title"
                      },
                      {
                        "type": "Input",
                        "props": {
                          "className": "border border-[var(--theme-shop-border)] rounded-lg",
                          "placeholder": "Sum up your experience",
                          "value": "{{reviewForm.title}}"
                        },
                        "actions": {
                          "change": {
                            "action": "setState",
                            "payload": { "path": "reviewForm.title", "value": "$event" }
                          }
                        }
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "gap-2"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-sm font-medium text-[var(--theme-shop-heading)]"
                        },
                        "text": "Your review"
                      },
                      {
                        "type": "Textarea",
                        "props": {
                          "className": "border border-[var(--theme-shop-border)] rounded-lg",
                          "placeholder": "Share your thoughts...",
                          "value": "{{reviewForm.body}}"
                        },
                        "actions": {
                          "change": {
                            "action": "setState",
                            "payload": { "path": "reviewForm.body", "value": "$event" }
                          }
                        }
                      }
                    ]
                  },
                  {
                    "type": "Button",
                    "props": {
                      "action": "primary",
                      "className": "self-start bg-[var(--theme-shop-button)] hover:bg-[var(--theme-shop-buttonHover)]"
                    },
                    "text": "Submit Review",
                    "actions": {
                      "click": {
                        "action": "submitReview"
                      }
                    }
                  }
                ]
              },
              {
                "type": "VStack",
                "condition": {
                  "and": [
                    { "var": "product.relatedProducts" },
                    { ">": [{ "var": ["product.relatedProducts.length", 0] }, 0] }
                  ]
                },
                "props": {
                  "className": "gap-6 border-t border-[var(--theme-shop-border)] pt-8"
                },
                "children": [
                  {
                    "type": "Heading",
                    "props": {
                      "size": "lg",
                      "className": "text-[var(--theme-shop-heading)]"
                    },
                    "text": "You may also like"
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4"
                    },
                    "children": [
                      {
                        "type": "Box",
                        "map": "product.relatedProducts",
                        "key": "$item.id",
                        "children": [{ "$ref": "fragments/product-card" }]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "VStack",
                "condition": {
                  "and": [
                    { "var": "product.frequentlyBoughtTogether" },
                    { ">": [{ "var": ["product.frequentlyBoughtTogether.length", 0] }, 0] }
                  ]
                },
                "props": {
                  "className": "gap-6 border-t border-[var(--theme-shop-border)] pt-8"
                },
                "children": [
                  {
                    "type": "Heading",
                    "props": {
                      "size": "lg",
                      "className": "text-[var(--theme-shop-heading)]"
                    },
                    "text": "Frequently bought together"
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4"
                    },
                    "children": [
                      {
                        "type": "Box",
                        "map": "product.frequentlyBoughtTogether",
                        "key": "$item.id",
                        "children": [{ "$ref": "fragments/product-card" }]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "VStack",
                "condition": {
                  "and": [
                    { "var": "product.recentlyViewed" },
                    { ">": [{ "var": ["product.recentlyViewed.length", 0] }, 0] }
                  ]
                },
                "props": {
                  "className": "gap-6 border-t border-[var(--theme-shop-border)] pt-8"
                },
                "children": [
                  {
                    "type": "Heading",
                    "props": {
                      "size": "lg",
                      "className": "text-[var(--theme-shop-heading)]"
                    },
                    "text": "Recently viewed"
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4"
                    },
                    "children": [
                      {
                        "type": "Box",
                        "map": "product.recentlyViewed",
                        "key": "$item.id",
                        "children": [{ "$ref": "fragments/product-card" }]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "Box",
        "condition": {
          "!": {
            "var": "product.id"
          }
        },
        "props": {
          "className": "flex flex-col items-center justify-center py-20 text-center"
        },
        "children": [
          {
            "type": "Heading",
            "props": {
              "size": "xl",
              "className": "text-[var(--theme-shop-heading)]"
            },
            "text": "Product not found"
          },
          {
            "type": "Button",
            "props": {
              "className": "mt-4 bg-[var(--theme-shop-button)]"
            },
            "text": "Continue Shopping",
            "actions": {
              "click": {
                "action": "navigate",
                "payload": {
                  "path": "/shop"
                }
              }
            }
          }
        ]
      }
    ]
  }
}