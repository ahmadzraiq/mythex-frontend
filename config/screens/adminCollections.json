{
  "layout": "admin",
  "content": {
    "type": "Box",
    "props": {
      "className": "flex flex-col gap-[24px] w-full"
    },
    "children": [
      {
        "type": "Box",
        "props": {
          "className": "flex flex-col gap-[4px]"
        },
        "children": [
          {
            "type": "Box",
            "props": {
              "className": "flex items-center gap-[6px] flex-row"
            },
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "text-[13px] text-[var(--theme-admin-muted)]"
                },
                "text": "Catalog"
              },
              {
                "type": "Icon",
                "props": {
                  "icon": "lucide:chevron-right",
                  "size": 14,
                  "color": "var(--theme-admin-label)"
                }
              },
              {
                "type": "Text",
                "props": {
                  "className": "text-[13px] text-[var(--theme-admin-muted)]"
                },
                "text": "Collections"
              }
            ]
          },
          {
            "type": "Text",
            "props": {
              "className": "text-[24px] font-bold text-[var(--theme-admin-text)]"
            },
            "text": "Collections"
          },
          {
            "type": "Text",
            "props": {
              "className": "text-[14px] text-[var(--theme-admin-label)]"
            },
            "text": "Collections are used to group products for navigation and filtering."
          }
        ],
        "_group": "Page Header"
      },
      {
        "type": "Box",
        "props": {
          "className": "bg-[var(--theme-admin-surface)] rounded-[12px] border border-[var(--theme-admin-border)] overflow-hidden"
        },
        "children": [
          {
            "type": "Box",
            "props": {
              "className": "grid gap-[0px] px-[20px] py-[12px] border-b border-[var(--theme-admin-border)]",
              "style": {
                "gridTemplateColumns": "2fr 1.5fr 0.8fr"
              }
            },
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "text-[11px] font-semibold uppercase tracking-wider text-[var(--theme-admin-label)]"
                },
                "text": "Name"
              },
              {
                "type": "Text",
                "props": {
                  "className": "text-[11px] font-semibold uppercase tracking-wider text-[var(--theme-admin-label)]"
                },
                "text": "Slug"
              },
              {
                "type": "Text",
                "props": {
                  "className": "text-[11px] font-semibold uppercase tracking-wider text-[var(--theme-admin-label)]"
                },
                "text": "Visibility"
              }
            ]
          },
          {
            "type": "Box",
            "props": {
              "className": "flex flex-col"
            },
            "map": "collections['ad000009-0000-0000-0000-000000000009']?.collections?.items",
            "key": "collection-row",
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "grid gap-[0px] px-[20px] py-[14px] border-b border-[var(--theme-admin-sidebar)] hover:bg-[var(--theme-admin-sidebar)]/50 transition-colors items-center",
                  "style": {
                    "gridTemplateColumns": "2fr 1.5fr 0.8fr"
                  }
                },
                "children": [
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex items-center gap-[10px] flex-row"
                    },
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": "w-[36px] h-[36px] rounded-[6px] overflow-hidden flex-shrink-0 bg-[var(--theme-admin-border)]/50"
                        },
                        "children": [
                          {
                            "type": "Image",
                            "props": {
                              "src": "{{context.item.data.featuredAsset?.preview}}",
                              "alt": "{{context.item.data.name}}",
                              "width": 36,
                              "height": 36,
                              "className": "w-full h-full object-cover"
                            },
                            "condition": "!!context.item.data.featuredAsset?.preview"
                          },
                          {
                            "type": "Icon",
                            "props": {
                              "icon": "lucide:folder",
                              "size": 16,
                              "color": "var(--theme-admin-label)",
                              "className": "m-auto mt-[10px]"
                            },
                            "condition": "!context.item.data.featuredAsset?.preview"
                          }
                        ]
                      },
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[13px] font-medium text-[var(--theme-admin-text)]"
                        },
                        "text": "{{context.item.data.name}}"
                      }
                    ]
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-[12px] text-[var(--theme-admin-label)] font-mono truncate"
                    },
                    "text": "{{context.item.data.slug}}"
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "inline-flex items-center px-[8px] py-[2px] rounded-full text-[11px] font-medium bg-[var(--theme-admin-success)]/20 text-[var(--theme-admin-success)]"
                    },
                    "text": "Public"
                  }
                ]
              }
            ]
          },
          {
            "type": "Box",
            "props": {
              "className": "flex flex-col items-center justify-center py-[60px] gap-[8px]"
            },
            "condition": "!(collections['ad000009-0000-0000-0000-000000000009']?.collections?.items?.length > 0)",
            "children": [
              {
                "type": "Icon",
                "props": {
                  "icon": "lucide:folder",
                  "size": 40,
                  "color": "var(--theme-admin-border)"
                }
              },
              {
                "type": "Text",
                "props": {
                  "className": "text-[15px] text-[var(--theme-admin-label)]"
                },
                "text": "No collections found"
              }
            ]
          }
        ],
        "_group": "Collections Table"
      }
    ]
  },
  "dataSources": [
    "ad000009-0000-0000-0000-000000000009"
  ]
}
