{
  "meta": { "title": "Account | LUMEN", "description": "Your account" },
  "state": {
    "user": { "name": "Alex", "email": "alex@example.com" },
    "ordersCount": 5,
    "loyaltyPoints": 1240,
    "addressesCount": 2
  },
  "layout": "store",
  "content": {
    "type": "Box",
    "props": { "className": "max-w-7xl mx-auto px-4 sm:px-6 py-8 md:py-12" },
    "children": [
      { "type": "Text", "props": { "className": "text-gray-500 text-xs font-medium tracking-widest uppercase mb-2" }, "text": "Welcome back" },
      { "type": "Heading", "props": { "size": "2xl", "className": "mb-10 font-light" }, "text": "My Account" },
      {
        "type": "Box",
        "props": { "className": "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6" },
        "children": [
          {
            "type": "Pressable",
            "props": { "className": "p-6 bg-white rounded-xl border border-gray-200 hover:border-primary-300 hover:shadow-soft-1 transition-all" },
            "actions": { "click": { "action": "navigate", "payload": { "path": "/account/orders" } } },
            "children": [
              { "type": "Text", "props": { "className": "text-2xl mb-3" }, "text": "📦" },
              { "type": "Text", "props": { "className": "font-semibold text-gray-900" }, "text": "Orders" },
              { "type": "Text", "props": { "className": "text-sm text-gray-600 mt-1" }, "text": "{{ordersCount}} orders" }
            ]
          },
          {
            "type": "Pressable",
            "props": { "className": "p-6 bg-white rounded-xl border border-gray-200 hover:border-primary-300 hover:shadow-soft-1 transition-all" },
            "actions": { "click": { "action": "navigate", "payload": { "path": "/account/addresses" } } },
            "children": [
              { "type": "Text", "props": { "className": "text-2xl mb-3" }, "text": "📍" },
              { "type": "Text", "props": { "className": "font-semibold text-gray-900" }, "text": "Addresses" },
              { "type": "Text", "props": { "className": "text-sm text-gray-600 mt-1" }, "text": "{{addressesCount}} saved" }
            ]
          },
          {
            "type": "Pressable",
            "props": { "className": "p-6 bg-white rounded-xl border border-gray-200 hover:border-primary-300 hover:shadow-soft-1 transition-all" },
            "actions": { "click": { "action": "navigate", "payload": { "path": "/account/wishlist" } } },
            "children": [
              { "type": "Text", "props": { "className": "text-2xl mb-3" }, "text": "♡" },
              { "type": "Text", "props": { "className": "font-semibold text-gray-900" }, "text": "Wishlist" }
            ]
          },
          {
            "type": "Pressable",
            "props": { "className": "p-6 bg-white rounded-xl border border-gray-200 hover:border-primary-300 hover:shadow-soft-1 transition-all" },
            "actions": { "click": { "action": "navigate", "payload": { "path": "/account/returns" } } },
            "children": [
              { "type": "Text", "props": { "className": "text-2xl mb-3" }, "text": "↩" },
              { "type": "Text", "props": { "className": "font-semibold text-gray-900" }, "text": "Returns" }
            ]
          }
        ]
      },
      {
        "type": "Box",
        "props": { "className": "mt-10 p-6 bg-gray-100 rounded-xl border border-gray-200" },
        "children": [
          { "type": "Text", "props": { "className": "text-xs font-medium tracking-widest text-gray-500 uppercase mb-2" }, "text": "Loyalty" },
          { "type": "Heading", "props": { "size": "lg", "className": "text-gray-900 font-light" }, "text": "{{loyaltyPoints}} points" },
          { "type": "Text", "props": { "className": "text-sm text-gray-600 mt-1" }, "text": "Redeem at checkout" }
        ]
      }
    ]
  }
}
