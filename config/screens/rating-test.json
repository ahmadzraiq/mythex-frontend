{
  "meta": { "title": "Star Rating System Component Demo" },
  "state": {},
  "ui": {
    "type": "Box",
    "props": { "className": "w-full min-h-screen bg-gray-50 dark:bg-gray-950" },
    "children": [
      {
        "type": "Box",
        "props": { "className": "max-w-[640px] mx-auto flex flex-col gap-[24px] py-[48px] px-[24px]" },
        "children": [
          { "type": "Text", "props": { "className": "text-[24px] font-bold text-gray-900 dark:text-white" }, "text": "Star Rating — Custom Trigger Demo" },

          {
            "type": "Box",
            "_system": { "id": "sys-rating", "name": "Star Rating" },
            "_overrides": [],
            "props": {
              "value": { "formula": "Number(variables['rating-test-value']) || 0" },
              "max": 5,
              "readOnly": false,
              "color": "#f59e0b",
              "emptyColor": "#d1d5db",
              "data-testid": "rating-strip",
              "className": "flex flex-row gap-[4px] items-center"
            },
            "actions": [{ "action": "wfOnRatingChange" }],
            "children": [
              {
                "type": "Box",
                "map": { "formula": "(()=>{const max=Number(context?.component?.props?.max)||5;const cur=Number(context?.component?.props?.value)||0;const out=[];for(let i=1;i<=max;i++)out.push({value:i,isFilled:i<=cur});return out})()" },
                "key": "context.item.data.value",
                "props": { "className": "contents" },
                "children": [
                  {
                    "type": "Box",
                    "props": {
                      "data-testid": { "formula": "'rating-star-' + (context?.item?.data?.value || '')" },
                      "style": {
                        "cursor": { "formula": "context?.component?.props?.readOnly?'default':'pointer'" }
                      }
                    },
                    "actions": [{ "action": "rating-wf-set" }],
                    "children": [
                      {
                        "type": "Icon",
                        "props": {
                          "icon": "lucide:star",
                          "size": 20,
                          "color": {
                            "formula": "context?.item?.data?.isFilled ? (context?.component?.props?.color || '#f59e0b') : (context?.component?.props?.emptyColor || '#d1d5db')"
                          }
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          },

          {
            "type": "Text",
            "props": { "className": "text-[14px] text-gray-700 dark:text-gray-300", "data-testid": "out-rating-value" },
            "text": { "formula": "'Rating: ' + (variables['rating-test-value'] || 0)" }
          }
        ]
      }
    ]
  }
}
