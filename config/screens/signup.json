{
  "meta": {
    "title": "Sign Up",
    "description": "Create your account"
  },
  "state": {
    "form": {
      "name": "",
      "email": "",
      "password": "",
      "confirmPassword": ""
    },
    "errors": {}
  },
  "ui": {
    "type": "Box",
    "props": {
      "className": "flex flex-col items-center justify-center min-h-screen w-full bg-background-50 p-6"
    },
    "children": [
      {
        "type": "Box",
        "props": {
          "className": "w-full max-w-md mx-auto"
        },
        "children": [
          {
            "type": "Heading",
            "props": {
              "size": "xl",
              "className": "mb-6 text-typography-900"
            },
            "text": "Sign Up"
          },
          {
            "type": "Box",
            "condition": {
              "var": "auth.error"
            },
            "props": {
              "className": "mb-4 p-3 bg-error-100 rounded-lg"
            },
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "text-error-700 text-sm"
                },
                "text": "{{auth.error}}"
              }
            ]
          },
          {
            "type": "Form",
            "props": {
              "defaultValues": {
                "form": {
                  "name": "",
                  "email": "",
                  "password": "",
                  "confirmPassword": ""
                }
              },
              "validationRules": {
                "form.name": {
                  "required": true
                },
                "form.email": {
                  "required": true,
                  "pattern": "email"
                },
                "form.password": {
                  "required": true,
                  "minLength": 8
                },
                "form.confirmPassword": {
                  "required": true,
                  "equals": "form.password",
                  "message": "Passwords must match"
                }
              },
              "submitAction": "signup"
            },
            "children": [
              {
                "type": "FormInputWithLabel",
                "props": {
                  "name": "form.name",
                  "label": "Name",
                  "placeholder": "John Doe",
                  "variant": "outline",
                  "className": "mb-4"
                }
              },
              {
                "type": "FormInputWithLabel",
                "props": {
                  "name": "form.email",
                  "label": "Email",
                  "placeholder": "you@example.com",
                  "variant": "outline",
                  "className": "mb-4"
                }
              },
              {
                "type": "FormInputWithLabel",
                "props": {
                  "name": "form.password",
                  "label": "Password",
                  "placeholder": "••••••••",
                  "variant": "outline",
                  "secureTextEntry": true,
                  "className": "mb-4"
                }
              },
              {
                "type": "FormInputWithLabel",
                "props": {
                  "name": "form.confirmPassword",
                  "label": "Confirm Password",
                  "placeholder": "••••••••",
                  "variant": "outline",
                  "secureTextEntry": true,
                  "className": "mb-6"
                }
              },
              {
                "type": "FormSubmitButton",
                "props": {
                  "action": "primary",
                  "className": "w-full mb-4"
                },
                "text": "Sign Up"
              }
            ]
          },
          {
            "type": "HStack",
            "props": {
              "className": "justify-center"
            },
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "text-typography-600 text-sm"
                },
                "text": "Already have an account? "
              },
              {
                "type": "Pressable",
                "actions": {
                  "click": {
                    "action": "navigate",
                    "payload": {
                      "path": "/login"
                    }
                  }
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-primary-600 font-medium text-sm"
                    },
                    "text": "Login"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}