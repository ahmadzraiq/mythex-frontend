      },
      {
        "type": "VStack",
        "props": { "className": "gap-4" },
        "children": [
          {
            "type": "Box",
            "map": "returns",
            "key": "return",
            "props": { "className": "p-6 bg-white rounded-xl border border-gray-200" },
