          {
            "type": "Text",
            "props": {
              "className": "text-[13px] text-gray-500 dark:text-gray-400"
            },
            "text": "The next element uses an unknown componentId — the renderer shows a red error boundary in dev mode."
          },
          {
            "type": "SharedComponent",
            "props": {
              "componentId": "sc-does-not-exist",
