                  },
                  {
                    "type": "SharedComponent",
                    "props": {
                      "componentId": "sc-info-card",
                      "title": "No Duplication",
                      "description": "The component tree is defined once in shared-components.json. Updates propagate to every instance automatically.",
                      "accent": "#22c55e",
                      "data-testid": "info-card-3"
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "Box",
        "props": {
