                    }
                  },
                  {
                    "type": "SharedComponent",
                    "props": {
                      "componentId": "sc-status-badge",
                      "label": "Draft",
                      "status": "draft",
                      "data-testid": "badge-instance-2"
                    }
                  },
                  {
                    "type": "SharedComponent",
                    "props": {
                      "componentId": "sc-status-badge",
                      "label": "Archived",
                      "status": "archived",
                      "data-testid": "badge-instance-3"
                    }
