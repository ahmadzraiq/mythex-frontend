            "props": {
              "className": "text-[14px] text-gray-500 dark:text-gray-400"
            },
            "text": "A shared component is defined once and placed as instances anywhere on any page. Each instance can pass its own prop values via context.component.props."
          }
        ]
      },
      {
        "type": "Box",
        "props": {
          "className": "w-full rounded-[16px] border-[1px] border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 overflow-hidden"
