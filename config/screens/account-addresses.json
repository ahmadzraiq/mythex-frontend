{
  "meta": {
    "title": "Addresses"
  },
  "state": {
    "form": {
      "fullName": "",
      "streetLine1": "",
      "streetLine2": "",
      "city": "",
      "province": "",
      "postalCode": "",
      "countryCode": "US",
      "phoneNumber": ""
    },
    "showAddForm": false
  },
  "layout": "account",
  "initActions": [
    {
      "action": "fetchCustomerAddresses"
    }
  ],
  "content": {
    "type": "Box",
    "props": {
      "className": "space-y-6 flex flex-col"
    },
    "children": [
      {
        "type": "Box",
        "props": {
          "className": "flex justify-between items-start"
        },
        "children": [
          {
            "type": "Box",
            "children": [
              {
                "type": "Heading",
                "props": {
                  "className": "text-3xl font-bold"
                },
                "text": "Addresses"
              },
              {
                "type": "Text",
                "props": {
                  "className": "text-[var(--theme-muted-foreground)] mt-2"
                },
                "text": "Manage your saved shipping and billing addresses"
              }
            ]
          },
          {
            "type": "Pressable",
            "props": {
              "className": "bg-[var(--theme-shop-button)] text-white hover:bg-[var(--theme-shop-buttonHover)] flex flex-row items-center justify-center py-3 px-4 rounded-md"
            },
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "text-white"
                },
                "text": "+ Add Address"
              }
            ],
            "actions": {
              "click": {
                "type": "set",
                "path": "showAddForm",
                "value": true
              }
            }
          }
        ]
      },
      {
        "type": "Card",
        "props": {
          "className": "p-6"
        },
        "condition": "{{showAddForm}}",
        "children": [
          {
            "type": "Heading",
            "props": {
              "className": "text-lg font-semibold mb-4"
            },
            "text": "Add New Address"
          },
          {
            "type": "Box",
            "props": {
              "className": "space-y-4 flex flex-col"
            },
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "space-y-2"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm font-medium"
                    },
                    "text": "Full name"
                  },
                  {
                    "type": "Input",
                    "children": [
                      {
                        "type": "InputField",
                        "props": {
                          "value": "{{variables['a4b5c6d7-e8f9-0123-abcd-123456789012'].value.fullName}}",
                          "placeholder": "Jane Doe"
                        },
                        "actions": {
                          "change": {
                            "type": "setFormField", "formId": "a4b5c6d7-e8f9-0123-abcd-123456789012", "field": "fullName", "value": "$event"
                          }
                        }
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Box",
                "props": {
                  "className": "space-y-2"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm font-medium"
                    },
                    "text": "Street address"
                  },
                  {
                    "type": "Input",
                    "children": [
                      {
                        "type": "InputField",
                        "props": {
                          "value": "{{variables['a4b5c6d7-e8f9-0123-abcd-123456789012'].value.streetLine1}}",
                          "placeholder": "123 Main St"
                        },
                        "actions": {
                          "change": {
                            "type": "setFormField", "formId": "a4b5c6d7-e8f9-0123-abcd-123456789012", "field": "streetLine1", "value": "$event"
                          }
                        }
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Box",
                "props": {
                  "className": "grid grid-cols-2 gap-4"
                },
                "children": [
                  {
                    "type": "Box",
                    "props": {
                      "className": "space-y-2"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-sm font-medium"
                        },
                        "text": "City"
                      },
                      {
                        "type": "Input",
                        "children": [
                          {
                            "type": "InputField",
                            "props": {
                              "value": "{{variables['a4b5c6d7-e8f9-0123-abcd-123456789012'].value.city}}",
                              "placeholder": "New York"
                            },
                            "actions": {
                              "change": {
                                "type": "setFormField", "formId": "a4b5c6d7-e8f9-0123-abcd-123456789012", "field": "city", "value": "$event"
                              }
                            }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "space-y-2"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-sm font-medium"
                        },
                        "text": "Postal code"
                      },
                      {
                        "type": "Input",
                        "children": [
                          {
                            "type": "InputField",
                            "props": {
                              "value": "{{variables['a4b5c6d7-e8f9-0123-abcd-123456789012'].value.postalCode}}",
                              "placeholder": "10001"
                            },
                            "actions": {
                              "change": {
                                "type": "setFormField", "formId": "a4b5c6d7-e8f9-0123-abcd-123456789012", "field": "postalCode", "value": "$event"
                              }
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Box",
                "props": {
                  "className": "space-y-2"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm font-medium"
                    },
                    "text": "Country code"
                  },
                  {
                    "type": "Input",
                    "children": [
                      {
                        "type": "InputField",
                        "props": {
                          "value": "{{variables['a4b5c6d7-e8f9-0123-abcd-123456789012'].value.countryCode}}",
                          "placeholder": "US"
                        },
                        "actions": {
                          "change": {
                            "type": "setFormField", "formId": "a4b5c6d7-e8f9-0123-abcd-123456789012", "field": "countryCode", "value": "$event"
                          }
                        }
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Box",
                "props": {
                  "className": "flex gap-2 flex-row"
                },
                "children": [
                  {
                    "type": "Pressable",
                    "props": {
                      "className": "bg-[var(--theme-shop-button)] text-white hover:bg-[var(--theme-shop-buttonHover)] flex flex-row items-center justify-center py-3 px-4 rounded-md"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-white"
                        },
                        "text": "Save Address"
                      }
                    ],
                    "actions": {
                      "click": {
                        "action": "createCustomerAddress"
                      }
                    }
                  },
                  {
                    "type": "Pressable",
                    "props": {
                      "className": "border border-[var(--theme-border)] bg-[var(--theme-content-bg)] text-[var(--theme-foreground)] hover:bg-[var(--theme-hero-bg)] flex flex-row items-center justify-center py-3 px-4 rounded-md"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[var(--theme-foreground)]"
                        },
                        "text": "Cancel"
                      }
                    ],
                    "actions": {
                      "click": {
                        "type": "set",
                        "path": "showAddForm",
                        "value": false
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "Box",
        "props": {
          "className": "text-center py-12"
        },
        "condition": "({{collections.a9b0c1d2-e3f4-5678-abcd-789012345678.data.activeCustomer.addresses.length}} || 0) === 0",
        "children": [
          {
            "type": "Text",
            "props": {
              "className": "text-[var(--theme-muted-foreground)]"
            },
            "text": "No saved addresses yet."
          }
        ]
      },
      {
        "type": "Box",
        "props": {
          "className": "grid grid-cols-1 md:grid-cols-2 gap-4"
        },
        "map": "collections.a9b0c1d2-e3f4-5678-abcd-789012345678.data.activeCustomer.addresses",
        "key": "addressCard",
        "children": [
          {
            "type": "Card",
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "p-4"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "font-semibold"
                    },
                    "text": "{{context.item.fullName}}"
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm text-[var(--theme-muted-foreground)] mt-1"
                    },
                    "text": "{{context.item.streetLine1}}"
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm text-[var(--theme-muted-foreground)]"
                    },
                    "text": "{{context.item.city}}, {{context.item.postalCode}}"
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm text-[var(--theme-muted-foreground)]"
                    },
                    "text": "{{context.item.country.name}}"
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex gap-2 mt-3 flex-row"
                    },
                    "children": [
                      {
                        "type": "Pressable",
                        "props": {
                          "className": "border border-[var(--theme-border)] bg-[var(--theme-content-bg)] text-[var(--theme-foreground)] hover:bg-[var(--theme-hero-bg)] text-xs h-8 px-3 flex flex-row items-center justify-center rounded-md"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-[var(--theme-foreground)]"
                            },
                            "text": "Edit"
                          }
                        ]
                      },
                      {
                        "type": "Pressable",
                        "props": {
                          "className": "border border-red-400 text-red-500 hover:bg-red-50 text-xs h-8 px-3 flex flex-row items-center justify-center rounded-md"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-red-500"
                            },
                            "text": "Delete"
                          }
                        ],
                        "actions": {
                          "click": {
                            "action": "deleteCustomerAddress"
                          }
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}