{
  "meta": {
    "title": "Addresses"
  },
  "state": {
    "addresses": [],
    "form": {
      "fullName": "",
      "streetLine1": "",
      "streetLine2": "",
      "city": "",
      "province": "",
      "postalCode": "",
      "countryCode": "US",
      "phoneNumber": ""
    },
    "showAddForm": false
  },
  "layout": "account",
  "initActions": [
    {
      "action": "fetchNavCollections"
    },
    {
      "action": "fetchCustomerAddresses"
    }
  ],
  "content": {
    "type": "Box",
    "props": {
      "className": "space-y-6 flex flex-col"
    },
    "children": [
      {
        "type": "Box",
        "props": {
          "className": "flex justify-between items-start"
        },
        "children": [
          {
            "type": "Box",
            "children": [
              {
                "type": "Heading",
                "props": {
                  "className": "text-3xl font-bold"
                },
                "text": "Addresses"
              },
              {
                "type": "Text",
                "props": {
                  "className": "text-[var(--theme-muted-foreground)] mt-2"
                },
                "text": "Manage your saved shipping and billing addresses"
              }
            ]
          },
          {
            "type": "Pressable",
            "props": {
              "className": "bg-[var(--theme-shop-button)] text-white hover:bg-[var(--theme-shop-buttonHover)] flex flex-row items-center justify-center py-3 px-4 rounded-md"
            },
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "text-white"
                },
                "text": "+ Add Address"
              }
            ],
            "actions": {
              "click": {
                "type": "set",
                "path": "showAddForm",
                "value": true
              }
            }
          }
        ]
      },
      {
        "type": "Card",
        "props": {
          "className": "p-6"
        },
        "condition": {
          "==": [
            {
              "var": "showAddForm"
            },
            true
          ]
        },
        "children": [
          {
            "type": "Heading",
            "props": {
              "className": "text-lg font-semibold mb-4"
            },
            "text": "Add New Address"
          },
          {
            "type": "Box",
            "props": {
              "className": "space-y-4 flex flex-col"
            },
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "space-y-2"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm font-medium"
                    },
                    "text": "Full name"
                  },
                  {
                    "type": "Input",
                    "children": [
                      {
                        "type": "InputField",
                        "props": {
                          "value": "{{form.fullName}}",
                          "placeholder": "Jane Doe"
                        },
                        "actions": {
                          "change": {
                            "action": "setState",
                            "payload": {
                              "path": "form.fullName",
                              "value": "$event"
                            }
                          }
                        }
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Box",
                "props": {
                  "className": "space-y-2"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm font-medium"
                    },
                    "text": "Street address"
                  },
                  {
                    "type": "Input",
                    "children": [
                      {
                        "type": "InputField",
                        "props": {
                          "value": "{{form.streetLine1}}",
                          "placeholder": "123 Main St"
                        },
                        "actions": {
                          "change": {
                            "action": "setState",
                            "payload": {
                              "path": "form.streetLine1",
                              "value": "$event"
                            }
                          }
                        }
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Box",
                "props": {
                  "className": "grid grid-cols-2 gap-4"
                },
                "children": [
                  {
                    "type": "Box",
                    "props": {
                      "className": "space-y-2"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-sm font-medium"
                        },
                        "text": "City"
                      },
                      {
                        "type": "Input",
                        "children": [
                          {
                            "type": "InputField",
                            "props": {
                              "value": "{{form.city}}",
                              "placeholder": "New York"
                            },
                            "actions": {
                              "change": {
                                "action": "setState",
                                "payload": {
                                  "path": "form.city",
                                  "value": "$event"
                                }
                              }
                            }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "space-y-2"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-sm font-medium"
                        },
                        "text": "Postal code"
                      },
                      {
                        "type": "Input",
                        "children": [
                          {
                            "type": "InputField",
                            "props": {
                              "value": "{{form.postalCode}}",
                              "placeholder": "10001"
                            },
                            "actions": {
                              "change": {
                                "action": "setState",
                                "payload": {
                                  "path": "form.postalCode",
                                  "value": "$event"
                                }
                              }
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Box",
                "props": {
                  "className": "space-y-2"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm font-medium"
                    },
                    "text": "Country code"
                  },
                  {
                    "type": "Input",
                    "children": [
                      {
                        "type": "InputField",
                        "props": {
                          "value": "{{form.countryCode}}",
                          "placeholder": "US"
                        },
                        "actions": {
                          "change": {
                            "action": "setState",
                            "payload": {
                              "path": "form.countryCode",
                              "value": "$event"
                            }
                          }
                        }
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Box",
                "props": {
                  "className": "flex gap-2 flex-row"
                },
                "children": [
                  {
                    "type": "Pressable",
                    "props": {
                      "className": "bg-[var(--theme-shop-button)] text-white hover:bg-[var(--theme-shop-buttonHover)] flex flex-row items-center justify-center py-3 px-4 rounded-md"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-white"
                        },
                        "text": "Save Address"
                      }
                    ],
                    "actions": {
                      "click": {
                        "action": "createCustomerAddress"
                      }
                    }
                  },
                  {
                    "type": "Pressable",
                    "props": {
                      "className": "border border-[var(--theme-border)] bg-[var(--theme-content-bg)] text-[var(--theme-foreground)] hover:bg-[var(--theme-hero-bg)] flex flex-row items-center justify-center py-3 px-4 rounded-md"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[var(--theme-foreground)]"
                        },
                        "text": "Cancel"
                      }
                    ],
                    "actions": {
                      "click": {
                        "type": "set",
                        "path": "showAddForm",
                        "value": false
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "Box",
        "props": {
          "className": "text-center py-12"
        },
        "condition": {
          "==": [
            {
              "var": [
                "addresses.length",
                0
              ]
            },
            0
          ]
        },
        "children": [
          {
            "type": "Text",
            "props": {
              "className": "text-[var(--theme-muted-foreground)]"
            },
            "text": "No saved addresses yet."
          }
        ]
      },
      {
        "type": "Box",
        "props": {
          "className": "grid grid-cols-1 md:grid-cols-2 gap-4"
        },
        "map": "addresses",
        "key": "addressCard",
        "children": [
          {
            "type": "Card",
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "p-4"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "font-semibold"
                    },
                    "text": "{{$item.fullName}}"
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm text-[var(--theme-muted-foreground)] mt-1"
                    },
                    "text": "{{$item.streetLine1}}"
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm text-[var(--theme-muted-foreground)]"
                    },
                    "text": "{{$item.city}}, {{$item.postalCode}}"
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm text-[var(--theme-muted-foreground)]"
                    },
                    "text": "{{$item.country.name}}"
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex gap-2 mt-3 flex-row"
                    },
                    "children": [
                      {
                        "type": "Pressable",
                        "props": {
                          "className": "border border-[var(--theme-border)] bg-[var(--theme-content-bg)] text-[var(--theme-foreground)] hover:bg-[var(--theme-hero-bg)] text-xs h-8 px-3 flex flex-row items-center justify-center rounded-md"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-[var(--theme-foreground)]"
                            },
                            "text": "Edit"
                          }
                        ]
                      },
                      {
                        "type": "Pressable",
                        "props": {
                          "className": "border border-red-400 text-red-500 hover:bg-red-50 text-xs h-8 px-3 flex flex-row items-center justify-center rounded-md"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-red-500"
                            },
                            "text": "Delete"
                          }
                        ],
                        "actions": {
                          "click": {
                            "action": "deleteCustomerAddress"
                          }
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
