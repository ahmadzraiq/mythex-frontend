{
  "meta": { "title": "Button System Component Demo" },
  "state": {},
  "ui": {
    "type": "Box",
    "props": { "className": "w-full min-h-screen bg-gray-50 dark:bg-gray-950" },
    "children": [
      {
        "type": "Box",
        "props": { "className": "max-w-[640px] mx-auto flex flex-col gap-[24px] py-[48px] px-[24px]" },
        "children": [
          { "type": "Text", "props": { "className": "text-[24px] font-bold text-gray-900 dark:text-white" }, "text": "Button — Custom Trigger Demo" },

          {
            "type": "Box",
            "_system": { "id": "sys-button", "name": "Button" },
            "_overrides": [],
            "props": {
              "variant": "solid",
              "size": "md",
              "label": "Click me",
              "data-testid": "button-enabled",
              "className": "flex flex-row items-center justify-center gap-[8px] rounded-[6px] hover:opacity-90 active:opacity-80 transition-opacity",
              "style": {
                "backgroundColor": { "formula": "context?.component?.props?.variant==='destructive'?'#dc2626':(context?.component?.props?.variant==='outline'||context?.component?.props?.variant==='ghost'||context?.component?.props?.variant==='link')?'transparent':'var(--theme-primary)'" },
                "borderWidth": { "formula": "context?.component?.props?.variant==='outline'?'1px':'0'" },
                "borderStyle": { "formula": "context?.component?.props?.variant==='outline'?'solid':'none'" },
                "borderColor": { "formula": "context?.component?.props?.variant==='outline'?'var(--theme-foreground)':'transparent'" },
                "paddingLeft": { "formula": "context?.component?.props?.size==='sm'?'12px':context?.component?.props?.size==='lg'?'28px':'20px'" },
                "paddingRight": { "formula": "context?.component?.props?.size==='sm'?'12px':context?.component?.props?.size==='lg'?'28px':'20px'" },
                "paddingTop": { "formula": "context?.component?.props?.size==='sm'?'6px':context?.component?.props?.size==='lg'?'14px':'10px'" },
                "paddingBottom": { "formula": "context?.component?.props?.size==='sm'?'6px':context?.component?.props?.size==='lg'?'14px':'10px'" },
                "opacity": { "formula": "context?.component?.props?.disabled?'0.5':'1'" },
                "cursor": { "formula": "context?.component?.props?.disabled?'not-allowed':'pointer'" },
                "pointerEvents": { "formula": "context?.component?.props?.disabled?'none':'auto'" }
              }
            },
            "actions": [
              { "action": "btn-wf-on-click" },
              { "action": "wfOnButtonClick" }
            ],
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "font-medium",
                  "style": {
                    "fontSize": { "formula": "context?.component?.props?.size==='sm'?'12px':context?.component?.props?.size==='lg'?'16px':'14px'" },
                    "color": { "formula": "context?.component?.props?.variant==='destructive'?'#ffffff':context?.component?.props?.variant==='link'?'var(--theme-primary)':(context?.component?.props?.variant==='outline'||context?.component?.props?.variant==='ghost')?'var(--theme-foreground)':'var(--theme-primary-foreground)'" }
                  }
                },
                "text": { "formula": "context?.component?.props?.label || ''" }
              }
            ]
          },

          {
            "type": "Box",
            "_system": { "id": "sys-button", "name": "Button" },
            "_overrides": [],
            "props": {
              "variant": "solid",
              "size": "md",
              "label": "Disabled",
              "disabled": true,
              "data-testid": "button-disabled",
              "className": "flex flex-row items-center justify-center gap-[8px] rounded-[6px] hover:opacity-90 active:opacity-80 transition-opacity",
              "style": {
                "backgroundColor": { "formula": "context?.component?.props?.variant==='destructive'?'#dc2626':(context?.component?.props?.variant==='outline'||context?.component?.props?.variant==='ghost'||context?.component?.props?.variant==='link')?'transparent':'var(--theme-primary)'" },
                "borderWidth": { "formula": "context?.component?.props?.variant==='outline'?'1px':'0'" },
                "borderStyle": { "formula": "context?.component?.props?.variant==='outline'?'solid':'none'" },
                "borderColor": { "formula": "context?.component?.props?.variant==='outline'?'var(--theme-foreground)':'transparent'" },
                "paddingLeft": { "formula": "context?.component?.props?.size==='sm'?'12px':context?.component?.props?.size==='lg'?'28px':'20px'" },
                "paddingRight": { "formula": "context?.component?.props?.size==='sm'?'12px':context?.component?.props?.size==='lg'?'28px':'20px'" },
                "paddingTop": { "formula": "context?.component?.props?.size==='sm'?'6px':context?.component?.props?.size==='lg'?'14px':'10px'" },
                "paddingBottom": { "formula": "context?.component?.props?.size==='sm'?'6px':context?.component?.props?.size==='lg'?'14px':'10px'" },
                "opacity": { "formula": "context?.component?.props?.disabled?'0.5':'1'" },
                "cursor": { "formula": "context?.component?.props?.disabled?'not-allowed':'pointer'" },
                "pointerEvents": { "formula": "context?.component?.props?.disabled?'none':'auto'" }
              }
            },
            "actions": [
              { "action": "btn-wf-on-click" },
              { "action": "wfOnButtonClick" }
            ],
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "font-medium",
                  "style": {
                    "fontSize": { "formula": "context?.component?.props?.size==='sm'?'12px':context?.component?.props?.size==='lg'?'16px':'14px'" },
                    "color": { "formula": "context?.component?.props?.variant==='destructive'?'#ffffff':context?.component?.props?.variant==='link'?'var(--theme-primary)':(context?.component?.props?.variant==='outline'||context?.component?.props?.variant==='ghost')?'var(--theme-foreground)':'var(--theme-primary-foreground)'" }
                  }
                },
                "text": { "formula": "context?.component?.props?.label || ''" }
              }
            ]
          },

          {
            "type": "Text",
            "props": { "className": "text-[14px] text-gray-700 dark:text-gray-300", "data-testid": "out-button-count" },
            "text": { "formula": "'Count: ' + (variables['btn-test-count'] || 0)" }
          },
          {
            "type": "Text",
            "props": { "className": "text-[14px] text-gray-700 dark:text-gray-300", "data-testid": "out-button-label" },
            "text": { "formula": "'Label: ' + (variables['btn-test-label'] || '(none)')" }
          }
        ]
      }
    ]
  }
}
