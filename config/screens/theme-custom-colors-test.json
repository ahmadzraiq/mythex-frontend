{
  "meta": {
    "title": "Theme Custom Colors Test"
  },
  "ui": {
    "type": "Box",
    "props": {
      "className": "w-full min-h-screen flex flex-col gap-[32px] py-[32px] px-[24px] bg-white dark:bg-gray-950",
      "data-testid": "tcc-page"
    },
    "id": "tcc-root",
    "children": [
      {
        "type": "Box",
        "props": {
          "className": "max-w-[960px] mx-auto w-full flex flex-col gap-[8px]"
        },
        "id": "tcc-header",
        "children": [
          {
            "type": "Text",
            "props": {
              "className": "text-[24px] font-bold text-foreground",
              "data-testid": "tcc-title"
            },
            "text": "Theme Custom Colors Test"
          },
          {
            "type": "Text",
            "props": {
              "className": "text-[14px] text-gray-500 dark:text-gray-400"
            },
            "text": "When this page is the focused page, the builder auto-seeds two sample custom colors — \"brand\" (#7c3aed light / #a78bfa dark) and \"brand-2\" (#06b6d4 light / #22d3ee dark) — into Theme \u203a Colors \u203a Ungrouped. The cards below resolve via CSS variables and the theme.colors.* formula path. Edit or delete them from the Theme tab to see the cards update live; cards fall back to neutral gray when a color is missing."
          }
        ]
      },
      {
        "type": "Box",
        "props": {
          "className": "max-w-[960px] mx-auto w-full flex flex-col gap-[12px]"
        },
        "id": "tcc-section-css",
        "children": [
          {
            "type": "Text",
            "props": {
              "className": "text-[16px] font-semibold text-foreground"
            },
            "text": "1. CSS variable bindings"
          },
          {
            "type": "Box",
            "props": {
              "className": "w-full flex flex-row gap-[16px] flex-wrap"
            },
            "children": [
              {
                "type": "Box",
                "id": "tcc-css-brand",
                "props": {
                  "className": "flex-1 min-w-[200px] h-[120px] rounded-[12px] flex items-center justify-center",
                  "style": {
                    "backgroundColor": "var(--theme-brand, #d1d5db)"
                  },
                  "data-testid": "tcc-css-brand"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-[14px] font-semibold !text-white"
                    },
                    "text": "var(--theme-brand)"
                  }
                ]
              },
              {
                "type": "Box",
                "id": "tcc-css-brand-2",
                "props": {
                  "className": "flex-1 min-w-[200px] h-[120px] rounded-[12px] flex items-center justify-center",
                  "style": {
                    "backgroundColor": "var(--theme-brand-2, #d1d5db)"
                  },
                  "data-testid": "tcc-css-brand-2"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-[14px] font-semibold !text-white"
                    },
                    "text": "var(--theme-brand-2)"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "Box",
        "props": {
          "className": "max-w-[960px] mx-auto w-full flex flex-col gap-[12px]"
        },
        "id": "tcc-section-formula",
        "children": [
          {
            "type": "Text",
            "props": {
              "className": "text-[16px] font-semibold text-foreground"
            },
            "text": "2. Formula bindings (theme.colors.*)"
          },
          {
            "type": "Box",
            "props": {
              "className": "w-full flex flex-row gap-[16px] flex-wrap"
            },
            "children": [
              {
                "type": "Box",
                "id": "tcc-formula-brand",
                "props": {
                  "className": "flex-1 min-w-[200px] h-[120px] rounded-[12px] p-[16px] flex flex-col gap-[6px]",
                  "style": {
                    "backgroundColor": {
                      "formula": "theme?.['colors']?.['brand'] || '#d1d5db'"
                    }
                  },
                  "data-testid": "tcc-formula-brand"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-[12px] font-mono !text-white/80"
                    },
                    "text": "theme.colors.brand"
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-[14px] font-semibold !text-white",
                      "data-testid": "tcc-formula-brand-value"
                    },
                    "text": {
                      "formula": "theme?.['colors']?.['brand'] || 'unset'"
                    }
                  }
                ]
              },
              {
                "type": "Box",
                "id": "tcc-formula-brand-2",
                "props": {
                  "className": "flex-1 min-w-[200px] h-[120px] rounded-[12px] p-[16px] flex flex-col gap-[6px]",
                  "style": {
                    "backgroundColor": {
                      "formula": "theme?.['colors']?.['brand-2'] || '#d1d5db'"
                    }
                  },
                  "data-testid": "tcc-formula-brand-2"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-[12px] font-mono !text-white/80"
                    },
                    "text": "theme.colors['brand-2']"
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-[14px] font-semibold !text-white",
                      "data-testid": "tcc-formula-brand-2-value"
                    },
                    "text": {
                      "formula": "theme?.['colors']?.['brand-2'] || 'unset'"
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
