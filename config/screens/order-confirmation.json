{
  "meta": {
    "title": "Order Confirmation"
  },
  "state": {
    "order": null
  },
  "layout": "store",
  "initActions": [
    {
      "action": "fetchNavCollections"
    },
    {
      "action": "fetchOrderByCode"
    }
  ],
  "content": {
    "type": "Box",
    "props": {
      "className": "container mx-auto px-4 py-16"
    },
    "children": [
      {
        "type": "Box",
        "props": {
          "className": "max-w-3xl mx-auto"
        },
        "children": [
          {
            "type": "Box",
            "props": {
              "className": "text-center py-16"
            },
            "condition": "!{{order}}",
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "text-[var(--theme-muted-foreground)]"
                },
                "text": "Loading order..."
              }
            ]
          },
          {
            "type": "Box",
            "props": {
              "className": "text-center mb-8"
            },
            "condition": "{{order}}",
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "flex items-center justify-center mb-4"
                },
                "children": [
                  {
                    "type": "NavIcon",
                    "props": {
                      "icon": "CheckCircle2",
                      "size": 64,
                      "className": "!text-green-500"
                    }
                  }
                ]
              },
              {
                "type": "Heading",
                "props": {
                  "className": "text-3xl font-bold mb-2 text-center"
                },
                "text": "Order Confirmed!"
              },
              {
                "type": "Box",
                "props": {
                  "className": "flex flex-row flex-wrap justify-center items-baseline gap-1"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-[var(--theme-muted-foreground)]"
                    },
                    "text": "Thank you for your order. Your order number is "
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "font-semibold text-[var(--theme-foreground)]"
                    },
                    "text": "{{order.code}}"
                  }
                ]
              }
            ]
          },
          {
            "type": "Card",
            "props": {
              "className": "mb-6 rounded-xl border border-[var(--theme-border)] shadow-sm bg-[var(--theme-content-bg)] p-0 overflow-hidden"
            },
            "condition": "{{order}}",
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "px-6 py-4 border-b border-[var(--theme-border)]"
                },
                "children": [
                  {
                    "type": "Heading",
                    "props": {
                      "className": "text-lg font-semibold leading-none"
                    },
                    "text": "Order Summary"
                  }
                ]
              },
              {
                "type": "Box",
                "props": {
                  "className": "px-6 py-4 space-y-4"
                },
                "children": [
                  {
                    "type": "Box",
                    "props": {
                      "className": "space-y-4 flex flex-col"
                    },
                    "map": "order.lines",
                    "key": "orderConfLine",
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex gap-4 items-center flex-row"
                        },
                        "children": [
                          {
                            "type": "Box",
                            "props": {
                              "className": "flex-shrink-0"
                            },
                            "condition": "{{$item.productVariant.product.featuredAsset.preview}}",
                            "children": [
                              {
                                "type": "NextImage",
                                "props": {
                                  "src": "{{$item.productVariant.product.featuredAsset.preview}}",
                                  "alt": "{{$item.productVariant.product.name}}",
                                  "width": 80,
                                  "height": 80,
                                  "className": "rounded object-cover w-20 h-20 object-center"
                                }
                              }
                            ]
                          },
                          {
                            "type": "Box",
                            "props": {
                              "className": "flex-1 min-w-0"
                            },
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "className": "font-medium"
                                },
                                "text": "{{$item.productVariant.product.name}}"
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "className": "text-sm text-[var(--theme-muted-foreground)]"
                                },
                                "text": "{{$item.productVariant.name}}",
                                "condition": "{{$item.productVariant.name}} !== {{$item.productVariant.product.name}}"
                              }
                            ]
                          },
                          {
                            "type": "Box",
                            "props": {
                              "className": "text-center w-16 flex flex-col"
                            },
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "className": "text-sm text-[var(--theme-muted-foreground)]"
                                },
                                "text": "Qty"
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "className": "font-medium"
                                },
                                "text": "{{$item.quantity}}"
                              }
                            ]
                          },
                          {
                            "type": "Box",
                            "props": {
                              "className": "text-right w-24"
                            },
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "className": "font-semibold"
                                },
                                "text": { "expr": "formatCurrency({{$item.linePriceWithTax}} / 100, {{order.currencyCode}} || 'USD')" }
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Divider",
                    "props": {
                      "className": "my-4 h-px w-full !bg-[var(--theme-border)]"
                    }
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex justify-between font-bold text-lg flex-row"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "text": "Total"
                      },
                      {
                        "type": "Text",
                        "text": { "expr": "formatCurrency(({{order.totalWithTax}} || 0) / 100, {{order.currencyCode}} || 'USD')" }
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Card",
            "props": {
              "className": "mb-6 rounded-xl border border-[var(--theme-border)] shadow-sm bg-[var(--theme-content-bg)] p-0 overflow-hidden"
            },
            "condition": "{{order}} && {{order.shippingAddress}}",
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "px-6 py-4 border-b border-[var(--theme-border)]"
                },
                "children": [
                  {
                    "type": "Heading",
                    "props": {
                      "className": "text-lg font-semibold leading-none"
                    },
                    "text": "Shipping Address"
                  }
                ]
              },
              {
                "type": "Box",
                "props": {
                  "className": "px-6 py-4"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "font-medium"
                    },
                    "text": "{{order.shippingAddress.fullName}}"
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm text-[var(--theme-muted-foreground)] mt-1"
                    },
                    "text": { "expr": "{{order.shippingAddress.streetLine1}} + ({{order.shippingAddress.streetLine2}} ? ', ' + {{order.shippingAddress.streetLine2}} : '')" }
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm text-[var(--theme-muted-foreground)]"
                    },
                    "text": "{{order.shippingAddress.city}}, {{order.shippingAddress.province}} {{order.shippingAddress.postalCode}}"
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm text-[var(--theme-muted-foreground)]"
                    },
                    "text": "{{order.shippingAddress.country}}"
                  }
                ]
              }
            ]
          },
          {
            "type": "Box",
            "props": {
              "className": "flex gap-4"
            },
            "condition": "{{order}}",
            "children": [
              {
                "type": "Pressable",
                "props": {
                  "className": "flex-1 rounded-md h-9 px-4 py-2 text-sm font-medium bg-[var(--theme-shop-button)] text-white hover:bg-[var(--theme-shop-buttonHover)] flex flex-row items-center justify-center"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-white"
                    },
                    "text": "Continue Shopping"
                  }
                ],
                "actions": {
                  "click": {
                    "action": "navigate",
                    "payload": {
                      "path": "/"
                    }
                  }
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
