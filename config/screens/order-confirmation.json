{
  "meta": { "title": "Order Confirmation" },
  "state": { "order": null },
  "layout": "store",
  "initActions": [{ "action": "fetchNavCollections" }, { "action": "fetchOrderByCode" }],
  "content": {
    "type": "Box",
    "props": { "className": "w-full max-w-screen-xl mx-auto px-4 py-16" },
    "children": [
      {
        "type": "Box",
        "props": { "className": "max-w-2xl mx-auto text-center space-y-6" },
        "children": [
          {
            "type": "Box",
            "props": { "className": "w-16 h-16 mx-auto rounded-full bg-green-100 flex items-center justify-center" },
            "children": [
              { "type": "Text", "props": { "className": "text-green-600 text-2xl" }, "text": "✓" }
            ]
          },
          { "type": "Heading", "props": { "className": "text-3xl font-bold" }, "text": "Order Confirmed!" },
          { "type": "Text", "props": { "className": "text-gray-500 text-lg" }, "text": "Thank you for your purchase. We'll send you a confirmation email shortly." },
          {
            "type": "Card",
            "children": [
              {
                "type": "Box",
                "props": { "className": "p-6 text-left space-y-4" },
                "children": [
                  {
                    "type": "HStack",
                    "props": { "className": "flex justify-between items-center" },
                    "children": [
                      { "type": "Text", "props": { "className": "text-sm text-gray-500" }, "text": "Order number" },
                      { "type": "Text", "props": { "className": "font-semibold" }, "text": "{{order.code}}" }
                    ]
                  },
                  {
                    "type": "HStack",
                    "props": { "className": "flex justify-between items-center" },
                    "children": [
                      { "type": "Text", "props": { "className": "text-sm text-gray-500" }, "text": "Status" },
                      { "type": "Badge", "children": [{ "type": "BadgeText", "text": "{{order.state}}" }] }
                    ]
                  },
                  {
                    "type": "HStack",
                    "props": { "className": "flex justify-between items-center" },
                    "children": [
                      { "type": "Text", "props": { "className": "text-sm text-gray-500" }, "text": "Total" },
                      { "type": "Text", "props": { "className": "font-bold text-lg" }, "text": { "expr": { "formatCurrency": [{ "/": [{ "var": ["order.totalWithTax", 0] }, 100] }, { "var": ["order.currencyCode", "USD"] }] } } }
                    ]
                  },
                  { "type": "Divider", "props": { "className": "my-2" } },
                  {
                    "type": "VStack",
                    "props": { "className": "space-y-3" },
                    "map": "order.lines",
                    "key": "orderConfLine",
                    "children": [
                      {
                        "type": "HStack",
                        "props": { "className": "flex gap-3 items-center" },
                        "children": [
                          {
                            "type": "NextImage",
                            "props": { "src": "{{$item.productVariant.product.featuredAsset.preview}}", "alt": "{{$item.productVariant.product.name}}", "width": 60, "height": 60, "className": "rounded-md object-cover w-15 h-15 flex-shrink-0" }
                          },
                          {
                            "type": "Box",
                            "props": { "className": "flex-1 min-w-0" },
                            "children": [
                              { "type": "Text", "props": { "className": "font-medium text-sm truncate" }, "text": "{{$item.productVariant.product.name}}" },
                              { "type": "Text", "props": { "className": "text-xs text-gray-500" }, "text": { "expr": { "var": "$item.quantity" }, "prefix": "Qty: " } }
                            ]
                          },
                          { "type": "Text", "props": { "className": "text-sm font-medium" }, "text": { "expr": { "formatCurrency": [{ "/": [{ "var": "$item.linePriceWithTax" }, 100] }, { "var": ["order.currencyCode", "USD"] }] } } }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "HStack",
            "props": { "className": "flex flex-col sm:flex-row gap-4 justify-center" },
            "children": [
              { "type": "Button", "props": { "className": "bg-[#1e293b] text-white hover:bg-[#334155] px-8" }, "children": [{ "type": "ButtonText", "props": { "className": "!text-white" }, "text": "Continue Shopping" }], "actions": { "click": { "action": "navigate", "payload": { "path": "/" } } } },
              { "type": "Button", "props": { "className": "border border-gray-200 bg-white text-gray-900 hover:bg-gray-100 px-8" }, "children": [{ "type": "ButtonText", "props": { "className": "!text-gray-900" }, "text": "View Orders" }], "actions": { "click": { "action": "navigate", "payload": { "path": "/account/orders" } } } }
            ]
          }
        ]
      }
    ]
  }
}
