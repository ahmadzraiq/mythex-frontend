{
  "meta": {
    "title": "Size Guide | SaraZ",
    "description": "Find your perfect fit"
  },
  "state": {},
  "layout": "store",
  "content": {
    "type": "Box",
    "props": {
      "className": "mx-auto max-w-4xl px-4 sm:px-6 py-12 md:py-16"
    },
    "children": [
      {
        "type": "Heading",
        "props": { "size": "2xl", "className": "mb-2 font-light" },
        "text": "Size Guide"
      },
      {
        "type": "Text",
        "props": { "className": "text-[var(--theme-shop-textMuted)] mb-8" },
        "text": "Find your perfect fit. All measurements are in cm."
      },
      {
        "type": "Box",
        "props": { "className": "overflow-x-auto mb-12" },
        "children": [
          {
            "type": "Table",
            "props": { "className": "w-full" },
            "children": [
              {
                "type": "TableHeader",
                "children": [
                  {
                    "type": "TableRow",
                    "children": [
                      { "type": "TableHead", "children": [{ "type": "Text", "text": "Size" }] },
                      { "type": "TableHead", "children": [{ "type": "Text", "text": "Chest" }] },
                      { "type": "TableHead", "children": [{ "type": "Text", "text": "Waist" }] },
                      { "type": "TableHead", "children": [{ "type": "Text", "text": "Hips" }] }
                    ]
                  }
                ]
              },
              {
                "type": "TableBody",
                "children": [
                  { "type": "TableRow", "children": [{ "type": "TableData", "children": [{ "type": "Text", "text": "XS" }] }, { "type": "TableData", "children": [{ "type": "Text", "text": "81-86" }] }, { "type": "TableData", "children": [{ "type": "Text", "text": "61-66" }] }, { "type": "TableData", "children": [{ "type": "Text", "text": "86-91" }] }] },
                  { "type": "TableRow", "children": [{ "type": "TableData", "children": [{ "type": "Text", "text": "S" }] }, { "type": "TableData", "children": [{ "type": "Text", "text": "86-91" }] }, { "type": "TableData", "children": [{ "type": "Text", "text": "66-71" }] }, { "type": "TableData", "children": [{ "type": "Text", "text": "91-96" }] }] },
                  { "type": "TableRow", "children": [{ "type": "TableData", "children": [{ "type": "Text", "text": "M" }] }, { "type": "TableData", "children": [{ "type": "Text", "text": "91-96" }] }, { "type": "TableData", "children": [{ "type": "Text", "text": "71-76" }] }, { "type": "TableData", "children": [{ "type": "Text", "text": "96-101" }] }] },
                  { "type": "TableRow", "children": [{ "type": "TableData", "children": [{ "type": "Text", "text": "L" }] }, { "type": "TableData", "children": [{ "type": "Text", "text": "96-101" }] }, { "type": "TableData", "children": [{ "type": "Text", "text": "76-81" }] }, { "type": "TableData", "children": [{ "type": "Text", "text": "101-106" }] }] },
                  { "type": "TableRow", "children": [{ "type": "TableData", "children": [{ "type": "Text", "text": "XL" }] }, { "type": "TableData", "children": [{ "type": "Text", "text": "101-106" }] }, { "type": "TableData", "children": [{ "type": "Text", "text": "81-86" }] }, { "type": "TableData", "children": [{ "type": "Text", "text": "106-111" }] }] }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "Text",
        "props": { "className": "text-sm text-[var(--theme-shop-textMuted)] mb-4" },
        "text": "Measure around the fullest part of your chest, natural waist, and hips. If you're between sizes, we recommend sizing up."
      },
      {
        "type": "Button",
        "props": { "variant": "outline" },
        "text": "Back to Shop",
        "actions": { "click": { "action": "navigate", "payload": { "path": "/shop" } } }
      }
    ]
  }
}
