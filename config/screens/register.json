{
  "meta": {
    "title": "Create Account"
  },
  "layout": "store",
  "content": {
    "type": "Box",
    "props": {
      "className": "flex flex-1 w-full items-center justify-center px-4"
    },
    "children": [
      {
        "type": "Box",
        "props": {
          "className": "w-full max-w-md min-w-0 space-y-6 flex flex-col"
        },
        "children": [
          {
            "type": "Box",
            "props": {
              "className": "space-y-2 text-center"
            },
            "children": [
              {
                "type": "Heading",
                "props": {
                  "className": "text-3xl font-bold text-center"
                },
                "text": "Create Account"
              },
              {
                "type": "Text",
                "props": {
                  "className": "text-[var(--theme-muted-foreground)] text-center"
                },
                "text": "Sign up to start shopping with us"
              }
            ]
          },
          {
            "type": "Box",
            "props": {
              "className": "w-full rounded-xl border border-[var(--theme-border)] bg-[var(--theme-card)] py-6 shadow-sm"
            },
            "children": [
              {
                "type": "FormContainer",
                "props": {
                  "initialFormData": {
                    "emailAddress": "",
                    "firstName": "",
                    "lastName": "",
                    "phoneNumber": "",
                    "password": "",
                    "confirmPassword": ""
                  },
                  "className": "px-6 space-y-4"
                },
                "actions": [
                  {
                    "action": "926c0ef9-beeb-41d3-924b-034b76b8b7cf"
                  }
                ],
                "children": [
                  {
                    "type": "Box",
                    "props": {
                      "className": "space-y-1"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-sm font-medium leading-none"
                        },
                        "text": "Email Address"
                      },
                      {
                        "type": "Input",
                        "id": "6d49365f-789e-417c-bdd6-263a14a54f68",
                        "props": {
                          "variant": "outline",
                          "size": "sm",
                          "className": "!text-[var(--theme-foreground)]",
                          "type": "email",
                          "placeholder": "you@example.com",
                          "placeholderTextColor": "#9ca3af",
                          "autoComplete": "email",
                          "value": "{{local.data.form.formData.emailAddress}}"
                        },
                        "name": "emailAddress",
                        "_validation": {
                          "trigger": "submit",
                          "rules": [
                            {
                              "type": "required",
                              "message": "Email is required"
                            },
                            {
                              "type": "email",
                              "message": "Please enter a valid email address"
                            }
                          ]
                        }
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "min-h-[18px]"
                        },
                        "condition": "local?.data?.form?.fields?.emailAddress?.isValid",
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-xs text-red-500 dark:text-red-400"
                            },
                            "text": "{{local.data.form.fields.emailAddress.isValid}}"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "grid grid-cols-2 gap-4"
                    },
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": "space-y-1"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-sm font-medium leading-none"
                            },
                            "text": "First name"
                          },
                          {
                            "type": "Input",
                            "id": "b7c54d06-8b24-443d-81da-ced51881ae34",
                            "props": {
                              "variant": "outline",
                              "size": "sm",
                              "className": "!text-[var(--theme-foreground)]",
                              "placeholder": "John",
                              "placeholderTextColor": "#9ca3af",
                              "autoComplete": "given-name",
                              "value": "{{local.data.form.formData.firstName}}"
                            },
                            "name": "firstName",
                            "_validation": {
                              "trigger": "submit",
                              "rules": [
                                {
                                  "type": "required",
                                  "message": "First name is required"
                                },
                                {
                                  "type": "minLength",
                                  "value": "2",
                                  "message": "Must be at least 2 characters"
                                }
                              ]
                            }
                          },
                          {
                            "type": "Box",
                            "props": {
                              "className": "min-h-[18px]"
                            },
                            "condition": "local?.data?.form?.fields?.firstName?.isValid",
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "className": "text-xs text-red-500 dark:text-red-400"
                                },
                                "text": "{{local.data.form.fields.firstName.isValid}}"
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "space-y-1"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-sm font-medium leading-none"
                            },
                            "text": "Last name"
                          },
                          {
                            "type": "Input",
                            "id": "09e3ef50-d78b-44d2-9635-c823f9c87964",
                            "props": {
                              "variant": "outline",
                              "size": "sm",
                              "className": "!text-[var(--theme-foreground)]",
                              "placeholder": "Doe",
                              "placeholderTextColor": "#9ca3af",
                              "autoComplete": "family-name",
                              "value": "{{local.data.form.formData.lastName}}"
                            },
                            "name": "lastName",
                            "_validation": {
                              "trigger": "submit",
                              "rules": [
                                {
                                  "type": "required",
                                  "message": "Last name is required"
                                },
                                {
                                  "type": "minLength",
                                  "value": "2",
                                  "message": "Must be at least 2 characters"
                                }
                              ]
                            }
                          },
                          {
                            "type": "Box",
                            "props": {
                              "className": "min-h-[18px]"
                            },
                            "condition": "local?.data?.form?.fields?.lastName?.isValid",
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "className": "text-xs text-red-500 dark:text-red-400"
                                },
                                "text": "{{local.data.form.fields.lastName.isValid}}"
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "space-y-1"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-sm font-medium leading-none"
                        },
                        "text": "Phone Number"
                      },
                      {
                        "type": "Input",
                        "id": "957459a9-0326-4fae-ad84-e92d95254897",
                        "props": {
                          "variant": "outline",
                          "size": "sm",
                          "className": "!text-[var(--theme-foreground)]",
                          "type": "tel",
                          "placeholder": "+1 234 567 8900",
                          "placeholderTextColor": "#9ca3af",
                          "autoComplete": "tel",
                          "value": "{{local.data.form.formData.phoneNumber}}"
                        },
                        "name": "phoneNumber",
                        "_validation": {
                          "trigger": "change",
                          "rules": [
                            {
                              "type": "phone",
                              "message": "Please enter a valid phone number"
                            }
                          ]
                        },
                        "_debounce": {
                          "enabled": true,
                          "delay": 600
                        }
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "min-h-[18px]"
                        },
                        "condition": "local?.data?.form?.fields?.phoneNumber?.isValid",
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-xs text-red-500 dark:text-red-400"
                            },
                            "text": "{{local.data.form.fields.phoneNumber.isValid}}"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "space-y-1"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-sm font-medium leading-none"
                        },
                        "text": "Password"
                      },
                      {
                        "type": "Input",
                        "id": "65068b99-5d5c-433a-b271-bafc413527ba",
                        "props": {
                          "variant": "outline",
                          "size": "sm",
                          "className": "!text-[var(--theme-foreground)]",
                          "type": "password",
                          "placeholder": "••••••••",
                          "placeholderTextColor": "#9ca3af",
                          "autoComplete": "new-password",
                          "value": "{{local.data.form.formData.password}}"
                        },
                        "name": "password",
                        "_validation": {
                          "trigger": "submit",
                          "rules": [
                            {
                              "type": "required",
                              "message": "Password is required"
                            },
                            {
                              "type": "minLength",
                              "value": "8",
                              "message": "Password must be at least 8 characters"
                            }
                          ]
                        }
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "min-h-[18px]"
                        },
                        "condition": "local?.data?.form?.fields?.password?.isValid",
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-xs text-red-500 dark:text-red-400"
                            },
                            "text": "{{local.data.form.fields.password.isValid}}"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "space-y-1"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-sm font-medium leading-none"
                        },
                        "text": "Confirm Password"
                      },
                      {
                        "type": "Input",
                        "id": "cca7f8b8-c894-451f-b08e-1f467d7f7f16",
                        "props": {
                          "variant": "outline",
                          "size": "sm",
                          "className": "!text-[var(--theme-foreground)]",
                          "type": "password",
                          "placeholder": "••••••••",
                          "placeholderTextColor": "#9ca3af",
                          "autoComplete": "new-password",
                          "value": "{{local.data.form.formData.confirmPassword}}"
                        },
                        "name": "confirmPassword",
                        "_validation": {
                          "trigger": "submit",
                          "rules": [
                            {
                              "type": "required",
                              "message": "Please confirm your password"
                            },
                            {
                              "type": "formula",
                              "formula": {
                                "formula": "local.data?.['form']?.['formData']?.['confirmPassword'] === local.data?.['form']?.['formData']?.['password']"
                              },
                              "message": "Passwords do not match"
                            }
                          ]
                        }
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "min-h-[18px]"
                        },
                        "condition": "local?.data?.form?.fields?.confirmPassword?.isValid",
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-xs text-red-500 dark:text-red-400"
                            },
                            "text": "{{local.data.form.fields.confirmPassword.isValid}}"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "text-sm text-red-500"
                    },
                    "condition": "_workflow?.lastAction === 'registerMutation' && _workflow?.lastError",
                    "children": [
                      {
                        "type": "Text",
                        "text": "{{_workflow.lastError}}"
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "name": "Submit",
                    "props": {
                      "type": "submit",
                      "className": "flex flex-row items-center justify-center cursor-pointer px-4 py-2 rounded-md w-full !bg-[var(--theme-primary)] hover:!bg-[var(--theme-primary)]"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "!text-white"
                        },
                        "text": "Create Account"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Box",
            "props": {
              "className": "px-6 mt-6 flex flex-row items-center justify-center"
            },
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "text-[var(--theme-muted-foreground)] text-sm text-center"
                },
                "text": "Already have an account? "
              },
              {
                "type": "Box",
                "actions": [
                  {
                    "action": "3517ed88-9e35-42fd-8d44-650cb590d210"
                  }
                ],
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm text-[var(--theme-primary)] underline hover:opacity-80 text-center"
                    },
                    "text": "Sign in"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
