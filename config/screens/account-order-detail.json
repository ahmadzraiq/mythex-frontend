{
  "meta": {
    "title": "Order Details"
  },
  "state": {},
  "layout": "account",
  "initActions": [
    {
      "action": "fetchNavCollections"
    },
    {
      "action": "fetchOrderDetail"
    }
  ],
  "content": {
    "type": "Box",
    "props": {
      "className": "space-y-6 flex flex-col"
    },
    "children": [
      {
        "type": "Box",
        "props": {
          "className": "flex items-center gap-3 flex-row"
        },
        "children": [
          {
            "type": "Pressable",
            "actions": {
              "click": {
                "action": "navigate",
                "payload": {
                  "path": "/account/orders"
                }
              }
            },
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "text-sm text-[var(--theme-muted-foreground)] hover:text-[var(--theme-foreground)] hover:underline transition-colors"
                },
                "text": "← Orders"
              }
            ]
          },
          {
            "type": "Heading",
            "props": {
              "className": "text-3xl font-bold"
            },
            "text": {
              "expr": {
                "var": "account.orderDetail.code"
              },
              "prefix": "Order #"
            }
          },
          {
            "type": "Badge",
            "props": {
              "className": "text-xs"
            },
            "children": [
              {
                "type": "BadgeText",
                "text": "{{account.orderDetail.state}}"
              }
            ]
          }
        ]
      },
      {
        "type": "Card",
        "children": [
          {
            "type": "Box",
            "props": {
              "className": "p-6 space-y-4"
            },
            "children": [
              {
                "type": "Heading",
                "props": {
                  "className": "text-lg font-semibold mb-4"
                },
                "text": "Items"
              },
              {
                "type": "Box",
                "props": {
                  "className": "space-y-4 flex flex-col"
                },
                "map": "account.orderDetail.lines",
                "key": "orderDetailLine",
                "children": [
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex gap-4 items-start flex-row"
                    },
                    "children": [
                      {
                        "type": "NextImage",
                        "props": {
                          "src": "{{$item.productVariant.product.featuredAsset.preview}}",
                          "alt": "{{$item.productVariant.product.name}}",
                          "width": 80,
                          "height": 80,
                          "className": "rounded-md object-cover w-20 h-20 flex-shrink-0 border border-[var(--theme-border)]"
                        }
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex-1 min-w-0"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "font-medium"
                            },
                            "text": "{{$item.productVariant.product.name}}"
                          },
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-sm text-[var(--theme-muted-foreground)]"
                            },
                            "text": "{{$item.productVariant.name}}"
                          },
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-sm text-[var(--theme-muted-foreground)] mt-1"
                            },
                            "text": {
                              "expr": {
                                "var": "$item.quantity"
                              },
                              "prefix": "Qty: "
                            }
                          }
                        ]
                      },
                      {
                        "type": "Text",
                        "props": {
                          "className": "font-semibold text-right flex-shrink-0"
                        },
                        "text": {
                          "expr": {
                            "formatCurrency": [
                              {
                                "/": [
                                  {
                                    "var": "$item.linePriceWithTax"
                                  },
                                  100
                                ]
                              },
                              {
                                "var": [
                                  "account.orderDetail.currencyCode",
                                  "USD"
                                ]
                              }
                            ]
                          }
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "Box",
        "props": {
          "className": "grid md:grid-cols-2 gap-6"
        },
        "children": [
          {
            "type": "Card",
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "p-6"
                },
                "children": [
                  {
                    "type": "Heading",
                    "props": {
                      "className": "text-base font-semibold mb-3"
                    },
                    "text": "Shipping Address"
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm"
                    },
                    "text": "{{account.orderDetail.shippingAddress.fullName}}"
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm text-[var(--theme-muted-foreground)]"
                    },
                    "text": "{{account.orderDetail.shippingAddress.streetLine1}}"
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm text-[var(--theme-muted-foreground)]"
                    },
                    "text": "{{account.orderDetail.shippingAddress.city}}, {{account.orderDetail.shippingAddress.postalCode}}"
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm text-[var(--theme-muted-foreground)]"
                    },
                    "text": "{{account.orderDetail.shippingAddress.country}}"
                  }
                ]
              }
            ]
          },
          {
            "type": "Card",
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "p-6 space-y-2"
                },
                "children": [
                  {
                    "type": "Heading",
                    "props": {
                      "className": "text-base font-semibold mb-3"
                    },
                    "text": "Order Summary"
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex justify-between text-sm flex-row"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[var(--theme-muted-foreground)]"
                        },
                        "text": "Subtotal"
                      },
                      {
                        "type": "Text",
                        "text": {
                          "expr": {
                            "formatCurrency": [
                              {
                                "/": [
                                  {
                                    "var": [
                                      "account.orderDetail.subTotalWithTax",
                                      0
                                    ]
                                  },
                                  100
                                ]
                              },
                              {
                                "var": [
                                  "account.orderDetail.currencyCode",
                                  "USD"
                                ]
                              }
                            ]
                          }
                        }
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex justify-between text-sm flex-row"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[var(--theme-muted-foreground)]"
                        },
                        "text": "Shipping"
                      },
                      {
                        "type": "Text",
                        "text": {
                          "expr": {
                            "formatCurrency": [
                              {
                                "/": [
                                  {
                                    "var": [
                                      "account.orderDetail.shippingWithTax",
                                      0
                                    ]
                                  },
                                  100
                                ]
                              },
                              {
                                "var": [
                                  "account.orderDetail.currencyCode",
                                  "USD"
                                ]
                              }
                            ]
                          }
                        }
                      }
                    ]
                  },
                  {
                    "type": "Divider"
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex justify-between font-bold flex-row"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "text": "Total"
                      },
                      {
                        "type": "Text",
                        "text": {
                          "expr": {
                            "formatCurrency": [
                              {
                                "/": [
                                  {
                                    "var": [
                                      "account.orderDetail.totalWithTax",
                                      0
                                    ]
                                  },
                                  100
                                ]
                              },
                              {
                                "var": [
                                  "account.orderDetail.currencyCode",
                                  "USD"
                                ]
                              }
                            ]
                          }
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
