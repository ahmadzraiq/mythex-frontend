                },
                "children": [
                  {
                    "type": "Box",
                    "props": {
                      "className": "w-full px-[24px] pt-[48px] pb-[12px] flex flex-col items-end justify-end min-h-[120px]"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[48px] font-light text-white text-right flex-col"
                        },
                        "text": "{{variables['ca1c0001-0000-0000-0000-000000000001']}}"
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "grid grid-cols-4 gap-[10px] px-[12px] pb-[16px]"
                    },
                    "children": [
                      {
                        "type": "Box",
