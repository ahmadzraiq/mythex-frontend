                          "className": "contents flex-col"
                        },
                        "children": [
                          {
                            "type": "Box",
                            "props": {
                              "className": "flex flex-col items-center justify-center cursor-pointer rounded-[9999px] h-[64px] hover:opacity-80 active:opacity-70 bg-[{{context.item.data.bg}}]"
                            },
                            "actions": [
                              {
                                "trigger": "click",
                                "workflowId": "calcButtonPress"
                              }
                            ],
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "className": "text-[20px] font-medium text-center text-[{{context.item.data.color}}] flex-col"
                                },
                                "text": "{{context.item.data.label}}"
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
