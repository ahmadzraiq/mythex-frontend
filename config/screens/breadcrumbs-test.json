{
  "meta": { "title": "Breadcrumbs System Component Demo" },
  "state": {},
  "ui": {
    "type": "Box",
    "props": { "className": "w-full min-h-screen bg-gray-50 dark:bg-gray-950" },
    "children": [
      {
        "type": "Box",
        "props": { "className": "max-w-[640px] mx-auto flex flex-col gap-[24px] py-[48px] px-[24px]" },
        "children": [
          { "type": "Text", "props": { "className": "text-[24px] font-bold text-gray-900 dark:text-white" }, "text": "Breadcrumbs — Custom Trigger Demo" },

          {
            "type": "Box",
            "_system": { "id": "sys-breadcrumbs", "name": "Breadcrumbs" },
            "_overrides": [],
            "props": {
              "items": [
                { "label": "Home", "href": "/" },
                { "label": "Category", "href": "/category" },
                { "label": "Page", "href": "/category/page" }
              ],
              "separatorIcon": "lucide:chevron-right",
              "data-testid": "breadcrumbs-strip",
              "className": "flex flex-row items-center gap-[4px]"
            },
            "actions": [{ "action": "wfOnBreadcrumbItemClick" }],
            "children": [
              {
                "type": "Box",
                "map": { "formula": "(()=>{const items=Array.isArray(context?.component?.props?.items)?context.component.props.items:[];return items.map((it,i)=>({label:it?.label||'',href:it?.href||'',index:i,isLast:i===items.length-1}))})()" },
                "key": "context.item.data.index",
                "props": { "className": "contents" },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "data-testid": { "formula": "'breadcrumb-' + (context?.item?.data?.index || 0)" },
                      "className": "text-[14px] font-medium",
                      "style": {
                        "color": { "formula": "context?.item?.data?.isLast?'var(--theme-foreground)':'var(--theme-primary)'" },
                        "cursor": { "formula": "context?.item?.data?.isLast?'default':'pointer'" }
                      }
                    },
                    "actions": [{ "action": "bc-wf-item-click" }],
                    "text": "{{context.item.data.label}}"
                  },
                  {
                    "type": "Icon",
                    "condition": "!context?.item?.data?.isLast",
                    "props": {
                      "icon": { "formula": "context?.component?.props?.separatorIcon || 'lucide:chevron-right'" },
                      "size": 14,
                      "color": "#9ca3af"
                    }
                  }
                ]
              }
            ]
          },

          {
            "type": "Text",
            "props": { "className": "text-[14px] text-gray-700 dark:text-gray-300", "data-testid": "out-breadcrumbs-label" },
            "text": { "formula": "'Last: ' + (variables['breadcrumbs-test-label'] || '(none)')" }
          }
        ]
      }
    ]
  }
}
