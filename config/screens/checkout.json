{
  "meta": { "title": "Checkout" },
  "state": {
    "checkout": { "step": "contact" },
    "completedSteps": [],
    "form": {
      "emailAddress": "", "firstName": "", "lastName": "",
      "fullName": "", "streetLine1": "", "streetLine2": "",
      "city": "", "province": "", "postalCode": "", "countryCode": "", "phoneNumber": ""
    },
    "errors": {}
  },
  "layout": "store",
  "initActions": [{ "action": "fetchNavCollections" }, 
    { "action": "fetchCheckoutOrder" },
    { "action": "fetchCountries" }
  ],
  "content": {
    "type": "Box",
    "props": { "className": "w-full max-w-screen-xl mx-auto px-4 py-8" },
    "children": [
      { "type": "Heading", "props": { "className": "text-3xl font-bold mb-8" }, "text": "Checkout" },
      {
        "type": "Box",
        "props": { "className": "grid lg:grid-cols-3 gap-8" },
        "children": [
          {
            "type": "Box",
            "props": { "className": "lg:col-span-2 space-y-4" },
            "children": [
              {
                "type": "Box",
                "props": { "className": "border rounded-lg px-6" },
                "condition": { "==": [{ "var": "auth.user" }, null] },
                "children": [
                  {
                    "type": "Pressable",
                    "props": { "className": "flex items-center gap-3 w-full py-4" },
                    "actions": { "click": { "type": "set", "path": "checkout.step", "value": "contact" } },
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": {
                            "expr": {
                              "cat": [
                                "flex items-center justify-center w-8 h-8 rounded-full text-sm font-semibold ",
                                { "if": [{ "in": ["contact", { "var": "completedSteps" }] }, "bg-green-500 text-white",
                                  { "if": [{ "==": [{ "var": "checkout.step" }, "contact"] }, "bg-[#1e293b] text-white", "bg-gray-100 text-gray-500"] }] }
                              ]
                            }
                          }
                        },
                        "children": [
                          { "type": "Text", "text": { "expr": { "if": [{ "in": ["contact", { "var": "completedSteps" }] }, "✓", "1"] } } }
                        ]
                      },
                      { "type": "Text", "props": { "className": "text-lg font-semibold" }, "text": "Contact Information" }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": { "className": "pb-6" },
                    "condition": { "==": [{ "var": "checkout.step" }, "contact"] },
                    "children": [
                      {
                        "type": "VStack",
                        "props": { "className": "space-y-4" },
                        "children": [
                          {
                            "type": "Box",
                            "props": { "className": "grid grid-cols-2 gap-4" },
                            "children": [
                              {
                                "type": "Box",
                                "props": { "className": "space-y-2" },
                                "children": [
                                  { "type": "Text", "props": { "className": "text-sm font-medium" }, "text": "First name" },
                                  {
                                    "type": "Input",
                                    "children": [
                                      { "type": "InputField", "props": { "placeholder": "Jane", "value": "{{form.firstName}}" }, "actions": { "change": { "action": "setState", "payload": { "path": "form.firstName", "value": "$event" } } } }
                                    ]
                                  }
                                ]
                              },
                              {
                                "type": "Box",
                                "props": { "className": "space-y-2" },
                                "children": [
                                  { "type": "Text", "props": { "className": "text-sm font-medium" }, "text": "Last name" },
                                  {
                                    "type": "Input",
                                    "children": [
                                      { "type": "InputField", "props": { "placeholder": "Doe", "value": "{{form.lastName}}" }, "actions": { "change": { "action": "setState", "payload": { "path": "form.lastName", "value": "$event" } } } }
                                    ]
                                  }
                                ]
                              }
                            ]
                          },
                          {
                            "type": "Box",
                            "props": { "className": "space-y-2" },
                            "children": [
                              { "type": "Text", "props": { "className": "text-sm font-medium" }, "text": "Email" },
                              {
                                "type": "Input",
                                "children": [
                                  { "type": "InputField", "props": { "type": "email", "placeholder": "you@example.com", "value": "{{form.emailAddress}}" }, "actions": { "change": { "action": "setState", "payload": { "path": "form.emailAddress", "value": "$event" } } } }
                                ]
                              }
                            ]
                          },
                          {
                            "type": "Button",
                            "props": { "className": "bg-[#1e293b] text-white hover:bg-[#334155]" },
                            "children": [{ "type": "ButtonText", "props": { "className": "!text-white" }, "text": "Continue" }],
                            "actions": { "click": { "action": "setCustomerForOrder" } }
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Box",
                "props": { "className": "border rounded-lg px-6" },
                "children": [
                  {
                    "type": "Pressable",
                    "props": { "className": "flex items-center gap-3 w-full py-4" },
                    "actions": { "click": { "type": "set", "path": "checkout.step", "value": "shipping" } },
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": { "expr": { "cat": ["flex items-center justify-center w-8 h-8 rounded-full text-sm font-semibold ", { "if": [{ "in": ["shipping", { "var": "completedSteps" }] }, "bg-green-500 text-white", { "if": [{ "==": [{ "var": "checkout.step" }, "shipping"] }, "bg-[#1e293b] text-white", "bg-gray-100 text-gray-500"] }] }] } }
                        },
                        "children": [{ "type": "Text", "text": { "expr": { "if": [{ "in": ["shipping", { "var": "completedSteps" }] }, "✓", "2"] } } }]
                      },
                      { "type": "Text", "props": { "className": "text-lg font-semibold" }, "text": "Shipping Address" }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": { "className": "pb-6" },
                    "condition": { "==": [{ "var": "checkout.step" }, "shipping"] },
                    "children": [
                      {
                        "type": "VStack",
                        "props": { "className": "space-y-4" },
                        "children": [
                          {
                            "type": "Box",
                            "props": { "className": "space-y-2" },
                            "children": [
                              { "type": "Text", "props": { "className": "text-sm font-medium" }, "text": "Full name" },
                              { "type": "Input", "children": [{ "type": "InputField", "props": { "placeholder": "Jane Doe", "value": "{{form.fullName}}" }, "actions": { "change": { "action": "setState", "payload": { "path": "form.fullName", "value": "$event" } } } }] }
                            ]
                          },
                          {
                            "type": "Box",
                            "props": { "className": "space-y-2" },
                            "children": [
                              { "type": "Text", "props": { "className": "text-sm font-medium" }, "text": "Street address" },
                              { "type": "Input", "children": [{ "type": "InputField", "props": { "placeholder": "123 Main St", "value": "{{form.streetLine1}}" }, "actions": { "change": { "action": "setState", "payload": { "path": "form.streetLine1", "value": "$event" } } } }] }
                            ]
                          },
                          {
                            "type": "Box",
                            "props": { "className": "grid grid-cols-2 gap-4" },
                            "children": [
                              {
                                "type": "Box",
                                "props": { "className": "space-y-2" },
                                "children": [
                                  { "type": "Text", "props": { "className": "text-sm font-medium" }, "text": "City" },
                                  { "type": "Input", "children": [{ "type": "InputField", "props": { "placeholder": "New York", "value": "{{form.city}}" }, "actions": { "change": { "action": "setState", "payload": { "path": "form.city", "value": "$event" } } } }] }
                                ]
                              },
                              {
                                "type": "Box",
                                "props": { "className": "space-y-2" },
                                "children": [
                                  { "type": "Text", "props": { "className": "text-sm font-medium" }, "text": "Postal code" },
                                  { "type": "Input", "children": [{ "type": "InputField", "props": { "placeholder": "10001", "value": "{{form.postalCode}}" }, "actions": { "change": { "action": "setState", "payload": { "path": "form.postalCode", "value": "$event" } } } }] }
                                ]
                              }
                            ]
                          },
                          {
                            "type": "Box",
                            "props": { "className": "space-y-2" },
                            "children": [
                              { "type": "Text", "props": { "className": "text-sm font-medium" }, "text": "Country code" },
                              { "type": "Input", "children": [{ "type": "InputField", "props": { "placeholder": "US", "value": "{{form.countryCode}}" }, "actions": { "change": { "action": "setState", "payload": { "path": "form.countryCode", "value": "$event" } } } }] }
                            ]
                          },
                          {
                            "type": "Button",
                            "props": { "className": "bg-[#1e293b] text-white hover:bg-[#334155]" },
                            "children": [{ "type": "ButtonText", "props": { "className": "!text-white" }, "text": "Continue" }],
                            "actions": { "click": { "action": "setShippingAddress" } }
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Box",
                "props": { "className": "border rounded-lg px-6" },
                "children": [
                  {
                    "type": "Pressable",
                    "props": { "className": "flex items-center gap-3 w-full py-4" },
                    "actions": { "click": { "type": "set", "path": "checkout.step", "value": "delivery" } },
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": { "expr": { "cat": ["flex items-center justify-center w-8 h-8 rounded-full text-sm font-semibold ", { "if": [{ "in": ["delivery", { "var": "completedSteps" }] }, "bg-green-500 text-white", { "if": [{ "==": [{ "var": "checkout.step" }, "delivery"] }, "bg-[#1e293b] text-white", "bg-gray-100 text-gray-500"] }] }] } }
                        },
                        "children": [{ "type": "Text", "text": { "expr": { "if": [{ "in": ["delivery", { "var": "completedSteps" }] }, "✓", "3"] } } }]
                      },
                      { "type": "Text", "props": { "className": "text-lg font-semibold" }, "text": "Delivery Method" }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": { "className": "pb-6 space-y-3" },
                    "condition": { "==": [{ "var": "checkout.step" }, "delivery"] },
                    "children": [
                      {
                        "type": "Box",
                        "props": { "className": "contents" },
                        "map": "checkout.shippingMethods",
                        "key": "shippingOpt",
                        "children": [
                          {
                            "type": "Pressable",
                            "props": { "className": "flex items-center justify-between p-4 border rounded-lg hover:border-primary transition-colors" },
                            "actions": { "click": { "type": "set", "path": "checkout.selectedShippingMethodId", "value": { "var": "$item.id" } } },
                            "children": [
                              {
                                "type": "VStack",
                                "props": { "className": "gap-0.5 text-left" },
                                "children": [
                                  { "type": "Text", "props": { "className": "font-medium text-sm" }, "text": "{{$item.name}}" },
                                  { "type": "Text", "props": { "className": "text-xs text-gray-500" }, "text": "{{$item.description}}" }
                                ]
                              },
                              { "type": "Text", "props": { "className": "font-semibold text-sm" }, "text": { "expr": { "formatCurrency": [{ "/": [{ "var": "$item.priceWithTax" }, 100] }, "USD"] } } }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "Button",
                        "props": { "className": "bg-[#1e293b] text-white hover:bg-[#334155] mt-2" },
                        "children": [{ "type": "ButtonText", "props": { "className": "!text-white" }, "text": "Continue" }],
                        "actions": { "click": { "action": "setShippingMethod" } }
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Box",
                "props": { "className": "border rounded-lg px-6" },
                "children": [
                  {
                    "type": "Pressable",
                    "props": { "className": "flex items-center gap-3 w-full py-4" },
                    "actions": { "click": { "type": "set", "path": "checkout.step", "value": "payment" } },
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": { "expr": { "cat": ["flex items-center justify-center w-8 h-8 rounded-full text-sm font-semibold ", { "if": [{ "in": ["payment", { "var": "completedSteps" }] }, "bg-green-500 text-white", { "if": [{ "==": [{ "var": "checkout.step" }, "payment"] }, "bg-[#1e293b] text-white", "bg-gray-100 text-gray-500"] }] }] } }
                        },
                        "children": [{ "type": "Text", "text": { "expr": { "if": [{ "in": ["payment", { "var": "completedSteps" }] }, "✓", "4"] } } }]
                      },
                      { "type": "Text", "props": { "className": "text-lg font-semibold" }, "text": "Payment Method" }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": { "className": "pb-6 space-y-3" },
                    "condition": { "==": [{ "var": "checkout.step" }, "payment"] },
                    "children": [
                      {
                        "type": "Box",
                        "props": { "className": "contents" },
                        "map": "checkout.paymentMethods",
                        "key": "paymentOpt",
                        "children": [
                          {
                            "type": "Pressable",
                            "props": { "className": "flex items-center gap-3 p-4 border rounded-lg hover:border-primary transition-colors" },
                            "actions": { "click": { "type": "set", "path": "checkout.selectedPaymentMethodCode", "value": { "var": "$item.code" } } },
                            "children": [
                              {
                                "type": "VStack",
                                "props": { "className": "gap-0.5 text-left flex-1" },
                                "children": [
                                  { "type": "Text", "props": { "className": "font-medium text-sm" }, "text": "{{$item.name}}" },
                                  { "type": "Text", "props": { "className": "text-xs text-gray-500" }, "text": "{{$item.description}}" }
                                ]
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "Button",
                        "props": { "className": "bg-[#1e293b] text-white hover:bg-[#334155] mt-2" },
                        "children": [{ "type": "ButtonText", "props": { "className": "!text-white" }, "text": "Place Order" }],
                        "actions": { "click": { "action": "transitionToArrangingPayment" } }
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Box",
            "props": { "className": "lg:col-span-1" },
            "children": [
              {
                "type": "Box",
                "props": { "className": "border rounded-lg p-6 bg-white sticky top-20 space-y-3" },
                "children": [
                  { "type": "Heading", "props": { "className": "text-lg font-bold" }, "text": "Order Summary" },
                  {
                    "type": "VStack",
                    "props": { "className": "space-y-2 max-h-64 overflow-y-auto" },
                    "map": "checkout.order.lines",
                    "key": "checkoutLine",
                    "children": [
                      {
                        "type": "HStack",
                        "props": { "className": "flex gap-2 text-sm" },
                        "children": [
                          { "type": "Text", "props": { "className": "flex-1 truncate" }, "text": "{{$item.productVariant.product.name}}" },
                          { "type": "Text", "props": { "className": "text-gray-500" }, "text": { "expr": { "var": "$item.quantity" }, "prefix": "×" } },
                          { "type": "Text", "props": { "className": "font-medium" }, "text": { "expr": { "formatCurrency": [{ "/": [{ "var": "$item.linePriceWithTax" }, 100] }, "USD"] } } }
                        ]
                      }
                    ]
                  },
                  { "type": "Box", "props": { "className": "border-t" } },
                  {
                    "type": "VStack",
                    "props": { "className": "space-y-1 text-sm" },
                    "children": [
                      {
                        "type": "HStack",
                        "props": { "className": "flex justify-between" },
                        "children": [
                          { "type": "Text", "props": { "className": "text-gray-500" }, "text": "Subtotal" },
                          { "type": "Text", "text": { "expr": { "formatCurrency": [{ "/": [{ "var": ["checkout.order.subTotalWithTax", 0] }, 100] }, "USD"] } } }
                        ]
                      },
                      {
                        "type": "HStack",
                        "props": { "className": "flex justify-between" },
                        "children": [
                          { "type": "Text", "props": { "className": "text-gray-500" }, "text": "Shipping" },
                          { "type": "Text", "text": { "expr": { "formatCurrency": [{ "/": [{ "var": ["checkout.order.shippingWithTax", 0] }, 100] }, "USD"] } } }
                        ]
                      },
                      { "type": "Box", "props": { "className": "border-t" } },
                      {
                        "type": "HStack",
                        "props": { "className": "flex justify-between font-bold text-base" },
                        "children": [
                          { "type": "Text", "text": "Total" },
                          { "type": "Text", "text": { "expr": { "formatCurrency": [{ "/": [{ "var": ["checkout.order.totalWithTax", 0] }, 100] }, "USD"] } } }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
