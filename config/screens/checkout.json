{
  "meta": {
    "title": "Checkout"
  },
  "state": {
    "checkout": {
      "step": "contact"
    },
    "form": {
      "emailAddress": "",
      "firstName": "",
      "lastName": "",
      "fullName": "",
      "company": "",
      "streetLine1": "",
      "streetLine2": "",
      "city": "",
      "province": "",
      "postalCode": "",
      "countryCode": "",
      "phoneNumber": ""
    },
    "errors": {}
  },
  "layout": "store",
  "initActions": [
    {
      "action": "fetchNavCollections"
    },
    {
      "action": "fetchCheckoutOrder"
    },
    {
      "action": "fetchCountries"
    },
    {
      "action": "fetchShippingMethods"
    },
    {
      "action": "fetchPaymentMethods"
    }
  ],
  "content": {
    "type": "Box",
    "props": {
      "className": "w-full max-w-screen-xl mx-auto px-4 py-8"
    },
    "children": [
      {
        "type": "Heading",
        "props": {
          "className": "text-3xl font-bold mb-8"
        },
        "text": "Checkout"
      },
      {
        "type": "Box",
        "props": {
          "className": "grid lg:grid-cols-3 gap-8"
        },
        "children": [
          {
            "type": "Box",
            "_meta": {
              "section": "checkout-steps",
              "description": "Contact, shipping, and payment steps"
            },
            "props": {
              "className": "lg:col-span-2 space-y-4"
            },
            "children": [
              {
                "$ref": "fragments/checkout/contact-step"
              },
              {
                "$ref": "fragments/checkout/shipping-step"
              },
              {
                "type": "Box",
                "props": {
                  "className": "border rounded-lg px-6 bg-[var(--theme-content-bg)]"
                },
                "children": [
                  {
                    "type": "Pressable",
                    "props": {
                      "className": { "expr": "'flex flex-row items-center justify-between w-full py-4 ' + ({{checkout.order.shippingAddress.streetLine1}} ? '' : 'opacity-50 pointer-events-none cursor-not-allowed')" }
                    },
                    "actions": {
                      "click": {
                        "type": "set",
                        "path": "checkout.step",
                        "value": "delivery"
                      }
                    },
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex flex-row items-center gap-3 flex-1 min-w-0"
                        },
                        "children": [
                          {
                            "type": "Box",
                            "props": {
                              "className": { "expr": "'flex items-center justify-center w-8 h-8 min-w-8 min-h-8 rounded-full overflow-hidden shrink-0 ' + (({{checkout.order.shippingLines.length}} || 0) > 0 ? 'bg-green-500 !text-white' : ({{checkout.step}} === 'delivery' ? 'bg-[var(--theme-shop-button)] !text-white' : 'bg-[var(--theme-hero-bg)] !text-[var(--theme-muted-foreground)]'))" }
                            },
                            "children": [
                              {
                                "type": "NavIcon",
                                "props": {
                                  "icon": "Check",
                                  "size": 16,
                                  "className": "!text-white"
                                },
                                "condition": "({{checkout.order.shippingLines.length}} || 0) > 0"
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "className": "font-semibold text-sm !text-white"
                                },
                                "text": "3",
                                "condition": "({{checkout.order.shippingLines.length}} || 0) <= 0 && {{checkout.step}} === 'delivery'"
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "className": "font-semibold text-sm !text-[var(--theme-muted-foreground)]"
                                },
                                "text": "3",
                                "condition": "({{checkout.order.shippingLines.length}} || 0) <= 0 && {{checkout.step}} !== 'delivery'"
                              }
                            ]
                          },
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-lg font-semibold"
                            },
                            "text": "Delivery Method"
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "ml-auto shrink-0"
                        },
                        "children": [
                          {
                            "type": "NavIcon",
                            "props": {
                              "icon": "ChevronUp",
                              "size": 16,
                              "className": "!text-[var(--theme-muted-foreground)]"
                            },
                            "condition": "{{checkout.step}} === 'delivery'"
                          },
                          {
                            "type": "NavIcon",
                            "props": {
                              "icon": "ChevronDown",
                              "size": 16,
                              "className": "!text-[var(--theme-muted-foreground)]"
                            },
                            "condition": "{{checkout.step}} !== 'delivery'"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "pb-6 space-y-3"
                    },
                    "condition": "{{checkout.step}} === 'delivery'",
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-sm text-[var(--theme-muted-foreground)]"
                        },
                        "text": "Select shipping method"
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex flex-row flex-wrap gap-4"
                        },
                        "children": [
                          {
                            "type": "Box",
                            "props": {
                              "className": "contents"
                            },
                            "map": "checkout.shippingMethods",
                            "key": "shippingOpt",
                            "children": [
                              {
                                "type": "Pressable",
                                "props": {
                                  "className": { "expr": "'flex flex-row items-center gap-3 p-4 border-2 rounded-lg w-full cursor-pointer transition-colors ' + ({{checkout.selectedShippingMethodId}} === {{$item.id}} ? 'border-[var(--theme-shop-button)] bg-[var(--theme-hero-bg)]' : 'border-[var(--theme-border)] hover:border-[var(--theme-shop-button)]')" }
                                },
                                "actions": {
                                  "click": {
                                    "type": "runMultiple",
                                    "actions": [
                                      {
                                        "type": "set",
                                        "path": "checkout.selectedShippingMethodId",
                                        "value": "{{$item.id}}"
                                      },
                                      {
                                        "action": "setState",
                                        "payload": {
                                          "path": "screens.checkout.errors.checkout.selectedShippingMethodId",
                                          "value": ""
                                        }
                                      }
                                    ]
                                  }
                                },
                                "children": [
                                  {
                                    "type": "Box",
                                    "props": {
                                      "className": { "expr": "'w-5 h-5 min-w-5 min-h-5 rounded-full border-2 flex items-center justify-center shrink-0 ' + ({{checkout.selectedShippingMethodId}} === {{$item.id}} ? 'border-[var(--theme-shop-button)] bg-[var(--theme-shop-button)]' : 'border-[var(--theme-border)]')" }
                                    },
                                    "children": [
                                      {
                                        "type": "Box",
                                        "props": {
                                          "className": "w-2 h-2 rounded-full bg-white pointer-events-none"
                                        },
                                        "condition": "{{checkout.selectedShippingMethodId}} === {{$item.id}}"
                                      }
                                    ]
                                  },
                                  {
                                    "type": "NavIcon",
                                    "props": {
                                      "icon": "Truck",
                                      "size": 20,
                                      "className": "!text-[var(--theme-muted-foreground)] shrink-0"
                                    }
                                  },
                                  {
                                    "type": "Box",
                                    "props": {
                                      "className": "gap-0.5 text-left flex-1 min-w-0 flex flex-col"
                                    },
                                    "children": [
                                      {
                                        "type": "Text",
                                        "props": {
                                          "className": "font-medium text-sm text-[var(--theme-foreground)]"
                                        },
                                        "text": "{{$item.name}}"
                                      },
                                      {
                                        "type": "Text",
                                        "props": {
                                          "className": "text-xs text-[var(--theme-muted-foreground)]"
                                        },
                                        "text": "{{$item.description}}"
                                      }
                                    ]
                                  },
                                  {
                                    "type": "Text",
                                    "props": {
                                      "className": "font-semibold text-sm text-[var(--theme-foreground)] shrink-0"
                                    },
                                    "text": { "expr": "formatCurrency({{$item.priceWithTax}} / 100, 'USD')" }
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "min-h-[20px]"
                        },
                        "condition": "{{screens.checkout.errors.checkout.selectedShippingMethodId}}",
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-sm text-red-500 dark:text-red-400"
                            },
                            "text": "{{errors.checkout.selectedShippingMethodId}}"
                          }
                        ]
                      },
                      {
                        "type": "Pressable",
                        "props": {
                          "className": { "expr": "'flex flex-row items-center justify-center bg-[var(--theme-shop-button)] text-white hover:bg-[var(--theme-shop-buttonHover)] mt-2 ' + ({{checkout.selectedShippingMethodId}} ? '' : 'opacity-50 pointer-events-none cursor-not-allowed')" }
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-white"
                            },
                            "text": "Continue to payment"
                          }
                        ],
                        "actions": {
                          "click": {
                            "action": "setShippingMethod"
                          }
                        }
                      }
                    ]
                  }
                ]
              },
              {
                "$ref": "fragments/checkout/payment-step"
              },
              {
                "type": "Box",
                "props": {
                  "className": "border rounded-lg px-6 bg-[var(--theme-content-bg)]"
                },
                "children": [
                  {
                    "type": "Pressable",
                    "props": {
                      "className": { "expr": "'flex flex-row items-center justify-between w-full py-4 ' + (({{checkout.step}} === 'review' || (({{auth.user}} || {{checkout.order.customer.emailAddress}}) && {{checkout.order.shippingAddress.streetLine1}} && ({{checkout.order.shippingLines.length}} || 0) > 0 && {{checkout.selectedPaymentMethodCode}})) ? '' : 'opacity-50 pointer-events-none cursor-not-allowed')" }
                    },
                    "actions": {
                      "click": {
                        "type": "set",
                        "path": "checkout.step",
                        "value": "review"
                      }
                    },
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex flex-row items-center gap-3 flex-1 min-w-0"
                        },
                        "children": [
                          {
                            "type": "Box",
                            "props": {
                              "className": { "expr": "'flex items-center justify-center w-8 h-8 min-w-8 min-h-8 rounded-full overflow-hidden shrink-0 ' + ({{checkout.step}} === 'review' ? 'bg-[var(--theme-shop-button)] !text-white' : 'bg-[var(--theme-hero-bg)] !text-[var(--theme-muted-foreground)]')" }
                            },
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "className": "font-semibold text-sm !text-white"
                                },
                                "text": "5",
                                "condition": "{{checkout.step}} === 'review'"
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "className": "font-semibold text-sm !text-[var(--theme-muted-foreground)]"
                                },
                                "text": "5",
                                "condition": "{{checkout.step}} !== 'review'"
                              }
                            ]
                          },
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-lg font-semibold"
                            },
                            "text": "Review & Place Order"
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "ml-auto shrink-0"
                        },
                        "children": [
                          {
                            "type": "NavIcon",
                            "props": {
                              "icon": "ChevronUp",
                              "size": 16,
                              "className": "!text-[var(--theme-muted-foreground)]"
                            },
                            "condition": "{{checkout.step}} === 'review'"
                          },
                          {
                            "type": "NavIcon",
                            "props": {
                              "icon": "ChevronDown",
                              "size": 16,
                              "className": "!text-[var(--theme-muted-foreground)]"
                            },
                            "condition": "{{checkout.step}} !== 'review'"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "pb-6 space-y-6"
                    },
                    "condition": "{{checkout.step}} === 'review'",
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "font-semibold text-lg"
                        },
                        "text": "Review your order"
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6"
                        },
                        "children": [
                          {
                            "type": "Box",
                            "props": {
                              "className": "space-y-3"
                            },
                            "condition": "{{auth.user}} === null",
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "className": "font-medium"
                                },
                                "text": "Contact"
                              },
                              {
                                "type": "Box",
                                "props": {
                                  "className": "text-sm text-[var(--theme-muted-foreground)] space-y-1"
                                },
                                "condition": "{{checkout.order.customer.emailAddress}}",
                                "children": [
                                  {
                                    "type": "Text",
                                    "text": "{{checkout.order.customer.firstName}} {{checkout.order.customer.lastName}}"
                                  },
                                  {
                                    "type": "Text",
                                    "text": "{{checkout.order.customer.emailAddress}}"
                                  }
                                ]
                              },
                              {
                                "type": "Pressable",
                                "props": {
                                  "className": "!border-[var(--theme-border)] flex flex-row items-center justify-center py-3 px-4 rounded-md"
                                },
                                "children": [
                                  {
                                    "type": "Text",
                                    "text": "Edit",
                                    "props": {}
                                  }
                                ],
                                "actions": {
                                  "click": {
                                    "type": "set",
                                    "path": "checkout.step",
                                    "value": "contact"
                                  }
                                }
                              }
                            ]
                          },
                          {
                            "type": "Box",
                            "props": {
                              "className": "space-y-3"
                            },
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "className": "font-medium"
                                },
                                "text": "Shipping Address"
                              },
                              {
                                "type": "Box",
                                "props": {
                                  "className": "text-sm text-[var(--theme-muted-foreground)] space-y-1"
                                },
                                "condition": "{{checkout.order.shippingAddress.streetLine1}}",
                                "children": [
                                  {
                                    "type": "Text",
                                    "text": "{{checkout.order.shippingAddress.fullName}}"
                                  },
                                  {
                                    "type": "Text",
                                    "text": "{{checkout.order.shippingAddress.streetLine1}}"
                                  },
                                  {
                                    "type": "Text",
                                    "text": "{{checkout.order.shippingAddress.city}}, {{checkout.order.shippingAddress.province}} {{checkout.order.shippingAddress.postalCode}}"
                                  },
                                  {
                                    "type": "Text",
                                    "text": "{{checkout.order.shippingAddress.country}}"
                                  }
                                ]
                              },
                              {
                                "type": "Pressable",
                                "props": {
                                  "className": "!border-[var(--theme-border)] flex flex-row items-center justify-center py-3 px-4 rounded-md"
                                },
                                "children": [
                                  {
                                    "type": "Text",
                                    "text": "Edit",
                                    "props": {}
                                  }
                                ],
                                "actions": {
                                  "click": {
                                    "type": "set",
                                    "path": "checkout.step",
                                    "value": "shipping"
                                  }
                                }
                              }
                            ]
                          },
                          {
                            "type": "Box",
                            "props": {
                              "className": "space-y-3"
                            },
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "className": "font-medium"
                                },
                                "text": "Delivery"
                              },
                              {
                                "type": "Box",
                                "props": {
                                  "className": "text-sm text-[var(--theme-muted-foreground)]"
                                },
                                "condition": "({{checkout.order.shippingLines.length}} || 0) > 0",
                                "children": [
                                  {
                                    "type": "Text",
                                    "text": "{{checkout.order.shippingLines.0.shippingMethod.name}}"
                                  },
                                  {
                                    "type": "Text",
                                    "text": { "expr": "{{checkout.order.shippingLines.0.priceWithTax}} === 0 ? 'FREE' : formatCurrency({{checkout.order.shippingLines.0.priceWithTax}} / 100, 'USD')" }
                                  }
                                ]
                              },
                              {
                                "type": "Pressable",
                                "props": {
                                  "className": "!border-[var(--theme-border)] flex flex-row items-center justify-center py-3 px-4 rounded-md"
                                },
                                "children": [
                                  {
                                    "type": "Text",
                                    "text": "Edit",
                                    "props": {}
                                  }
                                ],
                                "actions": {
                                  "click": {
                                    "type": "set",
                                    "path": "checkout.step",
                                    "value": "delivery"
                                  }
                                }
                              }
                            ]
                          },
                          {
                            "type": "Box",
                            "props": {
                              "className": "space-y-3"
                            },
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "className": "font-medium"
                                },
                                "text": "Payment Method"
                              },
                              {
                                "type": "Box",
                                "props": {
                                  "className": "text-sm text-[var(--theme-muted-foreground)] space-y-1"
                                },
                                "condition": "{{checkout.selectedPaymentMethodCode}}",
                                "children": [
                                  {
                                    "type": "Text",
                                    "props": {
                                      "className": "font-medium text-[var(--theme-foreground)]"
                                    },
                                    "text": "{{checkout.selectedPaymentMethodDisplay}}"
                                  }
                                ]
                              },
                              {
                                "type": "Pressable",
                                "props": {
                                  "className": "!border-[var(--theme-border)] flex flex-row items-center justify-center py-3 px-4 rounded-md"
                                },
                                "children": [
                                  {
                                    "type": "Text",
                                    "text": "Edit",
                                    "props": {}
                                  }
                                ],
                                "actions": {
                                  "click": {
                                    "type": "set",
                                    "path": "checkout.step",
                                    "value": "payment"
                                  }
                                }
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "min-h-[20px]"
                        },
                        "condition": "{{screens.checkout.errors.checkout.selectedPaymentMethodCode}}",
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-sm text-red-500 dark:text-red-400"
                            },
                            "text": "{{errors.checkout.selectedPaymentMethodCode}}"
                          }
                        ]
                      },
                      {
                        "type": "Pressable",
                        "props": {
                          "className": { "expr": "'flex flex-row items-center justify-center w-full bg-[var(--theme-shop-button)] text-white hover:bg-[var(--theme-shop-buttonHover)] !py-3 ' + ({{checkout.selectedPaymentMethodCode}} ? '' : 'opacity-50 pointer-events-none cursor-not-allowed')" }
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-white"
                            },
                            "text": "Place Order"
                          }
                        ],
                        "actions": {
                          "click": {
                            "action": "placeOrder"
                          }
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Box",
            "props": {
              "className": "lg:col-span-1"
            },
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "border border-[var(--theme-border)] rounded-lg p-6 bg-[var(--theme-content-bg)] sticky top-20 space-y-3"
                },
                "children": [
                  {
                    "type": "Heading",
                    "props": {
                      "className": "text-lg font-bold"
                    },
                    "text": "Order Summary"
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "space-y-3 max-h-64 overflow-y-auto flex flex-col"
                    },
                    "map": "checkout.order.lines",
                    "key": "checkoutLine",
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex gap-3 text-sm items-start flex-row"
                        },
                        "children": [
                          {
                            "type": "Box",
                            "props": {
                              "className": "flex-shrink-0 w-16 h-16 rounded overflow-hidden bg-[var(--theme-hero-bg)]"
                            },
                            "condition": "{{$item.productVariant.product.featuredAsset.preview}}",
                            "children": [
                              {
                                "type": "NextImage",
                                "props": {
                                  "src": "{{$item.productVariant.product.featuredAsset.preview}}",
                                  "alt": "{{$item.productVariant.product.name}}",
                                  "width": 64,
                                  "height": 64,
                                  "className": "w-16 h-16 object-cover"
                                }
                              }
                            ]
                          },
                          {
                            "type": "Box",
                            "props": {
                              "className": "flex-1 min-w-0 gap-0.5 flex flex-col"
                            },
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "className": "font-medium line-clamp-2"
                                },
                                "text": "{{$item.productVariant.product.name}}"
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "className": "text-xs text-[var(--theme-muted-foreground)]"
                                },
                                "condition": "{{$item.productVariant.name}} !== {{$item.productVariant.product.name}}",
                                "text": "{{$item.productVariant.name}}"
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "className": "text-xs text-[var(--theme-muted-foreground)]"
                                },
                                "text": "Qty: {{$item.quantity}}"
                              }
                            ]
                          },
                          {
                            "type": "Text",
                            "props": {
                              "className": "font-medium flex-shrink-0"
                            },
                            "text": { "expr": "formatCurrency({{$item.linePriceWithTax}} / 100, {{checkout.order.currencyCode}} || 'USD')" }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "border-t"
                    }
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "space-y-1 text-sm flex flex-col"
                    },
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex justify-between flex-row"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-[var(--theme-muted-foreground)]"
                            },
                            "text": "Subtotal"
                          },
                          {
                            "type": "Text",
                            "text": { "expr": "formatCurrency(({{checkout.order.subTotalWithTax}} || 0) / 100, {{checkout.order.currencyCode}} || 'USD')" }
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "contents"
                        },
                        "map": "checkout.order.discounts",
                        "key": "discount",
                        "condition": "({{checkout.order.discounts.length}} || 0) > 0",
                        "children": [
                          {
                            "type": "Box",
                            "props": {
                              "className": "flex justify-between text-sm text-green-600 flex-row"
                            },
                            "children": [
                              {
                                "type": "Text",
                                "text": "{{$item.description}}"
                              },
                              {
                                "type": "Text",
                                "text": { "expr": "formatCurrency({{$item.amountWithTax}} / 100, 'USD')" }
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex justify-between flex-row"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-[var(--theme-muted-foreground)]"
                            },
                            "text": "Shipping"
                          },
                          {
                            "type": "Text",
                            "text": { "expr": "({{checkout.order.shippingWithTax}} || 0) > 0 ? formatCurrency(({{checkout.order.shippingWithTax}} || 0) / 100, {{checkout.order.currencyCode}} || 'USD') : 'To be calculated'" }
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "border-t"
                        }
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex justify-between font-bold text-base flex-row"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "text": "Total"
                          },
                          {
                            "type": "Text",
                            "text": { "expr": "formatCurrency(({{checkout.order.totalWithTax}} || 0) / 100, {{checkout.order.currencyCode}} || 'USD')" }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
