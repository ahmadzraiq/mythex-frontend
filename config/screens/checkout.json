                    "type": "Heading",
                    "props": {
                      "className": "text-lg font-bold"
                    },
                    "text": "Order Summary"
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "space-y-3 max-h-64 overflow-y-auto flex flex-col"
                    },
                    "map": "collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.lines",
                    "key": "checkoutLine",
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex gap-3 text-sm items-start flex-row"
                        },
                        "children": [
                          {
                            "type": "Box",
                            "props": {
                              "className": "flex-shrink-0 w-16 h-16 rounded overflow-hidden bg-[var(--theme-hero-bg)]"
                            },
                            "condition": "context?.item?.data?.productVariant?.product?.featuredAsset?.preview",
                            "children": [
                              {
                                "type": "Image",
                                "props": {
                                  "src": "{{context.item.data.productVariant.product.featuredAsset.preview}}",
                                  "alt": "{{context.item.data.productVariant.product.name}}",
                                  "width": 64,
                                  "height": 64,
                                  "className": "w-16 h-16 object-cover"
                                }
                              }
                            ]
                          },
                          {
                            "type": "Box",
                            "props": {
                              "className": "flex-1 min-w-0 gap-0.5 flex flex-col"
                            },
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "className": "font-medium line-clamp-2"
                                },
                                "text": "{{context.item.data.productVariant.product.name}}"
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "className": "text-xs text-[var(--theme-muted-foreground)]"
                                },
                                "condition": "context?.item?.data?.productVariant?.name !== context?.item?.data?.productVariant?.product?.name",
                                "text": "{{context.item.data.productVariant.name}}"
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "className": "text-xs text-[var(--theme-muted-foreground)]"
                                },
                                "text": "Qty: {{context.item.data.quantity}}"
                              }
                            ]
                          },
                          {
                            "type": "Text",
                            "props": {
                              "className": "font-medium flex-shrink-0"
                            },
                            "text": {
                              "expr": "formatCurrency(context?.item?.data?.linePriceWithTax / 100, collections['b8c9d0e1-f2a3-4567-bcde-678901234567']?.data?.activeOrder?.currencyCode || 'USD')"
                            }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "border-t"
                    }
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "space-y-1 text-sm flex flex-col"
                    },
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex justify-between flex-row"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-[var(--theme-muted-foreground)]"
                            },
                            "text": "Subtotal"
                          },
                          {
                            "type": "Text",
                            "text": {
                              "expr": "formatCurrency((collections['b8c9d0e1-f2a3-4567-bcde-678901234567']?.data?.activeOrder?.subTotalWithTax || 0) / 100, collections['b8c9d0e1-f2a3-4567-bcde-678901234567']?.data?.activeOrder?.currencyCode || 'USD')"
                            }
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "contents"
                        },
                        "map": "collections.b8c9d0e1-f2a3-4567-bcde-678901234567.data.activeOrder.discounts",
                        "key": "discount",
                        "condition": "(collections['b8c9d0e1-f2a3-4567-bcde-678901234567']?.data?.activeOrder?.discounts?.length || 0) > 0",
                        "children": [
                          {
                            "type": "Box",
                            "props": {
                              "className": "flex justify-between text-sm text-green-600 flex-row"
                            },
                            "children": [
                              {
                                "type": "Text",
                                "text": "{{context.item.data.description}}"
                              },
                              {
                                "type": "Text",
                                "text": {
                                  "expr": "formatCurrency(context?.item?.data?.amountWithTax / 100, 'USD')"
                                }
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex justify-between flex-row"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-[var(--theme-muted-foreground)]"
                            },
                            "text": "Shipping"
                          },
                          {
                            "type": "Text",
                            "text": {
                              "expr": "(collections['b8c9d0e1-f2a3-4567-bcde-678901234567']?.data?.activeOrder?.shippingWithTax || 0) > 0 ? formatCurrency((collections['b8c9d0e1-f2a3-4567-bcde-678901234567']?.data?.activeOrder?.shippingWithTax || 0) / 100, collections['b8c9d0e1-f2a3-4567-bcde-678901234567']?.data?.activeOrder?.currencyCode || 'USD') : 'To be calculated'"
                            }
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "border-t"
                        }
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex justify-between font-bold text-base flex-row"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "text": "Total"
                          },
                          {
                            "type": "Text",
                            "text": {
                              "expr": "formatCurrency((collections['b8c9d0e1-f2a3-4567-bcde-678901234567']?.data?.activeOrder?.totalWithTax || 0) / 100, collections['b8c9d0e1-f2a3-4567-bcde-678901234567']?.data?.activeOrder?.currencyCode || 'USD')"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
