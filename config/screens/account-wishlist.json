{
  "meta": {"title": "Wishlist | SaraZ", "description": "Your saved products"},
  "state": {"wishlistShareLink": ""},
  "layout": "account",
  "content": {
    "type": "Box",
    "props": {"className": "w-full px-4 sm:px-6 py-8 md:py-12"},
    "children": [
      {
        "type": "HStack",
        "props": {"className": "justify-between items-start mb-8"},
        "children": [
          {
            "type": "VStack",
            "props": {"className": "gap-0"},
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "text-[var(--theme-shop-textMuted)] text-xs font-medium tracking-widest uppercase mb-2"
                },
                "text": "Saved"
              },
              {
                "type": "Heading",
                "props": {"size": "2xl", "className": "font-light"},
                "text": "Wishlist"
              }
            ]
          },
          {
            "type": "Pressable",
            "condition": {
              "and": [
                {"var": "account.wishlist"},
                {">": [{"var": ["account.wishlist.length", 0]}, 0]}
              ]
            },
            "props": {
              "className": "flex items-center gap-2 px-4 py-2 border border-[var(--theme-shop-border)] rounded-lg text-sm text-[var(--theme-shop-heading)] hover:border-[var(--theme-shop-button)]"
            },
            "actions": {"click": {"action": "shareWishlist"}},
            "children": [
              {
                "type": "NavIcon",
                "props": {"icon": "Share", "className": "size-4"}
              },
              {"type": "Text", "text": "Share"}
            ]
          }
        ]
      },
      {
        "type": "Box",
        "condition": {
          "and": [
            {"var": "account.wishlist"},
            {">": [{"var": ["account.wishlist.length", 0]}, 0]}
          ]
        },
        "props": {
          "className": "grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 md:gap-6 w-full"
        },
        "children": [
          {
            "type": "Box",
            "map": "account.wishlist",
            "key": "$item.id",
            "children": [
              {
                "type": "VStack",
                "props": {"className": "h-full gap-2 min-w-0"},
                "children": [
                  {"$ref": "fragments/product-card-wishlist"},
                  {
                    "type": "HStack",
                    "props": {"className": "gap-2"},
                    "children": [
                      {
                        "type": "Button",
                        "props": {
                          "size": "sm",
                          "action": "primary",
                          "className": "flex-1 !bg-[var(--theme-shop-button)] hover:!bg-[var(--theme-shop-buttonHover)]"
                        },
                        "text": "Add to Cart",
                        "actions": {
                          "click": {"action": "addToCartFromWishlist"}
                        }
                      },
                      {
                        "type": "Button",
                        "props": {
                          "size": "sm",
                          "variant": "outline",
                          "className": "shrink-0 !border-[var(--theme-shop-border)] !text-[var(--theme-shop-textMuted)] hover:!border-error-600 hover:!text-error-600"
                        },
                        "text": "Remove",
                        "actions": {"click": {"action": "removeFromWishlist"}}
                      }
                    ]
                  }
                ]
              }
            ],
            "props": {"className": "contents"}
          }
        ]
      },
      {
        "type": "Box",
        "condition": {
          "or": [
            {"!": {"var": "account.wishlist"}},
            {"==": [{"var": ["account.wishlist.length", 0]}, 0]}
          ]
        },
        "props": {
          "className": "flex flex-col items-center justify-center py-20 text-center"
        },
        "children": [
          {
            "type": "Text",
            "props": {"className": "text-4xl mb-4"},
            "text": "\u2661"
          },
          {
            "type": "Heading",
            "props": {
              "size": "lg",
              "className": "text-[var(--theme-shop-heading)] mb-2"
            },
            "text": "Your wishlist is empty"
          },
          {
            "type": "Text",
            "props": {"className": "text-[var(--theme-shop-textMuted)] mb-6"},
            "text": "Save items you love by clicking the heart icon"
          },
          {
            "type": "Button",
            "props": {
              "action": "primary",
              "className": "bg-[var(--theme-shop-button)] hover:bg-[var(--theme-shop-buttonHover)]"
            },
            "text": "Continue Shopping",
            "actions": {
              "click": {"action": "navigate", "payload": {"path": "/shop"}}
            }
          }
        ]
      }
    ]
  }
}
