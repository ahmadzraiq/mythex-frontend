{
  "meta": { "title": "Shop | NOIR & AURA", "description": "Browse our curated collection" },
  "state": {
    "store": { "products": [] }
  },
  "layout": "store",
  "initActions": [{ "action": "fetchStoreProducts" }],
  "content": {
    "type": "Box",
    "props": { "className": "mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8" },
    "children": [
      { "type": "Heading", "props": { "size": "2xl", "className": "text-2xl font-bold tracking-tight sm:text-3xl text-[#1a1a1a]" }, "text": "Shop" },
      {
        "type": "Box",
        "props": { "className": "mt-8 grid grid-cols-2 gap-4 sm:gap-6 lg:grid-cols-4" },
        "children": [
          {
            "type": "Box",
            "map": "store.products",
            "key": "product",
            "children": [{ "$ref": "fragments/product-card" }]
          }
        ]
      }
    ]
  }
}
