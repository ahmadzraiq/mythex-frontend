{
  "meta": {
    "title": "Login",
    "description": "Login to your account"
  },
  "state": {
    "form": {
      "email": "",
      "password": ""
    },
    "errors": {}
  },
  "ui": {
    "type": "Box",
    "props": {
      "className": "flex flex-col items-center justify-center min-h-screen w-full bg-background-50 p-6"
    },
    "children": [
      {
        "type": "Box",
        "props": {
          "className": "w-full max-w-md mx-auto"
        },
        "children": [
          {
            "type": "Heading",
            "props": {
              "size": "xl",
              "className": "mb-6 text-typography-900"
            },
            "text": "Login"
          },
          {
            "type": "Box",
            "condition": {
              "var": "auth.error"
            },
            "props": {
              "className": "mb-4 p-3 bg-error-100 rounded-lg"
            },
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "text-error-700 text-sm"
                },
                "text": "{{auth.error}}"
              }
            ]
          },
          {
            "type": "FormControl",
            "props": {
              "className": "mb-4"
            },
            "children": [
              {
                "type": "FormControlLabel",
                "children": [
                  {
                    "type": "FormControlLabelText",
                    "text": "Email"
                  }
                ]
              },
              {
                "type": "Input",
                "props": {
                  "placeholder": "you@example.com",
                  "value": "{{form.email}}",
                  "variant": "outline"
                },
                "actions": {
                  "change": {
                    "action": "setState",
                    "payload": {
                      "path": "form.email",
                      "value": "$event"
                    }
                  }
                }
              }
            ]
          },
          {
            "type": "FormControl",
            "props": {
              "className": "mb-6"
            },
            "children": [
              {
                "type": "FormControlLabel",
                "children": [
                  {
                    "type": "FormControlLabelText",
                    "text": "Password"
                  }
                ]
              },
              {
                "type": "Input",
                "props": {
                  "placeholder": "••••••••",
                  "value": "{{form.password}}",
                  "variant": "outline",
                  "secureTextEntry": true
                },
                "actions": {
                  "change": {
                    "action": "setState",
                    "payload": {
                      "path": "form.password",
                      "value": "$event"
                    }
                  }
                }
              }
            ]
          },
          {
            "type": "Button",
            "props": {
              "action": "primary",
              "className": "w-full mb-2"
            },
            "text": "Login",
            "actions": {
              "click": {
                "action": "login"
              }
            }
          },
          {
            "type": "Pressable",
            "props": {
              "className": "mb-4"
            },
            "actions": {
              "click": {
                "action": "navigate",
                "payload": {
                  "path": "/forgot-password"
                }
              }
            },
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "text-primary-600 text-sm"
                },
                "text": "Forgot password?"
              }
            ]
          },
          {
            "type": "HStack",
            "props": {
              "className": "justify-center"
            },
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "text-typography-600 text-sm"
                },
                "text": "Don't have an account? "
              },
              {
                "type": "Pressable",
                "actions": {
                  "click": {
                    "action": "navigate",
                    "payload": {
                      "path": "/signup"
                    }
                  }
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-primary-600 font-medium text-sm"
                    },
                    "text": "Sign up"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}