{
  "meta": {
    "title": "Login",
    "description": "Login to your account"
  },
  "state": {
    "form": {
      "email": "",
      "password": ""
    },
    "errors": {}
  },
  "ui": {
    "type": "Box",
    "props": {
      "className": "min-h-screen w-full flex flex-col md:flex-row bg-[var(--theme-content-bg)]"
    },
    "children": [
      {
        "type": "Box",
        "props": {
          "className": "hidden md:flex md:w-1/2 lg:w-3/5 relative overflow-hidden"
        },
        "children": [
          {
            "type": "NextImage",
            "props": {
              "src": "https://images.unsplash.com/photo-1483985988355-763728e1935b?w=1200&q=90",
              "alt": "Welcome",
              "fill": true,
              "className": "object-cover",
              "priority": true
            }
          },
          {
            "type": "Box",
            "props": {
              "className": "absolute inset-0 bg-gradient-to-r from-black/30 to-transparent"
            }
          },
          {
            "type": "Box",
            "props": {
              "className": "absolute bottom-12 left-12 right-12"
            },
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "text-white text-2xl font-semibold drop-shadow-md"
                },
                "text": "Welcome back"
              },
              {
                "type": "Text",
                "props": {
                  "className": "text-white/95 text-base mt-1 drop-shadow-sm"
                },
                "text": "Sign in to continue shopping"
              }
            ]
          }
        ]
      },
      {
        "type": "Box",
        "props": {
          "className": "flex-1 flex items-center justify-center p-6 md:p-12 bg-gradient-to-br from-[var(--theme-auth-bg)] via-[var(--theme-auth-bgAlt)] to-[var(--theme-auth-bg)]"
        },
        "children": [
          {
            "type": "Box",
            "props": {
              "className": "w-full max-w-md"
            },
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "md:hidden mb-8 text-center"
                },
                "children": [
                  {
                    "type": "Heading",
                    "props": {
                      "size": "xl",
                      "className": "text-[var(--theme-content-heading)]"
                    },
                    "text": "Welcome back"
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-[var(--theme-content-textMuted)] mt-1"
                    },
                    "text": "Sign in to continue"
                  }
                ]
              },
              {
                "type": "Box",
                "props": {
                  "className": "mb-4 p-3 rounded-lg bg-[var(--theme-surface)]/80 border border-[var(--theme-shop-border)]/40"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-[var(--theme-content-textMuted)] text-xs mb-1"
                    },
                    "text": "Password preview:"
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-[var(--theme-content-text)] text-sm font-mono break-all"
                    },
                    "text": "{{form.password}}"
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-[var(--theme-content-textMuted)] text-xs mt-2 mb-1"
                    },
                    "text": "Signup password (from last visit):"
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-[var(--theme-content-text)] text-sm font-mono break-all"
                    },
                    "text": "{{screens.signup.form.password}}"
                  }
                ]
              },
              {
                "type": "Card",
                "props": {
                  "className": "p-6 md:p-8 shadow-sm border-l-4 border-l-[var(--theme-shop-accent)] border border-[var(--theme-shop-border)]/60 rounded-2xl bg-[var(--theme-surface)]"
                },
                "children": [
                  {
                    "type": "Box",
                    "props": {
                      "className": "mb-6 hidden md:block"
                    },
                    "children": [
                      {
                        "type": "Heading",
                        "props": {
                          "size": "xl",
                          "className": "text-[var(--theme-shop-accent)] font-semibold"
                        },
                        "text": "Login"
                      },
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[var(--theme-content-textMuted)] text-sm mt-1"
                        },
                        "text": "Enter your credentials to continue"
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "condition": {
                      "var": "auth.error"
                    },
                    "props": {
                      "className": "mb-4 p-3 bg-error-100 rounded-lg"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-error-700 text-sm"
                        },
                        "text": "{{auth.error}}"
                      }
                    ]
                  },
                  {
                    "type": "Form",
                    "props": {
                      "defaultValues": {
                        "form": {
                          "email": "",
                          "password": ""
                        }
                      },
                      "validationRules": {
                        "form.email": {
                          "required": true,
                          "pattern": "email"
                        },
                        "form.password": {
                          "required": true
                        }
                      },
                      "submitAction": "login"
                    },
                    "children": [
                      {
                        "type": "FormInputWithLabel",
                        "props": {
                          "name": "form.email",
                          "label": "Email",
                          "placeholder": "you@example.com",
                          "variant": "outline",
                          "className": "mb-4"
                        }
                      },
                      {
                        "type": "FormInputWithLabel",
                        "props": {
                          "name": "form.password",
                          "label": "Password",
                          "placeholder": "••••••••",
                          "variant": "outline",
                          "secureTextEntry": true,
                          "className": "mb-6"
                        }
                      },
                      {
                        "type": "FormSubmitButton",
                        "props": {
                          "action": "primary",
                          "className": "w-full mb-4 py-3 rounded-lg !bg-[var(--theme-shop-accent)] hover:!bg-[var(--theme-shop-accentHover)] !text-white"
                        },
                        "text": "Login"
                      }
                    ]
                  },
                  {
                    "type": "Pressable",
                    "props": {
                      "className": "mb-6"
                    },
                    "actions": {
                      "click": {
                        "action": "navigate",
                        "payload": {
                          "path": "/forgot-password"
                        }
                      }
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[var(--theme-shop-accent)] text-sm hover:underline"
                        },
                        "text": "Forgot password?"
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "pt-4 border-t border-[var(--theme-shop-border)]/40"
                    },
                    "children": [
                      {
                        "type": "HStack",
                        "props": {
                          "className": "justify-center"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-[var(--theme-content-textMuted)] text-sm"
                            },
                            "text": "Don't have an account? "
                          },
                          {
                            "type": "Pressable",
                            "actions": {
                              "click": {
                                "action": "navigate",
                                "payload": {
                                  "path": "/signup"
                                }
                              }
                            },
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "className": "text-[var(--theme-shop-accent)] font-medium text-sm hover:underline"
                                },
                                "text": "Sign up"
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
