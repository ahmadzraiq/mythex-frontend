{
  "meta": {
    "title": "Forgot Password",
    "description": "Reset your password"
  },
  "state": {
    "form": {
      "email": ""
    },
    "errors": {}
  },
  "ui": {
    "type": "Box",
    "props": {
      "className": "flex flex-col items-center justify-center min-h-screen w-full bg-background-50 p-6"
    },
    "children": [
      {
        "type": "Box",
        "props": {
          "className": "w-full max-w-md mx-auto"
        },
        "children": [
          {
            "type": "Heading",
            "props": {
              "size": "xl",
              "className": "mb-6 text-typography-900"
            },
            "text": "Forgot Password"
          },
          {
            "type": "Text",
            "props": {
              "className": "text-typography-600 mb-6"
            },
            "text": "Enter your email to receive a reset link."
          },
          {
            "type": "Form",
            "props": {
              "defaultValues": {
                "form": {
                  "email": ""
                }
              },
              "validationRules": {
                "form.email": {
                  "required": true,
                  "pattern": "email"
                }
              },
              "submitAction": "forgotPassword"
            },
            "children": [
              {
                "type": "FormInputWithLabel",
                "props": {
                  "name": "form.email",
                  "label": "Email",
                  "placeholder": "you@example.com",
                  "variant": "outline",
                  "className": "mb-6"
                }
              },
              {
                "type": "FormSubmitButton",
                "props": {
                  "action": "primary",
                  "className": "w-full mb-4"
                },
                "text": "Send Reset Link"
              }
            ]
          },
          {
            "type": "Pressable",
            "actions": {
              "click": {
                "action": "navigate",
                "payload": {
                  "path": "/login"
                }
              }
            },
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "text-primary-600 text-sm"
                },
                "text": "Back to Login"
              }
            ]
          }
        ]
      }
    ]
  }
}