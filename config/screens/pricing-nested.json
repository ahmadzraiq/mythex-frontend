{
  "meta": {
    "title": "Nested Pricing Demo"
  },
  "state": {},
  "layout": "store",
  "content": {
    "type": "Box",
    "props": {
      "className": "w-full flex flex-col items-center py-[60px] px-[16px]"
    },
    "children": [
      {
        "type": "Text",
        "props": {
          "className": "text-[36px] font-bold text-center !text-[#3b0764] mb-[8px]"
        },
        "text": "Choose Your Plan"
      },
      {
        "type": "Text",
        "props": {
          "className": "text-[16px] font-normal text-center !text-[#6d28d9] mb-[40px]"
        },
        "text": "Nested repeat demo — inner map filters a separate flat variable by planId"
      },
      {
        "type": "Box",
        "props": {
          "className": "flex flex-row items-center justify-center gap-[12px] mb-[40px]"
        },
        "children": [
          {
            "type": "Text",
            "props": {
              "className": "text-[14px] font-medium !text-[#6d28d9]"
            },
            "text": "Monthly"
          },
          {
            "type": "Box",
            "props": {
              "className": "w-[48px] h-[26px] rounded-[13px] cursor-pointer relative",
              "style": {
                "backgroundColor": {
                  "formula": "variables['pr1c0003-0000-0000-0000-000000000003'] ? '#7c3aed' : '#d1d5db'"
                }
              }
            },
            "actions": [
              {
                "trigger": "click",
                "workflowId": "toggleNestedPricingBilling"
              }
            ],
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "w-[22px] h-[22px] rounded-[11px] bg-[#ffffff] absolute top-[2px]",
                  "style": {
                    "left": {
                      "formula": "variables['pr1c0003-0000-0000-0000-000000000003'] ? '24px' : '2px'"
                    }
                  }
                }
              }
            ]
          },
          {
            "type": "Text",
            "props": {
              "className": "text-[14px] font-medium !text-[#6d28d9]"
            },
            "text": "Yearly"
          }
        ]
      },
      {
        "type": "Box",
        "props": {
          "className": "flex flex-row items-start justify-center gap-[32px] w-full flex-wrap"
        },
        "children": [
          {
            "type": "Box",
            "map": "variables['pr1c0001-0000-0000-0000-000000000001']",
            "key": "id",
            "props": {
              "className": "contents"
            },
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "flex flex-col p-[32px] w-[340px] overflow-hidden border-[1px] border-[#ddd6fe] rounded-[16px]",
                  "style": {
                    "backgroundColor": "#ffffff",
                    "boxShadow": "0px 4px 12px 0px rgba(124, 58, 237, 0.08)"
                  }
                },
                "children": [
                  {
                    "type": "Box",
                    "condition": "context?.item?.data?.isFeatured",
                    "props": {
                      "className": "mb-[20px] w-full overflow-hidden rounded-[6px]",
                      "style": {
                        "backgroundColor": "#7c3aed"
                      }
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "py-[8px] text-[12px] font-bold text-center tracking-wide !text-[#ffffff]"
                        },
                        "text": "MOST POPULAR"
                      }
                    ]
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "mb-[20px] text-[24px] font-bold text-left !text-[#3b0764]"
                    },
                    "text": {
                      "formula": "context?.item?.data?.name"
                    }
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "items-start justify-center p-[20px] mb-[24px] w-full overflow-hidden rounded-[12px]",
                      "style": {
                        "backgroundColor": {
                          "formula": "context?.item?.data?.isFeatured ? 'linear-gradient(135deg, #7c3aed 0%, #6d28d9 100%)' : '#ede9fe'"
                        }
                      }
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[44px] font-bold text-left",
                          "style": {
                            "color": {
                              "formula": "context?.item?.data?.isFeatured ? '#ffffff' : '#3b0764'"
                            }
                          }
                        },
                        "text": {
                          "formula": "variables['pr1c0003-0000-0000-0000-000000000003'] ? '$' + toText(context?.item?.data?.yearlyPrice) : '$' + toText(context?.item?.data?.monthlyPrice)"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "className": "mt-[4px] text-[14px] font-normal text-left",
                          "style": {
                            "color": {
                              "formula": "context?.item?.data?.isFeatured ? 'rgba(255, 255, 255, 0.8)' : '#6d28d9'"
                            }
                          }
                        },
                        "text": {
                          "formula": "variables['pr1c0003-0000-0000-0000-000000000003'] ? '/year' : '/month'"
                        }
                      }
                    ]
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "mb-[28px] text-[14px] font-normal text-left leading-relaxed !text-[#6d28d9]"
                    },
                    "text": {
                      "formula": "context?.item?.data?.description"
                    }
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex flex-col gap-[12px] mb-[32px] w-full"
                    },
                    "children": [
                      {
                        "type": "Box",
                        "map": {
                          "formula": "variables['pr1c0002-0000-0000-0000-000000000002']?.[context?.item?.data?.index]"
                        },
                        "key": "id",
                        "props": {
                          "className": "contents"
                        },
                        "children": [
                          {
                            "type": "Box",
                            "props": {
                              "className": "flex flex-row items-center justify-start gap-[12px] w-full"
                            },
                            "children": [
                              {
                                "type": "Icon",
                                "props": {
                                  "icon": "lucide:check-circle",
                                  "size": 20,
                                  "color": "#7c3aed"
                                }
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "className": "text-[14px] font-normal text-left !text-[#3b0764]"
                                },
                                "text": "{{context.item.data.text}}"
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "items-center justify-center p-[14px] mb-[16px] cursor-pointer w-full overflow-hidden border-[1px] rounded-[10px]",
                      "style": {
                        "borderColor": {
                          "formula": "context?.item?.data?.isFeatured ? '#7c3aed' : '#ddd6fe'"
                        },
                        "backgroundColor": {
                          "formula": "context?.item?.data?.isFeatured ? '#7c3aed' : '#ede9fe'"
                        }
                      }
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[15px] font-semibold text-center",
                          "style": {
                            "color": {
                              "formula": "context?.item?.data?.isFeatured ? '#ffffff' : '#3b0764'"
                            }
                          }
                        },
                        "text": {
                          "formula": "context?.item?.data?.ctaText"
                        }
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex flex-row items-center justify-center gap-[8px] w-full"
                    },
                    "children": [
                      {
                        "type": "Icon",
                        "props": {
                          "icon": "lucide:check",
                          "size": 16,
                          "color": "#7c3aed"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[12px] font-normal text-center !text-[#6d28d9]"
                        },
                        "text": {
                          "formula": "context?.item?.data?.trustText"
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
