{
  "meta": {
    "title": "Order Details | SaraZ",
    "description": "View order details"
  },
  "state": {
    "order": null
  },
  "initActions": [{ "action": "fetchOrderById" }],
  "layout": "account",
  "content": {
    "type": "Box",
    "props": {
      "className": "w-full px-4 sm:px-6 py-8 md:py-12"
    },
    "children": [
      {
        "type": "Box",
        "condition": { "!": { "var": "order" } },
        "props": { "className": "text-center py-12" },
        "children": [
          { "type": "Text", "props": { "className": "text-[var(--theme-shop-textMuted)]" }, "text": "Loading order..." }
        ]
      },
      {
        "type": "Box",
        "condition": { "var": "order" },
        "props": { "className": "space-y-6" },
        "children": [
      {
        "type": "Pressable",
        "props": { "className": "text-sm text-[var(--theme-shop-textMuted)] hover:underline mb-6" },
        "actions": { "click": { "action": "navigate", "payload": { "path": "/account/orders" } } },
        "children": [{ "type": "Text", "text": "← Back to orders" }]
      },
      {
        "type": "HStack",
        "props": { "className": "justify-between items-start mb-8 flex-wrap gap-4" },
        "children": [
          {
            "type": "VStack",
            "props": { "className": "gap-1" },
            "children": [
              { "type": "Text", "props": { "className": "text-xs font-medium tracking-widest text-[var(--theme-shop-textMuted)] uppercase" }, "text": "Order" },
              { "type": "Heading", "props": { "size": "xl", "className": "font-light" }, "text": "{{order.id}}" },
              { "type": "Text", "props": { "className": "text-sm text-[var(--theme-shop-textMuted)]" }, "text": "{{order.date}}" }
            ]
          },
          {
            "type": "HStack",
            "props": { "className": "gap-4 items-center" },
            "children": [
              { "type": "Badge", "props": { "size": "sm", "className": "bg-success-100 text-success-700" }, "children": [{ "type": "BadgeText", "text": "{{order.status}}" }] },
              { "type": "Text", "props": { "className": "font-semibold" }, "text": "{{order.total}}" }
            ]
          }
        ]
      },
      {
        "type": "Box",
        "props": { "className": "grid grid-cols-1 lg:grid-cols-2 gap-8" },
        "children": [
          {
            "type": "Box",
            "props": { "className": "p-6 bg-[var(--theme-content-bg)] rounded-xl border border-[var(--theme-shop-border)]" },
            "children": [
              { "type": "Text", "props": { "className": "text-xs font-medium tracking-widest text-[var(--theme-shop-textMuted)] uppercase mb-4" }, "text": "Items" },
              {
                "type": "VStack",
                "props": { "className": "gap-4" },
                "children": [
                  {
                    "type": "Box",
                    "map": "order.items",
                    "key": "$item.product.name",
                    "props": { "className": "flex gap-4" },
                    "children": [
                      { "type": "Box", "props": { "className": "w-16 h-16 bg-[var(--theme-content-bgAlt)] rounded-lg shrink-0 overflow-hidden" }, "children": [{ "type": "NextImage", "props": { "src": "{{$item.product.image}}", "alt": "{{$item.product.name}}", "width": 64, "height": 64, "className": "object-cover w-full h-full" } }] },
                      { "type": "Box", "props": { "className": "flex-1 min-w-0" }, "children": [
                        { "type": "Text", "props": { "className": "font-medium" }, "text": "{{$item.product.name}}" },
                        { "type": "Text", "props": { "className": "text-sm text-[var(--theme-shop-textMuted)]" }, "text": "{{$item.variant}} × {{$item.quantity}}" },
                        { "type": "Text", "props": { "className": "font-semibold mt-1" }, "text": "{{$item.product.price}}" }
                      ]}
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Box",
            "props": { "className": "p-6 bg-[var(--theme-content-bg)] rounded-xl border border-[var(--theme-shop-border)]" },
            "children": [
              { "type": "Text", "props": { "className": "text-xs font-medium tracking-widest text-[var(--theme-shop-textMuted)] uppercase mb-4" }, "text": "Shipping address" },
              { "type": "Text", "props": { "className": "text-[var(--theme-shop-heading)]" }, "text": "{{order.shippingAddress}}" },
              { "type": "Divider", "props": { "className": "my-4" } },
              { "type": "HStack", "props": { "className": "justify-between text-sm mb-2" }, "children": [{ "type": "Text", "text": "Subtotal" }, { "type": "Text", "text": "{{order.subtotal}}" }] },
              { "type": "HStack", "props": { "className": "justify-between text-sm mb-2" }, "children": [{ "type": "Text", "text": "Shipping" }, { "type": "Text", "text": "{{order.shipping}}" }] },
              { "type": "HStack", "props": { "className": "justify-between font-semibold mt-4" }, "children": [{ "type": "Text", "text": "Total" }, { "type": "Text", "text": "{{order.total}}" }] }
            ]
          }
        ]
      },
      {
        "type": "HStack",
        "props": { "className": "gap-4 mt-8" },
        "children": [
          { "type": "Button", "props": { "variant": "outline", "size": "sm" }, "text": "Track order", "actions": { "click": { "action": "log", "payload": { "message": "Track order" } } } },
          { "type": "Button", "props": { "variant": "outline", "size": "sm" }, "text": "Request return", "actions": { "click": { "action": "navigate", "payload": { "path": "/account/returns" } } } }
        ]
      }
        ]
      }
    ]
  }
}
