{
  "meta": {
    "title": "Dashboard",
    "description": "E-commerce Dashboard"
  },
  "state": {},
  "layout": "authenticated",
  "content": {
    "type": "Box",
    "props": {
      "className": "flex-1 min-h-0 flex flex-col overflow-hidden"
    },
    "children": [
      {
        "type": "Box",
        "props": {
          "className": "p-6 flex-1 overflow-auto"
        },
        "children": [
          {
            "type": "HStack",
            "props": {
              "className": "justify-between items-center mb-6"
            },
            "children": [
              {
                "type": "Heading",
                "props": {
                  "size": "xl",
                  "className": "text-typography-900"
                },
                "text": "Overview"
              },
              {
                "type": "Pressable",
                "props": {
                  "className": "py-2 px-4 rounded-lg bg-primary-600"
                },
                "actions": {
                  "click": {
                    "action": "navigate",
                    "payload": {
                      "path": "/dashboard/products"
                    }
                  }
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-typography-0 font-medium"
                    },
                    "text": "+ Add Product"
                  }
                ]
              }
            ]
          },
          {
            "type": "Box",
            "condition": {
              "var": "products.loading"
            },
            "props": {
              "className": "flex justify-center py-12"
            },
            "children": [
              {
                "type": "Spinner",
                "props": {
                  "size": "large"
                }
              }
            ]
          },
          {
            "type": "Box",
            "condition": {
              "!": {
                "var": "products.loading"
              }
            },
            "props": {
              "className": "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4"
            },
            "children": [
              {
                "type": "Card",
                "map": "products.list",
                "key": "product",
                "props": {
                  "className": "p-4"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "font-semibold text-typography-900 mb-2"
                    },
                    "text": "{{$item.name}}"
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-primary-600 font-bold mb-1"
                    },
                    "text": "${{$item.price}}"
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-typography-600 text-sm"
                    },
                    "text": "{{$item.category}}"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "initActions": [
    {
      "action": "fetchProducts"
    }
  ]
}
