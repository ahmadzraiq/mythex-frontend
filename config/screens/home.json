                    "type": "Box",
                    "props": {
                      "className": "flex flex-col items-center gap-3"
                    },
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": "w-12 h-12 mx-auto bg-[#7c3aed]/10 rounded-full flex items-center justify-center"
                        },
                        "children": [
                          {
                            "type": "NavIcon",
                            "props": {
                              "icon": "Check",
                              "size": "sm",
                              "className": "text-[var(--theme-foreground)]"
                            }
                          }
                        ]
                      },
                      {
                        "type": "Heading",
                        "props": {
                          "className": "text-xl font-semibold text-[var(--theme-foreground)] text-center"
                        },
                        "text": "High Quality"
                      },
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[var(--theme-muted-foreground)] text-center"
                        },
                        "text": "Premium products carefully selected for you"
                      }
                    ]
