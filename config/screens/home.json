{
  "meta": { "title": "Vendure Store - Your One-Stop Shop" },
  "state": {},
  "layout": "store",
  "initActions": [
    { "action": "fetchNavCollections" },
    { "action": "fetchFeaturedProducts" }
  ],
  "content": {
    "type": "Box",
    "props": { "className": "w-full min-h-screen" },
    "children": [

      {
        "type": "Box",
        "props": { "className": "w-full relative bg-slate-100 dark:bg-slate-900 overflow-hidden" },
        "children": [
          {
            "type": "Box",
            "props": { "className": "w-full max-w-screen-xl mx-auto px-4 py-24 md:py-32" },
            "children": [
              {
                "type": "Box",
                "props": { "className": "w-full max-w-4xl mx-auto flex flex-col items-center gap-8" },
                "children": [
                  {
                    "type": "Heading",
                    "props": { "className": "text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight text-center text-slate-900 dark:text-slate-50" },
                    "text": "E-Commerce Starter Template"
                  },
                  {
                    "type": "Text",
                    "props": { "className": "text-xl md:text-2xl text-slate-500 dark:text-slate-400 max-w-2xl text-center" },
                    "text": "Powered by Vendure and Next.js"
                  },
                  {
                    "type": "Box",
                    "props": { "className": "flex flex-col sm:flex-row gap-4 justify-center items-center w-full pt-4" },
                    "children": [
                      {
                        "type": "Pressable",
                        "props": { "className": "inline-flex items-center justify-center min-w-[200px] h-11 px-8 rounded-lg bg-slate-900 dark:bg-slate-50 hover:bg-slate-800 dark:hover:bg-slate-200" },
                        "actions": { "click": { "action": "navigate", "payload": { "path": "/search" } } },
                        "children": [
                          { "type": "Text", "props": { "className": "text-slate-50 dark:text-slate-900 text-base font-semibold" }, "text": "Shop Now" }
                        ]
                      },
                      {
                        "type": "Pressable",
                        "props": { "className": "inline-flex flex-row items-center justify-center gap-2 min-w-[200px] h-11 px-8 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-transparent hover:bg-slate-50 dark:hover:bg-slate-800" },
                        "actions": { "click": { "action": "navigate", "payload": { "path": "/search" } } },
                        "children": [
                          { "type": "Text", "props": { "className": "text-slate-900 dark:text-slate-50 text-base font-semibold" }, "text": "View on GitHub" }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },

      {
        "type": "Box",
        "props": { "className": "py-12 md:py-16" },
        "children": [
          {
            "type": "Box",
            "props": { "className": "container mx-auto px-8" },
            "children": [
              {
                "type": "Heading",
                "props": { "className": "text-3xl md:text-4xl font-bold mb-8 text-slate-900 dark:text-slate-50" },
                "text": "Featured Products"
              },
              {
                "type": "Carousel",
                "props": { "loop": true, "align": "start", "showArrows": true },
                "children": [
                  {
                    "type": "CarouselSlide",
                    "map": "featured.products",
                    "props": { "className": "basis-full sm:basis-1/2 lg:basis-1/3 xl:basis-1/4" },
                    "children": [
                      {
                        "type": "Pressable",
                        "props": { "className": "group w-full text-left bg-white dark:bg-slate-800 rounded-lg overflow-hidden border border-slate-200 dark:border-slate-700 hover:shadow-lg transition-shadow duration-150" },
                        "actions": { "click": { "action": "navigate", "payload": { "routeConfig": "product", "slug": { "var": "$item.slug" } } } },
                        "children": [
                          {
                            "type": "Box",
                            "props": { "className": "aspect-square relative overflow-hidden bg-slate-100 dark:bg-slate-700" },
                            "children": [
                              {
                                "type": "NextImage",
                                "props": { "src": "{{$item.productAsset.preview}}", "alt": "{{$item.productName}}", "fill": true, "className": "object-cover group-hover:scale-105 transition-transform duration-300" },
                                "condition": { "!!": [{ "var": "$item.productAsset.preview" }] }
                              },
                              {
                                "type": "Box",
                                "props": { "className": "w-full h-full flex items-center justify-center" },
                                "condition": { "!": [{ "var": "$item.productAsset.preview" }] },
                                "children": [
                                  { "type": "Text", "props": { "className": "text-slate-400 dark:text-slate-500 text-sm" }, "text": "No image" }
                                ]
                              }
                            ]
                          },
                          {
                            "type": "Box",
                            "props": { "className": "p-4 space-y-2" },
                            "children": [
                              {
                                "type": "Heading",
                                "props": { "size": "sm", "className": "font-medium text-slate-900 dark:text-slate-100 line-clamp-2 group-hover:text-slate-600 dark:group-hover:text-slate-300 transition-colors" },
                                "text": "{{$item.productName}}"
                              },
                              {
                                "type": "Text",
                                "props": { "className": "text-lg font-bold text-slate-900 dark:text-slate-100" },
                                "text": {
                                  "expr": {
                                    "if": [
                                      { "==": [{ "var": "$item.priceWithTax.__typename" }, "SinglePrice"] },
                                      { "formatCurrency": [{ "var": "$item.priceWithTax.value" }, { "var": "$item.currencyCode" }] },
                                      { "cat": ["from ", { "formatCurrency": [{ "var": "$item.priceWithTax.min" }, { "var": "$item.currencyCode" }] }] }
                                    ]
                                  }
                                }
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },

      {
        "type": "Box",
        "props": { "className": "w-full py-16 bg-slate-50 dark:bg-slate-900/50" },
        "children": [
          {
            "type": "Box",
            "props": { "className": "w-full max-w-screen-xl mx-auto px-4" },
            "children": [
              {
                "type": "Box",
                "props": { "className": "w-full grid grid-cols-1 md:grid-cols-3 gap-8" },
                "children": [
                  {
                    "type": "Box",
                    "props": { "className": "flex flex-col items-center gap-3" },
                    "children": [
                      {
                        "type": "Box",
                        "props": { "className": "w-12 h-12 mx-auto bg-slate-900/10 dark:bg-slate-100/10 rounded-full flex items-center justify-center" },
                        "children": [
                          { "type": "NavIcon", "props": { "icon": "Check", "size": "sm", "className": "text-slate-900 dark:text-slate-100" } }
                        ]
                      },
                      { "type": "Heading", "props": { "className": "text-xl font-semibold text-slate-900 dark:text-slate-100 text-center" }, "text": "High Quality" },
                      { "type": "Text", "props": { "className": "text-slate-500 dark:text-slate-400 text-center" }, "text": "Premium products carefully selected for you" }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": { "className": "flex flex-col items-center gap-3" },
                    "children": [
                      {
                        "type": "Box",
                        "props": { "className": "w-12 h-12 mx-auto bg-slate-900/10 dark:bg-slate-100/10 rounded-full flex items-center justify-center" },
                        "children": [
                          { "type": "NavIcon", "props": { "icon": "CircleDollarSign", "size": "sm", "className": "text-slate-900 dark:text-slate-100" } }
                        ]
                      },
                      { "type": "Heading", "props": { "className": "text-xl font-semibold text-slate-900 dark:text-slate-100 text-center" }, "text": "Best Prices" },
                      { "type": "Text", "props": { "className": "text-slate-500 dark:text-slate-400 text-center" }, "text": "Competitive pricing on all our products" }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": { "className": "flex flex-col items-center gap-3" },
                    "children": [
                      {
                        "type": "Box",
                        "props": { "className": "w-12 h-12 mx-auto bg-slate-900/10 dark:bg-slate-100/10 rounded-full flex items-center justify-center" },
                        "children": [
                          { "type": "NavIcon", "props": { "icon": "Zap", "size": "sm", "className": "text-slate-900 dark:text-slate-100" } }
                        ]
                      },
                      { "type": "Heading", "props": { "className": "text-xl font-semibold text-slate-900 dark:text-slate-100 text-center" }, "text": "Fast Delivery" },
                      { "type": "Text", "props": { "className": "text-slate-500 dark:text-slate-400 text-center" }, "text": "Quick and reliable shipping worldwide" }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }

    ]
  }
}
