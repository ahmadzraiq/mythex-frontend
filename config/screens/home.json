{
  "meta": {
    "title": "Vendure Store - Your One-Stop Shop"
  },
  "state": {},
  "layout": "store",
  "initActions": [],
  "content": {
    "type": "Box",
    "props": {
      "className": "w-full min-h-screen"
    },
    "children": [
      {
        "type": "Box",
        "props": {
          "className": "w-full relative bg-[var(--theme-hero-bg)] overflow-hidden"
        },
        "children": [
          {
            "type": "Box",
            "props": {
              "className": "w-full max-w-screen-xl mx-auto px-4 py-24 md:py-32"
            },
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "w-full max-w-4xl mx-auto flex flex-col items-center gap-8"
                },
                "children": [
                  {
                    "type": "Heading",
                    "props": {
                      "className": "text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight text-center text-[var(--theme-foreground)]"
                    },
                    "text": "E-Commerce Starter Template"
                  },
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-xl md:text-2xl text-[var(--theme-muted-foreground)] max-w-2xl text-center"
                    },
                    "text": "Powered by Vendure and Next.js"
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex flex-col sm:flex-row gap-4 justify-center items-center w-full pt-4"
                    },
                    "children": [
                      {
                        "type": "Pressable",
                        "props": {
                          "className": "inline-flex items-center justify-center min-w-[200px] h-11 px-8 rounded-lg bg-[var(--theme-shop-button)] hover:bg-[var(--theme-shop-buttonHover)]"
                        },
                        "actions": {
                          "click": {
                            "action": "navigate",
                            "payload": {
                              "path": "/search"
                            }
                          }
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-[var(--theme-shop-buttonText)] text-base font-semibold"
                            },
                            "text": "Shop Now"
                          }
                        ]
                      },
                      {
                        "type": "Pressable",
                        "props": {
                          "className": "inline-flex flex-row items-center justify-center gap-2 min-w-[200px] h-11 px-8 rounded-lg border border-[var(--theme-border)] bg-[var(--theme-content-bg)] hover:bg-[var(--theme-hero-bg)]"
                        },
                        "actions": {
                          "click": {
                            "action": "navigate",
                            "payload": {
                              "path": "/search"
                            }
                          }
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-[var(--theme-foreground)] text-base font-semibold"
                            },
                            "text": "View on GitHub"
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "Box",
        "props": {
          "className": "py-12 md:py-16"
        },
        "children": [
          {
            "type": "Box",
            "props": {
              "className": "container mx-auto px-8"
            },
            "children": [
              {
                "type": "Heading",
                "props": {
                  "className": "text-3xl md:text-4xl font-bold mb-8 text-[var(--theme-foreground)]"
                },
                "text": "Featured Products"
              },
              {
                "type": "Carousel",
                "props": {
                  "loop": true,
                  "align": "start",
                  "showArrows": true
                },
                "children": [
                  {
                    "type": "CarouselSlide",
                    "map": "collections.c3d4e5f6-a7b8-9012-cdef-123456789012.data.search.items",
                    "props": {
                      "className": "basis-full sm:basis-1/2 lg:basis-1/3 xl:basis-1/4"
                    },
                    "children": [
                      {
                        "type": "Pressable",
                        "props": {
                          "className": "group w-full text-left bg-[var(--theme-content-bg)] rounded-lg overflow-hidden border border-[var(--theme-border)] hover:shadow-lg transition-shadow duration-150"
                        },
                        "actions": {
                          "click": {
                            "action": "navigate",
                            "payload": {
                              "routeConfig": "product",
                              "slug": "{{context.item.slug}}"
                            }
                          }
                        },
                        "children": [
                          {
                            "type": "Box",
                            "props": {
                              "className": "aspect-square relative overflow-hidden bg-[var(--theme-hero-bg)]"
                            },
                            "children": [
                              {
                                "type": "NextImage",
                                "props": {
                                  "src": "{{context.item.productAsset.preview}}",
                                  "alt": "{{context.item.productName}}",
                                  "fill": true,
                                  "className": "object-cover group-hover:scale-105 transition-transform duration-300"
                                },
                                "condition": "{{context.item.productAsset.preview}}"
                              },
                              {
                                "type": "Box",
                                "props": {
                                  "className": "w-full h-full flex items-center justify-center"
                                },
                                "condition": "!{{context.item.productAsset.preview}}",
                                "children": [
                                  {
                                    "type": "Text",
                                    "props": {
                                      "className": "text-[var(--theme-muted-foreground)] text-sm"
                                    },
                                    "text": "No image"
                                  }
                                ]
                              }
                            ]
                          },
                          {
                            "type": "Box",
                            "props": {
                              "className": "p-4 space-y-2"
                            },
                            "children": [
                              {
                                "type": "Heading",
                                "props": {
                                  "size": "sm",
                                  "className": "font-medium text-[var(--theme-foreground)] line-clamp-2 hover:opacity-70 transition-opacity"
                                },
                                "text": "{{context.item.productName}}"
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "className": "text-lg font-bold text-[var(--theme-foreground)]"
                                },
                                "text": {
                                  "expr": "{{context.item.priceWithTax.__typename}} === 'SinglePrice' ? formatCurrency({{context.item.priceWithTax.value}}, {{context.item.currencyCode}}) : 'from ' + formatCurrency({{context.item.priceWithTax.min}}, {{context.item.currencyCode}})"
                                }
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "Box",
        "props": {
          "className": "w-full py-16 bg-[var(--theme-hero-bg)]"
        },
        "children": [
