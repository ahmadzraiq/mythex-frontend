{
  "meta": {
    "title": "My Orders"
  },
  "state": {
    "currentPage": 1
  },
  "layout": "account",
  "content": {
    "type": "Box",
    "children": [
      {
        "type": "Heading",
        "props": {
          "className": "text-3xl font-bold mb-6"
        },
        "text": "My Orders"
      },
      {
        "type": "Box",
        "props": {
          "className": "text-center py-12"
        },
        "condition": "(collections['c5d6e7f8-a9b0-1234-cdef-345678901234']?.data?.activeCustomer?.orders?.items?.length || 0) === 0",
        "children": [
          {
            "type": "Text",
            "props": {
              "className": "text-[var(--theme-muted-foreground)]"
            },
            "text": "You haven't placed any orders yet."
          }
        ]
      },
      {
        "type": "Box",
        "props": {
          "className": "border rounded-lg overflow-hidden"
        },
        "condition": "(collections['c5d6e7f8-a9b0-1234-cdef-345678901234']?.data?.activeCustomer?.orders?.items?.length || 0) > 0",
        "children": [
          {
            "type": "Box",
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "bg-[var(--theme-muted)]"
                },
                "children": [
                  {
                    "type": "Box",
                    "children": [
                      {
                        "type": "Box",
                        "children": [
                          {
                            "type": "Text",
                            "text": "Order Number"
                          }
                        ],
                        "props": {
                          "className": "font-medium text-sm px-3 py-2 flex-1"
                        }
                      },
                      {
                        "type": "Box",
                        "children": [
                          {
                            "type": "Text",
                            "text": "Date"
                          }
                        ],
                        "props": {
                          "className": "font-medium text-sm px-3 py-2 flex-1"
                        }
                      },
                      {
                        "type": "Box",
                        "children": [
                          {
                            "type": "Text",
                            "text": "Status"
                          }
                        ],
                        "props": {
                          "className": "font-medium text-sm px-3 py-2 flex-1"
                        }
                      },
                      {
                        "type": "Box",
                        "children": [
                          {
                            "type": "Text",
                            "text": "Items"
                          }
                        ],
                        "props": {
                          "className": "font-medium text-sm px-3 py-2 flex-1"
                        }
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "text-right font-medium text-sm px-3 py-2 flex-1"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "text": "Total"
                          }
                        ]
                      }
                    ],
                    "props": {
                      "className": "flex flex-row"
                    }
                  }
                ]
              },
              {
                "type": "Box",
                "children": [
                  {
                    "type": "Box",
                    "map": "collections.c5d6e7f8-a9b0-1234-cdef-345678901234.data.activeCustomer.orders.items",
                    "key": "orderRow",
                    "props": {
                      "className": "hover:bg-[var(--theme-muted)] flex flex-row"
                    },
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": "font-medium text-sm px-3 py-3 flex-1"
                        },
                        "children": [
                          {
                            "type": "Box",
                            "props": {
                              "className": "inline-flex items-center gap-1 px-3 py-1.5 border border-[var(--theme-border)] rounded-md text-sm hover:bg-[var(--theme-muted)] transition-colors"
                            },
                            "actions": [
                              {
                                "action": "476b28a3-7e9c-44f9-8913-a6f8c4904630"
                              }
                            ],
                            "children": [
                              {
                                "type": "Text",
                                "text": "{{context.item.data.code}}"
                              },
                              {
                                "type": "Icon",
                                "props": {
                                  "icon": "lucide:share",
                                  "className": "h-3 w-3"
                                }
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "children": [
                          {
                            "type": "Text",
                            "text": "{{context.item.data.createdAt}}"
                          }
                        ],
                        "props": {
                          "className": "text-sm px-3 py-3 flex-1"
                        }
                      },
                      {
                        "type": "Box",
                        "children": [
                          {
                            "type": "Box",
                            "props": {
                              "className": "text-xs font-medium"
                            },
                            "children": [
                              {
                                "type": "Text",
                                "text": "{{context.item.data.state}}"
                              }
                            ]
                          }
                        ],
                        "props": {
                          "className": "text-sm px-3 py-3 flex-1"
                        }
                      },
                      {
                        "type": "Box",
                        "children": [
                          {
                            "type": "Text",
                            "text": "{{context.item.data.lines.length}} item(s)"
                          }
                        ],
                        "props": {
                          "className": "text-sm px-3 py-3 flex-1"
                        }
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "text-right text-sm px-3 py-3 flex-1"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "font-medium"
                            },
                            "text": {
                              "expr": "formatCurrency(context?.item?.data?.totalWithTax / 100, context?.item?.data?.currencyCode)"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ],
            "props": {
              "className": ""
            }
          }
        ]
      }
    ]
  }
}
