{
  "meta": {
    "title": "My Orders"
  },
  "state": {
    "orders": [],
    "currentPage": 1
  },
  "layout": "account",
  "initActions": [
    {
      "action": "fetchNavCollections"
    },
    {
      "action": "fetchCustomerOrders"
    }
  ],
  "content": {
    "type": "Box",
    "children": [
      {
        "type": "Heading",
        "props": {
          "className": "text-3xl font-bold mb-6"
        },
        "text": "My Orders"
      },
      {
        "type": "Box",
        "props": {
          "className": "text-center py-12"
        },
        "condition": "({{orders.length}} || 0) === 0",
        "children": [
          {
            "type": "Text",
            "props": {
              "className": "text-[var(--theme-muted-foreground)]"
            },
            "text": "You haven't placed any orders yet."
          }
        ]
      },
      {
        "type": "Box",
        "props": {
          "className": "border rounded-lg overflow-hidden"
        },
        "condition": "{{orders.length}} > 0",
        "children": [
          {
            "type": "Table",
            "children": [
              {
                "type": "TableHeader",
                "props": {
                  "className": "bg-[var(--theme-hero-bg)]"
                },
                "children": [
                  {
                    "type": "TableRow",
                    "children": [
                      {
                        "type": "TableHead",
                        "children": [
                          {
                            "type": "Text",
                            "text": "Order Number"
                          }
                        ]
                      },
                      {
                        "type": "TableHead",
                        "children": [
                          {
                            "type": "Text",
                            "text": "Date"
                          }
                        ]
                      },
                      {
                        "type": "TableHead",
                        "children": [
                          {
                            "type": "Text",
                            "text": "Status"
                          }
                        ]
                      },
                      {
                        "type": "TableHead",
                        "children": [
                          {
                            "type": "Text",
                            "text": "Items"
                          }
                        ]
                      },
                      {
                        "type": "TableHead",
                        "props": {
                          "className": "text-right"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "text": "Total"
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "TableBody",
                "children": [
                  {
                    "type": "TableRow",
                    "map": "orders",
                    "key": "orderRow",
                    "props": {
                      "className": "hover:bg-[var(--theme-hero-bg)]"
                    },
                    "children": [
                      {
                        "type": "TableData",
                        "props": {
                          "className": "font-medium"
                        },
                        "children": [
                          {
                            "type": "Pressable",
                            "props": {
                              "className": "inline-flex items-center gap-1 px-3 py-1.5 border border-[var(--theme-border)] rounded-md text-sm hover:bg-[var(--theme-hero-bg)] transition-colors"
                            },
                            "actions": {
                              "click": {
                                "action": "navigate",
                                "payload": {
                                  "routeConfig": "order-detail",
                                  "slug": "{{$item.code}}"
                                }
                              }
                            },
                            "children": [
                              {
                                "type": "Text",
                                "text": "{{$item.code}}"
                              },
                              {
                                "type": "NavIcon",
                                "props": {
                                  "icon": "Share",
                                  "className": "h-3 w-3"
                                }
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "TableData",
                        "children": [
                          {
                            "type": "Text",
                            "text": "{{$item.createdAt}}"
                          }
                        ]
                      },
                      {
                        "type": "TableData",
                        "children": [
                          {
                            "type": "Badge",
                            "props": {
                              "className": "text-xs font-medium"
                            },
                            "children": [
                              {
                                "type": "BadgeText",
                                "text": "{{$item.state}}"
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "TableData",
                        "children": [
                          {
                            "type": "Text",
                            "text": "{{$item.lines.length}} item(s)"
                          }
                        ]
                      },
                      {
                        "type": "TableData",
                        "props": {
                          "className": "text-right"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "font-medium"
                            },
                            "text": {
                              "expr": "formatCurrency({{$item.totalWithTax}} / 100, {{$item.currencyCode}})"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
