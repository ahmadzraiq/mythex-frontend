{
  "meta": {
    "title": "My Orders"
  },
  "state": {
    "currentPage": 1
  },
  "layout": "account",
  "content": {
    "type": "Box",
    "children": [
      {
        "type": "Text",
        "props": {
          "className": "text-[30px] font-bold mb-[24px]"
        },
        "text": "My Orders"
      },
      {
        "type": "Box",
        "props": {
          "className": "text-center py-[48px]"
        },
        "condition": "(collections['c5d6e7f8-a9b0-1234-cdef-345678901234']?.activeCustomer?.orders?.items?.length || 0) === 0",
        "children": [
          {
            "type": "Text",
            "props": {
              "className": "text-[var(--theme-muted-foreground)]"
            },
            "text": "You haven't placed any orders yet."
          }
        ]
      },
      {
        "type": "Box",
        "props": {
          "className": "border-[1px] rounded-[8px] overflow-hidden"
        },
        "condition": "(collections['c5d6e7f8-a9b0-1234-cdef-345678901234']?.activeCustomer?.orders?.items?.length || 0) > 0",
        "children": [
          {
            "type": "Box",
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "bg-[var(--theme-muted)]"
                },
                "children": [
                  {
                    "type": "Box",
                    "children": [
                      {
                        "type": "Box",
                        "children": [
                          {
                            "type": "Text",
                            "text": "Order Number"
                          }
                        ],
                        "props": {
                          "className": "font-medium text-[14px] px-[12px] py-[8px] flex-1"
                        }
                      },
                      {
                        "type": "Box",
                        "children": [
                          {
                            "type": "Text",
                            "text": "Date"
                          }
                        ],
                        "props": {
                          "className": "font-medium text-[14px] px-[12px] py-[8px] flex-1"
                        }
                      },
                      {
                        "type": "Box",
                        "children": [
                          {
                            "type": "Text",
                            "text": "Status"
                          }
                        ],
                        "props": {
                          "className": "font-medium text-[14px] px-[12px] py-[8px] flex-1"
                        }
                      },
                      {
                        "type": "Box",
                        "children": [
                          {
                            "type": "Text",
                            "text": "Items"
                          }
                        ],
                        "props": {
                          "className": "font-medium text-[14px] px-[12px] py-[8px] flex-1"
                        }
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "text-right font-medium text-[14px] px-[12px] py-[8px] flex-1"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "text": "Total"
                          }
                        ]
                      }
                    ],
                    "props": {
                      "className": "flex flex-row"
                    }
                  }
                ]
              },
              {
                "type": "Box",
                "children": [
                  {
                    "type": "Box",
                    "map": "collections.c5d6e7f8-a9b0-1234-cdef-345678901234.activeCustomer.orders.items",
                    "key": "orderRow",
                    "props": {
                      "className": "hover:bg-[var(--theme-muted)] flex flex-row"
                    },
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": "font-medium text-[14px] px-[12px] py-[12px] flex-1"
                        },
                        "children": [
                          {
                            "type": "Box",
                            "props": {
                              "className": "inline-flex items-center gap-[4px] px-[12px] py-[6px] border-[1px] border-[var(--theme-border)] rounded-[6px] text-[14px] hover:bg-[var(--theme-muted)]"
                            },
                            "actions": [
                              {
                                "action": "476b28a3-7e9c-44f9-8913-a6f8c4904630"
                              }
                            ],
                            "children": [
                              {
                                "type": "Text",
                                "text": "{{context.item.data.code}}"
                              },
                              {
                                "type": "Icon",
                                "props": {
                                  "icon": "lucide:share",
                                  "className": "h-[12px] w-[12px]"
                                }
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "children": [
                          {
                            "type": "Text",
                            "text": "{{context.item.data.createdAt}}"
                          }
                        ],
                        "props": {
                          "className": "text-[14px] px-[12px] py-[12px] flex-1"
                        }
                      },
                      {
                        "type": "Box",
                        "children": [
                          {
                            "type": "Box",
                            "props": {
                              "className": "text-[12px] font-medium"
                            },
                            "children": [
                              {
                                "type": "Text",
                                "text": "{{context.item.data.state}}"
                              }
                            ]
                          }
                        ],
                        "props": {
                          "className": "text-[14px] px-[12px] py-[12px] flex-1"
                        }
                      },
                      {
                        "type": "Box",
                        "children": [
                          {
                            "type": "Text",
                            "text": "{{context.item.data.lines.length}} item(s)"
                          }
                        ],
                        "props": {
                          "className": "text-[14px] px-[12px] py-[12px] flex-1"
                        }
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "text-right text-[14px] px-[12px] py-[12px] flex-1"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "font-medium"
                            },
                            "text": {
                              "formula": "formatCurrency(context?.item?.data?.totalWithTax / 100, context?.item?.data?.currencyCode)"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ],
            "props": {
              "className": ""
            }
          }
        ]
      }
    ]
  }
}
