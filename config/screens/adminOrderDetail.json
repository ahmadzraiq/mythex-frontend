{
  "layout": "admin",
  "content": {
    "type": "Box",
    "props": {
      "className": "flex flex-col gap-[24px] w-full"
    },
    "children": [
      {
        "type": "Box",
        "props": {
          "className": "flex items-center gap-[12px] flex-row"
        },
        "children": [
          {
            "type": "Box",
            "props": {
              "className": "flex items-center gap-[6px] h-[34px] px-[12px] rounded-[6px] bg-[var(--theme-admin-surface)] border border-[var(--theme-admin-border)] text-[var(--theme-admin-muted)] hover:bg-[var(--theme-admin-surface-hover)] cursor-pointer transition-colors flex-row"
            },
            "actions": [
              {
                "action": "admin-nav-orders"
              }
            ],
            "children": [
              {
                "type": "Icon",
                "props": {
                  "icon": "lucide:arrow-left",
                  "size": 14
                }
              },
              {
                "type": "Text",
                "props": {
                  "className": "text-[13px]"
                },
                "text": "Back to Orders"
              }
            ]
          },
          {
            "type": "Text",
            "props": {
              "className": "text-[22px] font-bold text-white"
            },
            "text": {
              "formula": "concat('Order ', collections['ad000003-0000-0000-0000-000000000003']?.order?.code || '')"
            }
          }
        ],
        "_group": "Page Header"
      },
      {
        "type": "Box",
        "props": {
          "className": "grid grid-cols-1 lg:grid-cols-3 gap-[20px]"
        },
        "children": [
          {
            "type": "Box",
            "props": {
              "className": "lg:col-span-2 flex flex-col gap-[20px]"
            },
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "bg-[var(--theme-admin-surface)] rounded-[12px] border border-[var(--theme-admin-border)] overflow-hidden"
                },
                "children": [
                  {
                    "type": "Box",
                    "props": {
                      "className": "px-[20px] py-[14px] border-b border-[var(--theme-admin-border)]"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[15px] font-semibold text-white"
                        },
                        "text": "Order Lines"
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex flex-col divide-y divide-[var(--theme-admin-sidebar)]"
                    },
                    "map": "collections.ad000003-0000-0000-0000-000000000003.order.lines",
                    "key": "order-line",
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex flex-row items-center gap-[16px] p-[16px]"
                        },
                        "children": [
                          {
                            "type": "Image",
                            "props": {
                              "src": "{{context.item.data.image_url}}",
                              "alt": "{{context.item.data.product_name}}",
                              "width": 56,
                              "height": 56,
                              "className": "w-[56px] h-[56px] rounded-[8px] object-cover border border-[var(--theme-admin-border)] flex-shrink-0"
                            }
                          },
                          {
                            "type": "Box",
                            "props": {
                              "className": "flex-1 min-w-0"
                            },
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "className": "text-[14px] font-medium text-white truncate"
                                },
                                "text": "{{context.item.data.product_name}}"
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "className": "text-[12px] text-[var(--theme-admin-label)] mt-[2px]"
                                },
                                "text": {
                                  "formula": "concat(context.item.data.variant_name || '', ' · SKU: ', context.item.data.sku || '')"
                                }
                              },
                              {
                                "type": "Text",
                                "props": {
                                  "className": "text-[12px] text-[var(--theme-admin-muted)] mt-[4px]"
                                },
                                "text": {
                                  "formula": "concat(formatCurrency(context.item.data.unit_price || 0, 'USD'), ' × ', String(context.item.data.quantity || 0))"
                                }
                              }
                            ]
                          },
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-[14px] font-semibold text-white flex-shrink-0"
                            },
                            "text": {
                              "formula": "formatCurrency(context.item.data.line_total || 0, 'USD')"
                            }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex flex-col items-center justify-center py-[40px] gap-[8px]"
                    },
                    "condition": "!(collections['ad000003-0000-0000-0000-000000000003']?.order?.lines?.length > 0)",
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[14px] text-[var(--theme-admin-label)]"
                        },
                        "text": "No order lines"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Box",
            "props": {
              "className": "flex flex-col gap-[16px]"
            },
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "bg-[var(--theme-admin-surface)] rounded-[12px] border border-[var(--theme-admin-border)] p-[20px] flex flex-col gap-[16px]"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-[15px] font-semibold text-white"
                    },
                    "text": "Order Summary"
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex flex-col gap-[10px]"
                    },
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex items-center justify-between flex-row"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-[13px] text-[var(--theme-admin-muted)]"
                            },
                            "text": "Subtotal"
                          },
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-[13px] text-white"
                            },
                            "text": {
                              "formula": "formatCurrency(collections['ad000003-0000-0000-0000-000000000003']?.order?.sub_total || 0, 'USD')"
                            }
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex items-center justify-between flex-row"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-[13px] text-[var(--theme-admin-muted)]"
                            },
                            "text": "Shipping"
                          },
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-[13px] text-white"
                            },
                            "text": {
                              "formula": "formatCurrency(collections['ad000003-0000-0000-0000-000000000003']?.order?.shipping || 0, 'USD')"
                            }
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "h-[1px] bg-[var(--theme-admin-surface-hover)]"
                        }
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex items-center justify-between flex-row"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-[14px] font-semibold text-white"
                            },
                            "text": "Total"
                          },
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-[14px] font-semibold text-white"
                            },
                            "text": {
                              "formula": "formatCurrency(collections['ad000003-0000-0000-0000-000000000003']?.order?.total || 0, 'USD')"
                            }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex flex-col gap-[8px]"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[12px] font-medium text-[var(--theme-admin-muted)] uppercase tracking-wider"
                        },
                        "text": "Current Status"
                      },
                      {
                        "type": "Text",
                        "props": {
                          "className": {
                            "formula": "concat('inline-flex items-center px-[10px] py-[4px] rounded-full text-[12px] font-medium w-fit ', (collections['ad000003-0000-0000-0000-000000000003']?.order?.state === 'Delivered' ? 'bg-[var(--theme-admin-success)]/20 text-[var(--theme-admin-success)]' : collections['ad000003-0000-0000-0000-000000000003']?.order?.state === 'Cancelled' ? 'bg-[var(--theme-admin-danger)]/20 text-[var(--theme-admin-danger)]' : 'bg-[var(--theme-admin-warning)]/20 text-[var(--theme-admin-warning)]'))"
                          }
                        },
                        "text": "{{collections['ad000003-0000-0000-0000-000000000003']?.order?.state || '—'}}"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Box",
                "props": {
                  "className": "bg-[var(--theme-admin-surface)] rounded-[12px] border border-[var(--theme-admin-border)] p-[20px] flex flex-col gap-[12px]"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-[15px] font-semibold text-white"
                    },
                    "text": "Customer"
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex flex-col gap-[6px]"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[13px] font-medium text-[var(--theme-admin-muted)]"
                        },
                        "text": {
                          "formula": "concat(collections['ad000003-0000-0000-0000-000000000003']?.order?.first_name || '', ' ', collections['ad000003-0000-0000-0000-000000000003']?.order?.last_name || '').trim() || 'Guest'"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[13px] text-[var(--theme-admin-label)]"
                        },
                        "text": "{{collections['ad000003-0000-0000-0000-000000000003']?.order?.email_address || '—'}}"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Box",
                "props": {
                  "className": "bg-[var(--theme-admin-surface)] rounded-[12px] border border-[var(--theme-admin-border)] p-[20px] flex flex-col gap-[12px]"
                },
                "condition": "collections['ad000003-0000-0000-0000-000000000003']?.order?.street_line1",
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-[15px] font-semibold text-white"
                    },
                    "text": "Shipping Address"
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex flex-col gap-[4px]"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[13px] text-[var(--theme-admin-muted)]"
                        },
                        "text": "{{collections['ad000003-0000-0000-0000-000000000003']?.order?.shipping_full_name || ''}}"
                      },
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[13px] text-[var(--theme-admin-label)]"
                        },
                        "text": "{{collections['ad000003-0000-0000-0000-000000000003']?.order?.street_line1 || ''}}"
                      },
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[13px] text-[var(--theme-admin-label)]"
                        },
                        "condition": "collections['ad000003-0000-0000-0000-000000000003']?.order?.street_line2",
                        "text": "{{collections['ad000003-0000-0000-0000-000000000003']?.order?.street_line2}}"
                      },
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[13px] text-[var(--theme-admin-label)]"
                        },
                        "text": {
                          "formula": "concat(collections['ad000003-0000-0000-0000-000000000003']?.order?.city || '', ', ', collections['ad000003-0000-0000-0000-000000000003']?.order?.province || '', ' ', collections['ad000003-0000-0000-0000-000000000003']?.order?.postal_code || '')"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[13px] text-[var(--theme-admin-label)] uppercase"
                        },
                        "text": "{{collections['ad000003-0000-0000-0000-000000000003']?.order?.country_code || ''}}"
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ],
        "_group": "Order Detail"
      }
    ]
  },
  "dataSources": [
    "ad000003-0000-0000-0000-000000000003"
  ]
}
