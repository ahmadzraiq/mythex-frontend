{
  "meta": { "title": "Contact Us | SaraZ", "description": "Get in touch" },
  "state": { "form": { "name": "", "email": "", "subject": "", "message": "" } },
  "layout": "store",
  "content": {
    "type": "Box",
    "props": { "className": "mx-auto max-w-3xl px-4 sm:px-6 py-12 md:py-16" },
    "children": [
      { "type": "Heading", "props": { "size": "2xl", "className": "mb-8 font-light" }, "text": "Contact Us" },
      { "type": "Text", "props": { "className": "text-[var(--theme-shop-textMuted)] mb-8" }, "text": "Have a question? We'd love to hear from you." },
      { "type": "Box", "props": { "className": "grid grid-cols-1 md:grid-cols-2 gap-8 mb-12" }, "children": [
        { "type": "Box", "children": [
          { "type": "Text", "props": { "className": "text-xs font-medium tracking-widest text-[var(--theme-shop-textMuted)] uppercase mb-2" }, "text": "Email" },
          { "type": "Text", "text": "hello@saraz.com" }
        ]},
        { "type": "Box", "children": [
          { "type": "Text", "props": { "className": "text-xs font-medium tracking-widest text-[var(--theme-shop-textMuted)] uppercase mb-2" }, "text": "Phone" },
          { "type": "Text", "text": "+971 4 123 4567" }
        ]},
        { "type": "Box", "children": [
          { "type": "Text", "props": { "className": "text-xs font-medium tracking-widest text-[var(--theme-shop-textMuted)] uppercase mb-2" }, "text": "Address" },
          { "type": "Text", "text": "Dubai Mall, Dubai, UAE" }
        ]}
      ]},
      { "type": "Box", "props": { "className": "p-6 bg-[var(--theme-content-bg)] rounded-xl border border-[var(--theme-shop-border)]" }, "children": [
        { "type": "Text", "props": { "className": "text-sm font-medium mb-4" }, "text": "Send a message" },
        { "type": "VStack", "props": { "className": "gap-4" }, "children": [
          { "type": "Input", "props": { "placeholder": "Your name", "value": "{{form.name}}" }, "actions": { "change": { "action": "setState", "payload": { "path": "form.name", "value": "$event" } } } },
          { "type": "Input", "props": { "placeholder": "Email", "value": "{{form.email}}" }, "actions": { "change": { "action": "setState", "payload": { "path": "form.email", "value": "$event" } } } },
          { "type": "Input", "props": { "placeholder": "Subject", "value": "{{form.subject}}" }, "actions": { "change": { "action": "setState", "payload": { "path": "form.subject", "value": "$event" } } } },
          { "type": "Textarea", "props": { "placeholder": "Message", "value": "{{form.message}}" }, "actions": { "change": { "action": "setState", "payload": { "path": "form.message", "value": "$event" } } } },
          { "type": "Button", "props": { "action": "primary" }, "text": "Send", "actions": { "click": { "action": "log", "payload": { "message": "Contact form submitted" } } } }
        ]}
      ]}
    ]
  }
}
