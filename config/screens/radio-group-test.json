{
  "meta": { "title": "Radio Group System Component Demo" },
  "state": {},
  "ui": {
    "type": "Box",
    "props": { "className": "w-full min-h-screen bg-gray-50 dark:bg-gray-950" },
    "children": [
      {
        "type": "Box",
        "props": { "className": "max-w-[640px] mx-auto flex flex-col gap-[24px] py-[48px] px-[24px]" },
        "children": [
          { "type": "Text", "props": { "className": "text-[24px] font-bold text-gray-900 dark:text-white" }, "text": "Radio Group — Custom Trigger Demo" },

          {
            "type": "RadioGroup",
            "_system": { "id": "sys-radio-group", "name": "Radio Group" },
            "_overrides": [],
            "props": {
              "options": [
                { "value": "a", "label": "Option A" },
                { "value": "b", "label": "Option B" },
                { "value": "c", "label": "Option C" }
              ],
              "value": "",
              "orientation": "vertical",
              "data-testid": "radio-group",
              "className": "flex flex-col gap-[12px]"
            },
            "actions": [
              { "action": "rg-wf-on-change" },
              { "action": "wfOnRadioGroupChange" }
            ],
            "children": [
              {
                "type": "Box",
                "map": { "formula": "Array.isArray(context?.component?.props?.options) ? context.component.props.options : []" },
                "key": "context.item.data.value",
                "props": { "className": "contents" },
                "children": [
                  {
                    "type": "Radio",
                    "props": {
                      "value": { "formula": "context?.item?.data?.value" },
                      "data-testid": { "formula": "'radio-' + (context?.item?.data?.value || '')" }
                    },
                    "children": [
                      { "type": "RadioIndicator" },
                      { "type": "RadioLabel", "text": "{{context.item.data.label}}" }
                    ]
                  }
                ]
              }
            ]
          },

          {
            "type": "Text",
            "props": { "className": "text-[14px] text-gray-700 dark:text-gray-300", "data-testid": "out-radio-group-value" },
            "text": { "formula": "'Selected: ' + (variables['rg-test-value'] || '(none)')" }
          }
        ]
      }
    ]
  }
}
