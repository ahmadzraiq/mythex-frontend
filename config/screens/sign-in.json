{
  "meta": {
    "title": "Sign In"
  },
  "layout": "store",
  "content": {
    "type": "Box",
    "props": {
      "className": "flex flex-1 w-full items-center justify-center px-4"
    },
    "children": [
      {
        "type": "Box",
        "props": {
          "className": "w-full max-w-md min-w-0 space-y-6 flex flex-col"
        },
        "children": [
          {
            "type": "Box",
            "props": {
              "className": "space-y-2 text-center"
            },
            "children": [
              {
                "type": "Heading",
                "props": {
                  "className": "text-3xl font-bold text-center"
                },
                "text": "Sign In"
              },
              {
                "type": "Text",
                "props": {
                  "className": "text-[var(--theme-muted-foreground)] text-center"
                },
                "text": "Enter your credentials to access your account"
              }
            ]
          },
          {
            "type": "Card",
            "props": {
              "className": "w-full !rounded-xl !border !border-[var(--theme-border)] !bg-[var(--theme-content-bg)] !py-6 !shadow-sm"
            },
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "px-6 space-y-4"
                },
                "children": [
                  {
                    "type": "Box",
                    "props": {
                      "className": "space-y-2"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-sm font-medium leading-none"
                        },
                        "text": "Email"
                      },
                      {
                        "type": "Input",
                        "props": {
                          "variant": "outline",
                          "size": "sm",
                          "className": "w-full !rounded-md !border-[var(--theme-border)] !bg-[var(--theme-content-bg)]"
                        },
                        "children": [
                          {
                            "type": "InputField",
                            "props": {
                              "type": "email",
                              "placeholder": "you@example.com",
                              "placeholderTextColor": "#9ca3af",
                              "value": "{{variables['e6f7a8b9-c0d1-2345-efab-456789012345'].value.username}}",
                              "className": "!text-[var(--theme-foreground)]"
                            },
                            "actions": {
                              "change": {
                                "type": "runMultiple",
                                "actions": [
                                  {
                                    "type": "setFormField",
                                    "formId": "e6f7a8b9-c0d1-2345-efab-456789012345",
                                    "field": "username",
                                    "value": "$event"
                                  },
                                  {
                                    "type": "setVar",
                                    "path": "e6f7a8b9-c0d1-2345-efab-456789012345.errors.username",
                                    "value": ""
                                  }
                                ]
                              }
                            }
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "min-h-[20px]"
                        },
                        "condition": "{{variables['e6f7a8b9-c0d1-2345-efab-456789012345'].errors.username}}",
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-sm text-red-500 dark:text-red-400"
                            },
                            "text": "{{variables['e6f7a8b9-c0d1-2345-efab-456789012345'].errors.username}}"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "space-y-2"
                    },
                    "children": [
                      {
                        "type": "Box",
                        "props": {
                          "className": "flex flex-row items-center justify-between"
                        },
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-sm font-medium leading-none"
                            },
                            "text": "Password"
                          },
                          {
                            "type": "Pressable",
                            "actions": {
                              "click": {
                                "action": "navigate",
                                "payload": {
                                  "path": "/forgot-password"
                                }
                              }
                            },
                            "children": [
                              {
                                "type": "Text",
                                "props": {
                                  "className": "text-[var(--theme-muted-foreground)] hover:text-[var(--theme-foreground)] text-sm"
                                },
                                "text": "Forgot password?"
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "Input",
                        "props": {
                          "variant": "outline",
                          "size": "sm",
                          "className": "w-full !rounded-md !border-[var(--theme-border)] !bg-[var(--theme-content-bg)]"
                        },
                        "children": [
                          {
                            "type": "InputField",
                            "props": {
                              "type": "password",
                              "placeholder": "••••••••",
                              "placeholderTextColor": "#9ca3af",
                              "value": "{{variables['e6f7a8b9-c0d1-2345-efab-456789012345'].value.password}}",
                              "className": "!text-[var(--theme-foreground)]"
                            },
                            "actions": {
                              "change": {
                                "type": "runMultiple",
                                "actions": [
                                  {
                                    "type": "setFormField",
                                    "formId": "e6f7a8b9-c0d1-2345-efab-456789012345",
                                    "field": "password",
                                    "value": "$event"
                                  },
                                  {
                                    "type": "setVar",
                                    "path": "e6f7a8b9-c0d1-2345-efab-456789012345.errors.password",
                                    "value": ""
                                  }
                                ]
                              }
                            }
                          }
                        ]
                      },
                      {
                        "type": "Box",
                        "props": {
                          "className": "min-h-[20px]"
                        },
                        "condition": "{{variables['e6f7a8b9-c0d1-2345-efab-456789012345'].errors.password}}",
                        "children": [
                          {
                            "type": "Text",
                            "props": {
                              "className": "text-sm text-red-500 dark:text-red-400"
                            },
                            "text": "{{variables['e6f7a8b9-c0d1-2345-efab-456789012345'].errors.password}}"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Pressable",
                    "props": {
                      "className": "w-full !bg-[var(--theme-shop-button)] hover:!bg-[var(--theme-shop-buttonHover)] !text-white flex flex-row items-center justify-center py-3 rounded-md"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-white"
                        },
                        "text": "Sign In"
                      }
                    ],
                    "actions": {
                      "click": {
                        "action": "login"
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "type": "Box",
            "props": {
              "className": "px-6 mt-6 flex flex-row items-center justify-center"
            },
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "text-[var(--theme-muted-foreground)] text-sm text-center"
                },
                "text": "Don't have an account? "
              },
              {
                "type": "Pressable",
                "actions": {
                  "click": {
                    "action": "navigate",
                    "payload": {
                      "path": "/register"
                    }
                  }
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-sm text-[var(--theme-shop-button)] underline hover:opacity-80 text-center"
                    },
                    "text": "Register"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "initActions": []
}
