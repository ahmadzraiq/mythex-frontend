{
  "meta": {
    "title": "Admin Login"
  },
  "content": {
    "type": "Box",
    "props": {
      "className": "min-h-screen w-full flex items-center justify-center bg-[var(--theme-admin-sidebar)]"
    },
    "children": [
      {
        "type": "Box",
        "props": {
          "className": "w-full max-w-[440px] mx-auto px-[24px]"
        },
        "children": [
          {
            "type": "Box",
            "props": {
              "className": "flex flex-col items-center mb-[32px]"
            },
            "children": [
              {
                "type": "Box",
                "props": {
                  "className": "w-[52px] h-[52px] rounded-[12px] bg-[var(--theme-admin-accent)] flex items-center justify-center mb-[16px] shadow-lg"
                },
                "children": [
                  {
                    "type": "Text",
                    "props": {
                      "className": "text-[20px] font-bold text-white"
                    },
                    "text": "DC"
                  }
                ]
              },
              {
                "type": "Text",
                "props": {
                  "className": "text-[26px] font-bold text-[var(--theme-admin-text)] tracking-tight"
                },
                "text": "Admin Portal"
              },
              {
                "type": "Text",
                "props": {
                  "className": "text-[14px] text-[var(--theme-admin-muted)] mt-[6px]"
                },
                "text": "Sign in to access the admin dashboard"
              }
            ]
          },
          {
            "type": "Box",
            "props": {
              "className": "bg-[var(--theme-admin-surface)] border border-[var(--theme-admin-border)] rounded-[12px] p-[32px] shadow-xl"
            },
            "children": [
              {
                "type": "FormContainer",
                "id": "admin-login-form",
                "props": {
                  "initialFormData": {
                    "email": "",
                    "password": ""
                  },
                  "className": "flex flex-col gap-[20px]"
                },
                "actions": [
                  {
                    "action": "admin-submit-login"
                  }
                ],
                "children": [
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex flex-col gap-[6px]"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[13px] font-medium text-[var(--theme-admin-muted)]"
                        },
                        "text": "Email Address"
                      },
                      {
                        "type": "Input",
                        "props": {
                          "name": "email",
                          "type": "email",
                          "placeholder": "admin@example.com",
                          "autoComplete": "email",
                          "className": "w-full h-[42px] px-[14px] rounded-[8px] bg-[var(--theme-admin-sidebar)] border border-[var(--theme-admin-border)] text-[var(--theme-admin-text)] text-[14px] focus:outline-none focus:border-[var(--theme-admin-accent)]"
                        }
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "flex flex-col gap-[6px]"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[13px] font-medium text-[var(--theme-admin-muted)]"
                        },
                        "text": "Password"
                      },
                      {
                        "type": "Input",
                        "props": {
                          "name": "password",
                          "secureTextEntry": true,
                          "placeholder": "••••••••",
                          "autoComplete": "current-password",
                          "className": "w-full h-[42px] px-[14px] rounded-[8px] bg-[var(--theme-admin-sidebar)] border border-[var(--theme-admin-border)] text-[var(--theme-admin-text)] text-[14px] focus:outline-none focus:border-[var(--theme-admin-accent)]"
                        }
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "className": "rounded-[8px] bg-red-500/10 border border-[var(--theme-admin-danger)] px-[14px] py-[10px]"
                    },
                    "condition": "variables['adm1n2l3-4567-89ab-cdef-012345678901']",
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[13px] text-[var(--theme-admin-danger)]"
                        },
                        "text": "{{variables['adm1n2l3-4567-89ab-cdef-012345678901']}}"
                      }
                    ]
                  },
                  {
                    "type": "Box",
                    "props": {
                      "type": "submit",
                      "className": "flex items-center justify-center cursor-pointer w-full h-[44px] bg-[var(--theme-admin-accent)] hover:bg-[var(--theme-admin-accent-hover)] rounded-[8px] transition-colors"
                    },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-white font-semibold text-[14px]"
                        },
                        "text": "Sign in to Admin"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Box",
            "props": {
              "className": "flex justify-center mt-[20px]"
            },
            "children": [
              {
                "type": "Text",
                "props": {
                  "className": "text-[12px] text-[var(--theme-admin-label)]"
                },
                "text": "Default: admin@example.com / Admin1234!"
              }
            ]
          }
        ]
      }
    ]
  }
}
