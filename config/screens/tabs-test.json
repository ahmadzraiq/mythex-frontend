{
  "meta": { "title": "Tabs System Component Demo" },
  "state": {},
  "ui": {
    "type": "Box",
    "props": { "className": "w-full min-h-screen bg-gray-50 dark:bg-gray-950" },
    "children": [
      {
        "type": "Box",
        "props": { "className": "max-w-[640px] mx-auto flex flex-col gap-[24px] py-[48px] px-[24px]" },
        "children": [
          { "type": "Text", "props": { "className": "text-[24px] font-bold text-gray-900 dark:text-white" }, "text": "Tabs — Custom Trigger Demo" },

          {
            "type": "Box",
            "_system": { "id": "sys-tabs", "name": "Tabs" },
            "_overrides": [],
            "props": {
              "tabs": [
                { "label": "Tab 1", "value": "tab1" },
                { "label": "Tab 2", "value": "tab2" },
                { "label": "Tab 3", "value": "tab3" }
              ],
              "defaultTab": "tab1",
              "data-testid": "tabs-strip",
              "className": "flex flex-row border-b border-border w-full"
            },
            "actions": [{ "action": "wfOnTabsChange" }],
            "children": [
              {
                "type": "Box",
                "map": { "formula": "Array.isArray(context?.component?.props?.tabs) ? context.component.props.tabs : []" },
                "key": "context.item.data.value",
                "props": { "className": "contents" },
                "children": [
                  {
                    "type": "Box",
                    "props": {
                      "data-testid": { "formula": "'tab-' + (context?.item?.data?.value || '')" },
                      "className": "px-[16px] py-[8px] cursor-pointer",
                      "style": {
                        "borderBottomWidth": "2px",
                        "borderBottomStyle": "solid",
                        "borderBottomColor": { "formula": "context?.item?.data?.value===context?.component?.variables?.['tabs-v-active-uuid']?'var(--theme-primary)':'transparent'" }
                      }
                    },
                    "actions": [{ "action": "tabs-wf-select-tab" }],
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "className": "text-[14px] font-medium",
                          "style": {
                            "color": { "formula": "context?.item?.data?.value===context?.component?.variables?.['tabs-v-active-uuid']?'var(--theme-primary)':'var(--theme-muted-foreground)'" }
                          }
                        },
                        "text": "{{context.item.data.label}}"
                      }
                    ]
                  }
                ]
              }
            ]
          },

          {
            "type": "Text",
            "props": { "className": "text-[14px] text-gray-700 dark:text-gray-300", "data-testid": "out-tabs-value" },
            "text": { "formula": "'Active: ' + (variables['tabs-test-value'] || '(none)')" }
          }
        ]
      }
    ]
  }
}
