{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sdui-actions",
  "title": "SDUI Actions",
  "description": "Named action definitions. Keys are action names; values are action configs matching one of the defined action types.",
  "type": "object",
  "additionalProperties": {
    "$ref": "#/$defs/ActionConfig"
  },
  "$defs": {
    "ActionConfig": {
      "description": "A single action definition — one of the supported SDUI action types.",
      "anyOf": [
        {
          "$ref": "#/$defs/ActionRef"
        },
        {
          "$ref": "#/$defs/WorkflowStepsAction"
        },
        {
          "$ref": "#/$defs/FetchAction"
        },
        {
          "$ref": "#/$defs/GraphqlAction"
        },
        {
          "$ref": "#/$defs/SetAction"
        },
        {
          "$ref": "#/$defs/SetVarAction"
        },
        {
          "$ref": "#/$defs/ValidateAction"
        },
        {
          "$ref": "#/$defs/NavigateAction"
        },
        {
          "$ref": "#/$defs/RunMultipleAction"
        },
        {
          "$ref": "#/$defs/IncrementAction"
        },
        {
          "$ref": "#/$defs/DecrementAction"
        },
        {
          "$ref": "#/$defs/ToggleAction"
        },
        {
          "$ref": "#/$defs/AppendToPathAction"
        },
        {
          "$ref": "#/$defs/GoToPageAction"
        },
        {
          "$ref": "#/$defs/NavigateWithQueryAction"
        },
        {
          "$ref": "#/$defs/SetFormFieldAction"
        },
        {
          "$ref": "#/$defs/OpenDrawerAction"
        },
        {
          "$ref": "#/$defs/CloseDrawerAction"
        },
        {
          "$ref": "#/$defs/SetThemeAction"
        },
        {
          "$ref": "#/$defs/ShareAction"
        },
        {
          "$ref": "#/$defs/ResetFormAction"
        },
        {
          "$ref": "#/$defs/WfBranchAction"
        },
        {
          "$ref": "#/$defs/WfMultiOptionBranchAction"
        },
        {
          "$ref": "#/$defs/WfForEachAction"
        },
        {
          "$ref": "#/$defs/WfWhileLoopAction"
        },
        {
          "$ref": "#/$defs/WfBreakLoopAction"
        },
        {
          "$ref": "#/$defs/WfContinueLoopAction"
        },
        {
          "$ref": "#/$defs/WfPassThroughConditionAction"
        },
        {
          "$ref": "#/$defs/WfNavigateToAction"
        },
        {
          "$ref": "#/$defs/WfNavigatePrevAction"
        },
        {
          "$ref": "#/$defs/WfPageLoaderAction"
        },
        {
          "$ref": "#/$defs/WfChangeLanguageAction"
        },
        {
          "$ref": "#/$defs/WfChangeVariableValueAction"
        },
        {
          "$ref": "#/$defs/WfFetchCollectionAction"
        },
        {
          "$ref": "#/$defs/WfFetchCollectionsParallelAction"
        },
        {
          "$ref": "#/$defs/WfUpdateCollectionAction"
        },
        {
          "$ref": "#/$defs/WfResetVariableValueAction"
        },
        {
          "$ref": "#/$defs/WfExecuteComponentActionAction"
        },
        {
          "$ref": "#/$defs/WfReturnValueAction"
        },
        {
          "$ref": "#/$defs/WfTimeDelayAction"
        },
        {
          "$ref": "#/$defs/WfUploadFileAction"
        },
        {
          "$ref": "#/$defs/WfStopPropagationAction"
        },
        {
          "$ref": "#/$defs/WfCopyToClipboardAction"
        },
        {
          "$ref": "#/$defs/WfDownloadFileFromUrlAction"
        },
        {
          "$ref": "#/$defs/WfCreateUrlFromBase64Action"
        },
        {
          "$ref": "#/$defs/WfEncodeFileAsBase64Action"
        },
        {
          "$ref": "#/$defs/WfOpenPopupAction"
        },
        {
          "$ref": "#/$defs/WfCloseAllPopupsAction"
        },
        {
          "$ref": "#/$defs/WfRunProjectWorkflowAction"
        },
        {
          "$ref": "#/$defs/RefetchDataSourceAction"
        },
        {
          "$ref": "#/$defs/MergeAtPathAction"
        },
        {
          "$ref": "#/$defs/SubmitFormAction"
        },
        {
          "$ref": "#/$defs/SetStateAction"
        },
        {
          "$ref": "#/$defs/CycleIndexAction"
        },
        {
          "$ref": "#/$defs/ClearPersistedPathsAction"
        }
      ]
    },
    "JsonLogicExpr": {
      "description": "A JSON Logic expression or a plain value.",
      "oneOf": [
        {
          "type": "object"
        },
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "type": "array"
        }
      ]
    },
    "ActionArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/StepConfig"
      }
    },
    "StepConfig": {
      "description": "A workflow step: an action type (or ActionRef) plus optional step metadata (id, name, disabled, condition, config, structural branches).",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "disabled": {
          "type": "boolean"
        },
        "condition": {},
        "_debounce": {},
        "action": {
          "type": "string"
        },
        "config": {
          "type": "object",
          "additionalProperties": {}
        },
        "trueBranch": {
          "$ref": "#/$defs/ActionArray"
        },
        "falseBranch": {
          "$ref": "#/$defs/ActionArray"
        },
        "branches": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/BranchDef"
          }
        },
        "defaultBranch": {
          "$ref": "#/$defs/ActionArray"
        },
        "loopBody": {
          "$ref": "#/$defs/ActionArray"
        }
      }
    },
    "BranchDef": {
      "type": "object",
      "required": [
        "label",
        "steps"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "steps": {
          "$ref": "#/$defs/ActionArray"
        }
      }
    },
    "ActionRef": {
      "description": "A reference to a named action defined elsewhere in the actions registry.",
      "type": "object",
      "required": [
        "action"
      ],
      "properties": {
        "action": {
          "type": "string"
        },
        "payload": {
          "type": "object"
        },
        "condition": {},
        "name": {
          "type": "string",
          "description": "Human-readable display name for this action."
        }
      },
      "additionalProperties": false
    },
    "WorkflowStepsAction": {
      "description": "A sequential workflow of steps executed by workflow-steps-handler.",
      "type": "object",
      "required": [
        "type",
        "steps"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "workflowSteps"
          ]
        },
        "trigger": {
          "type": "string",
          "description": "The event that triggers this workflow (e.g. click, change, submit, valueChange)."
        },
        "steps": {
          "$ref": "#/$defs/ActionArray"
        },
        "onErrorSteps": {
          "$ref": "#/$defs/ActionArray"
        },
        "name": {
          "type": "string",
          "description": "Human-readable display name for this action."
        }
      },
      "additionalProperties": false
    },
    "FetchAction": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "fetch"
          ]
        },
        "url": {
          "type": "string",
          "description": "REST endpoint URL. Supports {{variable}} interpolation."
        },
        "method": {
          "type": "string",
          "enum": [
            "GET",
            "POST",
            "PUT",
            "PATCH",
            "DELETE"
          ],
          "default": "GET"
        },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "body": {
          "description": "Request body — plain object or JSON Logic expression."
        },
        "storeIn": {
          "type": "string",
          "description": "Zustand data path to store the response."
        },
        "storeFullResponseIn": {
          "type": "string"
        },
        "responsePath": {
          "type": "string",
          "description": "Dot-path to extract from the response."
        },
        "errorMessagePath": {
          "type": "string"
        },
        "onSuccess": {
          "$ref": "#/$defs/ActionConfig"
        },
        "name": {
          "type": "string",
          "description": "Human-readable display name for this action."
        }
      },
      "additionalProperties": false
    },
    "GraphqlAction": {
      "type": "object",
      "required": [
        "type",
        "query"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "graphql"
          ]
        },
        "query": {
          "type": "string",
          "description": "GraphQL query or mutation string."
        },
        "variables": {
          "description": "Query variables — plain object or JSON Logic."
        },
        "endpoint": {
          "type": "string",
          "description": "Override for engineConventions.graphqlEndpoint."
        },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "storeIn": {
          "type": "string"
        },
        "storeFullResponseIn": {
          "type": "string"
        },
        "responsePath": {
          "type": "string"
        },
        "storeHeaderIn": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Map response header names to store paths."
        },
        "errorMessagePath": {
          "type": "string"
        },
        "invalidateCache": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stopPropagation": {
          "type": "boolean"
        },
        "onSuccess": {
          "$ref": "#/$defs/ActionConfig"
        },
        "name": {
          "type": "string",
          "description": "Human-readable display name for this action."
        }
      },
      "additionalProperties": false
    },
    "SetAction": {
      "type": "object",
      "required": [
        "type",
        "path",
        "value"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "set"
          ]
        },
        "path": {
          "type": "string"
        },
        "value": {},
        "name": {
          "type": "string",
          "description": "Human-readable display name for this action."
        }
      },
      "additionalProperties": false
    },
    "SetVarAction": {
      "type": "object",
      "required": [
        "type",
        "path",
        "value"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "setVar"
          ]
        },
        "path": {
          "type": "string"
        },
        "value": {},
        "name": {
          "type": "string",
          "description": "Human-readable display name for this action."
        }
      },
      "additionalProperties": false
    },
    "ValidateAction": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "validate"
          ]
        },
        "formId": {
          "type": "string"
        },
        "rules": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "required": {
                "type": "boolean"
              },
              "minLength": {
                "type": "number"
              },
              "maxLength": {
                "type": "number"
              },
              "pattern": {
                "type": "string"
              },
              "equals": {},
              "equalsField": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        },
        "storeErrorsIn": {
          "type": "string"
        },
        "onSuccess": {
          "$ref": "#/$defs/ActionConfig"
        },
        "name": {
          "type": "string",
          "description": "Human-readable display name for this action."
        }
      },
      "additionalProperties": false
    },
    "NavigateAction": {
      "type": "object",
      "required": [
        "action"
      ],
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "navigate"
          ]
        },
        "payload": {
          "type": "object",
          "properties": {
            "path": {
              "$ref": "#/$defs/JsonLogicExpr"
            },
            "routeConfig": {
              "type": "string"
            },
            "slug": {
              "$ref": "#/$defs/JsonLogicExpr"
            }
          }
        },
        "name": {
          "type": "string",
          "description": "Human-readable display name for this action."
        }
      },
      "additionalProperties": false
    },
    "RunMultipleAction": {
      "type": "object",
      "required": [
        "type",
        "actions"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "runMultiple"
          ]
        },
        "actions": {
          "$ref": "#/$defs/ActionArray"
        },
        "condition": {},
        "_debounce": {
          "type": "number"
        },
        "name": {
          "type": "string",
          "description": "Human-readable display name for this action."
        }
      },
      "additionalProperties": false
    },
    "IncrementAction": {
      "type": "object",
      "required": [
        "type",
        "path"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "increment"
          ]
        },
        "path": {
          "type": "string"
        },
        "amount": {
          "$ref": "#/$defs/JsonLogicExpr"
        },
        "min": {
          "type": "number",
          "default": 0
        },
        "name": {
          "type": "string",
          "description": "Human-readable display name for this action."
        }
      },
      "additionalProperties": false
    },
    "DecrementAction": {
      "type": "object",
      "required": [
        "type",
        "path"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "decrement"
          ]
        },
        "path": {
          "type": "string"
        },
        "amount": {
          "$ref": "#/$defs/JsonLogicExpr"
        },
        "min": {
          "type": "number",
          "default": 0
        },
        "name": {
          "type": "string",
          "description": "Human-readable display name for this action."
        }
      },
      "additionalProperties": false
    },
    "ToggleAction": {
      "type": "object",
      "required": [
        "type",
        "path"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "toggle"
          ]
        },
        "path": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "description": "Human-readable display name for this action."
        }
      },
      "additionalProperties": false
    },
    "AppendToPathAction": {
      "type": "object",
      "required": [
        "type",
        "targetPath",
        "value"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "appendToPath"
          ]
        },
        "targetPath": {
          "type": "string"
        },
        "value": {
          "$ref": "#/$defs/JsonLogicExpr"
        },
        "resetFormPath": {
          "type": "string"
        },
        "resetFormValue": {},
        "name": {
          "type": "string",
          "description": "Human-readable display name for this action."
        }
      },
      "additionalProperties": false
    },
    "GoToPageAction": {
      "type": "object",
      "required": [
        "type",
        "page"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "goToPage"
          ]
        },
        "page": {
          "$ref": "#/$defs/JsonLogicExpr"
        },
        "path": {
          "type": "string"
        },
        "paginationPath": {
          "type": "string"
        },
        "pageSize": {
          "$ref": "#/$defs/JsonLogicExpr"
        },
        "fetchAction": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "description": "Human-readable display name for this action."
        }
      },
      "additionalProperties": false
    },
    "NavigateWithQueryAction": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "navigateWithQuery"
          ]
        },
        "path": {
          "$ref": "#/$defs/JsonLogicExpr"
        },
        "params": {
          "type": "object",
          "additionalProperties": {}
        },
        "queryParams": {
          "type": "object",
          "additionalProperties": {}
        },
        "remove": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "replace": {
          "type": "boolean"
        },
        "name": {
          "type": "string",
          "description": "Human-readable display name for this action."
        }
      },
      "additionalProperties": false
    },
    "SetFormFieldAction": {
      "type": "object",
      "required": [
        "type",
        "field"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "setFormField"
          ]
        },
        "formId": {
          "type": "string"
        },
        "field": {
          "type": "string"
        },
        "value": {},
        "validationTrigger": {
          "type": "string",
          "enum": [
            "submit",
            "change",
            "blur"
          ]
        },
        "validationRules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "value": {}
            }
          }
        },
        "_debounce": {},
        "name": {
          "type": "string",
          "description": "Human-readable display name for this action."
        }
      },
      "additionalProperties": false
    },
    "OpenDrawerAction": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "openDrawer"
          ]
        },
        "name": {
          "type": "string",
          "description": "Human-readable display name for this action."
        }
      },
      "additionalProperties": false
    },
    "CloseDrawerAction": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "closeDrawer"
          ]
        },
        "name": {
          "type": "string",
          "description": "Human-readable display name for this action."
        }
      },
      "additionalProperties": false
    },
    "SetThemeAction": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "setTheme"
          ]
        },
        "theme": {
          "type": "string",
          "enum": [
            "light",
            "dark",
            "system"
          ]
        },
        "value": {
          "type": "string",
          "enum": [
            "light",
            "dark",
            "system"
          ]
        },
        "name": {
          "type": "string",
          "description": "Human-readable display name for this action."
        }
      },
      "additionalProperties": false
    },
    "ShareAction": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "share"
          ]
        },
        "slug": {
          "$ref": "#/$defs/JsonLogicExpr"
        },
        "title": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "description": "Human-readable display name for this action."
        }
      },
      "additionalProperties": false
    },
    "ResetFormAction": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "resetForm"
          ]
        },
        "path": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "description": "Human-readable display name for this action."
        }
      },
      "additionalProperties": false
    },
    "WfBranchAction": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "branch"
          ]
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "disabled": {
          "type": "boolean"
        },
        "config": {
          "type": "object",
          "properties": {
            "condition": {
              "description": "Expression that evaluates to boolean."
            }
          }
        },
        "trueBranch": {
          "$ref": "#/$defs/ActionArray"
        },
        "falseBranch": {
          "$ref": "#/$defs/ActionArray"
        }
      },
      "additionalProperties": false
    },
    "WfMultiOptionBranchAction": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "multiOptionBranch"
          ]
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "disabled": {
          "type": "boolean"
        },
        "config": {
          "type": "object",
          "properties": {
            "condition": {
              "description": "Expression whose value is matched against branch labels."
            },
            "defaultBranch": {
              "type": "boolean"
            }
          }
        },
        "branches": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/BranchDef"
          }
        },
        "defaultBranch": {
          "$ref": "#/$defs/ActionArray"
        }
      },
      "additionalProperties": false
    },
    "WfForEachAction": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "forEach"
          ]
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "disabled": {
          "type": "boolean"
        },
        "config": {
          "type": "object",
          "properties": {
            "items": {
              "description": "Array expression to iterate over."
            }
          }
        },
        "loopBody": {
          "$ref": "#/$defs/ActionArray"
        }
      },
