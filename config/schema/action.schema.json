{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sdui-actions",
  "title": "SDUI Actions",
  "description": "Action definitions - keys are action names, values are action configs",
  "type": "object",
  "additionalProperties": {
    "type": "object",
    "properties": {
      "type": { "type": "string" },
      "url": { "type": "string" },
      "query": { "type": "string" },
      "variables": { "type": "object" },
      "storeIn": { "type": "string" },
      "responsePath": { "type": "string" },
      "path": { "type": "string" },
      "rules": { "type": "object" },
      "storeErrorsIn": { "type": "string" },
      "onSuccess": {},
      "actions": { "type": "array" }
    },
    "additionalProperties": true
  }
}
